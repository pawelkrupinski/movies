<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<!--
  NOT CURRENTLY WIRED INTO THE BUILD. Associated Domains (iOS Universal Links)
  requires a PAID Apple Developer Program membership; a free/personal team can't
  provision it ("Personal development teams do not support the Associated Domains
  capability"). So `CODE_SIGN_ENTITLEMENTS` is intentionally absent from
  project.pbxproj and the app ships with only the kinowo:// custom URL scheme
  (Info.plist CFBundleURLTypes), which needs no paid account.

  To enable Universal Links once on a paid team: add
  `CODE_SIGN_ENTITLEMENTS = Kinowo/Kinowo.entitlements;` to the app target's
  build settings (it was in all four XCBuildConfiguration blocks) and enable the
  Associated Domains capability for the App ID in the developer portal. The AASA
  is already served at https://kinowo.fly.dev/.well-known/apple-app-site-association.
-->
<dict>
	<!-- Universal Links: the OS fetches https://kinowo.fly.dev/.well-known/
	     apple-app-site-association and routes matching links (city, film,
	     copy-to-clipboard filter links) into the app via onOpenURL. -->
	<key>com.apple.developer.associated-domains</key>
	<array>
		<string>applinks:kinowo.fly.dev</string>
		<string>webcredentials:kinowo.fly.dev</string>
	</array>
</dict>
</plist>
