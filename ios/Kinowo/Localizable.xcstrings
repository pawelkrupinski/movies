{
  "sourceLanguage": "en",
  "strings": {
    "areapicker.confirm": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Show listings"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pokaż repertuar"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Programm anzeigen"
          }
        }
      }
    },
    "areapicker.subtitle": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Show cinemas only in the areas you pick. You can change this anytime."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pokaż kina tylko w wybranych okolicach. Zawsze możesz to zmienić."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zeige nur Kinos in den von dir gewählten Regionen. Du kannst das jederzeit ändern."
          }
        }
      }
    },
    "areapicker.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose your areas"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wybierz okolice"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle deine Regionen"
          }
        }
      }
    },
    "cinemafilter.all_cinemas": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "All cinemas"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
