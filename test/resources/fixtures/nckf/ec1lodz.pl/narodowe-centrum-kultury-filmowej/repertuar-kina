<script>
    document.addEventListener("DOMContentLoaded", function () {
        const filterContainer = document.getElementById("days-filter");

        if (filterContainer.dataset.init === "true") return;
        filterContainer.dataset.init = "true";

        filterContainer.innerHTML = "";
        const dayNames = ["Niedziela", "Poniedziałek", "Wtorek", "Środa", "Czwartek", "Piątek", "Sobota"];
        const today = new Date();
        today.setHours(0, 0, 0, 0);

        const getFullDate = (dateEl) => {
            if (!dateEl) return null;
            const attrVal = dateEl.getAttribute("data-full-date");
            const hidden = dateEl.parentElement?.querySelector(".daty-godz-seansow__date-full")?.textContent?.trim();
            const raw = attrVal || hidden;
            if (!raw) return null;
            const parsed = new Date(raw.includes("T") ? raw : `${raw}T00:00:00`);
            return isNaN(parsed.getTime()) ? null : parsed;
        };

        const parseFutureDate = (value, reference) => {
            const dateEl = value && value.nodeType === 1 ? value : null;
            const text = dateEl ? dateEl.textContent.trim() : value;

            const full = dateEl ? getFullDate(dateEl) : null;
            if (full) return full;

            if (!text || typeof text !== "string") return null;

            const [d, m] = text.split('.').map(Number);
            if (!d || !m) return null;
            const base = new Date(reference);
            base.setHours(0, 0, 0, 0);
            let date = new Date(base.getFullYear(), m - 1, d);
            if (date < base) {
                date.setFullYear(date.getFullYear() + 1);
            }
            return date;
        };

        const parseFutureDateTime = (dateValue, timeText, reference) => {
            const date = parseFutureDate(dateValue, reference);
            if (!date) return null;
            const [h, min] = (timeText || "").split(":").map(Number);
            if (!isNaN(h)) {
                date.setHours(h, isNaN(min) ? 0 : min, 0, 0);
            }
            return date;
        };

        const foundDates = new Set();
        document.querySelectorAll(".daty-godz-seansow__date").forEach(el => {
            const itemDate = parseFutureDate(el, today);
            if (itemDate >= today) {
                foundDates.add(el.textContent.trim());
            } else {
                const datyBlock = el.closest(".daty-godz-seansow");
                if (datyBlock) datyBlock.remove();
            }
        });

        const showAllBtn = document.createElement("button");
        showAllBtn.className = "day-filter-button active full";
        showAllBtn.dataset.date = "all";
        showAllBtn.textContent = "Pełny repertuar";
        filterContainer.appendChild(showAllBtn);

        for (let i = 0; i <= 13; i++) {
            const date = new Date(today);
            date.setDate(today.getDate() + i);
            const formatted = date.toLocaleDateString("pl-PL", { day: "2-digit", month: "2-digit" }); // "09.04"
            const label = i === 0 ? "Dziś" : i === 1 ? "Jutro" : dayNames[date.getDay()];

            if (!foundDates.has(formatted)) continue;

            const button = document.createElement("button");
            button.className = "day-filter-button";
            button.dataset.date = formatted;
            button.innerHTML = `<span class="day-label">${label}</span><strong>${formatted}</strong>`;
            filterContainer.appendChild(button);
        }

        filterContainer.addEventListener("click", (e) => {
            const btn = e.target.closest("button");
            if (!btn) return;

            document.querySelectorAll(".day-filter-button").forEach(b => b.classList.remove("active"));
            btn.classList.add("active");

            const selectedDate = btn.dataset.date;
            const eventItems = document.querySelectorAll(".events-archive__item");

            eventItems.forEach(item => {
                let matchesDate = false;

                const seansy = item.querySelectorAll(".daty-godz-seansow");
                seansy.forEach(s => s.style.display = "");

                if (selectedDate === "all") {
                    item.classList.remove("hidden");
                    return;
                }

                seansy.forEach(seans => {
                    const seansDate = seans.querySelector(".daty-godz-seansow__date")?.textContent.trim();
                    if (seansDate !== selectedDate) {
                        seans.style.display = "none";
                    } else {
                        matchesDate = true;
                    }
                });

                item.classList.toggle("hidden", !matchesDate);
            });
        });
        document.querySelectorAll(".daty-godz-seansow-wrapper").forEach(wrapper => {
            const items = Array.from(wrapper.querySelectorAll(".daty-godz-seansow"));

            items.sort((a, b) => {
                const dateA = parseFutureDateTime(
                    a.querySelector(".daty-godz-seansow__date"),
                    a.querySelector(".daty-godz-seansow__hour")?.textContent.trim() || "",
                    today
                );
                const dateB = parseFutureDateTime(
                    b.querySelector(".daty-godz-seansow__date"),
                    b.querySelector(".daty-godz-seansow__hour")?.textContent.trim() || "",
                    today
                );

                return (dateA?.getTime() || 0) - (dateB?.getTime() || 0);
            });

            items.forEach(item => wrapper.appendChild(item));
        });

        const now = new Date();

        document.querySelectorAll(".events-archive__item").forEach(item => {
            const seansy = item.querySelectorAll(".daty-godz-seansow");
            let hasUpcoming = false;

            seansy.forEach(seans => {
                const dateEl = seans.querySelector(".daty-godz-seansow__date");
                const dateText = dateEl?.textContent.trim();
                const hourText = seans.querySelector(".daty-godz-seansow__hour")?.textContent.trim();

                if (!dateText || !hourText) {
                    seans.remove();
                    return;
                }

                const seansDate = parseFutureDateTime(dateEl, hourText, now);

                if (!seansDate || seansDate < now) {
                    seans.remove();
                } else {
                    hasUpcoming = true;
                }
            });

            if (!hasUpcoming) {
                item.remove();
            }
        });

    });

</script>

    

