      Cookies.set('font_size_cookie', 'normal', {expires: 7});
      /*location.reload();*/
    }
  });
  jQuery('#plusBtn').click(function () {
    var font_size_cookie = Cookies.get('font_size_cookie');
    if (font_size_cookie == undefined || font_size_cookie == 'normal') {
      Cookies.set('font_size_cookie', '150', {expires: 7});
      Cookies.set('font_size_200_cookie', 'normal', {expires: 7});
      font_150();
    } else {
      Cookies.set('font_size_cookie', 'normal', {expires: 7});
      /*location.reload();*/
    }
  });
  jQuery('#plusBtnplus').click(function () {
    var font_size_200_cookie = Cookies.get('font_size_200_cookie');
    if (font_size_200_cookie == undefined || font_size_200_cookie == 'normal') {
      Cookies.set('font_size_200_cookie', '200', {expires: 7});
      Cookies.set('font_size_cookie', 'normal', {expires: 7});
      font_200();
    } else {
      Cookies.set('font_size_200_cookie', 'normal', {expires: 7});
      /*location.reload();*/
    }
  });

  if (Cookies.get('kontrast_cookie') == 'biały') {
    /*changeContrast();*/
    setTimeout(function(){
      changeContrast();
    }, 1000);
  }
  if (Cookies.get('kontrast_level_cookie') == 'high') {
    changeContrastLevel();
  }
  if (Cookies.get('font_size_cookie') == 'normal') {
    font_normal();
  }
  if (Cookies.get('font_size_cookie') == '150') {
    font_150();
  }
  if (Cookies.get('font_size_200_cookie') == '200') {
    font_200();
  }


  function changeContrast(){
    jQuery('a').toggleClass('font-bold')
    jQuery('.edit-box a').toggleClass('text-underline')
    jQuery('p, h1, h2, h3, h4, div, address, a, tr, th, td.day, span, #search, .search-form button').toggleClass('color-black')
    jQuery('.day.today.active, .ribbon h3, .ribbon div, .ribbon, .navbar a, .secondary-top-menu.nav .dropdown-menu a, .mejs-currenttime, .mejs-duration').toggleClass('color-white')
    jQuery('.ribbon').toggleClass('bg-purple')
    jQuery('.option-block, .site-options').toggleClass('bg-light')
    /*jQuery('.day.today.active, .logotyp-item, .ribbon, .navbar, .dropdown-menu, .swiper-pagination-bullet').toggleClass('bg-black')*/
    jQuery('.logotyp-item, .swiper-pagination-bullet, .swiper-button-next span, .swiper-button-prev span').toggleClass('bg-black')
    jQuery('body, .datepicker thead tr:first-child th, th/*, .secondary-top-menu.nav .dropdown-menu*/').toggleClass('bg-white')
    jQuery('.border-dash-b, .border-dash-t, #search').toggleClass('border-black')
    jQuery('#logo img').toggleClass('outline-black')
    /*jQuery('img, .posters-img-holder').toggleClass('filter-grayscale')*/
    jQuery('.map .ribbon').toggleClass('z-index-1')
    jQuery('#plusBtn, #plusBtnplus').removeClass('color-black')
    jQuery('.black_white').addClass('color-active')
    jQuery('.disable_autoplay svg, .on_autoplay svg').toggleClass('fill-black')
    jQuery('body, a, h3, h2, span, p, div, svg, address, th, td').removeClass('ContrastLevel')
    jQuery('a').removeClass('ContrastLevelWhite')
  }
  function changeContrastLevel(){
    jQuery('body').toggleClass('ContrastLevel');
    jQuery('.contrast_level').toggleClass('color-active');
  }
  function font_normal(){
    jQuery('body, .primary-menu, h3, .side-nav a, .dropdown-menu a').removeClass('biggest-size').removeClass('bigger-size')
    jQuery('#normalBtn').addClass('color-active')
    jQuery('#plusBtnplus, #plusBtn').removeClass('color-active')
  }
  function font_150(){
    jQuery('body, .primary-menu, h3, .side-nav a, .dropdown-menu a').removeClass('biggest-size')
    jQuery('body, .primary-menu, h3, .side-nav a, .dropdown-menu a').addClass('bigger-size')
    jQuery('#plusBtn').addClass('color-active')
    jQuery('#plusBtnplus, #normalBtn').removeClass('color-active')
  }
  function font_200(){
    jQuery('body, .primary-menu, h3, .side-nav a, .dropdown-menu a').removeClass('bigger-size')
    jQuery('body, .primary-menu, h3, .side-nav a, .dropdown-menu a').addClass('biggest-size')
    jQuery('#plusBtnplus').addClass('color-active')
    jQuery('#plusBtn, #normalBtn').removeClass('color-active')
  }
</script>

