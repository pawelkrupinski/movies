utube.com/embed/loBwcgZt_m4"],"posters":["https://movies.helios.pl/images/KPopoweLowczynieplakat.jpg"],"pictures":["https://movies.helios.pl/images/Kpopowelowczyniedemonow8.jpg","https://movies.helios.pl/images/Kpopowelowczyniedemonow7.jpg","https://movies.helios.pl/images/Kpopowelowczyniedemonow6.jpg","https://movies.helios.pl/images/Kpopowelowczyniedemonow5.jpg","https://movies.helios.pl/images/Kpopowelowczyniedemonow4.jpg","https://movies.helios.pl/images/Kpopowelowczyniedemonow3.jpg","https://movies.helios.pl/images/Kpopowelowczyniedemonow2.jpg","https://movies.helios.pl/images/Kpopowelowczyniedemonow1.jpg"],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"10","value":"10","description":"od lat 10"}],"brightcoveVideos":[],"release":"2D/NAP","name":"K-popowe Łowczynie Demonów: Karaoke w Helios na Scenie","link":null,"screeningId":"2109ff57-9abd-4567-952c-08e9d4482749","screenId":"d5d37d41-5d98-41a8-8e78-9f319943b982","cinemaId":"3e60a454-c438-4c9b-b24f-7c6feff3b5ed","timeFrom":"2026-06-11T16:30:00+02:00","timeTo":"2026-06-11T18:16:00+02:00","saleTimeTo":"2026-06-11T17:00:00+02:00","reservationTimeTo":"2026-06-11T15:30:00+02:00","availabilityStatus":1,"maxOccupancy":194,"audience":0,"generalAdmission":false,"isScreenSwapping":false,"externalId":2868677,"items":[{"movieId":"4c6e0734-8000-45cf-9abe-161ae1a5ff6e","moviePrintId":"d882e05d-f8ef-4987-ba35-fb379d34fca7","timeFrom":"2026-06-11T16:30:00+02:00","timeTo":"2026-06-11T18:16:00+02:00","movieName":"K-popowe Łowczynie Demonów: Karaoke","speakingType":"Napisy","printType":"2D","screenId":"d5d37d41-5d98-41a8-8e78-9f319943b982","movieSubPrintLabel":"PS"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":6,"symbol":"HELIOS NA SCENIE","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"8ede9a2d-3a2f-4ec2-9799-7ce8c9d2cbbf","duration":133,"description":"Jest rok 1939. Świat pogrąża się w chaosie. Tysiące wybitnych Polaków trafiają do rosyjskiej niewoli, gdzie poddawani są indoktrynacji będącej częścią wielkiego planu. Ambitny agent wroga stawia sobie za punkt honoru złamanie oporu jednego z nich. To młody pianista światowej sławy, cieszący się szacunkiem współosadzonych. Jego kapitulacja może skutkować przejściem wielu innych na stronę przeciwnika. Rozpoczyna się podstępna gra, pełna manipulacji, gróźb i obietnic. Każdy z więźniów zmuszony jest dokonać dramatycznego wyboru, z którym będzie musiał żyć lub umrzeć. Nieświadomi swojej roli, z utęsknieniem czekają na moment wyzwolenia, który może być ich zgubą. Towarzysze broni podejmą próbę śmiertelnie ryzykownej ucieczki czy zdadzą się na łaskę wroga? Czasu jest coraz mniej, bo swój ostateczny ruch może wykonać on w każdej chwili.","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"14c7bb44-6562-4ad9-8d7a-ab747fa73829","name":"dramat","description":""},{"id":"a78fead9-c0f8-4fc6-96de-c665a6458acd","name":"historyczny","description":""}],"trailers":[],"posters":["https://movies.helios.pl/images/pojedynekplakat.jpg"],"pictures":["https://movies.helios.pl/images/Pojedynek7(1).jpg","https://movies.helios.pl/images/Pojedynek6(1).jpg","https://movies.helios.pl/images/Pojedynek5(1).jpg","https://movies.helios.pl/images/Pojedynek4(1).jpg","https://movies.helios.pl/images/Pojedynek3(1).jpg","https://movies.helios.pl/images/Pojedynek2(1).jpg","https://movies.helios.pl/images/Pojedynek1(1).jpg"],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"15","value":"15","description":"od lat 15"}],"brightcoveVideos":[],"release":"2D/NAP","name":"Pojedynek - KNT","link":null,"screeningId":"0b5e52b8-caa8-4b94-8dbd-61d5d7729aac","screenId":"ccf85f20-1001-475e-84e1-f7e4937363a6","cinemaId":"3e60a454-c438-4c9b-b24f-7c6feff3b5ed","timeFrom":"2026-06-08T10:00:00+02:00","timeTo":"2026-06-08T12:13:00+02:00","saleTimeTo":"2026-06-08T10:30:00+02:00","reservationTimeTo":"2026-06-08T09:00:00+02:00","availabilityStatus":1,"maxOccupancy":194,"audience":27,"generalAdmission":false,"isScreenSwapping":false,"externalId":7854117,"items":[{"movieId":"e09a334e-42f5-4b8b-82c6-ed98db9b0402","moviePrintId":"591e1922-e8ff-4fd6-81fe-64a352a206c1","timeFrom":"2026-06-08T10:00:00+02:00","timeTo":"2026-06-08T12:13:00+02:00","movieName":"Pojedynek","speakingType":"Napisy","printType":"2D","screenId":"ccf85f20-1001-475e-84e1-f7e4937363a6","movieSubPrintLabel":"PS"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":7,"symbol":"KINO NA TEMAT","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"4add03a9-c644-43b3-a734-acef3cfe73e8","duration":139,"description":"George Fahmy (w tej roli Fares Fares) to największa gwiazda egipskiego kina. Zwany jest “faraonem ekranu”. Zwraca na niego uwagę sam prezydent Egiptu Abd al-Fattah as Sisi, który życzy sobie, aby gwiazdor zagrał główną rolę w filmie biograficznym, gloryfikującym prezydenta. Okazuje się, że jest to propozycja nie do odrzucenia – władza szantażem wymusza na aktorze jej przyjęcie.\n\nPoczątkowo, jak przystało na gwiazdę, bohater liczy na to, że będzie miał sporo do powiedzenia, zarówno w sprawie swojej roli, jak i kształtu całego filmu. Szybko jednak zostaje sprowadzony na ziemię. Głównie za sprawą obecnego na planie tajemniczego doktora Manssoura, który sprawuje pieczę nad produkcją i jej odpowiednim, propagandowym tonem. Sytuację dodatkowo komplikuje romans, w jaki Fahmy wdaje się z żoną jednego z wysoko postawionych generałów. To moment, w którym fikcja i rzeczywistość zaczynają się niebezpiecznie przenikać.","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"939b8bbb-4f8f-4fd6-875d-16e483eccdea","name":"thriller","description":""}],"trailers":["https://www.youtube.com/embed/-DWKk_XNt0E"],"posters":["https://movies.helios.pl/images/OrlyRepublikiPlakat.jpg"],"pictures":["https://movies.helios.pl/images/Orłyrepubliki7.jpg","https://movi