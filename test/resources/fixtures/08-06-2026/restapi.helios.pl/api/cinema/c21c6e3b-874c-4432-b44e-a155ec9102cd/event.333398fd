To":"2026-06-11T22:30:00+02:00","saleTimeTo":"2026-06-11T20:30:00+02:00","reservationTimeTo":"2026-06-11T19:00:00+02:00","availabilityStatus":1,"maxOccupancy":112,"audience":0,"generalAdmission":false,"isScreenSwapping":false,"externalId":29686786,"items":[{"movieId":"b233f278-496b-4504-ac06-725630c68db1","moviePrintId":"2076a1e7-fffb-4dc7-b499-8398284b48eb","timeFrom":"2026-06-11T20:00:00+02:00","timeTo":"2026-06-11T22:30:00+02:00","movieName":"Podziemny krąg","speakingType":"Napisy","printType":"2D","screenId":"a0433da9-b091-41ef-8eb7-c7a9eefe3af3","movieSubPrintLabel":"ps"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":16,"symbol":"HELIOS REPLAY","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"0558005a-3851-48a5-be9d-4ae12a240224","duration":150,"description":"Już 4 czerwca kultowy „Podziemny krąg” („Fight Club”) wraca do kin po ponad 25 latach od premiery!\n\nTen prowokacyjny dramat, z udziałem Brada Pitta i Edwarda Nortona, w reżyserii Davida Finchera, opowiada o znudzonym i wyobcowanym mężczyźnie, który wraz z charyzmatycznym towarzyszem tworzą działający w podziemiu klub walki.","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"939b8bbb-4f8f-4fd6-875d-16e483eccdea","name":"thriller","description":""},{"id":"41200b53-4f1a-43c3-9c8e-cbe84751b892","name":"kryminał","description":""},{"id":"14c7bb44-6562-4ad9-8d7a-ab747fa73829","name":"dramat","description":""}],"trailers":[],"posters":["https://movies.helios.pl/images/Pozdziemnykragplakat.jpg"],"pictures":["https://movies.helios.pl/images/Podziemnykrag3.jpg","https://movies.helios.pl/images/Podziemnykrag2.jpg","https://movies.helios.pl/images/Podziemnykrag1.jpg"],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"15","value":"15","description":"od lat 15"}],"brightcoveVideos":[],"release":"2D/NAP","name":"Podziemny krąg w Helios RePlay","link":null,"screeningId":"5f397a1c-d965-41ea-94ae-26c416c6b0c5","screenId":"a0433da9-b091-41ef-8eb7-c7a9eefe3af3","cinemaId":"c21c6e3b-874c-4432-b44e-a155ec9102cd","timeFrom":"2026-06-10T20:00:00+02:00","timeTo":"2026-06-10T22:30:00+02:00","saleTimeTo":"2026-06-10T20:30:00+02:00","reservationTimeTo":"2026-06-10T19:00:00+02:00","availabilityStatus":1,"maxOccupancy":112,"audience":0,"generalAdmission":false,"isScreenSwapping":false,"externalId":29686786,"items":[{"movieId":"b233f278-496b-4504-ac06-725630c68db1","moviePrintId":"2076a1e7-fffb-4dc7-b499-8398284b48eb","timeFrom":"2026-06-10T20:00:00+02:00","timeTo":"2026-06-10T22:30:00+02:00","movieName":"Podziemny krąg","speakingType":"Napisy","printType":"2D","screenId":"a0433da9-b091-41ef-8eb7-c7a9eefe3af3","movieSubPrintLabel":"ps"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":16,"symbol":"HELIOS REPLAY","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"6c94cbc9-7a80-4a09-b3ad-5602eb24acbd","duration":195,"description":"Obejmująca 34 miasta i 85 koncertów trasa stała się największym tournée w historii koreańskiego artysty. Dodatkowego znaczenia temu wydarzeniu nadaje data koncertu - 13 czerwca, czyli rocznica debiutu BTS - symboliczny moment celebrujący zarówno dotychczasową drogę zespołu, jak i nowy rozdział ich kariery. \n\nTrasa ARIRANG towarzyszy piątemu albumowi studyjnemu grupy i opowiada o tożsamości BTS poprzez szczere emocje, tęsknotę i miłość, które od lat łączą ich z fanami na całym świecie. Imponująca scena 360 stopni sprawia, że widzowie stają się częścią widowiska i mogą poczuć energię koncertu z każdej perspektywy. \n\nNie przegap tego wyjątkowego wydarzenia. Przeżyj wielki powrót BTS na kinowym ekranie 13 czerwca - prosto z Busanu. \n\nUwaga: w wybranych krajach transmisja może odbywać się z opóźnieniem ze względu na różnice stref czasowych.","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"249045c8-3c6f-4ffe-abf3-ec3a85a2b1b1","name":"koncert ","description":""}],"trailers":[],"posters":["https://movies.helios.pl/images/BTSBusanPlakat(1).jpg"],"pictures":["https://movies.helios.pl/images/BTSczerwiec7.jpg","https://movies.helios.pl/images/BTSczerwiec3.jpg","https://movies.helios.pl/images/BTSczerwiec2.jpg","https://movies.helios.pl/images/BTSczerwiec1.jpg"],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"40","value":"10 lat","description":"od lat 10"}],"brightcoveVideos":[],"release":"2D/ORG","name":"BTS World Tour ‘ARIRANG’ in Busan: Live Viewing w Helios na Scenie","link":null,"screeningId":"3480b179-064a-4ea1-bcbe-768b74f9f321","screenId":"ee8e7893-49c3-4ee7-b2a3-814917680b3d","cinemaId":"c21c6e3b-874c-4432-b44e-a155ec9102cd","timeFrom":"2026-06-13T11:45:00+02:00","timeTo":"2026-06-13T15:00:00+02:00","saleTimeTo":"2026-06-13T12:15:00+02:00","reservationTimeTo":"2026-06-13T10:45:00+02:00","availabilityStatus":1,"maxOccupancy":163,"audience":43,"generalAdmission":false,"isScreenSwapping":false,"externalId":98745545,"items":[{"movieId":"fa55f94f-5ef2-4c03-95c9-d42bd7222047","moviePrintId":"b89ae438-86b6-42da-ab24-2a8f0b940215","timeFrom":"2026-06-13T11:45:00+02:00","timeTo":"2026-06-13T15:00:00+02:00","movieName":"BTS World Tour ‘ARIRANG’ in Busan: Live Viewing","speakingType":"ORG","printType":"2D","screenId":"ee8e7893-49c3-4ee7-b2a3-814917680b3d","movieSubPrintLabel":"PS"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":6,"symbol":"HELIOS NA SCENIE","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"4f103d1e-9983-4753-a14c-5ad571688313","duration":106,"description":"Bo właśnie tak tak tak się wyżej wznieś! W kinach tylko 10-18 czerwca! Domknij Honmoon i zaśpiewaj najlepsze hity z filmu „K-popowe łowczynie demonów” razem z HUNTR/X i Saja Boys. Pełna wersja karaoke hitowego filmu Netflixa w kinach tylko 10-18 czerwca.\n\nGwiazdy K-popu Rumi, Mira i Zoey w przerwach między koncertami na pełnych stadionach