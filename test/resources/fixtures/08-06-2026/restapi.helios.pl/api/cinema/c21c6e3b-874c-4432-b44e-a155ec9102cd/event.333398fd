-9c8e-cbe84751b892","name":"kryminał","description":""},{"id":"14c7bb44-6562-4ad9-8d7a-ab747fa73829","name":"dramat","description":""}],"trailers":[],"posters":["https://movies.helios.pl/images/Pozdziemnykragplakat.jpg"],"pictures":["https://movies.helios.pl/images/Podziemnykrag3.jpg","https://movies.helios.pl/images/Podziemnykrag2.jpg","https://movies.helios.pl/images/Podziemnykrag1.jpg"],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"15","value":"15","description":"od lat 15"}],"brightcoveVideos":[],"release":"2D/NAP","name":"Podziemny krąg w Helios RePlay","link":null,"screeningId":"6bb6f1de-4b69-4f35-b4b2-7ec3dfd76fb4","screenId":"a0433da9-b091-41ef-8eb7-c7a9eefe3af3","cinemaId":"c21c6e3b-874c-4432-b44e-a155ec9102cd","timeFrom":"2026-06-09T20:30:00+02:00","timeTo":"2026-06-09T23:00:00+02:00","saleTimeTo":"2026-06-09T21:00:00+02:00","reservationTimeTo":"2026-06-09T19:30:00+02:00","availabilityStatus":1,"maxOccupancy":112,"audience":8,"generalAdmission":false,"isScreenSwapping":false,"externalId":29686786,"items":[{"movieId":"b233f278-496b-4504-ac06-725630c68db1","moviePrintId":"2076a1e7-fffb-4dc7-b499-8398284b48eb","timeFrom":"2026-06-09T20:30:00+02:00","timeTo":"2026-06-09T23:00:00+02:00","movieName":"Podziemny krąg","speakingType":"Napisy","printType":"2D","screenId":"a0433da9-b091-41ef-8eb7-c7a9eefe3af3","movieSubPrintLabel":"ps"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":16,"symbol":"HELIOS REPLAY","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"6c94cbc9-7a80-4a09-b3ad-5602eb24acbd","duration":195,"description":"Obejmująca 34 miasta i 85 koncertów trasa stała się największym tournée w historii koreańskiego artysty. Dodatkowego znaczenia temu wydarzeniu nadaje data koncertu - 13 czerwca, czyli rocznica debiutu BTS - symboliczny moment celebrujący zarówno dotychczasową drogę zespołu, jak i nowy rozdział ich kariery. \n\nTrasa ARIRANG towarzyszy piątemu albumowi studyjnemu grupy i opowiada o tożsamości BTS poprzez szczere emocje, tęsknotę i miłość, które od lat łączą ich z fanami na całym świecie. Imponująca scena 360 stopni sprawia, że widzowie stają się częścią widowiska i mogą poczuć energię koncertu z każdej perspektywy. \n\nNie przegap tego wyjątkowego wydarzenia. Przeżyj wielki powrót BTS na kinowym ekranie 13 czerwca - prosto z Busanu. \n\nUwaga: w wybranych krajach transmisja może odbywać się z opóźnieniem ze względu na różnice stref czasowych.","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"249045c8-3c6f-4ffe-abf3-ec3a85a2b1b1","name":"koncert ","description":""}],"trailers":[],"posters":["https://movies.helios.pl/images/BTSBusanPlakat(1).jpg"],"pictures":["https://movies.helios.pl/images/BTSczerwiec7.jpg","https://movies.helios.pl/images/BTSczerwiec3.jpg","https://movies.helios.pl/images/BTSczerwiec2.jpg","https://movies.helios.pl/images/BTSczerwiec1.jpg"],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"40","value":"10 lat","description":"od lat 10"}],"brightcoveVideos":[],"release":"2D/ORG","name":"BTS World Tour ‘ARIRANG’ in Busan: Live Viewing w Helios na Scenie","link":null,"screeningId":"b93a2760-b6be-476a-8679-ca50f65bd254","screenId":"ee8e7893-49c3-4ee7-b2a3-814917680b3d","cinemaId":"c21c6e3b-874c-4432-b44e-a155ec9102cd","timeFrom":"2026-06-13T15:30:00+02:00","timeTo":"2026-06-13T18:45:00+02:00","saleTimeTo":"2026-06-13T16:00:00+02:00","reservationTimeTo":"2026-06-13T14:30:00+02:00","availabilityStatus":1,"maxOccupancy":163,"audience":7,"generalAdmission":false,"isScreenSwapping":false,"externalId":98745545,"items":[{"movieId":"fa55f94f-5ef2-4c03-95c9-d42bd7222047","moviePrintId":"b89ae438-86b6-42da-ab24-2a8f0b940215","timeFrom":"2026-06-13T15:30:00+02:00","timeTo":"2026-06-13T18:45:00+02:00","movieName":"BTS World Tour ‘ARIRANG’ in Busan: Live Viewing","speakingType":"ORG","printType":"2D","screenId":"ee8e7893-49c3-4ee7-b2a3-814917680b3d","movieSubPrintLabel":"PS"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":6,"symbol":"HELIOS NA SCENIE","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"4f103d1e-9983-4753-a14c-5ad571688313","duration":106,"description":"Bo właśnie tak tak tak się wyżej wznieś! W kinach tylko 10-18 czerwca! Domknij Honmoon i zaśpiewaj najlepsze hity z filmu „K-popowe łowczynie demonów” razem z HUNTR/X i Saja Boys. Pełna wersja karaoke hitowego filmu Netflixa w kinach tylko 10-18 czerwca.\n\nGwiazdy K-popu Rumi, Mira i Zoey w przerwach między koncertami na pełnych stadionach bronią fanów przed nadnaturalnymi zagrożeniami, korzystając ze swoich tajemnych mocy.","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"9212e3f5-252f-4d08-b375-2923037a4591","name":"animowany","description":""}],"trailers":["https://www.youtube.com/embed/loBwcgZt_m4"],"posters":["https://movies.helios.pl/images/KPopoweLowczynieplakat.jpg"],"pictures":["https://movies.helios.pl/images/Kpopowelowczyniedemonow8.jpg","https://movies.helios.pl/images/Kpopowelowczyniedemonow7.jpg","https://movies.helios.pl/images/Kpopowelowczyniedemonow6.jpg","https://movies.helios.pl/images/Kpopowelowczyniedemonow5.jpg","https://movies.helios.pl/images/Kpopowelowczyniedemonow4.jpg","https://movies.helios.pl/images/Kpopowelowczyniedemonow3.jpg","https://movies.helios.pl/images/Kpopowelowczyniedemonow2.jpg","https://movies.helios.pl/images/Kpopowelowczyniedemonow1.jpg"],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"10","value":"10","description":"od lat 10"}],"brightcoveVideos":[],"release":"2D/NAP","name":"K-popowe Łowczynie Demonów: Karaoke w Helios na Scenie","link":null,"screeningId":"27626bc2-0763-4207-b57f-462741545d07","screenId":"6cea83f6-a365-4aed-86d8-672786c1bfb3","cinemaId":"c21c6e3b-874c-4432-b44e-a155ec9102cd","timeFrom":"2026-06-11T16:30:00+02:00","timeTo":"2026-06-11T18:16:00+0