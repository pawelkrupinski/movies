71-cc089ac446d1","screenId":"a0433da9-b091-41ef-8eb7-c7a9eefe3af3","cinemaId":"c21c6e3b-874c-4432-b44e-a155ec9102cd","timeFrom":"2026-06-08T09:00:00+02:00","timeTo":"2026-06-08T11:00:00+02:00","saleTimeTo":"2026-06-08T09:30:00+02:00","reservationTimeTo":"2026-06-08T08:00:00+02:00","availabilityStatus":1,"maxOccupancy":112,"audience":42,"generalAdmission":false,"isScreenSwapping":false,"externalId":744412365,"items":[{"movieId":"040d2e11-ff64-4722-b82a-cc2730855c50","moviePrintId":"12377068-57a9-457b-b557-8b2172014f79","timeFrom":"2026-06-08T09:00:00+02:00","timeTo":"2026-06-08T11:00:00+02:00","movieName":"Willow i tajemniczy las ","speakingType":"DUB","printType":"2D","screenId":"a0433da9-b091-41ef-8eb7-c7a9eefe3af3","movieSubPrintLabel":"ps"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":8,"symbol":"KINO NA TEMAT JUNIOR","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"16cdc91a-de6c-4116-b0d2-9b802901b5a1","duration":130,"description":"9-letni Wolfgang po nagłej śmierci matki jest zmuszony zamieszkać ze swoim ojcem, z którym wcześniej nie utrzymywał kontaktu. Chłopiec ma wysoki iloraz inteligencji i marzy o wyjeździe do Paryża, żeby zostać najlepszym pianistą na świecie. Jednak największym wyzwaniem będzie dla niego zbudowanie od zera relacji ze swoim rodzicem.","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"6bcd8fba-fbc2-466a-9f37-ce7a42443c2e","name":"familijny","description":""},{"id":"14c7bb44-6562-4ad9-8d7a-ab747fa73829","name":"dramat","description":""}],"trailers":["https://www.youtube.com/embed/-L-IqjJmxro"],"posters":["https://movies.helios.pl/images/plakatniezwyklychlopak.jpg"],"pictures":[],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"10","value":"10","description":"od lat 10"}],"brightcoveVideos":[],"release":"2D/DUB","name":"Niezwykły chłopak - KNT","link":null,"screeningId":"863f6035-b6c8-43e3-b606-a6411297b818","screenId":"6cea83f6-a365-4aed-86d8-672786c1bfb3","cinemaId":"c21c6e3b-874c-4432-b44e-a155ec9102cd","timeFrom":"2026-06-10T10:30:00+02:00","timeTo":"2026-06-10T12:40:00+02:00","saleTimeTo":"2026-06-10T11:00:00+02:00","reservationTimeTo":"2026-06-10T09:30:00+02:00","availabilityStatus":1,"maxOccupancy":163,"audience":65,"generalAdmission":false,"isScreenSwapping":false,"externalId":74442356,"items":[{"movieId":"b8efb135-e61e-4d76-90e2-5b127bdeeb9a","moviePrintId":"35048f53-3edd-4e6b-aed1-3eaf3bc8ae92","timeFrom":"2026-06-10T10:30:00+02:00","timeTo":"2026-06-10T12:40:00+02:00","movieName":"Niezwykły chłopak","speakingType":"DUB","printType":"2D","screenId":"6cea83f6-a365-4aed-86d8-672786c1bfb3","movieSubPrintLabel":"ps"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":7,"symbol":"KINO NA TEMAT","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"feee7612-9cd6-4397-a516-db46be76e2c4","duration":159,"description":"W 1939 roku Szpilman jest cenionym pianistą i kompozytorem, który mieszka wraz z rodziną w Warszawie. Kiedy do stolicy wkraczają naziści, życie żydowskiego muzyka zamienia się w koszmar: traci kolejne prawa, trafia do getta, obserwuje dwa powstania i próbuje przetrwać w zniszczonym mieście. Pomaga mu przypadek, łut szczęścia oraz miłość do muzyki.","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"b36e63dc-85ea-4670-93db-f785f49c720e","name":"biograficzny","description":""},{"id":"14c7bb44-6562-4ad9-8d7a-ab747fa73829","name":"dramat","description":""}],"trailers":["https://www.youtube.com/embed/KTDhBh_vL_Q"],"posters":["https://movies.helios.pl/images/pianistaplakat.png"],"pictures":["https://movies.helios.pl/images/Pianista7.jpg","https://movies.helios.pl/images/Pianista6.jpg","https://movies.helios.pl/images/Pianista5.jpg","https://movies.helios.pl/images/Pianista4.jpg","https://movies.helios.pl/images/Pianista3.jpg","https://movies.helios.pl/images/Pianista2.jpg","https://movies.helios.pl/images/Pianista1.jpg"],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"15","value":"15","description":"od lat 15"}],"brightcoveVideos":[],"release":"2D/NAP","name":"Pianista w Helios RePlay","link":null,"screeningId":"723963b3-f4ad-456b-bf52-9d0e6f36bf4b","screenId":"274c4d10-6f11-4c6d-943d-8be6a5eadf47","cinemaId":"c21c6e3b-874c-4432-b44e-a155ec9102cd","timeFrom":"2026-06-14T15:00:00+02:00","timeTo":"2026-06-14T17:39:00+02:00","saleTimeTo":"2026-06-14T15:30:00+02:00","reservationTimeTo":"2026-06-14T14:00:00+02:00","availabilityStatus":1,"maxOccupancy":163,"audience":0,"generalAdmission":false,"isScreenSwapping":false,"externalId":128645,"items":[{"movieId":"117e6eec-1144-4b1a-9600-a86530ca8b3a","moviePrintId":"98e18e82-1d60-4df6-ae6e-e9c76a4d486d","timeFrom":"2026-06-14T15:00:00+02:00","timeTo":"2026-06-14T17:39:00+02:00","movieName":"Pianista","speakingType":"Napisy","printType":"2D","screenId":"274c4d10-6f11-4c6d-943d-8be6a5eadf47","movieSubPrintLabel":"ps"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":16,"symbol":"HELIOS REPLAY","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"d7bb09f1-a1ea-4982-915d-db91d91397cc","duration":176,"description":"Nigdy nie jest za późno, by zacząć od nowa. Emanujący optymizmem i pogodą ducha portret dojrzałej kobiety, która robi wszystko, by ocalić swój dom i siebie.\n\n María Ángeles od 40 lat mieszka w słonecznym apartamencie w marokańskim Tangerze. Gdy zostaje zmuszona do jego opuszczenia, nie potrafi się z tym pogodzić. To, co początkowo wydaje się bolesną koniecznością, nieoczekiwanie staje się jednak nowym początkiem. W życiu Marii Ángeles pojawia się miejsce zarówno na nowych przyjaciół, jak i na niespodziewaną miłość. „Drugie życie” to zdobywca nagrody publiczności festiwalu w Wenecji. W roli głównej zachwycająca Carmen Maura, ikona filmów Almodóvara.","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"4a3d74ad-af64-4a6a-a640-e75c762899c8","name":"romans","description":""},{"id":"14c7bb44-6562-4ad9-8d7a-ab747fa73829","name":"dramat","description":""}],"trailers":["https://www.youtube.com/embed/8xyTxjwUwfQ"],"posters":["https://movies.helios.pl/images/drugiezycieplakat.jpg"],"pictures":["https://movies.helios.pl/images/Drugiezycie7.jpg","https://movies.helios.pl/images/Drugiezycie6.jpg","https://movies.helios.pl/images/Drugiezycie5.jpg","https://movies.helios.pl/images/Drugiezycie4.jpg","https://movies.helios.pl/images/Drugiezycie3.jpg","https://movies.helios.pl/images/Drugiezycie2.jpg","https://movies.helios.pl/images/Drugiezycie1.jpg"],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"15","value":"15","description":"od lat 15"}],"brightcoveVideos":[],"release":"2D/NAP","name":"Drugie życie - Kino Kobiet","link":null,"screeningId":"22eb0e3d-29ca-4015-a9fc-1fcb9db60fd4","screenId":"ad8ec004-5483-4e3f-9d2e-e2c24e521b91","cinemaId":"c21c6e3b-874c-4432-b44e-a155ec9102cd","timeFrom":"2026-06-10T18:00:00+02:00","timeTo":"2026-06-10T20:56:00+02:00","saleTimeTo":"2026-06-10T18:30:00+02:00","reservationTimeTo":"2026-06-10T17:00:00+02:00","availabilityStatus":1,"maxOccupancy":241,"audience":86,"generalAdmission":false,"isScreenSwapping":false,"externalId":835356,"items":[{"movieId":"efba3b90-d2db-4d41-b474-60d596a59302","moviePrintId":"4a18ef08-42c9-481a-b3ba-e757ea39fec5","timeFrom":"2026-06-10T18:00:00+02:00","timeTo":"2026-06-10T20:56:00+02:00","movieName":"Drugie życie","speakingType":"Napisy","printType":"2D","screenId":"ad8ec004-5483-4e3f-9d2e-e2c24e521b91","movieSubPrintLabel":"PS"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":2,"symbol":"KINO KOBIET","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"8548c02a-56bf-4df4-8085-fbb356648e06","duration":110,"description":"Waldek ma dość – w domu chaos, w sieci drama, a jego 