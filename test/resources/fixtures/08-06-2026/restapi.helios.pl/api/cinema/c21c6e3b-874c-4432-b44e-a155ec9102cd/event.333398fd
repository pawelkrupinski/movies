[{"id":"9fa84454-3318-4d8f-bd42-0125bcba84ca","duration":130,"description":"Polly i Tim wraz z trójką dzieci stają przed koniecznością przeprowadzenia się na odludną angielską prowincję. Wkrótce po przyjeździe najmłodsi odkrywają niezwykłe drzewo, zamieszkane przez barwne, ekscentryczne postacie. Jeśli odważą się wspiąć na jego szczyt, czekają na nie fantastyczne krainy, pełne zapierających dech przygód.","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"726b5445-9bb2-48ff-8ef1-c4e96bb92399","name":"przygodowy","description":""},{"id":"6bcd8fba-fbc2-466a-9f37-ce7a42443c2e","name":"familijny","description":""},{"id":"32d53995-2198-4b43-aa57-235bfeee409e","name":"fantasy","description":""}],"trailers":["https://www.youtube.com/embed/T1FJ-tzNDXc"],"posters":["https://movies.helios.pl/images/DRZEWOMAGIITEASERPLAKAT(1).png"],"pictures":["https://movies.helios.pl/images/Drzewomagii7(1).jpg","https://movies.helios.pl/images/Drzewomagii6(1).jpg","https://movies.helios.pl/images/Drzewomagii5(1).jpg","https://movies.helios.pl/images/Drzewomagii4(1).jpg","https://movies.helios.pl/images/Drzewomagii3(1).jpg","https://movies.helios.pl/images/Drzewomagii2(1).jpg","https://movies.helios.pl/images/Drzewomagii1(1).jpg"],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"8","value":"8","description":"od lat 8"}],"brightcoveVideos":[],"release":"2D/DUB","name":"Drzewo Magii - KNT","link":null,"screeningId":"9fdb05bc-6af9-4660-94c7-9c0ca91d8d6f","screenId":"ad8ec004-5483-4e3f-9d2e-e2c24e521b91","cinemaId":"c21c6e3b-874c-4432-b44e-a155ec9102cd","timeFrom":"2026-06-10T10:00:00+02:00","timeTo":"2026-06-10T12:10:00+02:00","saleTimeTo":"2026-06-10T10:30:00+02:00","reservationTimeTo":"2026-06-10T09:00:00+02:00","availabilityStatus":1,"maxOccupancy":241,"audience":42,"generalAdmission":false,"isScreenSwapping":false,"externalId":74222365,"items":[{"movieId":"f222b6a2-1b42-430c-80f9-f93e67d877b5","moviePrintId":"536eb5ef-