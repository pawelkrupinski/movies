odziemny krąg” („Fight Club”) wraca do kin po ponad 25 latach od premiery!\n\nTen prowokacyjny dramat, z udziałem Brada Pitta i Edwarda Nortona, w reżyserii Davida Finchera, opowiada o znudzonym i wyobcowanym mężczyźnie, który wraz z charyzmatycznym towarzyszem tworzą działający w podziemiu klub walki.","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"939b8bbb-4f8f-4fd6-875d-16e483eccdea","name":"thriller","description":""},{"id":"41200b53-4f1a-43c3-9c8e-cbe84751b892","name":"kryminał","description":""},{"id":"14c7bb44-6562-4ad9-8d7a-ab747fa73829","name":"dramat","description":""}],"trailers":[],"posters":["https://movies.helios.pl/images/Pozdziemnykragplakat.jpg"],"pictures":["https://movies.helios.pl/images/Podziemnykrag3.jpg","https://movies.helios.pl/images/Podziemnykrag2.jpg","https://movies.helios.pl/images/Podziemnykrag1.jpg"],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"15","value":"15","description":"od lat 15"}],"brightcoveVideos":[],"release":"2D/NAP","name":"Podziemny krąg w Helios RePlay","link":null,"screeningId":"a3f8ce34-0da8-4d41-883e-eaeae5e23b8b","screenId":"63a94c77-c702-4262-b02e-4eab923a97ea","cinemaId":"7582cee7-2815-4897-8715-e90a5b99d2e4","timeFrom":"2026-06-09T18:00:00+02:00","timeTo":"2026-06-09T20:30:00+02:00","saleTimeTo":"2026-06-09T18:30:00+02:00","reservationTimeTo":"2026-06-09T17:00:00+02:00","availabilityStatus":1,"maxOccupancy":208,"audience":0,"generalAdmission":false,"isScreenSwapping":false,"externalId":29686786,"items":[{"movieId":"b233f278-496b-4504-ac06-725630c68db1","moviePrintId":"2076a1e7-fffb-4dc7-b499-8398284b48eb","timeFrom":"2026-06-09T18:00:00+02:00","timeTo":"2026-06-09T20:30:00+02:00","movieName":"Podziemny krąg","speakingType":"Napisy","printType":"2D","screenId":"63a94c77-c702-4262-b02e-4eab923a97ea","movieSubPrintLabel":"ps"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":16,"symbol":"HELIOS REPLAY","