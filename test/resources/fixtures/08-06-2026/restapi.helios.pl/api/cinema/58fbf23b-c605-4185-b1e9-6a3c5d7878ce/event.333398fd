a-4a974a75c874","duration":134,"description":"Andrea to utalentowany uczeń włoskiej szkoły, który śpiewa również w chórze. Staje się to powodem drwin wśród rówieśników. Przewodzi im Christian, najprzystojniejszy chłopak w szkole. Andrea pada ofiarą przemocy psychicznej i nie potrafi sobie z tym poradzić. ","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"14c7bb44-6562-4ad9-8d7a-ab747fa73829","name":"dramat","description":""}],"trailers":[],"posters":["https://movies.helios.pl/images/chlopakwrozowychspodniachplakat(1).jpg"],"pictures":["https://movies.helios.pl/images/Chłopiecwrozowychspodniach1(1).jpg"],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"13","value":"13","description":"od lat 13"}],"brightcoveVideos":[],"release":"2D/DUB","name":"Chłopiec w różowych spodniach - KNT","link":null,"screeningId":"d0dd09f5-0bb8-47f6-baa1-8b5cbfc8df8b","screenId":"791c6d72-f7fd-4a9a-914f-6dfb00c46b32","cinemaId":"58fbf23b-c605-4185-b1e9-6a3c5d7878ce","timeFrom":"2026-06-08T09:30:00+02:00","timeTo":"2026-06-08T11:44:00+02:00","saleTimeTo":"2026-06-08T10:00:00+02:00","reservationTimeTo":"2026-06-08T08:30:00+02:00","availabilityStatus":1,"maxOccupancy":155,"audience":45,"generalAdmission":false,"isScreenSwapping":false,"externalId":548657856,"items":[{"movieId":"482f71e6-85bd-46f6-8de4-4d98ffd75b5b","moviePrintId":"72a4e610-39a9-4ca7-85d6-33c924bca6b5","timeFrom":"2026-06-08T09:30:00+02:00","timeTo":"2026-06-08T11:44:00+02:00","movieName":"Chłopiec w różowych spodniach","speakingType":"DUB","printType":"2D","screenId":"791c6d72-f7fd-4a9a-914f-6dfb00c46b32","movieSubPrintLabel":"ps"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":7,"symbol":"KINO NA TEMAT","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"0558005a-3851-48a5-be9d-4ae12a240224","duration":150,"description":"Już 4 czerwca kultowy „Podziemny krąg” („Fight Club”) wraca do kin po po