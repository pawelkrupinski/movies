"description":""},{"id":"14c7bb44-6562-4ad9-8d7a-ab747fa73829","name":"dramat","description":""}],"trailers":["https://www.youtube.com/embed/KTDhBh_vL_Q"],"posters":["https://movies.helios.pl/images/pianistaplakat.png"],"pictures":["https://movies.helios.pl/images/Pianista7.jpg","https://movies.helios.pl/images/Pianista6.jpg","https://movies.helios.pl/images/Pianista5.jpg","https://movies.helios.pl/images/Pianista4.jpg","https://movies.helios.pl/images/Pianista3.jpg","https://movies.helios.pl/images/Pianista2.jpg","https://movies.helios.pl/images/Pianista1.jpg"],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"15","value":"15","description":"od lat 15"}],"brightcoveVideos":[],"release":"2D/NAP","name":"Pianista w Helios RePlay","link":null,"screeningId":"b9c58533-44eb-4589-9b2d-ddcfe6c274d4","screenId":"75ab1a35-7c6a-4a2b-9c60-4afb7c19f68b","cinemaId":"5c699a45-d219-4f4e-90f4-4aac0ca44a88","timeFrom":"2026-06-14T15:00:00+02:00","timeTo":"2026-06-14T17:39:00+02:00","saleTimeTo":"2026-06-14T15:30:00+02:00","reservationTimeTo":"2026-06-14T14:00:00+02:00","availabilityStatus":1,"maxOccupancy":146,"audience":7,"generalAdmission":false,"isScreenSwapping":false,"externalId":128645,"items":[{"movieId":"117e6eec-1144-4b1a-9600-a86530ca8b3a","moviePrintId":"98e18e82-1d60-4df6-ae6e-e9c76a4d486d","timeFrom":"2026-06-14T15:00:00+02:00","timeTo":"2026-06-14T17:39:00+02:00","movieName":"Pianista","speakingType":"Napisy","printType":"2D","screenId":"75ab1a35-7c6a-4a2b-9c60-4afb7c19f68b","movieSubPrintLabel":"ps"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":16,"symbol":"HELIOS REPLAY","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"d7bb09f1-a1ea-4982-915d-db91d91397cc","duration":176,"description":"Nigdy nie jest za późno, by zacząć od nowa. Emanujący optymizmem i pogodą ducha portret dojrzałej kobiety, która robi wszystko, by ocalić swój dom i siebie.\n\n María Ángeles od 40 lat mieszka w słonecznym apartamencie w marokańskim Tangerze. Gdy zostaje zmuszona do jego opuszczenia, nie potrafi się z tym pogodzić. To, co początkowo wydaje się bolesną koniecznością, nieoczekiwanie staje się jednak nowym początkiem. W życiu Marii Ángeles pojawia się miejsce zarówno na nowych przyjaciół, jak i na niespodziewaną miłość. „Drugie życie” to zdobywca nagrody publiczności festiwalu w Wenecji. W roli głównej zachwycająca Carmen Maura, ikona filmów Almodóvara.","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"4a3d74ad-af64-4a6a-a640-e75c762899c8","name":"romans","description":""},{"id":"14c7bb44-6562-4ad9-8d7a-ab747fa73829","name":"dramat","description":""}],"trailers":["https://www.youtube.com/embed/8xyTxjwUwfQ"],"posters":["https://movies.helios.pl/images/drugiezycieplakat.jpg"],"pictures":["https://movies.helios.pl/images/Drugiezycie7.jpg","https://movies.helios.pl/images/Drugiezycie6.jpg","https://movies.helios.pl/images/Drugiezycie5.jpg","https://movies.helios.pl/images/Drugiezycie4.jpg","https://movies.helios.pl/images/Drugiezycie3.jpg","https://movies.helios.pl/images/Drugiezycie2.jpg","https://movies.helios.pl/images/Drugiezycie1.jpg"],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"15","value":"15","description":"od lat 15"}],"brightcoveVideos":[],"release":"2D/NAP","name":"Drugie życie - Kino Kobiet","link":null,"screeningId":"9754bd48-2f0a-44fe-a0ff-0b06664f8c85","screenId":"9ce70cd2-2660-42a4-851f-6aaf5df3f330","cinemaId":"5c699a45-d219-4f4e-90f4-4aac0ca44a88","timeFrom":"2026-06-10T18:00:00+02:00","timeTo":"2026-06-10T20:56:00+02:00","saleTimeTo":"2026-06-10T18:30:00+02:00","reservationTimeTo":"2026-06-10T17:00:00+02:00","availabilityStatus":1,"maxOccupancy":276,"audience":80,"generalAdmission":false,"isScreenSwapping":false,"externalId":835356,"items":[{"movieId":"efba3b90-d2db-4d41-b474-60d596a59302","moviePrintId":"4a18ef08-42c9-481a-b3ba-e757ea39fec5","timeFrom":"2026-06-10T18:0