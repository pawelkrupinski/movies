[{"movieId":"b233f278-496b-4504-ac06-725630c68db1","moviePrintId":"2076a1e7-fffb-4dc7-b499-8398284b48eb","timeFrom":"2026-06-10T20:45:00+02:00","timeTo":"2026-06-10T23:15:00+02:00","movieName":"Podziemny krąg","speakingType":"Napisy","printType":"2D","screenId":"d0b546a8-af89-4782-8ed5-41b481bc934a","movieSubPrintLabel":"ps"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":16,"symbol":"HELIOS REPLAY","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"6c94cbc9-7a80-4a09-b3ad-5602eb24acbd","duration":195,"description":"Obejmująca 34 miasta i 85 koncertów trasa stała się największym tournée w historii koreańskiego artysty. Dodatkowego znaczenia temu wydarzeniu nadaje data koncertu - 13 czerwca, czyli rocznica debiutu BTS - symboliczny moment celebrujący zarówno dotychczasową drogę zespołu, jak i nowy rozdział ich kariery. \n\nTrasa ARIRANG towarzyszy piątemu albumowi studyjnemu grupy i opowiada o tożsamości BTS poprzez szczere emocje, tęsknotę i miłość, które od lat łączą ich z fanami na całym świecie. Imponująca scena 360 stopni sprawia, że widzowie stają się częścią widowiska i mogą poczuć energię koncertu z każdej perspektywy. \n\nNie przegap tego wyjątkowego wydarzenia. Przeżyj wielki powrót BTS na kinowym ekranie 13 czerwca - prosto z Busanu. \n\nUwaga: w wybranych krajach transmisja może odbywać się z opóźnieniem ze względu na różnice stref czasowych.","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"249045c8-3c6f-4ffe-abf3-ec3a85a2b1b1","name":"koncert ","description":""}],"trailers":[],"posters":["https://movies.helios.pl/images/BTSBusanPlakat(1).jpg"],"pictures":["https://movies.helios.pl/images/BTSczerwiec7.jpg","https://movies.helios.pl/images/BTSczerwiec3.jpg","https://movies.helios.pl/images/BTSczerwiec2.jpg","https://movies.helios.pl/images/BTSczerwiec1.jpg"],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"40","value":"1