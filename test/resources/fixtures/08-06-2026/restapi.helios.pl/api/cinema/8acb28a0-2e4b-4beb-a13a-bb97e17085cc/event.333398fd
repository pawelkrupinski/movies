ód bliskości, ale i agresję, która wybucha w nieoczekiwanych momentach.","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"14c7bb44-6562-4ad9-8d7a-ab747fa73829","name":"dramat","description":""}],"trailers":[],"posters":["\\\\172.20.202.64\\movies\\images\\LOBUZplakat.jpg"],"pictures":[],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"15","value":"15","description":"od lat 15"}],"brightcoveVideos":[],"release":"2D/NAP","name":"Łobuz - KNT","link":null,"screeningId":"8d3dc9c3-70b8-4be2-8ce5-6e02eb1128c5","screenId":"ae9985fd-b531-4bb1-a2eb-46bc0d2280df","cinemaId":"8acb28a0-2e4b-4beb-a13a-bb97e17085cc","timeFrom":"2026-06-10T16:15:00+02:00","timeTo":"2026-06-10T18:14:00+02:00","saleTimeTo":"2026-06-10T16:45:00+02:00","reservationTimeTo":"2026-06-10T15:15:00+02:00","availabilityStatus":1,"maxOccupancy":76,"audience":23,"generalAdmission":false,"isScreenSwapping":false,"externalId":456565235,"items":[{"movieId":"edc4365e-7641-43bb-9c68-8111a1a6e977","moviePrintId":"e0213252-8377-44ee-9464-cc2fac773792","timeFrom":"2026-06-10T16:15:00+02:00","timeTo":"2026-06-10T18:14:00+02:00","movieName":"Łobuz","speakingType":"Napisy","printType":"2D","screenId":"ae9985fd-b531-4bb1-a2eb-46bc0d2280df","movieSubPrintLabel":"ps"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":7,"symbol":"KINO NA TEMAT","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]}]