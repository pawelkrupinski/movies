. Jak z tego wybrnąć, żeby zachować dziewczynę i najlepszego przyjaciela? Piętrzą się trudne pytania, sekrety i wielkie dylematy. Jak Bert ma to wszystko ogarnąć, żeby nie wydarzyła się totalna katastrofa?","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"14c7bb44-6562-4ad9-8d7a-ab747fa73829","name":"dramat","description":""},{"id":"33b6d7c4-1777-46f4-9ae2-6d1cbf8d8b40","name":"komedia","description":""}],"trailers":[],"posters":["https://movies.helios.pl/images/plakatjakberttowszystkoogar.jpg"],"pictures":["https://movies.helios.pl/images/JakBerttowszystkoogarnie5.jpg","https://movies.helios.pl/images/JakBerttowszystkoogarnie4.jpg","https://movies.helios.pl/images/JakBerttowszystkoogarnie3.jpg","https://movies.helios.pl/images/JakBerttowszystkoogarnie2.jpg","https://movies.helios.pl/images/JakBerttowszystkoogarnie1.jpg"],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"13","value":"13","description":"od lat 13"}],"brightcoveVideos":[],"release":"2D/DUB","name":"Jak Bert to wszystko ogarnie? - KNT","link":null,"screeningId":"e11682f9-1d1a-45ee-9131-63c82de5f7f8","screenId":"e86cab1c-5e3a-47e6-9c5c-8b1605f49338","cinemaId":"8acb28a0-2e4b-4beb-a13a-bb97e17085cc","timeFrom":"2026-06-09T09:00:00+02:00","timeTo":"2026-06-09T10:43:00+02:00","saleTimeTo":"2026-06-09T09:30:00+02:00","reservationTimeTo":"2026-06-09T08:00:00+02:00","availabilityStatus":1,"maxOccupancy":129,"audience":0,"generalAdmission":false,"isScreenSwapping":false,"externalId":545466,"items":[{"movieId":"6a5dabbc-00aa-438d-bc11-15e4447e76c1","moviePrintId":"714d2599-192e-450c-98b2-26e8216e6558","timeFrom":"2026-06-09T09:00:00+02:00","timeTo":"2026-06-09T10:43:00+02:00","movieName":"Jak Bert to wszystko ogarnie?","speakingType":"DUB","printType":"2D","screenId":"e86cab1c-5e3a-47e6-9c5c-8b1605f49338","movieSubPrintLabel":"PS"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":7,"symbol":"KINO NA TEMAT"