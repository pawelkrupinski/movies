,"posters":["\\\\172.20.202.64\\movies\\images\\plakatpodrecznikdlasuperbohaterow.jpg"],"pictures":[],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"6","value":"6","description":"od lat 6"}],"brightcoveVideos":[],"release":"2D/DUB","name":"Podręcznik dla superbohaterów - KNTJ","link":null,"screeningId":"21316c8c-a9b4-4d9f-a079-b0bd0355b7e6","screenId":"b9b19d98-df4d-4db8-be68-33e0a7843da4","cinemaId":"8acb28a0-2e4b-4beb-a13a-bb97e17085cc","timeFrom":"2026-06-10T09:30:00+02:00","timeTo":"2026-06-10T11:21:00+02:00","saleTimeTo":"2026-06-10T10:00:00+02:00","reservationTimeTo":"2026-06-10T08:30:00+02:00","availabilityStatus":1,"maxOccupancy":129,"audience":27,"generalAdmission":false,"isScreenSwapping":false,"externalId":755523652,"items":[{"movieId":"5af2b933-3a64-4a24-978b-1d53750e1d98","moviePrintId":"3b9a94e6-843e-4e3f-8ee3-48c6abcac064","timeFrom":"2026-06-10T09:30:00+02:00","timeTo":"2026-06-10T11:21:00+02:00","movieName":"Podręcznik dla superbohaterów","speakingType":"DUB","printType":"2D","screenId":"b9b19d98-df4d-4db8-be68-33e0a7843da4","movieSubPrintLabel":"ps"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":8,"symbol":"KINO NA TEMAT JUNIOR","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"7d61261d-af61-4717-8087-35ea842813ee","duration":152,"description":"Złowieszcze Imperium upadło, a imperialni watażkowie rozpierzchli się po Galaktyce. Kiełkująca Nowa Republika pragnie ochronić wszystko, o co walczyła Rebelia. Werbuje więc legendarnego łowcę nagród, Mandalorianina Din Djarina (Pedro Pascal) i jego młodego podopiecznego Grogu. Film, w którym wystąpi również Sigourney Weaver, wyreżyserował Jon Favreau, a wyprodukowali go Jon Favreau, Kathleen Kennedy, Dave Filoni i Ian Bryce. Muzykę spokmponował Ludwig Göransson.\n\nW filmie Mandalorian i Grogu znajduje się kilka scen z dynamicznymi efektami świetlnymi, które mogą powodować dyskomfort u widzów wrażliwych na światło i wpływać na osoby z epilepsją fotogenną.","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"32d53995-2198-4b43-aa57-235bfeee409e","name":"fantasy","description":""},{"id":"12131c24-a1c8-413d-98ee-d6f860dc905c","name":"akcja","description":""},{"id":"726b5445-9bb2-48ff-8ef1-c4e96bb92399","name":"przygodowy","description":""}],"trailers":[],"posters":["https://movies.helios.pl/images/mandalorianplakat.jpg"],"pictures":[],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"13","value":"13","description":"od lat 13"}],"brightcoveVideos":[],"release":"2D/DUB","name":"Mandalorian & Grogu - DUB - KNT","link":null,"screeningId":"2d72cf96-7ab6-4173-8563-c668289ef49b","screenId":"ba86d127-6d1e-4f74-a69f-95cceb14530f","cinemaId":"8acb28a0-2e4b-4beb-a13a-bb97e17085cc","timeFrom":"2026-06-08T13:00:00+02:00","timeTo":"2026-06-08T15:32:28+02:00","saleTimeTo":"2026-06-08T13:30:00+02:00","reservationTimeTo":"2026-06-08T12:00:00+02:00","availabilityStatus":1,"maxOccupancy":101,"audience":44,"generalAdmission":false,"isScreenSwapping":false,"externalId":6892222,"items":[{"movieId":"0ec14de2-9816-42db-8c85-4ef4b964c919","moviePrintId":"d534d41b-7579-4bdb-a59b-eb2190e1a8a4","timeFrom":"2026-06-08T13:00:00+02:00","timeTo":"2026-06-08T15:32:28+02:00","movieName":"Mandalorian & Grogu","speakingType":"DUB","printType":"2D","screenId":"ba86d127-6d1e-4f74-a69f-95cceb14530f","movieSubPrintLabel":"ps"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":7,"symbol":"KINO NA TEMAT","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"ed834156-8c3f-4332-8f23-3c9b0648811c","duration":108,"description":"Makoto jest zwyczajną nastolatką, spędzającą większość czasu z przyjaciółmi. Kiedy pewnego dnia, spiesząc się z wizytą do ciotki, cudem unika potrącenia przez pociąg – przeskakuje w czasie do momentu sprzed wypadku. Korzystając z nowo poznanych zdolności, naprawia swoje codzienne błędy – od słabych ocen na sprawdzianach po nieudane wyznania miłości. Kiedy jednak dosięgają ją konsekwencje manipulowania czasem, Makoto musi zrobić wszystko, żeby uniknąć straszliwej przyszłości, której nie da się cofnąć.\nOdkryj na nowo film nominowanego do Oscara reżysera Mamoru Hosoda „O dziewczynie skaczącej przez czas” na wielkim ekranie, odnowiony w oszałamiającej jakości 4K.\nWIDZOWIE POKAZÓW W RAMACH PROJEKTU HELIOS ANIME OTRZYMAJĄ ","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"ecd4a997-2c14-4fd9-98c2-53ac7087a9bc","name":"anime","description":""}],"trailers":[],"posters":["https://movies.helios.pl/images/Dziewczynaskaczacaplakat.jpg"],"pictures":["https://movies.helios.pl/images/Odziewczynieskaczacejprzezczas7.jpg","https://movies.helios.pl/images/Odziewczynieskaczacejprzezczas6.jpg","https://movies.helios.pl/images/Odziewczynieskaczacejprzezczas5.jpg","https://movies.helios.pl/images/Odziewczynieskaczacejprzezczas4.jpg","https://movies.helios.pl/images/Odziewczynieskaczacejprzezczas3.jpg","https://movies.helios.pl/images/Odziewczynieskaczacejprzezczas2.jpg","https://movies.helios.pl/images/Odziewczynieskaczacejprzezczas1.jpg"],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"13","value":"13","description":"od lat 13"}],"brightcoveVideos":[],"release":"2D/NAP","name":"O dziewczynie skaczącej przez czas w Helios Anime","link":null,"screeningId":"296eddf3-34ac-47b2-8e79-999c97b15675","screenId":"15cf4b6c-e8f8-41dd-a177-89ec02c52be8","cinemaId":"8acb28a0-2e4b-4beb-a13a-bb97e17085cc","timeFrom":"2026-06-13T15:30:00+02:00","timeTo":"2026-06-13T17:18:00+02:00","saleTimeTo":"2026-06-13T16:00:00+02:00","reservationTimeTo":"2026-06-13T14:30:00+02:00","availabilityStatus":1,"maxOccupancy":129,"audience":7,"generalAdmission":false,"isScreenSwapping":false,"externalId":54245687,"items":[{"movieId":"9119aa2a-c2cf-4c37-bb76-918faec77850","moviePrintId":"d8e8e674-b775-49f5-8bf8-f210118ecf7d","timeFrom":"2026-06-13T15:30:00+02:00","timeTo":"2026-06-13T17:18:00+02:00","movieName":"O dziewczynie skaczącej przez czas","speakingType":"Napisy","printType":"2D","screenId":"15cf4b6c-e8f8-41dd-a177-89ec02c52be8","movieSubPrintLabel":"PS"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":13,"symbol":"HELIOS ANIME","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"0558005a-3851-48a5-be9d-4ae12a240224","duration":150,"description":"Już 4 czerwca kultowy „Podziemny krąg” („Fight Club”) wraca do kin po ponad 25 latach od premiery!\n\nTen prowokacyjny dramat, z udziałem Brada Pitta i Edwarda Nortona, w reżyserii Davida Finchera, opowiada o znudzonym i wyobcowanym mężczyźnie, który wraz z charyzmatycznym towarzyszem tworzą działający w podziemiu klub walki.","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"939b8bbb-4f8f-4fd6-875d-16e483eccdea","name":"thriller","description":""},{"id":"41200b53-4f1a-43c3-9c8e-cbe84751b892","name":"kryminał","description":""},{"id":"14c7bb44-6562-4ad9-8d7a-ab747fa73829","name":"dramat","description":""}],"trailers":[],"posters":["https://movies.helios.pl/images/Pozdziemnykragplakat.jpg"],"pictures":["https://movies.helios.pl/images/Podziemnykrag3.jpg","https://movies.helios.pl/images/Podziemnykrag2.jpg","https://movies.helios.pl/images/Podziemnykrag1.jpg"],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"15","value":"15","description":"od lat 15"}],"brightcoveVideos":[],"release":"2D/NAP","name":"Podziemny krąg w Helios RePlay","link":null,"screeningId":"d4696e8d-8447-45e8-9077-376ad3deb039","screenId":"7f14cc22-562e-4390-85af-2b0593e0b8f8","cinemaId":"8acb28a0-2e4b-4beb-a13a-bb97e17085cc","timeFrom":"2026-06-11T19:45:00+02:00","timeTo":"2026-06-11T22:15:00+02:00","saleTimeTo":"2026-06-11T20:15:00+02:00","reservationTimeTo":"2026-06-11T18:45:00+02:00","availabilityStatus":1,"maxOccupancy":129,"audience":0,"generalAdmission":false,"isScreenSwapping":false,"externalId":29686786,"items":[{"movieId":"b233f278-496b-4504-ac06-725630c68db1","moviePrintId":"2076a1e7-fffb-4dc7-b499-8398284b48eb","timeFrom":"2026-06-11T19:45:00+02:00","timeTo":"2026-06-11T22:15:00+02:00","movieName":"Podziemny krąg","speakingType":"Napisy","printType":"2D","screenId":"7f14cc22-562e-4390-85af-2b0593e0b8f8","movieSubPrintLabel":"ps"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":16,"symbol":"HELIOS REPLAY","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"6c94cbc9-7a80-4a09-b3ad-5602eb24acbd","duration":195,"description":"Obejmująca 34 miasta i 85 koncertów trasa stała się największym tournée w historii koreańskiego artysty. Dodatkowego znaczenia temu wydarzeniu nadaje data koncertu - 13 czerwca, czyli rocznica debiutu BTS - symboliczny moment celebrujący zarówno dotychczasową drogę zespołu, jak i nowy rozdział ich kariery. \n\nTrasa ARIRANG towarzyszy piątemu albumowi studyjnemu grupy i opowiada o tożsamości BTS poprzez szczere emocje, tęsknotę i miłość, które od lat łączą ich z fanami na całym świecie. Imponująca scena 360 stopni sprawia, że widzowie stają się częścią widowiska i mogą poczuć energię koncertu z każdej perspektywy. \n\nNie przegap tego wyjątkowego wydarzenia. Przeżyj wielki powrót BTS na kinowym ekranie 13 czerwca - prosto z Busanu. \n\nUwaga: w wybranych krajach transmisja może odbywać się z opóźnieniem ze względu na różnice stref czasowych.","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"249045c8-3c6f-4ffe-abf3-ec3a85a2b1b1","name":"koncert ","description":""}],"trailers":[],"posters":["https://movies.helios.pl/images/BTSBusanPlakat(1).jpg"],"pictures":["https://movies.helios.pl/images/BTSczerwiec7.jpg","https://movies.helios.pl/images/BTSczerwiec3.jpg","https://movies.helios.pl/images/BTSczerwiec2.jpg","https://movies.helios.pl/images/BTSczerwiec1.jpg"],"po