l - AF","link":null,"screeningId":"3931e28e-7414-4093-ac91-d302a2dd6bdb","screenId":"ae9985fd-b531-4bb1-a2eb-46bc0d2280df","cinemaId":"8acb28a0-2e4b-4beb-a13a-bb97e17085cc","timeFrom":"2026-06-09T09:00:00+02:00","timeTo":"2026-06-09T11:38:00+02:00","saleTimeTo":"2026-06-09T09:30:00+02:00","reservationTimeTo":"2026-06-09T08:00:00+02:00","availabilityStatus":1,"maxOccupancy":76,"audience":45,"generalAdmission":false,"isScreenSwapping":false,"externalId":75632589,"items":[{"movieId":"6219f570-ced4-42d3-98b0-0afa8957e4fe","moviePrintId":"0d56cd17-925b-4dfc-80fe-c7f2fa1c8bb9","timeFrom":"2026-06-09T09:00:00+02:00","timeTo":"2026-06-09T11:38:00+02:00","movieName":"Michael","speakingType":"Napisy","printType":"2D","screenId":"ae9985fd-b531-4bb1-a2eb-46bc0d2280df","movieSubPrintLabel":"ps"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":9,"symbol":"AKADEMIA FILMOWA","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"9fa84454-3318-4d8f-bd42-0125bcba84ca","duration":130,"description":"Polly i Tim wraz z trójką dzieci stają przed koniecznością przeprowadzenia się na odludną angielską prowincję. Wkrótce po przyjeździe najmłodsi odkrywają niezwykłe drzewo, zamieszkane przez barwne, ekscentryczne postacie. Jeśli odważą się wspiąć na jego szczyt, czekają na nie fantastyczne krainy, pełne zapierających dech przygód.","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"726b5445-9bb2-48ff-8ef1-c4e96bb92399","name":"przygodowy","description":""},{"id":"6bcd8fba-fbc2-466a-9f37-ce7a42443c2e","name":"familijny","description":""},{"id":"32d53995-2198-4b43-aa57-235bfeee409e","name":"fantasy","description":""}],"trailers":["https://www.youtube.com/embed/T1FJ-tzNDXc"],"posters":["https://movies.helios.pl/images/DRZEWOMAGIITEASERPLAKAT(1).png"],"pictures":["https://movies.helios.pl/images/Drzewomagii7(1).jpg","https://movies.helios.pl/images/Drzewomagii6(1).jpg","https://movies.helio