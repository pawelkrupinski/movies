zylas7.jpg","https://movies.helios.pl/images/Willowitajemniczylas6.jpg","https://movies.helios.pl/images/Willowitajemniczylas5.jpg","https://movies.helios.pl/images/Willowitajemniczylas4.jpg","https://movies.helios.pl/images/Willowitajemniczylas3.jpg","https://movies.helios.pl/images/Willowitajemniczylas2.jpg","https://movies.helios.pl/images/Willowitajemniczylas1.jpg"],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"6","value":"6","description":"od lat 6"}],"brightcoveVideos":[],"release":"2D/DUB","name":"Willow i tajemniczy las - KNTJ","link":null,"screeningId":"3ea2d9c4-67e8-4ce1-ad2a-d2adadfdd31a","screenId":"ddcefa44-aa0f-48df-8323-54c7111bcbb3","cinemaId":"0bdb21cd-cf7d-4efb-829f-d1913a666b83","timeFrom":"2026-06-09T10:00:00+02:00","timeTo":"2026-06-09T12:00:00+02:00","saleTimeTo":"2026-06-09T10:30:00+02:00","reservationTimeTo":"2026-06-09T09:00:00+02:00","availabilityStatus":1,"maxOccupancy":263,"audience":30,"generalAdmission":false,"isScreenSwapping":false,"externalId":744412365,"items":[{"movieId":"040d2e11-ff64-4722-b82a-cc2730855c50","moviePrintId":"12377068-57a9-457b-b557-8b2172014f79","timeFrom":"2026-06-09T10:00:00+02:00","timeTo":"2026-06-09T12:00:00+02:00","movieName":"Willow i tajemniczy las ","speakingType":"DUB","printType":"2D","screenId":"ddcefa44-aa0f-48df-8323-54c7111bcbb3","movieSubPrintLabel":"ps"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":8,"symbol":"KINO NA TEMAT JUNIOR","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"4add03a9-c644-43b3-a734-acef3cfe73e8","duration":139,"description":"George Fahmy (w tej roli Fares Fares) to największa gwiazda egipskiego kina. Zwany jest “faraonem ekranu”. Zwraca na niego uwagę sam prezydent Egiptu Abd al-Fattah as Sisi, który życzy sobie, aby gwiazdor zagrał główną rolę w filmie biograficznym, gloryfikującym prezydenta. Okazuje się, że jest to propozycja nie do odrzucenia – władza szantażem wymusza na aktorze jej przyjęcie.\n\nPoczątkowo, jak przystało na gwiazdę, bohater liczy na to, że będzie miał sporo do powiedzenia, zarówno w sprawie swojej roli, jak i kształtu całego filmu. Szybko jednak zostaje sprowadzony na ziemię. Głównie za sprawą obecnego na planie tajemniczego doktora Manssoura, który sprawuje pieczę nad produkcją i jej odpowiednim, propagandowym tonem. Sytuację dodatkowo komplikuje romans, w jaki Fahmy wdaje się z żoną jednego z wysoko postawionych generałów. To moment, w którym fikcja i rzeczywistość zaczynają się niebezpiecznie przenikać.","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"939b8bbb-4f8f-4fd6-875d-16e483eccdea","name":"thriller","description":""}],"trailers":["https://www.youtube.com/embed/-DWKk_XNt0E"],"posters":["https://movies.helios.pl/images/OrlyRepublikiPlakat.jpg"],"pictures":["https://movies.helios.pl/images/Orłyrepubliki7.jpg","https://movies.helios.pl/images/Orłyrepubliki6.jpg","https://movies.helios.pl/images/Orłyrepubliki5.jpg","https://movies.helios.pl/images/Orłyrepubliki4.jpg","https://movies.helios.pl/images/Orłyrepubliki3.jpg","https://movies.helios.pl/images/Orłyrepubliki2.jpg","https://movies.helios.pl/images/Orłyrepubliki1.jpg"],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"15","value":"15","description":"od lat 15"}],"brightcoveVideos":[],"release":"2D/NAP","name":"Orły republiki - Kino Konesera","link":null,"screeningId":"e986dba6-a9a6-410f-8181-a26e1045ecf3","screenId":"6463cb01-6586-44eb-8147-cbe81e513a0e","cinemaId":"0bdb21cd-cf7d-4efb-829f-d1913a666b83","timeFrom":"2026-06-08T18:00:00+02:00","timeTo":"2026-06-08T20:19:00+02:00","saleTimeTo":"2026-06-08T18:30:00+02:00","reservationTimeTo":"2026-06-08T17:00:00+02:00","availabilityStatus":1,"maxOccupancy":111,"audience":2,"generalAdmission":false,"isScreenSwapping":false,"externalId":54668712,"items":[{"movieId":"9fc5d4d9-9c34-4abf-b663-e2ff769a6f15","moviePrintId":"44473cb6-36f2-41c5-aa94-f46b78efb1fd","timeFrom":"2026-06-08T18:00:00+02:00","timeTo":"2026-06-08T20:19:00+02:00","movieName":"Orły republiki","speakingType":"Napisy","printType":"2D","screenId":"6463cb01-6586-44eb-8147-cbe81e513a0e","movieSubPrintLabel":"PS"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":1,"symbol":"KINO KONESERA","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"394c674b-a795-4c2a-9757-b904c4e1f794","duration":105,"description":"Mira to pogodna 12-latka. Uwielbia tworzyć małe dzieła sztuki z plastiku z recyklingu i spędzać czas z dwójką swych przyjaciół. Wszystko się zmienia, gdy w jej klasie pojawia się nowa, popularna dziewczyna. Przed Mirą trudne dylematy - czy powinna porzucić plany własnej wystawy sztuki i tak jak inne dziewczyny rozmawiać tylko o zakochiwaniu się?","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"6bcd8fba-fbc2-466a-9f37-ce7a42443c2e","name":"familijny","description":""}],"trailers":[],"posters":["\\\\172.20.202.64\\movies\\images\\miraplakat.jpg"],"pictures":[],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"9","value":"9","description":"od lat 9"}],"brightcoveVideos":[],"release":"2D/DUB","name":"Mira - KNT","link":null,"screeningId":"1ae84ce1-d634-437d-9068-5822394aa6a6","screenId":"f4d978d7-c8d2-4a89-a129-bfac108b1d0c","cinemaId":"0bdb21cd-cf7d-4efb-829f-d1913a666b83","timeFrom":"2026-06-09T09:30:00+02:00","timeTo":"2026-06-09T11:15:00+02:00","saleTimeTo":"2026-06-09T10:00:00+02:00","reservationTimeTo":"2026-06-09T08:30:00+02:00","availabilityStatus":1,"maxOccupancy":92,"audience":27,"generalAdmission":false,"isScreenSwapping":false,"externalId":74412356,"items":[{"movieId":"1f919af2-f4f8-423b-a737-7cd0d6f36638","moviePrintId":"c02eb697-afa2-41f6-9110-2a4611726d8c","timeFrom":"2026-06-09T09:30:00+02:00","timeTo":"2026-06-09T11:15:00+02:00","movieName":"Mira","speakingType":"DUB","printType":"2D","screenId":"f4d978d7-c8d2-4a89-a129-bfac108b1d0c","movieSubPrintLabel":"ps"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":7,"symbol":"KINO NA TEMAT","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"feee7612-9cd6-4397-a516-db46be76e2c4","duration":159,"description":"W 1939 roku Szpilman jest cenionym pianistą i kompozytorem, który mieszka wraz z rodziną w Warszawie. Kiedy do stolicy wkraczają naziści, życie żydowskiego muzyka zamienia się w koszmar: traci kolejne prawa, trafia do getta, obserwuje dwa powstania i próbuje przetrwać w zniszczonym mieście. Pomaga mu przypadek, łut szczęścia oraz miłość do muzyki.","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"b36e63dc-85ea-4670-93db-f785f49c720e","name":"biograficzny","description":""},{"id":"14c7bb44-6562-4ad9-8d7a-ab747fa73829","name":"dramat","description":""}],"trailers":["https://www.youtube.com/embed/KTDhBh_vL_Q"],"posters":["https://movies.helios.pl/images/pianistaplakat.png"],"pictures":["https://movies.helios.pl/images/Pianista7.jpg","https://movies.helios.pl/images/Pianista6.jpg","https://movies.helios.pl/images/Pianista5.jpg","https://movies.helios.pl/images/Pianista4.jpg","https://movies.helios.pl/images/Pianista3.jpg","https://movies.helios.pl/images/Pianista2.jpg","https://movies.helios.pl/images/Pianista1.jpg"],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"15","value":"15","description":"od lat 15"}],"brightcoveVideos":[],"release":"2D/NAP","name":"Pianista w Helios RePlay","link":null,"screeningId":"4ea905d8-bf2e-436b-bc0c-d7f965eba172","screenId":"6463cb01-6586-44eb-8147-cbe81e513a0e","cinemaId":"0bdb21cd-cf7d-4efb-829f-d1913a666b83","timeFrom":"2026-06-14T15:00:00+02:00","timeTo":"2026-06-14T17:39:00+02:00","saleTimeTo":"2026-06-14T15:30:00+02:00","reservationTimeTo":"2026-06-14T14:00:00+02:00","availabilityStatus":1,"maxOccupancy":111,"audience":11,"generalAdmission":false,"isScreenSwapping":false,"externalId":128645,"items":[{"movieId":"117e6eec-1144-4b1a-9600-a86530ca8b3a","moviePrintId":"98e18e82-1d60-4df6-ae6e-e9c76a4d486d","timeFrom":"2026-06-14T15:00:00+02:00","timeTo":"2026-06-14T17:39:00+02:00","movieName":"Pianista","speakingType":"Napisy","printType":"2D","screenId":"6463cb01-6586-44eb-8147-cbe81e513a0e","movieSubPrintLabel":"ps"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":16,"symbol":"HELIOS REPLAY","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"d7bb09f1-a1ea-4982-915d-db91d91397cc","duration":176,"description":"Nigdy nie jest za późno, by zacząć od nowa. Emanujący optymizmem i pogodą ducha portret dojrzałej kobiety, która robi wszystko, by ocalić swój dom i siebie.\n\n María Ángeles od 40 lat mieszka w słonecznym apartamencie w marokańskim Tangerze. Gdy zostaje zmuszona do jego opuszczenia, nie potrafi się z tym pogodzić. To, co początkowo wydaje się bolesną koniecznością, nieoczekiwanie staje się jednak nowym początkiem. W życiu Marii Ángeles pojawia się miejsce zarówno na nowych przyjaciół, jak i na niespodziewaną miłość. „Drugie życie” to zdobywca nagrody publiczności festiwalu w Wenecji. W roli głównej zachwycająca Carmen Maura, ikona filmów Almodóvara.","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"4a3d74ad-af64-4a6a-a640-e75c762899c8","name":"romans","description":""},{"id":"14c7bb44-6562-4ad9-8d7a-ab747fa73829","name":"dramat","description":""}],"trailers":["https://www.youtube.com/embed/8xyTxjwUwfQ"],"posters":["https://movies.helios.pl/images/drugiezycieplakat.jpg"],"pictures":["https://movies.helios.pl/images/Drugiezycie7.jpg","https://movies.helios.pl/images/Drugiezycie6.jpg","https://movies.helios.pl/images/Drugiezycie5.jpg","https://movies.helios.pl/images/Drugiezycie4.jpg","https://movies.helios.pl/images/Drugiezycie3.jpg","https://movies.helios.pl/images/Drugiezycie2.jpg","https://movies.helios.pl/images/Drugiezycie1.jpg"],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"15","value":"15","description":"od lat 15"}],"brightcoveVideos":[],"release":"2D/NAP","name":"Drugie życie - Kino Kobiet","link":null,"screeningId":"342b2987-ffba-4989-acec-3d2a89261f1f","screenId":"ddcefa44-aa0f-48df-8323-54c7111bcbb3","cinemaId":"0bdb21cd-cf7d-4efb-829f-d1913a666b83","timeFrom":"2026-06-10T18:00:00+02:00","timeTo":"2026-06-10T20:56:00+02:00","saleTimeTo":"2026-06-10T18:30:00+02:00","reservationTimeTo":"2026-06-10T17:00:00+02:00","availabilityStatus":1,"maxOccupancy":263,"audience":156,"generalAdmission":false,"isScreenSwapping":false,"externalId":835356,"items":[{"movieId":"efba3b90-d2db-4d41-b474-60d596a59302","moviePrintId":"4a18ef08-42c9-481a-b3ba-e757ea39fec5","timeFrom":"2026-06-10T18:00:00+02:00","timeTo":"2026-06-10T20:56:00+02:00","movieName":"Drugie życie","speakingType":"Napisy","printType":"2D","screenId":"ddcefa44-aa0f-48df-8323-54c7111bcbb3","movieSubPrintLabel":"PS"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":2,"symbol":"KINO KOBIET","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"77c067e5-92a1-4aac-890f-f3737985b192","duration":115,"description":"Dwadzieścia sześć lat po tym, jak udało im się uciec przed podejrzanie znajomym zamaskowanym zabójcą, stała ekipa z serii STRASZNYCH FILMÓW znów znalazła się na celowniku mordercy i żadna seria horrorów nie jest bezpieczna.\n\nBracia Wayans (Marlon i Shawn), Anna Faris i Regina Hall ponownie łączą siły w filmie STRASZNY FILM gdzie wraz z powracającymi ulubieńcami i nowymi twarzami rozpruwają na strzępy rebooty, remaki, requele, prequele, sequele, spin-offy, horrory z wyższej półki, historie oryginalne, wszystko, co zawiera słowo „dziedzictwo” oraz każdy „ostatni rozdział”, który absolutnie nie jest ostatni.\n\nNic nie jest święte.\nŻaden motyw nie przetrwa.\nKażda granica zostaje przekroczona.\nBracia Wayans powracają, by scancelować Cancel Culture.","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"33b6d7c4-1777-46f4-9ae2-6d1cbf8d8b40","name":"komedia","description":""},{"id":"9ae3bc89-bae0-446b-b990-24846c2992e7","name":"horror","description":""}],"trailers":[],"posters":["https://movies.helios.pl/images/Strasznyfilmplakat.jpg"],"pictures":[],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"13","value":"13","description":"od lat 13"}],"brightcoveVideos":[],"release":"2D/NAP","name":"Straszny film - napisy - AF","link":null,"screeningId":"eea6e085-03a2-4815-80c0-c777f7fee3d7","screenId":"ddcefa44-aa0f-48df-8323-54c7111bcbb3","cinemaId":"0bdb21cd-cf7d-4efb-829f-d1913a666b83","timeFrom":"2026-06-08T10:30:00+02:00","timeTo":"2026-06-08T12:25:31+02:00","saleTimeTo":"2026-06-08T11:00:00+02:00","reservationTimeTo":"2026-06-08T09:30:00+02:00","availabilityStatus":1,"maxOccupancy":263,"audience":61,"generalAdmission":false,"isScreenSwapping":false,"externalId":981233,"items":[{"movieId":"2bc2793c-e216-47ec-8deb-5b87dc917219","moviePrintId":"791bde94-5173-4226-aa04-79d2d0c4e882","timeFrom":"2026-06-08T10:30:00+02:00","timeTo":"2026-06-08T12:25:31+02:00","movieName":"Straszny film ","speakingType":"Napisy","printType":"2D","screenId":"ddcefa44-aa0f-48df-8323-54c7111bcbb3","movieSubPrintLabel":"PS"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":9,"symbol":"AKADEMIA FILMOWA","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"8548c02a-56bf-4df4-8085-fbb356648e06","duration":110,"description":"Waldek ma dość – w domu chaos, w sieci drama, a jego gamingowy team się sypie. W emocjach robi coś głupiego – pisze złośliwy komentarz… i nieświadomie uruchamia lawinę hejtu, która uderza w jedną z najbliższych mu osób – Delfinę.","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"6bcd8fba-fbc2-466a-9f37-ce7a42443c