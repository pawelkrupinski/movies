podrecznikdlasuperbohaterow.jpg"],"pictures":[],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"6","value":"6","description":"od lat 6"}],"brightcoveVideos":[],"release":"2D/DUB","name":"Podręcznik dla superbohaterów - KNTJ","link":null,"screeningId":"6137de54-a888-465a-9edd-7449206f5641","screenId":"9fdde7d3-7221-4881-ba95-115bdcad573f","cinemaId":"3e616682-1048-46d8-954d-a2c8de8e7ee4","timeFrom":"2026-06-09T09:45:00+02:00","timeTo":"2026-06-09T11:36:00+02:00","saleTimeTo":"2026-06-09T10:15:00+02:00","reservationTimeTo":"2026-06-09T08:45:00+02:00","availabilityStatus":1,"maxOccupancy":130,"audience":94,"generalAdmission":false,"isScreenSwapping":false,"externalId":755523652,"items":[{"movieId":"5af2b933-3a64-4a24-978b-1d53750e1d98","moviePrintId":"3b9a94e6-843e-4e3f-8ee3-48c6abcac064","timeFrom":"2026-06-09T09:45:00+02:00","timeTo":"2026-06-09T11:36:00+02:00","movieName":"Podręcznik dla superbohaterów","speakingType":"DUB","printType":"2D","screenId":"9fdde7d3-7221-4881-ba95-115bdcad573f","movieSubPrintLabel":"ps"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":8,"symbol":"KINO NA TEMAT JUNIOR","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"0558005a-3851-48a5-be9d-4ae12a240224","duration":150,"description":"Już 4 czerwca kultowy „Podziemny krąg” („Fight Club”) wraca do kin po ponad 25 latach od premiery!\n\nTen prowokacyjny dramat, z udziałem Brada Pitta i Edwarda Nortona, w reżyserii Davida Finchera, opowiada o znudzonym i wyobcowanym mężczyźnie, który wraz z charyzmatycznym towarzyszem tworzą działający w podziemiu klub walki.","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"939b8bbb-4f8f-4fd6-875d-16e483eccdea","name":"thriller","description":""},{"id":"41200b53-4f1a-43c3-9c8e-cbe84751b892","name":"kryminał","description":""},{"id":"14c7bb44-6562-4ad9-8d7a-ab747fa73829","name":"dramat","description":""}],"trailers":[],"posters":["https://movies.helios.pl/images/Pozdziemnykragplakat.jpg"],"pictures":["https://movies.helios.pl/images/Podziemnykrag3.jpg","https://movies.helios.pl/images/Podziemnykrag2.jpg","https://movies.helios.pl/images/Podziemnykrag1.jpg"],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"15","value":"15","description":"od lat 15"}],"brightcoveVideos":[],"release":"2D/NAP","name":"Podziemny krąg w Helios RePlay","link":null,"screeningId":"3fb014da-2965-415e-abbc-2a85fd8b1726","screenId":"64d3c4ae-525c-4990-a15c-158846348d23","cinemaId":"3e616682-1048-46d8-954d-a2c8de8e7ee4","timeFrom":"2026-06-08T20:30:00+02:00","timeTo":"2026-06-08T23:00:00+02:00","saleTimeTo":"2026-06-08T21:00:00+02:00","reservationTimeTo":"2026-06-08T19:30:00+02:00","availabilityStatus":1,"maxOccupancy":130,"audience":0,"generalAdmission":false,"isScreenSwapping":false,"externalId":29686786,"items":[{"movieId":"b233f278-496b-4504-ac06-725630c68db1","moviePrintId":"2076a1e7-fffb-4dc7-b499-8398284b48eb","timeFrom":"2026-06-08T20:30:00+02:00","timeTo":"2026-06-08T23:00:00+02:00","movieName":"Podziemny krąg","speakingType":"Napisy","printType":"2D","screenId":"64d3c4ae-525c-4990-a15c-158846348d23","movieSubPrintLabel":"ps"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":16,"symbol":"HELIOS REPLAY","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"6c94cbc9-7a80-4a09-b3ad-5602eb24acbd","duration":195,"description":"Obejmująca 34 miasta i 85 koncertów trasa stała się największym tournée w historii koreańskiego artysty. Dodatkowego znaczenia temu wydarzeniu nadaje data koncertu - 13 czerwca, czyli rocznica debiutu BTS - symboliczny moment celebrujący zarówno dotychczasową drogę zespołu, jak i nowy rozdział ich kariery. \n\nTrasa ARIRANG towarzyszy piątemu albumowi studyjnemu grupy i opowiada o tożsamości BTS poprzez szczere emocje, tęsknotę i miłość, które od lat łączą ich z fanami na całym świecie. Imponująca scena 360 stopni sprawia, że widzowie stają się częścią widowiska i mogą poczuć energię koncertu z każdej perspektywy. \n\nNie przegap tego wyjątkowego wydarzenia. Przeżyj wielki powrót BTS na kinowym ekranie 13 czerwca - prosto z Busanu. \n\nUwaga: w wybranych krajach transmisja może odbywać się z opóźnieniem ze względu na różnice stref czasowych.","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"249045c8-3c6f-4ffe-abf3-ec3a85a2b1b1","name":"koncert ","description":""}],"trailers":[],"posters":["https://movies.helios.pl/images/BTSBusanPlakat(1).jpg"],"pictures":["https://movies.helios.pl/images/BTSczerwiec7.jpg","https://movies.helios.pl/images/BTSczerwiec3.jpg","https://movies.helios.pl/images/BTSczerwiec2.jpg","https://movies.helios.pl/images/BTSczerwiec1.jpg"],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"40","value":"10 lat","description":"od lat 10"}],"brightcoveVideos":[],"release":"2D/ORG","name":"BTS World Tour ‘ARIRANG’ in Busan: Live Viewing w Helios na Scenie","link":null,"screeningId":"634e12c0-c454-46c9-bfb8-0e14a5eda532","screenId":"684603a9-598b-452d-9fb7-858fa02c5771","cinemaId":"3e616682-1048-46d8-954d-a2c8de8e7ee4","timeFrom":"2026-06-13T15:30:00+02:00","timeTo":"2026-06-13T18:45:00+02:00","saleTimeTo":"2026-06-13T16:00:00+02:00","reservationTimeTo":"2026-06-13T14:30:00+02:00","availabilityStatus":1,"maxOccupancy":185,"audience":30,"generalAdmission":false,"isScreenSwapping":false,"externalId":98745545,"items":[{"movieId":"fa55f94f-5ef2-4c03-95c9-d42bd7222047","moviePrintId":"b89ae438-86b6-42da-ab24-2a8f0b940215","timeFrom":"2026-06-13T15:30:00+02:00","timeTo":"2026-06-13T18:45:00+02:00","movieName":"BTS World Tour ‘ARIRANG’ in Busan: Live Viewing","speakingType":"ORG","printType":"2D","screenId":"684603a9-598b-452d-9fb7-858fa02c5771","movieSubPrintLabel":"PS"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":6,"symbol":"HELIOS NA SCENIE","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"4f103d1e-9983-4753-a14c-5ad571688313","duration":106,"description":"Bo właśnie tak tak tak się wyżej wznieś! W kinach tylko 10-18 czerwca! Domknij Honmoon i zaśpiewaj najlepsze hity z filmu „K-popowe łowczynie demonów” razem z HUNTR/X i Saja Boys. Pełna wersja karaoke hitowego filmu Netflixa w kinach tylko 10-18 czerwca.\n\nGwiazdy K-popu Rumi, Mira i Zoey w przerwach między koncertami na pełnych stadionach bronią fanów przed nadnaturalnymi zagrożeniami, korzystając ze swoich tajemnych mocy.","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"9212e3f5-252f-4d08-b375-2923037a4591","name":"animowany","description":""}],"trailers":["https://www.youtube.com/embed/loBwcgZt_m4"],"posters":["https://movies.helios.pl/images/KPopoweLowczynieplakat.jpg"],"pictures":["https://movies.helios.pl/images/Kpopowelowczyniedemonow8.jpg","https://movies.helios.pl/images/Kpopowelowczyniedemonow7.jpg","https://movies.helios.pl/images/Kpopowelowczyniedemonow6.jpg","https://movies.helios.pl/images/Kpopowelowczyniedemonow5.jpg","https://movies.helios.pl/images/Kpopowelowczyniedemonow4.jpg","https://movies.helios.pl/images/Kpopowelowczyniedemonow3.jpg","https://movies.helios.pl/images/Kpopowelowczyniedemonow2.jpg","https://movies.helios.pl/images/Kpopowelowczyniedemonow1.jpg"],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"10","value":"10","description":"od lat 10"}],"brightcoveVideos":[],"release":"2D/NAP","name":"K-popowe Łowczynie Demonów: Karaoke w Helios na Scenie","link":null,"screeningId":"1713a70a-5da5-4a79-9fb1-0fbe17da13ec","screenId":"1b8cac35-8971-405f-92a1-88ca567727e0","cinemaId":"3e616682-1048-46d8-954d-a2c8de8e7ee4","timeFrom":"2026-06-11T16:30:00+02:00","timeTo":"2026-06-11T18:16:00+02:00","saleTimeTo":"2026-06-11T17:00:00+02:00","reservationTimeTo":"2026-06-11T15:30:00+02:00","availabilityStatus":1,"maxOccupancy":130,"audience":0,"generalAdmission":false,"isScreenSwapping":false,"externalId":2868677,"items":[{"movieId":"4c6e0734-8000-45cf-9abe-161ae1a5ff6e","moviePrintId":"d882e05d-f8ef-4987-ba35-fb379d34fca7","timeFrom":"2026-06-11T16:30:00+02:00","timeTo":"2026-06-11T18:16:00+02:00","movieName":"K-popowe Łowczynie Demonów: Karaoke","speakingType":"Napisy","printType":"2D","screenId":"1b8cac35-8971-405f-92a1-88ca567727e0","movieSubPrintLabel":"PS"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":6,"symbol":"HELIOS NA SCENIE","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"4add03a9-c644-43b3-a734-acef3cfe73e8","duration":139,"description":"George Fahmy (w tej roli Fares Fares) to największa gwiazda egipskiego kina. Zwany jest “faraonem ekranu”. Zwraca na niego uwagę sam prezydent Egiptu Abd al-Fattah as Sisi, który życzy sobie, aby gwiazdor zagrał główną rolę w filmie biograficznym, gloryfikującym prezydenta. Okazuje się, że jest to propozycja nie do odrzucenia – władza szantażem wymusza na aktorze jej przyjęcie.\n\nPoczątkowo, jak przystało na gwiazdę, bohater liczy na to, że będzie miał sporo do powiedzenia, zarówno w sprawie swojej roli, jak i kształtu całego filmu. Szybko jednak zostaje sprowadzony na ziemię. Głównie za sprawą obecnego na planie tajemniczego doktora Manssoura, który sprawuje pieczę nad produkcją i jej odpowiednim, propagandowym tonem. Sytuację dodatkowo komplikuje romans, w jaki Fahmy wdaje się z żoną jednego z wysoko postawionych generałów. To moment, w którym fikcja i rzeczywistość zaczynają się niebezpiecznie przenikać.","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"939b8bbb-4f8f-4fd6-875d-16e483eccdea","name":"thriller","description":""}],"trailers":["https://www.youtube.com/embed/-DWKk_XNt0E"],"posters":["https://movies.helios.pl/images/OrlyRepublikiPlakat.jpg"],"pictures":["https://movies.helios.pl/images/Orłyrepubliki7.jpg","https://movies.helios.pl/images/Orłyrepubliki6.jpg","https://movies.helios.pl/images/Orłyrepubliki5.jpg","https://movies.helios.pl/images/Orłyrepubliki4.jpg","https://movies.helios.pl/images/Orłyrepubliki3.jpg","https://movies.helios.pl/images/Orłyrepubliki2.jpg","https://movies.helios.pl/images/Orłyrepubliki1.jpg"],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"15","value":"15","description":"od lat 15"}],"brightcoveVideos":[],"release":"2D/NAP","name":"Orły republiki - Kino Konesera","link":null,"screeningId":"02322fa5-2ee1-419f-a7f5-fa02f4703f77","screenId":"64d3c4ae-525c-4990-a15c-158846348d23","cinemaId":"3e616682-1048-46d8-954d-a2c8de8e7ee4","timeFrom":"2026-06-08T18:00:00+02:00","timeTo":"2026-06-08T20:19:00+02:00","saleTimeTo":"2026-06-08T18:30:00+02:00","reservationTimeTo":"2026-06-08T17:00:00+02:00","availabilityStatus":1,"maxOccupancy":130,"audience":2,"generalAdmission":false,"isScreenSwapping":false,"externalId":54668712,"items":[{"movieId":"9fc5d4d9-9c34-4abf-b663-e2ff769a6f15","moviePrintId":"44473cb6-36f2-41c5-aa94-f46b78efb1fd","timeFrom":"2026-06-08T18:00:00+02:00","timeTo":"2026-06-08T20:19:00+02:00","movieName":"Orły republiki","speakingType":"Napisy","printType":"2D","screenId":"64d3c4ae-525c-4990-a15c-158846348d23","movieSubPrintLabel":"PS"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":1,"symbol":"KINO KONESERA","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"d7bb09f1-a1ea-4982-915d-db91d91397cc","duration":176,"description":"Nigdy nie jest za późno, by zacząć od nowa. Emanujący optymizmem i pogodą ducha portret dojrzałej kobiety, która robi wszystko, by ocalić swój dom i siebie.\n\n María Ángeles od 40 lat mieszka w słonecznym apartamencie w marokańskim Tangerze. Gdy zostaje zmuszona do jego opuszczenia, nie potrafi się z tym pogodzić. To, co początkowo wydaje się bolesną koniecznością, nieoczekiwanie staje się jednak nowym początkiem. W życiu Marii Ángeles pojawia się miejsce zarówno na nowych przyjaciół, jak i na niespodziewaną miłość. „Drugie życie” to zdobywca nagrody publiczności festiwalu w Wenecji. W roli głównej zachwycająca Carmen Maura, ikona filmów Almodóvara.","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"4a3d74ad-af64-4a6a-a640-e75c762899c8","name":"romans","description":""},{"id":"14c7bb44-6562-4ad9-8d7a-ab747fa73829","name":"dramat","description":""}],"trailers":["https://www.youtube.com/embed/8xyTxjwUwfQ"],"posters":["https://movies.helios.pl/images/drugiezycieplakat.jpg"],"pictures":["https://movies.helios.pl/images/Drugiezycie7.jpg","https://movies.helios.pl/images/Drugiezycie6.jpg","https://movies.helios.pl/images/Drugiezycie5.jpg","https://movies.helios.pl/images/Drugiezycie4.jpg","https://movies.helios.pl/images/Drugiezycie3.jpg","https://movies.helios.pl/images/Drugiezycie2.jpg","https://movies.helios.pl/images/Drugiezycie1.jpg"],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"15","value":"15","description":"od lat 15"}],"brightcoveVideos":[],"release":"2D/NAP","name":"Drugie życie - Kino Kobiet","link":null,"screeningId":"450e838d-f8be-4e69-8620-52fa4656df50","screenId":"b97b7aed-efa3-4b86-a0cc-cc94afc46216","cinemaId":"3e616682-1048-46d8-954d-a2c8de8e7ee4","timeFrom":"2026-06-10T18:00:00+02:00","timeTo":"2026-06-10T20:56:00+02:00","saleTimeTo":"2026-06-10T18:30:00+02:00","reservationTimeTo":"2026-06-10T17:00:00+02:00","availabilityStatus":1,"maxOccupancy":375,"audience":63,"generalAdmission":false,"isScreenSwapping":false,"externalId":835356,"items":[{"movieId":"efba3b90-d2db-4d41-b474-60d596a59302","moviePrintId":"4a18ef08-42c9-481a-b3ba-e757ea39fec5","timeFrom":"2026-06-10T18:00:00+02:00","timeTo":"2026-06-10T20:56:00+02:00","movieName":"Drugie życie","speakingType":"Napisy","printType":"2D","screenId":"b97b7aed-efa3-4b86-a0cc-cc94afc46216","movieSubPrintLabel":"PS"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags"