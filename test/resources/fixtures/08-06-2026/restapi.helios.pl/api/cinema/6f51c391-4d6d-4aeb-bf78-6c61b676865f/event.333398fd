nSwapping":false,"externalId":85411112,"items":[{"movieId":"364004bb-6fcb-4eaa-be12-6372c1df9ad9","moviePrintId":"1778f6fa-cff5-4fb3-b10a-95c80345de77","timeFrom":"2026-06-09T09:30:00+02:00","timeTo":"2026-06-09T11:40:00+02:00","movieName":"Sny o miłości","speakingType":"Napisy","printType":"2D","screenId":"68c1706d-fbdf-44f7-a439-28cab790c8b6","movieSubPrintLabel":"ps"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":7,"symbol":"KINO NA TEMAT","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"63d573e0-e66e-4a01-a6fe-348812c59969","duration":112,"description":"Studniówka, konflikty, złamane serca i AI zamiast lektur. W trzeciej części kultowej serii klasa maturalna dostaje w kość – od siebie nawzajem, od nauczycieli i od życia. Jest miłość, jest drama, są przerwy w szatni i decyzje, które naprawdę coś znaczą. Tym razem stawką jest nie tylko matura, ale i pierwsze dorosłe wybory. Kiedy Dante próbuje pogodzić własne marzenia z rzeczywistością, a jego relacja z Nel zostaje wystawiona na próbę, do gry wchodzi tajemniczy Adam. W tle – powrót Korka, nowe uczucia Cegły i pytanie, czy lojalność, przyjaźń i miłość mają szansę przetrwać w świecie podziałów społecznych. Dorosłość właśnie zaczyna mówić: „sprawdzam”.","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"33b6d7c4-1777-46f4-9ae2-6d1cbf8d8b40","name":"komedia","description":""},{"id":"5c1136a2-c48c-4f15-95e0-68f86f3c8858","name":"obyczajowy","description":""}],"trailers":[],"posters":["https://movies.helios.pl/images/pm3plakat.jpg"],"pictures":["https://movies.helios.pl/images/PieprzycMickiewicza37(1).jpg","https://movies.helios.pl/images/PieprzycMickiewicza36(1).jpg","https://movies.helios.pl/images/PieprzycMickiewicza35(1).jpg","https://movies.helios.pl/images/PieprzycMickiewicza34(2).jpg","https://movies.helios.pl/images/PieprzycMickiewicza33(2).jpg","https://movies.helios.pl/images/PieprzycMickiewicza32(2).jpg","https://movies.helios.pl/images/PieprzycMickiewicza31(2).jpg"],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"13","value":"13","description":"od lat 13"}],"brightcoveVideos":[],"release":"2D/ORG","name":"Piep*zyć Mickiewicza 3 - KNT","link":null,"screeningId":"660b56e5-fd03-4605-a130-9571b4aad420","screenId":"c6023718-9f96-4c65-bec7-0b1ee8359b04","cinemaId":"6f51c391-4d6d-4aeb-bf78-6c61b676865f","timeFrom":"2026-06-10T10:00:00+02:00","timeTo":"2026-06-10T11:52:00+02:00","saleTimeTo":"2026-06-10T10:30:00+02:00","reservationTimeTo":"2026-06-10T09:00:00+02:00","availabilityStatus":1,"maxOccupancy":324,"audience":52,"generalAdmission":false,"isScreenSwapping":false,"externalId":754123656,"items":[{"movieId":"d9b28e17-1444-4660-b56d-67866f8e9f86","moviePrintId":"4ccf6b1f-4aec-4828-a62d-470a82e1507d","timeFrom":"2026-06-10T10:00:00+02:00","timeTo":"2026-06-10T11:52:00+02:00","movieName":"Piep*zyć Mickiewicza 3","speakingType":"ORG","printType":"2D","screenId":"c6023718-9f96-4c65-bec7-0b1ee8359b04","movieSubPrintLabel":"PS"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":7,"symbol":"KINO NA TEMAT","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"ed834156-8c3f-4332-8f23-3c9b0648811c","duration":108,"description":"Makoto jest zwyczajną nastolatką, spędzającą większość czasu z przyjaciółmi. Kiedy pewnego dnia, spiesząc się z wizytą do ciotki, cudem unika potrącenia przez pociąg – przeskakuje w czasie do momentu sprzed wypadku. Korzystając z nowo poznanych zdolności, naprawia swoje codzienne błędy – od słabych ocen na sprawdzianach po nieudane wyznania miłości. Kiedy jednak dosięgają ją konsekwencje manipulowania czasem, Makoto musi zrobić wszystko, żeby uniknąć straszliwej przyszłości, której nie da się cofnąć.\nOdkryj na nowo film nominowanego do Oscara reżysera Mamoru Hosoda „O dziewczynie skaczącej przez czas” na wielkim ekranie, odnowiony w oszałamiającej jakości 4K.\nWIDZOWIE POKAZÓW W RAMACH PROJEKTU HELIOS ANIME OTRZYMAJĄ ","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"ecd4a997-2c14-4fd9-98c2-53ac7087a9bc","name":"anime","description":""}],"trailers":[],"posters":["https://movies.helios.pl/images/Dziewczynaskaczacaplakat.jpg"],"pictures":["https://movies.helios.pl/images/Odziewczynieskaczacejprzezczas7.jpg","https://movies.helios.pl/images/Odziewczynieskaczacejprzezczas6.jpg","https://movies.helios.pl/images/Odziewczynieskaczacejprzezczas5.jpg","https://movies.helios.pl/images/Odziewczynieskaczacejprzezczas4.jpg","https://movies.helios.pl/images/Odziewczynieskaczacejprzezczas3.jpg","https://movies.helios.pl/images/Odziewczynieskaczacejprzezczas2.jpg","https://movies.helios.pl/images/Odziewczynieskaczacejprzezczas1.jpg"],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"13","value":"13","description":"od lat 13"}],"brightcoveVideos":[],"release":"2D/NAP","name":"O dziewczynie skaczącej przez czas w Helios Anime","link":null,"screeningId":"a7f70672-4288-4f27-a870-0e7390ed1fab","screenId":"f5f57006-90ad-47df-a670-b5c01679ef99","cinemaId":"6f51c391-4d6d-4aeb-bf78-6c61b676865f","timeFrom":"2026-06-13T15:30:00+02:00","timeTo":"2026-06-13T17:18:00+02:00","saleTimeTo":"2026-06-13T16:00:00+02:00","reservationTimeTo":"2026-06-13T14:30:00+02:00","availabilityStatus":1,"maxOccupancy":113,"audience":3,"generalAdmission":false,"isScreenSwapping":false,"externalId":54245687,"items":[{"movieId":"9119aa2a-c2cf-4c37-bb76-918faec77850","moviePrintId":"d8e8e674-b775-49f5-8bf8-f210118ecf7d","timeFrom":"2026-06-13T15:30:00+02:00","timeTo":"2026-06-13T17:18:00+02:00","movieName":"O dziewczynie skaczącej przez czas","speakingType":"Napisy","printType":"2D","screenId":"f5f57006-90ad-47df-a670-b5c01679ef99","movieSubPrintLabel":"PS"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":13,"symbol":"HELIOS ANIME","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"0558005a-3851-48a5-be9d-4ae12a240224","duration":150,"description":"Już 4 czerwca kultowy „Podziemny krąg” („Fight Club”) wraca do kin po ponad 25 latach od premiery!\n\nTen prowokacyjny dramat, z udziałem Brada Pitta i Edwarda Nortona, w reżyserii Davida Finchera, opowiada o znudzonym i wyobcowanym mężczyźnie, który wraz z charyzmatycznym towarzyszem tworzą działający w podziemiu klub walki.","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"939b8bbb-4f8f-4fd6-875d-16e483eccdea","name":"thriller","description":""},{"id":"41200b53-4f1a-43c3-9c8e-cbe84751b892","name":"kryminał","description":""},{"id":"14c7bb44-6562-4ad9-8d7a-ab747fa73829","name":"dramat","description":""}],"trailers":[],"posters":["https://movies.helios.pl/images/Pozdziemnykragplakat.jpg"],"pictures":["https://movies.helios.pl/images/Podziemnykrag3.jpg","https://movies.helios.pl/images/Podziemnykrag2.jpg","https://movies.helios.pl/images/Podziemnykrag1.jpg"],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"15","value":"15","description":"od lat 15"}],"brightcoveVideos":[],"release":"2D/NAP","name":"Podziemny krąg w Helios RePlay","link":null,"screeningId":"f34cfc3d-458a-4736-8237-58067ff545a8","screenId":"f5f57006-90ad-47df-a670-b5c01679ef99","cinemaId":"6f51c391-4d6d-4aeb-bf78-6c61b676865f","timeFrom":"2026-06-08T20:30:00+02:00","timeTo":"2026-06-08T23:00:00+02:00","saleTimeTo":"2026-06-08T21:00:00+02:00","reservationTimeTo":"2026-06-08T19:30:00+02:00","availabilityStatus":1,"maxOccupancy":113,"audience":1,"generalAdmission":false,"isScreenSwapping":false,"externalId":29686786,"items":[{"movieId":"b233f278-496b-4504-ac06-725630c68db1","moviePrintId":"2076a1e7-fffb-4dc7-b499-8398284b48eb","timeFrom":"2026-06-08T20:30:00+02:00","timeTo":"2026-06-08T23:00:00+02:00","movieName":"Podziemny krąg","speakingType":"Napisy","printType":"2D","screenId":"f5f57006-90ad-47df-a670-b5c01679ef99","movieSubP