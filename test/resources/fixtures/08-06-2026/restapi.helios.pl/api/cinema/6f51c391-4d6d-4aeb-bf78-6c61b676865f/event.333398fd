o":"2026-06-11T17:00:00+02:00","reservationTimeTo":"2026-06-11T15:30:00+02:00","availabilityStatus":1,"maxOccupancy":113,"audience":0,"generalAdmission":false,"isScreenSwapping":false,"externalId":2868677,"items":[{"movieId":"4c6e0734-8000-45cf-9abe-161ae1a5ff6e","moviePrintId":"d882e05d-f8ef-4987-ba35-fb379d34fca7","timeFrom":"2026-06-11T16:30:00+02:00","timeTo":"2026-06-11T18:16:00+02:00","movieName":"K-popowe Łowczynie Demonów: Karaoke","speakingType":"Napisy","printType":"2D","screenId":"f5f57006-90ad-47df-a670-b5c01679ef99","movieSubPrintLabel":"PS"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":6,"symbol":"HELIOS NA SCENIE","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"f7c02d9a-0c5f-4a06-bfcc-9557c509861b","duration":120,"description":"Willow odziedziczyła nie tylko majątek po swej babci, ale także magiczne moce. Niestety jej ojciec planuje sprzedać las, z którego wywodzi się cała magia. Wraz z trzema innymi czarownicami postanawiają uratować czarodziejską krainę.","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"6bcd8fba-fbc2-466a-9f37-ce7a42443c2e","name":"familijny","description":""}],"trailers":[],"posters":["https://movies.helios.pl/images/plakatwillow.jpg"],"pictures":["https://movies.helios.pl/images/Willowitajemniczylas7.jpg","https://movies.helios.pl/images/Willowitajemniczylas6.jpg","https://movies.helios.pl/images/Willowitajemniczylas5.jpg","https://movies.helios.pl/images/Willowitajemniczylas4.jpg","https://movies.helios.pl/images/Willowitajemniczylas3.jpg","https://movies.helios.pl/images/Willowitajemniczylas2.jpg","https://movies.helios.pl/images/Willowitajemniczylas1.jpg"],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"6","value":"6","description":"od lat 6"}],"brightcoveVideos":[],"release":"2D/DUB","name":"Willow i tajemniczy las - KNTJ","link":null,"screeningId":"319f0350-bb7e-4d6c-b785-ddc395a46f5e","screenId":"f5f57006-90ad-47df-a670-b5c01679ef99","cinemaId":"6f51c391-4d6d-4aeb-bf78-6c61b676865f","timeFrom":"2026-06-08T10:00:00+02:00","timeTo":"2026-06-08T12:00:00+02:00","saleTimeTo":"2026-06-08T10:30:00+02:00","reservationTimeTo":"2026-06-08T09:00:00+02:00","availabilityStatus":1,"maxOccupancy":113,"audience":24,"generalAdmission":false,"isScreenSwapping":false,"externalId":744412365,"items":[{"movieId":"040d2e11-ff64-4722-b82a-cc2730855c50","moviePrintId":"12377068-57a9-457b-b557-8b2172014f79","timeFrom":"2026-06-08T10:00:00+02:00","timeTo":"2026-06-08T12:00:00+02:00","movieName":"Willow i tajemniczy las ","speakingType":"DUB","printType":"2D","screenId":"f5f57006-90ad-47df-a670-b5c01679ef99","movieSubPrintLabel":"ps"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":8,"symbol":"KINO NA TEMAT JUNIOR","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"4add03a9-c644-43b3-a734-acef3cfe73e8","duration":139,"description":"George Fahmy (w tej roli Fares Fares) to największa gwiazda egipskiego kina. Zwany jest “faraonem ekranu”. Zwraca na niego uwagę sam prezydent Egiptu Abd al-Fattah as Sisi, który życzy sobie, aby gwiazdor zagrał główną rolę w filmie biograficznym, gloryfikującym prezydenta. Okazuje się, że jest to propozycja nie do odrzucenia – władza szantażem wymusza na aktorze jej przyjęcie.\n\nPoczątkowo, jak przystało na gwiazdę, bohater liczy na to, że będzie miał sporo do powiedzenia, zarówno w sprawie swojej roli, jak i kształtu całego filmu. Szybko jednak zostaje sprowadzony na ziemię. Głównie za sprawą obecnego na planie tajemniczego doktora Manssoura, który sprawuje pieczę nad produkcją i jej odpowiednim, propagandowym tonem. Sytuację dodatkowo komplikuje romans, w jaki Fahmy wdaje się z żoną jednego z wysoko postawionych generałów. To moment, w którym fikcja i rzeczywistość zaczynają się niebezpiecznie przenikać.","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"939b8bbb-4f8f-4fd6-875d-16e483eccdea","name":"thriller","description":""}],"trailers":["https://www.youtube.com/embed/-DWKk_XNt0E"],"posters":["https://movies.helios.pl/images/OrlyRepublikiPlakat.jpg"],"pictures":["https://movies.helios.pl/images/Orłyrepubliki7.jpg","https://movies.helios.pl/images/Orłyrepubliki6.jpg","https://movies.helios.pl/images/Orłyrepubliki5.jpg","https://movies.helios.pl/images/Orłyrepubliki4.jpg","https://movies.helios.pl/images/Orłyrepubliki3.jpg","https://movies.helios.pl/images/Orłyrepubliki2.jpg","https://movies.helios.pl/images/Orłyrepubliki1.jpg"],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"15","value":"15","description":"od lat 15"}],"brightcoveVideos":[],"release":"2D/NAP","name":"Orły republiki - Kino Konesera","link":null,"screeningId":"c2a87bcb-01e2-4ef1-adf2-799c8f5d6ef6","screenId":"f5f57006-90ad-47df-a670-b5c01679ef99","cinemaId":"6f51c391-4d6d-4aeb-bf78-6c61b676865f","timeFrom":"2026-06-08T18:00:00+02:00","timeTo":"2026-06-08T20:19:00+02:00","saleTimeTo":"2026-06-08T18:30:00+02:00","reservationTimeTo":"2026-06-08T17:00:00+02:00","availabilityStatus":1,"maxOccupancy":113,"audience":2,"generalAdmission":false,"isScreenSwapping":false,"externalId":54668712,"items":[{"movieId":"9fc5d4d9-9c34-4abf-b663-e2ff769a6f15","moviePrintId":"44473cb6-36f2-41c5-aa94-f46b78efb1fd","timeFrom":"2026-06-08T18:00:00+02:00","timeTo":"2026-06-08T20:19:00+02:00","movieName":"Orły republiki","speakingType":"Napisy","printType":"2D","screenId":"f5f57006-90ad-47df-a670-b5c01679ef99","movieSubPrintLabel":"PS"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":1,"symbol":"KINO KONESERA","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"feee7612-9cd6-4397-a516-db46be76e2c4","duration":159,"description":"W 1939 roku Szpilman jest cenionym pianistą i kompozytorem, który mieszka wraz z rodziną w Warszawie. Kiedy do stolicy wkraczają naziści, życie żydowskiego muzyka zamienia się w koszmar: traci kolejne prawa, trafia do getta, obserwuje dwa powstania i próbuje przetrwać w zniszczonym mieście. Pomaga mu przypadek, łut szczęścia oraz miłość do muzyki.","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"b36e63dc-85ea-4670-93db-f785f49c720e","name":"biograficzny","description":""},{"id":"14c7bb44-6562-4ad9-8d7a-ab747fa73829","name":"dramat","description":""}],"trailers":["https://www.youtube.com/embed/KTDhBh_vL_Q"],"posters":["https://movies.helios.pl/images/pianistaplakat.png"],"pictures":["https://movies.helios.pl/images/Pianista7.jpg","https://movies.helios.pl/images/Pianista6.jpg","https://movies.helios.pl/images/Pianista5.jpg","https://movies.helios.pl/images/Pianista4.jpg","https://movies.helios.pl/images/Pianista3.jpg","https://movies.helios.pl/images/Pianista2.jpg","https://movies.helios.pl/images/Pianista1.jpg"],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"15","value":"15","description":"od lat 15"}],"brightcoveVideos":[],"release":"2D/NAP","name":"Pianista w Helios RePlay","link":null,"screeningId":"a43013f9-a1dd-4ace-a0e1-c14163a92247","screenId":"03dce564-0207-49dd-a87e-964d13db1c59","cinemaId":"6f51c391-4d6d-4aeb-bf78-6c61b676865f","timeFrom":"2026-06-14T15:00:00+02:00","timeTo":"2026-06-14T17:39:00+02:00","saleTimeTo":"2026-06-14T15:30:00+02:00","reservationTimeTo":"2026-06-14T14:00:00+02:00","availabilityStatus":1,"maxOccupancy":169,"audience":1,"generalAdmission":false,"isScreenSwapping":false,"externalId":128645,"items":[{"movieId":"117e6eec-1144-4b1a-9600-a86530ca8b3a","moviePrintId":"98e18e82-1d60-4df6-ae6e-e9c76a4d486d","timeFrom":"2026-06-14T15:00:00+02:00","timeTo":"2026-06-14T17:39:00+02:00","movieName":"Pianista","speakingType":"Napisy","printType":"2D","screenId":"03dce564-0207-49dd-a87e-964d13db1c59","movieSubPrintLabel":"ps"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":16,"symbol":"HELIOS REPLAY","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"d7bb09f1-a1ea-4982-915d-db91d91397cc","duration":176,"description":"Nigdy nie jest za późno, by zacząć od nowa. Emanujący optymizmem i pogodą ducha portret dojrzałej kobiety, która robi wszystko, by ocalić swój dom i siebie.\n\n María Ángeles od 40 lat mieszka w słonecznym apartamencie w marokańskim Tangerze. Gdy zostaje zmuszona do jego opuszczenia, nie potrafi się z tym pogodzić. To, co początkowo wydaje się bolesną koniecznością, nieoczekiwanie staje się jednak nowym początkiem. W życiu Marii Ángeles pojawia się miejsce zarówno na nowych przyjaciół, jak i na niespodziewaną miłość. „Drugie życie” to zdobywca nagrody publiczności festiwalu w Wenecji. W roli głównej zachwycająca Carmen Maura, ikona filmów Almodóvara.","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"4a3d74ad-af64-4a6a-a640-e75c762899c8","name":"romans","description":""},{"id":"14c7bb44-6562-4ad9-8d7a-ab747fa73829","name":"dramat","description":""}],"trailers":["https://www.youtube.com/embed/8xyTxjwUwfQ"],"posters":["https://movies.helios.pl/images/drugiezycieplakat.jpg"],"pictures":["https://movies.helios.pl/images/Drugiezycie7.jpg","https://movies.helios.pl/images/Drugiezycie6.jpg","https://movies.helios.pl/images/Drugiezycie5.jpg","https://movies.helios.pl/images/Drugiezycie4.jpg","https://movies.helios.pl/images/Drugiezycie3.jpg","https://movies.helios.pl/images/Drugiezycie2.jpg","https://movies.helios.pl/images/Drugiezycie1.jpg"],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"15","value":"15","description":"od lat 15"}],"brightcoveVideos":[],"release":"2D/NAP","name":"Drugie życie - Kino Kobiet","link":null,"screeningId":"6db8b279-9d64-4f68-8a05-97f380d992c6","screenId":"c6023718-9f96-4c65-bec7-0b1ee8359b04","cinemaId":"6f51c391-4d6d-4aeb-bf78-6c61b676865f","timeFrom":"2026-06-10T18:00:00+02:00","timeTo":"2026-06-10T20: