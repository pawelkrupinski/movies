-a640-e75c762899c8","name":"romans","description":""},{"id":"14c7bb44-6562-4ad9-8d7a-ab747fa73829","name":"dramat","description":""}],"trailers":["https://www.youtube.com/embed/8xyTxjwUwfQ"],"posters":["https://movies.helios.pl/images/drugiezycieplakat.jpg"],"pictures":["https://movies.helios.pl/images/Drugiezycie7.jpg","https://movies.helios.pl/images/Drugiezycie6.jpg","https://movies.helios.pl/images/Drugiezycie5.jpg","https://movies.helios.pl/images/Drugiezycie4.jpg","https://movies.helios.pl/images/Drugiezycie3.jpg","https://movies.helios.pl/images/Drugiezycie2.jpg","https://movies.helios.pl/images/Drugiezycie1.jpg"],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"15","value":"15","description":"od lat 15"}],"brightcoveVideos":[],"release":"2D/NAP","name":"Drugie życie - Kino Kobiet","link":null,"screeningId":"afbe2c61-f47a-444f-8c76-c00440ec437d","screenId":"e1ccc5a7-f5d5-40a4-b8b7-b326000c2522","cinemaId":"ec0ba789-c70b-42e7-8adf-8c9595888672","timeFrom":"2026-06-10T19:00:00+02:00","timeTo":"2026-06-10T21:56:00+02:00","saleTimeTo":"2026-06-10T19:30:00+02:00","reservationTimeTo":"2026-06-10T18:00:00+02:00","availabilityStatus":1,"maxOccupancy":235,"audience":147,"generalAdmission":false,"isScreenSwapping":false,"externalId":835356,"items":[{"movieId":"efba3b90-d2db-4d41-b474-60d596a59302","moviePrintId":"4a18ef08-42c9-481a-b3ba-e757ea39fec5","timeFrom":"2026-06-10T19:00:00+02:00","timeTo":"2026-06-10T21:56:00+02:00","movieName":"Drugie życie","speakingType":"Napisy","printType":"2D","screenId":"e1ccc5a7-f5d5-40a4-b8b7-b326000c2522","movieSubPrintLabel":"PS"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":2,"symbol":"KINO KOBIET","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]}]