add40eb","timeFrom":"2026-06-11T16:30:00+02:00","timeTo":"2026-06-11T18:16:00+02:00","saleTimeTo":"2026-06-11T17:00:00+02:00","reservationTimeTo":"2026-06-11T15:30:00+02:00","availabilityStatus":1,"maxOccupancy":143,"audience":2,"generalAdmission":false,"isScreenSwapping":false,"externalId":2868677,"items":[{"movieId":"4c6e0734-8000-45cf-9abe-161ae1a5ff6e","moviePrintId":"d882e05d-f8ef-4987-ba35-fb379d34fca7","timeFrom":"2026-06-11T16:30:00+02:00","timeTo":"2026-06-11T18:16:00+02:00","movieName":"K-popowe Łowczynie Demonów: Karaoke","speakingType":"Napisy","printType":"2D","screenId":"1ba7906a-2fec-4360-9313-47b07c2b6328","movieSubPrintLabel":"PS"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":6,"symbol":"HELIOS NA SCENIE","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"16cdc91a-de6c-4116-b0d2-9b802901b5a1","duration":130,"description":"9-letni Wolfgang po nagłej śmierci matki jest zmuszony zamieszkać ze swoim ojcem, z którym wcześniej nie utrzymywał kontaktu. Chłopiec ma wysoki iloraz inteligencji i marzy o wyjeździe do Paryża, żeby zostać najlepszym pianistą na świecie. Jednak największym wyzwaniem będzie dla niego zbudowanie od zera relacji ze swoim rodzicem.","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"6bcd8fba-fbc2-466a-9f37-ce7a42443c2e","name":"familijny","description":""},{"id":"14c7bb44-6562-4ad9-8d7a-ab747fa73829","name":"dramat","description":""}],"trailers":["https://www.youtube.com/embed/-L-IqjJmxro"],"posters":["https://movies.helios.pl/images/plakatniezwyklychlopak.jpg"],"pictures":[],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"10","value":"10","description":"od lat 10"}],"brightcoveVideos":[],"release":"2D/DUB","name":"Niezwykły chłopak - KNT","link":null,"screeningId":"4a1451dc-de2b-4ec8-a1b8-eeec583d2c02","screenId":"56327303-43a2-4df7-946e-6f2a14d98130","cinemaId":"d09e2607-693f-479f-8deb-59a18add40eb","timeFrom":"2026-06-08T09:00:00+02:00","timeTo":"2026-06-08T11:10:00+02:00","saleTimeTo":"2026-06-08T09:30:00+02:00","reservationTimeTo":"2026-06-08T08:00:00+02:00","availabilityStatus":1,"maxOccupancy":153,"audience":0,"generalAdmission":false,"isScreenSwapping":false,"externalId":74442356,"items":[{"movieId":"b8efb135-e61e-4d76-90e2-5b127bdeeb9a","moviePrintId":"35048f53-3edd-4e6b-aed1-3eaf3bc8ae92","timeFrom":"2026-06-08T09:00:00+02:00","timeTo":"2026-06-08T11:10:00+02:00","movieName":"Niezwykły chłopak","speakingType":"DUB","printType":"2D","screenId":"56327303-43a2-4df7-946e-6f2a14d98130","movieSubPrintLabel":"ps"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":7,"symbol":"KINO NA TEMAT","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"4add03a9-c644-43b3-a734-acef3cfe73e8","duration":139,"description":"George Fahmy (w tej roli Fares Fares) to największa gwiazda egipskiego kina. Zwany jest “faraonem ekranu”. Zwraca na niego uwagę sam prezydent Egiptu Abd al-Fattah as Sisi, który życzy sobie, aby gwiazdor zagrał główną rolę w filmie biograficznym, gloryfikującym prezydenta. Okazuje się, że jest to propozycja nie do odrzucenia – władza szantażem wymusza na aktorze jej przyjęcie.\n\nPoczątkowo, jak przystało na gwiazdę, bohater liczy na to, że będzie miał sporo do powiedzenia, zarówno w sprawie swojej roli, jak i kształtu całego filmu. Szybko jednak zostaje sprowadzony na ziemię. Głównie za sprawą obecnego na planie tajemniczego doktora Manssoura, który sprawuje pieczę nad produkcją i jej odpowiednim, propagandowym tonem. Sytuację dodatkowo komplikuje romans, w jaki Fahmy wdaje się z żoną jednego z wysoko postawionych generałów. To moment, w którym fikcja i rzeczywistość zaczynają się niebezpiecznie przenikać.","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"939b8bbb-4f8f-4fd6-875d-16e483eccdea","name":"thriller","description":""}],"trailers":["https://www.youtube.com/embed/-DWKk_XNt0E"],"posters":["https://movies.helios.pl/images/OrlyRepublikiPlakat.jpg"],"pictures":["https://movies.helios.pl/images/Orłyrepubliki7.jpg","https://movies.helios.pl/images/Orłyrepubliki6.jpg","https://movies.helios.pl/images/Orłyrepubliki5.jpg","https://movies.helios.pl/images/Orłyrepubliki4.jpg","https://movies.helios.pl/images/Orłyrepubliki3.jpg","https://movies.helios.pl/images/Orłyrepubliki2.jpg","https://movies.helios.pl/images/Orłyrepubliki1.jpg"],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"15","value":"15","description":"od lat 15"}],"brightcoveVideos":[],"release":"2D/NAP","name":"Orły republiki - Kino Konesera","link":null,"screeningId":"edf680a5-49d6-4c07-a62b-d9920615b5fd","screenId":"1ba7906a-2fec-4360-9313-47b07c2b6328","cinemaId":"d09e2607-693f-479f-8deb-59a18add40eb","timeFrom":"2026-06-08T18:00:00+02:00","timeTo":"2026-06-08T20:19:00+02:00","saleTimeTo":"2026-06-08T18:30:00+02:00","reservationTimeTo":"2026-06-08T17:00:00+02:00","availabilityStatus":1,"maxOccupancy":143,"audience":2,"generalAdmission":false,"isScreenSwapping":false,"externalId":54668712,"items":[{"movieId":"9fc5d4d9-9c34-4abf-b663-e2ff769a6f15","moviePrintId":"44473cb6-36f2-41c5-aa94-f46b78efb1fd","timeFrom":"2026-06-08T18:00:00+02:00","timeTo":"2026-06-08T20:19:00+02:00","movieName":"Orły republiki","speakingType":"Napisy","printType":"2D","screenId":"1ba7906a-2fec-4360-9313-47b07c2b6328","movieSubPrintLabel":"PS"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":1,"symbol":"KINO KONESERA","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"feee7612-9cd6-4397-a516-db46be76e2c4","duration":159,"description":"W 1939 roku Szpilman jest cenionym pianistą i kompozytorem, który mieszka wraz z rodziną w Warszawie. Kiedy do stolicy wkraczają naziści, życie żydowskiego muzyka zamienia się w koszmar: traci kolejne prawa, trafia do getta, obserwuje dwa powstania i próbuje przetrwać w zniszczonym mieście. Pomaga mu przypadek, łut szczęścia oraz miłość do muzyki.","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"b36e63dc-85ea-4670-93db-f785f49c720e","name":"biograficzny","description":""},{"id":"14c7bb44-6562-4ad9-8d7a-ab747fa73829","name":"dramat","description":""}],"trailers":["https://www.youtube.com/embed/KTDhBh_vL_Q"],"posters":["https://movies.helios.pl/images/pianistaplakat.png"],"pictures":["https://movies.helios.pl/images/Pianista7.jpg","https://movies.helios.pl/images/Pianista6.jpg","https://movies.helios.pl/images/Pianista5.jpg","https://movies.helios.pl/images/Pianista4.jpg","https://movies.helios.pl/images/Pianista3.jpg","https://movies.helios.pl/images/Pianista2.jpg","https://movies.helios.pl/images/Pianista1.jpg"],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"15","value":"15","description":"od lat 15"}],"brightcoveVideos":[],"release":"2D/NAP","name":"Pianista w Helios RePlay","link":null,"screeningId":"56e00ac2-36d6-4921-bc34-65d903e9473f","screenId":"2d6ccbf5-2499-4ce7-be60-a09ee784ae87","cinemaId":"d09e2607-693f-479f-8deb-59a18add40eb","timeFrom":"2026-06-14T15:00:00+02:00","timeTo":"2026-06-14T17:39:00+02:00","saleTimeTo":"2026-06-14T15:30:00+02:00","reservationTimeTo":"2026-06-14T14:00:00+02:00","availabilityStatus":1,"maxOccupancy":144,"audience":1,"generalAdmission":false,"isScreenSwapping":false,"externalId":128645,"items":[{"movieId":"117e6eec-1144-4b1a-9600-a86530ca8b3a","moviePrintId":"98e18e82-1d60-4df6-ae6e-e9c76a4d486d","timeFrom":"2026-06-14T15:00:00+02:00","timeTo":"2026-06-14T17:39:00+02:00","movieName":"Pianista","speakingType":"Napisy","printType":"2D","screenId":"2d6ccbf5-2499-4ce7-be60-a09ee784ae87","movieSubPrintLabel":"ps"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":16,"symbol":"HELIOS REPLAY","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"d7bb09f1-a1ea-4982-915d-db91d91397cc","duration":176,"description":"Nigdy nie jest za późno, by zacząć od nowa. Emanujący optymizmem i pogodą ducha portret dojrzałej kobiety, która robi wszystko, by ocalić swój dom i siebie.\n\n María Ángeles od 40 lat mieszka w słonecznym apartamencie w marokańskim Tangerze. Gdy zostaje zmuszona do jego opuszczenia, nie potrafi się z tym pogodzić. To, co początkowo wydaje się bolesną koniecznością, nieoczekiwanie staje się jednak nowym początkiem. W życiu Marii Ángeles pojawia się miejsce zarówno na nowych przyjaciół, jak i na niespodziewaną miłość. „Drugie życie” to zdobywca nagrody publiczności festiwalu w Wenecji. W roli głównej zachwycająca Carmen Maura, ikona filmów Almodóvara.","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"4a3d74ad-af64-4a6a-a640-e75c762899c8","name":"romans","description":""},{"id":"14c7bb44-6562-4ad9-8d7a-ab747fa73829","name":"dramat","description":""}],"trailers":["https://www.youtube.com/embed/8xyTxjwUwfQ"],"posters":["https://movies.helios.pl/images/drugiezycieplakat.jpg"],"pictures":["https://movies.helios.pl/images/Drugiezycie7.jpg","https://movies.helios.pl/images/Drugiezycie6.jpg","https://movies.helios.pl/images/Drugiezycie5.jpg","https://movies.helios.pl/images/Drugiezycie4.jpg","https://movies.helios.pl/images/Drugiezycie3.jpg","https://movies.helios.pl/images/Drugiezycie2.jpg","https://movies.helios.pl/images/Drugiezycie1.jpg"],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"15","value":"15","description":"od lat 15"}],"brightcoveVideos":[],"release":"2D/NAP","name":"Drugie życie - Kino Kobiet","link":null,"screeningId":"210fb2cd-f66c-4ad4-9c1d-c0391f56f4c0","screenId":"98d7c2ff-0340-4d76-bbf9-92b743cdb898","cinemaId":"d09e2607-693f-479f-8deb-59a18add40eb","timeFrom":"2026-06-10T18:00:00+02:00","timeTo":"2026-06-10T20:56:00+02:00","saleTimeTo":"2026-06-10T18:30:00+02:00","reservationTimeTo":"2026-06-10T17:00:00+02:00","availabili