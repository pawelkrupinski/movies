os.pl/images/Babystar4.jpg","https://movies.helios.pl/images/Babystar3.jpg","https://movies.helios.pl/images/Babystar2.jpg","https://movies.helios.pl/images/Babystar1.jpg"],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"13","value":"13","description":"od lat 13"}],"brightcoveVideos":[],"release":"2D/NAP","name":"Babystar - KNT","link":null,"screeningId":"2dc15166-18a5-4037-ba6d-e81f3b7367ae","screenId":"e3b43bf7-b519-4cec-bbbc-e002aa832287","cinemaId":"99d1a365-3dad-4c9b-a9e9-6e6177630708","timeFrom":"2026-06-11T13:30:00+02:00","timeTo":"2026-06-11T15:28:00+02:00","saleTimeTo":"2026-06-11T14:00:00+02:00","reservationTimeTo":"2026-06-11T12:30:00+02:00","availabilityStatus":1,"maxOccupancy":225,"audience":14,"generalAdmission":false,"isScreenSwapping":false,"externalId":745233211,"items":[{"movieId":"909cb22a-e1c4-4485-854b-1fea1218b38e","moviePrintId":"cfe8c781-3d6c-40b4-b782-34bbe716fb87","timeFrom":"2026-06-11T13:30:00+02:00","timeTo":"2026-06-11T15:28:00+02:00","movieName":"Babystar","speakingType":"Napisy","printType":"2D","screenId":"e3b43bf7-b519-4cec-bbbc-e002aa832287","movieSubPrintLabel":"ps"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":7,"symbol":"KINO NA TEMAT","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"ed834156-8c3f-4332-8f23-3c9b0648811c","duration":108,"description":"Makoto jest zwyczajną nastolatką, spędzającą większość czasu z przyjaciółmi. Kiedy pewnego dnia, spiesząc się z wizytą do ciotki, cudem unika potrącenia przez pociąg – przeskakuje w czasie do momentu sprzed wypadku. Korzystając z nowo poznanych zdolności, naprawia swoje codzienne błędy – od słabych ocen na sprawdzianach po nieudane wyznania miłości. Kiedy jednak dosięgają ją konsekwencje manipulowania czasem, Makoto musi zrobić wszystko, żeby uniknąć straszliwej przyszłości, której nie da się cofnąć.\nOdkryj na nowo film nominowanego do Oscara reżysera Mamoru Hosoda „O dziewczynie skaczącej przez czas” na wielkim ekranie, odnowiony w oszałamiającej jakości 4K.\nWIDZOWIE POKAZÓW W RAMACH PROJEKTU HELIOS ANIME OTRZYMAJĄ ","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"ecd4a997-2c14-4fd9-98c2-53ac7087a9bc","name":"anime","description":""}],"trailers":[],"posters":["https://movies.helios.pl/images/Dziewczynaskaczacaplakat.jpg"],"pictures":["https://movies.helios.pl/images/Odziewczynieskaczacejprzezczas7.jpg","https://movies.helios.pl/images/Odziewczynieskaczacejprzezczas6.jpg","https://movies.helios.pl/images/Odziewczynieskaczacejprzezczas5.jpg","https://movies.helios.pl/images/Odziewczynieskaczacejprzezczas4.jpg","https://movies.helios.pl/images/Odziewczynieskaczacejprzezczas3.jpg","https://movies.helios.pl/images/Odziewczynieskaczacejprzezczas2.jpg","https://movies.helios.pl/images/Odziewczynieskaczacejprzezczas1.jpg"],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"13","value":"13","description":"od lat 13"}],"brightcoveVideos":[],"release":"2D/NAP","name":"O dziewczynie skaczącej przez czas w Helios Anime","link":null,"screeningId":"1e2e2a9e-60e4-491d-85b3-996c5e409f9c","screenId":"d79f68b6-d908-49d4-a64b-c66f481db1de","cinemaId":"99d1a365-3dad-4c9b-a9e9-6e6177630708","timeFrom":"2026-06-13T15:30:00+02:00","timeTo":"2026-06-13T17:18:00+02:00","saleTimeTo":"2026-06-13T16:00:00+02:00","reservationTimeTo":"2026-06-13T14:30:00+02:00","availabilityStatus":1,"maxOccupancy":136,"audience":5,"generalAdmission":false,"isScreenSwapping":false,"externalId":54245687,"items":[{"movieId":"9119aa2a-c2cf-4c37-bb76-918faec77850","moviePrintId":"d8e8e674-b775-49f5-8bf8-f210118ecf7d","timeFrom":"2026-06-13T15:30:00+02:00","timeTo":"2026-06-13T17:18:00+02:00","movieName":"O dziewczynie skaczącej przez czas","speakingType":"Napisy","printType":"2D","screenId":"d79f68b6-d908-49d4-a64b-c66f481db1de","movieSubPrintLabel":"PS"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":13,"symbol":"HELIOS ANIME","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"0558005a-3851-48a5-be9d-4ae12a240224","duration":150,"description":"Już 4 czerwca kultowy „Podziemny krąg” („Fight Club”) wraca do kin po ponad 25 latach od premiery!\n\nTen prowokacyjny dramat, z udziałem Brada Pitta i Edwarda Nortona, w reżyserii Davida Finchera, opowiada o znudzonym i wyobcowanym mężczyźnie, który wraz z charyzmatycznym towarzyszem tworzą działający w podziemiu klub walki.","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"939b8bbb-4f8f-4fd6-875d-16e483eccdea","name":"thriller","description":""},{"id":"41200b53-4f1a-43c3-9c8e-cbe84751b892","name":"kryminał","description":""},{"id":"14c7bb44-6562-4ad9-8d7a-ab747fa73829","name":"dramat","description":""}],"trailers":[],"posters":["https://movies.helios.pl/images/Pozdziemnykragplakat.jpg"],"pictures":["https://movies.helios.pl/images/Podziemnykrag3.jpg","https://movies.helios.pl/images/Podziemnykrag2.jpg","https://movies.helios.pl/images/Podziemnykrag1.jpg"],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"15","value":"15","description":"od lat 15"}],"brightcoveVideos":[],"release":"2D/NAP","name":"Podziemny krąg w Helios RePlay","link":null,"screeningId":"d1448b0a-8b13-4c81-a78e-04b317b84529","screenId":"e9bff315-e786-4f10-b598-54de7f540aab","cinemaId":"99d1a365-3dad-4c9b-a9e9-6e6177630708","timeFrom":"2026-06-11T19:45:00+02:00","timeTo":"2026-06-11T22:15:00+02:00","saleTimeTo":"2026-06-11T20:15:00+02:00","reservationTimeTo":"2026-06-11T18:45:00+02:00","availabilityStatus":1,"maxOccupancy":146,"audience":0,"generalAdmission":false,"isScreenSwapping":false,"externalId":29686786,"items":[{"movieId":"b233f278-496b-4504-ac06-725630c68db1","moviePrintId":"2076a1e7-fffb-4dc7-b499-8398284b48eb","timeFrom":"2026-06-11T19:45:00+02:00","timeTo":"2026-06-11T22:15:00+02:00","movieName":"Podziemny krąg","speakingType":"Napisy","printType":"2D","screenId":"e9bff315-e786-4f10-b598-54de7f540aab","movieSubPrintLabel":"ps"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":16,"symbol":"HELIOS REPLAY","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"6c94cbc9-7a80-4a09-b3ad-5602eb24acbd","duration":195,"description":"Obejmująca 34 miasta i 85 koncertów trasa stała się największym tournée w historii koreańskiego artysty. Dodatkowego znaczenia temu wydarzeniu nadaje data koncertu - 13 czerwca, czyli rocznica debiutu BTS - symboliczny moment celebrujący zarówno dotychczasową drogę zespołu, jak i nowy rozdział ich kariery. \n\nTrasa ARIRANG towarzyszy piątemu albumowi studyjnemu grupy i opowiada o tożsamości BTS poprzez szczere emocje, tęsknotę i miłość, które od lat łączą ich z fanami na całym świecie. Imponująca scena 360 stopni sprawia, że widzowie stają się częścią widowiska i mogą poczuć energię koncertu z każdej perspektywy. \n\nNie przegap tego wyjątkowego wydarzenia. Przeżyj wielki powrót BTS na kinowym ekranie 13 czerwca - prosto z Busanu. \n\nUwaga: w wybranych krajach transmisja może odbywać się z opóźnieniem ze względu na różnice stref czasowych.","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"249045c8-3c6f-4ffe-abf3-ec3a85a2b1b1","name":"koncert ","description":""}],"trailers":[],"posters":["https://movies.helios.pl/images/BTSBusanPlakat(1).jpg"],"pictures":["https://movies.helios.pl/images/BTSczerwiec7.jpg","https://movies.helios.pl/images/BTSczerwiec3.jpg","https://movies.helios.pl/images/BTSczerwiec2.jpg","https://movies.helios.pl/images/BTSczerwiec1.jpg"],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"40","value":"10 lat","description":"od lat 10"}],"brightcoveVideos":[],"release":"2D/ORG","name":"BTS World Tour ‘ARIRANG’ in Busan: Live Viewing w Helios na Scenie","link":null,"screeningId":"79a8de31-99df-4362-abcd-e378b20aaf2a","screenId":"cac597d