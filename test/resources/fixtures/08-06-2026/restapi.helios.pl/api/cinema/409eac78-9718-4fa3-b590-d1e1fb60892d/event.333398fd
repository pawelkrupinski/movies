rowadzi ich do nieznanych, fascynujących zakątków miasta, gdzie będą musieli działać pod przykrywką. Ich relacja zostaje wystawiona na próbę, a stawka rośnie z każdą chwilą.","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"9212e3f5-252f-4d08-b375-2923037a4591","name":"animowany","description":""}],"trailers":[],"posters":["https://movies.helios.pl/images/zwierzogrod2plakat.jpg"],"pictures":[],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"6","value":"6","description":"od lat 6"}],"brightcoveVideos":[],"release":"2D/DUB","name":"Zwierzogród 2 - KNTJ","link":null,"screeningId":"08d20f8e-1182-4f31-ae5d-8a38b70f5708","screenId":"5a606749-f8ab-4c76-99f1-e25c67e68c59","cinemaId":"409eac78-9718-4fa3-b590-d1e1fb60892d","timeFrom":"2026-06-11T14:30:00+02:00","timeTo":"2026-06-11T16:38:00+02:00","saleTimeTo":"2026-06-11T15:00:00+02:00","reservationTimeTo":"2026-06-11T13:30:00+02:00","availabilityStatus":1,"maxOccupancy":377,"audience":41,"generalAdmission":false,"isScreenSwapping":false,"externalId":333580,"items":[{"movieId":"fd579877-8215-4a72-a1b6-d2bae868c4f4","moviePrintId":"d30d06d3-0d5b-4363-ace0-f07d8904629e","timeFrom":"2026-06-11T14:30:00+02:00","timeTo":"2026-06-11T16:38:00+02:00","movieName":"Zwierzogród 2","speakingType":"DUB","printType":"2D","screenId":"5a606749-f8ab-4c76-99f1-e25c67e68c59","movieSubPrintLabel":"ps"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":8,"symbol":"KINO NA TEMAT JUNIOR","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"8548c02a-56bf-4df4-8085-fbb356648e06","duration":110,"description":"Waldek ma dość – w domu chaos, w sieci drama, a jego gamingowy team się sypie. W emocjach robi coś głupiego – pisze złośliwy komentarz… i nieświadomie uruchamia lawinę hejtu, która uderza w jedną z najbliższych mu osób – Delfinę.","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,