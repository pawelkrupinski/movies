/amelia_01_1080_x_1080.jpg","thumb":"/media/gallery/thumb/amelia_01_1080_x_1080.jpg"},"title":"amelia_01_1080 x 1080","description":null,"image":"/media/gallery/images/amelia_01_1080_x_1080.jpg"},"trailer":"https://www.youtube.com/watch?v=rWI231gZXgM","url":"http://kinopalacowe.pl/filmy/13125-plenerowe-paacowe-amelia/","ticket_type":2,"ticket_url":"https://ckzamek.bilety24.pl/kup-bilety/?id=930243","lead":"PLENEROWE PAŁACOWE - pokazy na Dziedzińcu Zamkowym Miejsce wydarzenia:  Dziedziniec Zamkowy (wejście od Al....","vertical_bg_position":null,"horizontal_bg_position":null,"is_en_sign":false,"start_date":"2026-06-16","start_time":"21:30:00","occurrence":{"id":18920,"date":"2026-06-16T21:30:00","datetime":"2026-06-16T21:30:00","bilety24":{"price":"16.00","available":true,"ticket_url":"https://ckzamek.bilety24.pl/kup-bilety/?id=930243"}}},{"id":14623,"title":"Plenerowe Pałacowe 2026","photo":{"sizes":{"sm":"/media/gallery/sm/PP_2026_www_najnowszy.jpg","md":"/media/gallery/md/PP_2026_www_najnowszy.jpg","lg":"/media/gallery/lg/PP_2026_www_najnowszy.jpg","thumb":"/media/gallery/thumb/PP_2026_www_najnowszy.jpg"},"title":"PP_2026_www_najnowszy","description":null,"image":"/media/gallery/images/PP_2026_www_najnowszy.jpg"},"description":"<p><span style=\"font-weight: bold;\">WAKACYJNE SEANSE FILMOWE NA DZIEDZIŃCU ZAMKOWYM</span> we wtorki, środy i czwartki.</p><p><span style=\"color: inherit;\">Od 16 czerwca do 3 września zapraszamy na pokazy <span style=\"font-weight: bold;\">Plenerowego Pałacowego</span>, czyli wieczornych pokazów na Zamkowym Dziedzińcu.&nbsp;</span><span style=\"color: inherit;\">Tegoroczny program bogaty jest w klasykę, ale nie brakuje w nim najgorętszych tytułów z minionych sezonów. To filmy, które idealnie pasują do letnich, ciepłych wieczorów spędzonych na leżaku pod chmurką.</span></p><p><span style=\"color: inherit;\">Na terenie Dziedzińca Zamkowego będą sprzedawane napoje.&nbsp;</span></p><p><span style=\"color: inherit; font-weight: bold;\">Uwaga! Na terenie Dziedzińca Zamkowego nie będzie możliwości zakupu biletów. </span><span style=\"color: inherit;\">Zapraszamy do kasy CK Zamek (czerwona tuba w Holu Wielkim) lub zakupu biletów online.</span></p><p>--</p><p>Dla kogo: młodzież, dorośli</p><p>Miejsce wydarzenia: <a href=\"https://ckzamek.pl/artykuly/206-dziedziniec-zamkowy/\" style=\"font-weight: bold;\">Dziedziniec Zamkowy</a> (wejście od Al. Niepodległości, obok klubów Hades i Dubliner)<br></p><p><span style=\"font-weight: bold;\">bilety</span>: 18 zł (normalny), 16 zł (z Kartą Kinomana), 16 zł (grupowy - od 10 osób)</p><p>--</p><p>[Kolorowa grafika. Na niebieskim tle złote gwiazdki otaczają napis PLENEROWE PAŁACOWE 2026. Pod nimi trzy marmurowe zwierzęta: lew, lis i ptak, zajmują miejsca przed ekranem, na którym zaczyna się film.]</p>","start_date":"2026-06-16","start_time":"21:30:00","occurrence":null,"place":"Dziedziniec Zamkowy","category":"Kino Pałacowe","url":"http://kinopalacowe.pl/wydarzenia/14623-plenerowe-paacowe-2026/","link":null,"get_type":0,"ticket_type":2,"is_special":false,"show_in_header":false,"ticket_url":null,"lead":"WAKACYJNE SEANSE FILMOWE NA DZIEDZIŃCU ZAMKOWYM we wtorki, środy i czwartki. Od 16 czerwca do 3 września zapraszamy...","age_category":[1,2,3],"hide_date":false,"is_pinned":false,"vertical_bg_position":null,"horizontal_bg_position":null,"end_date":null}]}]},{"day":1781654400.0,"subsections":[{"name":"main","entries":[{"id":14415,"title":"DKF Zamek: Summer Wars","category":"Sala 1 - Kinowa","photo":{"sizes":{"sm":"/media/gallery/sm/1_sUMMER_Wars.jpg","md":"/media/gallery/md/1_sUMMER_Wars.jpg","lg":"/media/gallery/lg/1_sUMMER_Wars.jpg","thumb":"/media/gallery/thumb/1_sUMMER_Wars.jpg"},"title":"1_sUMMER Wars","description":null,"image":"/media/gallery/images/1_sUMMER_Wars.jpg"},"trailer":null,"url":"http://kinopalacowe.pl/filmy/14415-dkf-zamek-summer-wars/","ticket_type":2,"ticket_url":"https://ckzamek.bilety24.pl/kup-bilety/?id=925071","lead":"Kenji to nieśmiały moderator pl