                <div class="col-12 movies-movie__single__info">
                    <h2 class="movies-movie__single__title" title="90. URODZINY PAVAROTTIEGO">90. URODZINY PAVAROTTIEGO</h2>
                    <ul class="movies-movie__single__moreinfo">
                            <li>wersja:  2D, NAP  </li>
                        <li>czas: 95 min.</li>
