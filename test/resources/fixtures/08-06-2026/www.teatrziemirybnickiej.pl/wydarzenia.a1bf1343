<script>
    $(document).on('change', '#cnt-event-list-filters select', function() {
        $('#cnt-event-list-filters form').submit();
    });

    function filtersSelectType(typeCode) {
        var typeCode = $.trim(typeCode);
        $('#cnt-event-list-filters input[type="checkbox"][value="' + typeCode + '"]').attr('checked', !$('#cnt-event-list-filters input[type="checkbox"][value="' + typeCode + '"]').attr('checked'));
        if(typeCode == 'all') {
            $('#cnt-event-list-filters input[type="checkbox"]:not([value="' + typeCode + '"])').attr('checked', false);
        }
        else {
            $('#cnt-event-list-filters input[type="checkbox"][value="all"]').attr('checked', false);
        }
        $('#cnt-event-list-filters form').submit();
    }
