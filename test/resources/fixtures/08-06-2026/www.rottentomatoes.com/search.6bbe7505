            <script>
                const encodedData = sessionStorage.getItem('oneTrustSyncData');
                let id, token;

                if (encodedData) {
                    try {
                        const oneTrustSyncData = JSON.parse(atob(encodedData));
                        id = oneTrustSyncData?.id;
                        token = oneTrustSyncData?.token;
                    } catch (e) {}
                }

                if (id && token) {
                    var OneTrust = {
                        dataSubjectParams: {
                            id,
                            isAnonymous: false,
                            token
                        }
                    };
                }
            </script>
            
