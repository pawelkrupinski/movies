<overlay-base
    data-AuthInitiateManager="overlayBase:close"
    data-AuthProfileManager="overlayBase"
    data-PagePollsIndexManager="authOverlay:close"
    hidden
>
    <overlay-flows data-AuthInitiateManager="overlayFlows" data-AuthProfileManager="overlayFlows" slot="content">
        <action-icon
            slot="close"
            class="auth-overlay__icon-button auth-overlay__icon-button--close"
