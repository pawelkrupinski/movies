83gkbvsnslxbUpOJGwNK.jpg","release_date":"1990-08-17","softcore":false,"video":false,"vote_average":7.039,"vote_count":1914},{"adult":false,"backdrop_path":"/xXR8BCRUMUbrPQ1QAumbL0x93fV.jpg","genre_ids":[99],"id":1208994,"title":"Naturalna dzikość serca","original_language":"no","original_title":"Ukjent landskap","overview":"Intymna opowieść o wyborach życiowych, wolności, miłości, ale też stracie. Rodzina Marii i Nika prowadzi samowystarczalne życie w zgodzie z naturą na małej farmie zaszytej w norweskim lesie. Wybierają świadomie, z odpowiedzialnością za świat i przyszłość swoich dzieci.","popularity":0.3341,"poster_path":"/znufRhOP1b2TzRUZgUPTNgOYPIY.jpg","release_date":"2024-04-15","softcore":false,"video":false,"vote_average":7.8,"vote_count":16}],"total_pages":1,"total_results":5}