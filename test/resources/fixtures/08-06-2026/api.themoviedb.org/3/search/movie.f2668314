ego Młodzieży Wszechpolskiej. Pierwszym zadaniem dla każdej z grup było stworzenie rozumianego przez siebie symbolu państwa polskiego. Symbole te zostały następnie umieszczone na koszulkach rozdanych uczestnikom projektu. Później nastąpiła konfrontacja wszystkich grup, wraz z wcześniej stworzonymi przez nich planszami z symbolem Polski, podczas której wykonywano dalsze zadania otrzymane od reżysera. Przedstawiciele danej grupy mogli na przykład coś domalować do symbolu innej grupy lub coś z niego usunąć itp.","popularity":0.0168,"poster_path":null,"release_date":"2007-01-01","softcore":false,"video":false,"vote_average":0.0,"vote_count":0},{"adult":false,"backdrop_path":null,"genre_ids":[],"id":119567,"title":"Gei Oni","original_language":"en","original_title":"Gei Oni","overview":"","popularity":0.1531,"poster_path":"/5ehi7sQqwY5aovbSVSd29eV0ktP.jpg","release_date":"2012-07-13","softcore":false,"video":false,"vote_average":0.0,"vote_count":0},{"adult":false,"backdrop_path":"/8vA4t7OdoTMPf1Po0bN44leo2CP.jpg","genre_ids":[99],"id":515576,"title":"Oni žive","original_language":"sr","original_title":"Oni žive","overview":"","popularity":0.2894,"poster_path":"/skdAQVk9xv32fWUwn3oHNIbA5g5.jpg","release_date":"2018-04-01","softcore":false,"video":false,"vote_average":0.0,"vote_count":0},{"adult":false,"backdrop_path":null,"genre_ids":[],"id":1146206,"title":"Oni Azami","original_language":"xx","original_title":"Oni Azami","overview":"","popularity":0.2049,"poster_path":null,"release_date":"1927-01-01","softcore":false,"video":false,"vote_average":8.0,"vote_count":1},{"adult":false,"backdrop_path":null,"genre_ids":[18],"id":922928,"title":"On, ona, oni","original_language":"pl","original_title":"On, ona, oni","overview":"","popularity":0.1211,"poster_path":null,"release_date":"1983-12-12","softcore":false,"video":false,"vote_average":8.0,"vote_count":1},{"adult":false,"backdrop_path":null,"genre_ids":[18],"id":1069409,"title":"Wakanohana monogatari dohyou no oni","original