{"page":1,"results":[{"adult":false,"gender":0,"id":2388870,"known_for_department":"Acting","name":"Grzegorz Lipiec","original_name":"Grzegorz Lipiec","popularity":0.0143,"profile_path":null,"known_for":[{"adult":false,"backdrop_path":"/dINV5XtHFWwtZT0SUBrFRQRHLmo.jpg","id":623756,"title":"That Life Makes Sense","original_title":"Że życie ma sens","overview":"The film is set in Osiedle Piastowskie in Zielona Góra. A group of friends from the yard finds a way to provincial stagnation in amateur filmmaking. Their latest picture is on the threshold of going beyond the concrete block. Unexpectedly, a boy from the neighborhood appears with new ideas. In addition to colorful laser techno events, happy evenings in a local pub and entertainment friends, it offers drug experiments.","poster_path":"/uP5fz87YxABMtdKGnxIiL6r6u7G.jpg","media_type":"movie","original_language":"pl","genre_ids":[18],"popularity":0.0379,"release_date":"2001-04-20","softcore":false,"video":false,"vote_average":7.4,"vote_count":5}]}],"total_pages":1,"total_results":1}