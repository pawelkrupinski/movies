{"page":1,"results":[{"adult":false,"backdrop_path":"/2RV5M80S4El2R5bmqpBJx6hpquT.jpg","genre_ids":[18,36],"id":953735,"title":"Marinette","original_language":"fr","original_title":"Marinette","overview":"Marinette Pichon ma za sobą ciężkie życiowe doświadczenia. Mimo przeciwności losu osiąga sukces sportowy i zostaje przyjęta do francuskiej reprezentacji w piłce nożnej. Szybko zwraca uwagę amerykańskiego klubu piłkarskiego. Skuszona złożoną przez jego członków propozycją rusza w daleką podróż za ocean, by zrealizować swoje wielkie marzenie: zostać najbardziej uznaną piłkarką na świecie. Pewne sprawy jednak nie układają się po jej myśli. Pichon była pierwszą francuską zawodniczką, którą zwerbowano do amerykańskiej ligi zawodowej. Pobiła rekord strzelonych bramek na mecz.","popularity":1.475,"poster_path":"/aM7o55PKT45q630Qmma1fNu99Cd.jpg","release_date":"2023-06-07","softcore":false,"video":false,"vote_average":6.5,"vote_count":74},{"adult":false,"backdrop_path":null,"genre_ids":[],"id":1428819,"title":"Avec Marinette","original_language":"fr","original_title":"Avec Marinette","overview":"","popularity":0.0143,"poster_path":null,"release_date":"1999-01-01","softcore":false,"video":false,"vote_average":0.0,"vote_count":0},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":503717,"title":"Marinette torna a casa","original_language":"en","original_title":"Marinette torna a casa","overview":"","popularity":0.0646,"poster_path":null,"release_date":"2014-02-07","softcore":false,"video":false,"vote_average":5.0,"vote_count":1}],"total_pages":1,"total_results":3}