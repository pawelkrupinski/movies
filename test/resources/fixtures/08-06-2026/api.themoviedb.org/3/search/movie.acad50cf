{"page":1,"results":[{"adult":false,"backdrop_path":"/s3X7UVfnmycegqfkWSp4oEplJbn.jpg","genre_ids":[53,80],"id":504582,"title":"La Gomera","original_language":"ro","original_title":"La Gomera","overview":"\"La Gomera\" zaczyna się jak klasyczny czarny kryminał, by szybko skręcić w rejony kina autorskiego. Głównym bohaterem jest skorumpowany policjant, który przybywa na tytułową wyspę, chcąc załatwić jeden ze swoich ciemnych interesów. Aby utrzymać wszystko w tajemnicy, musi opanować lokalny język gwizdów zwany silbo. Jakby tego było mało, w życiu mężczyzny pojawia się zjawiskowa femme fatale o imieniu Gilda.","popularity":1.6686,"poster_path":"/b4kfwMdpjqARUw8NXy5OWZj28JC.jpg","release_date":"2019-09-13","softcore":false,"video":false,"vote_average":6.0,"vote_count":181},{"adult":false,"backdrop_path":null,"genre_ids":[],"id":1021218,"title":"La Gomera - Die schönsten Wanderungen auf der Kanareninsel","original_language":"de","original_title":"La Gomera - Die schönsten Wanderungen auf der Kanareninsel","overview":"","popularity":0.0,"poster_path":null,"release_date":"","softcore":false,"video":false,"vote_average":0.0,"vote_count":0},{"adult":false,"backdrop_path":null,"genre_ids":[],"id":1021217,"title":"Kanarische Inseln - Inselhopping auf El Hierro, La Palma und La Gomera","original_language":"de","original_title":"Kanarische Inseln - Inselhopping auf El Hierro, La Palma und La Gomera","overview":"","popularity":0.0261,"poster_path":null,"release_date":"","softcore":false,"video":false,"vote_average":0.0,"vote_count":0},{"adult":false,"backdrop_path":"/4h30X1Ss9QIy9zKPLZJSbL8W8G7.jpg","genre_ids":[53,80,9648],"id":437035,"title":"La niebla y la doncella","original_language":"es","original_title":"La niebla y la doncella","overview":"","popularity":0.5795,"poster_path":"/f2s1m6K64vFboWp9NjqiKrTDXsF.jpg","release_date":"2017-09-01","softcore":false,"video":false,"vote_average":5.6,"vote_count":103}],"total_pages":1,"total_results":4}