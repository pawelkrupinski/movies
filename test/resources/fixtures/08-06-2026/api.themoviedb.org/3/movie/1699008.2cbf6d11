{"adult":false,"backdrop_path":null,"belongs_to_collection":null,"budget":0,"genres":[{"id":99,"name":"Dokumentalny"}],"homepage":"https://rafaelfilm.pl/poslani/","id":1699008,"imdb_id":null,"origin_country":["PL"],"original_language":"pl","original_title":"Posłani","overview":"Osią opowieści jest niecodzienna droga Michała Ulewińskiego, który przemierza niemal 650 kilometrów przez Polskę, niosąc 15-kilogramowy krzyż. Trasa — od Zalewu Wiślanego po Giewont, dalej przez Gniezno aż do Sokółki — układa się w symboliczny znak krzyża na mapie kraju. To nie tylko wysiłek fizyczny. To intensywna, osobista modlitwa, duchowa walka i proces głębokiej wewnętrznej przemiany.","popularity":0.1015,"poster_path":"/u9IK99Q1jOPg9pJK38ZdiCkwLfZ.jpg","production_companies":[{"id":257092,"logo_path":null,"name":"DAW Production","origin_country":"PL"}],"production_countries":[{"iso_3166_1":"PL","name":"Poland"}],"release_date":"2026-05-22","revenue":0,"runtime":83,"softcore":false,"spoken_languages":[{"english_name":"Polish","iso_639_1":"pl","name":"Polski"}],"status":"Released","tagline":"","title":"Posłani","video":false,"vote_average":0.0,"vote_count":0,"credits":{"cast":[],"crew":[{"adult":false,"gender":0,"id":2619788,"known_for_department":"Directing","name":"Dariusz Walusiak","original_name":"Dariusz Walusiak","popularity":0.0143,"profile_path":null,"credit_id":"6a0d90ac373bcaf068a2b223","department":"Directing","job":"Director"}]}}