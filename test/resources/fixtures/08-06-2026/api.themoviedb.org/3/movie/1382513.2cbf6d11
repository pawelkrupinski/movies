{"adult":false,"backdrop_path":"/jeQnkrXy95nmjNZcLhRNXXIsjZv.jpg","belongs_to_collection":null,"budget":0,"genres":[{"id":12,"name":"Przygodowy"},{"id":18,"name":"Dramat"}],"homepage":"","id":1382513,"imdb_id":"tt29283995","origin_country":["HU","DE","GR"],"original_language":"el","original_title":"Κότα","overview":"Nasza pierzasta bohaterka ucieka z klatki bateryjnej. Znajduje schronienie w podupadłej restauracji na greckim wybrzeżu. Tam odkrywa miłość, poznaje ludzką hierarchię i walczy o ochronę swoich jaj przed chciwym właścicielem. Kura jest świadkiem kradzieży, przemytu i brudnych interesów. Zwierzęca bohaterka, której walka o macierzyństwo odzwierciedla chaotyczne kompromisy i ciche bitwy ludzkiego życia.","popularity":1.9349,"poster_path":"/xmHzLoSEguCNj4b0nSiqu0npNHF.jpg","production_companies":[{"id":789,"logo_path":"/rQ0fru0nm1oCsz2npnAgXEl11AH.png","name":"Pallas Film","origin_country":"DE"},{"id":78855,"logo_path":"/vuizOS4PimCsbVcBMi7Ei2I2pnj.png","name":"View Master Films","origin_country":"GR"},{"id":32545,"logo_path":"/oivNQ1dScP0yynYm10xGAkyBLSf.png","name":"Twenty Twenty Vision Filmproduktion","origin_country":"DE"},{"id":11237,"logo_path":"/nzPEges9ftjCDQWru0qrIfTX8OR.png","name":"ZDF/Arte","origin_country":"DE"},{"id":128330,"logo_path":"/j5YMevr8nQPCY7J5WbkuAS3EQqm.png","name":"FocusFox","origin_country":"HU"}],"production_countries":[{"iso_3166_1":"DE","name":"Germany"},{"iso_3166_1":"HU","name":"Hungary"},{"iso_3166_1":"GR","name":"Greece"}],"release_date":"2026-02-20","revenue":0,"runtime":96,"softcore":false,"spoken_languages":[{"english_name":"Greek","iso_639_1":"el","name":"ελληνικά"}],"status":"Released","tagline":"","title":"Hen","video":false,"vote_average":7.167,"vote_count":6,"credits":{"cast":[{"adult":false,"gender":2,"id":1092405,"known_for_department":"Acting","name":"Γιάννης Κοκιασμένος","original_name":"Γιάννης Κοκιασμένος","popularity":0.1811,"profile_path":"/xUASnaMbiW9qFO7MPj2pJyJkDSI.jpg","cast_id":7,"character":"Restaurant