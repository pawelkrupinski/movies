{"adult":false,"backdrop_path":"/y2FNZLHynsevBnVTocGW6c3pQpr.jpg","belongs_to_collection":null,"budget":0,"genres":[{"id":18,"name":"Drama"}],"homepage":"https://www.janusfilms.com/films/1012","id":422,"imdb_id":"tt0056801","origin_country":["IT"],"original_language":"it","original_title":"8½","overview":"Guido Anselmi, a film director, finds himself creatively barren at the peak of his career. Urged by his doctors to rest, Anselmi heads for a luxurious resort, but a sorry group gathers—his producer, staff, actors, wife, mistress, and relatives—each one begging him to get on with the show. In retreat from their dependency, he fantasizes about past women and dreams of his childhood.","popularity":4.4287,"poster_path":"/23VIf7zNxAgaXwIlvzd3IvOd9sY.jpg","production_companies":[{"id":9387,"logo_path":null,"name":"Cineriz","origin_country":"IT"},{"id":10882,"logo_path":null,"name":"Francinex","origin_country":"FR"}],"production_countries":[{"iso_3166_1":"IT","name":"Italy"},{"iso_3166_1":"FR","name":"France"}],"release_date":"1963-02-14","revenue":0,"runtime":139,"softcore":false,"spoken_languages":[{"english_name":"German","iso_639_1":"de","name":"Deutsch"},{"english_name":"English","iso_639_1":"en","name":"English"},{"english_name":"French","iso_639_1":"fr","name":"Français"},{"english_name":"Italian","iso_639_1":"it","name":"Italiano"}],"status":"Released","tagline":"A picture that goes beyond what men think about - because no man ever thought about it in quite this way!","title":"8½","video":false,"vote_average":8.1,"vote_count":2529,"alternative_titles":{"titles":[{"iso_3166_1":"US","title":"Eight and a Half","type":""},{"iso_3166_1":"IT","title":"Otto e mezzo","type":""},{"iso_3166_1":"US","title":"8.5","type":""},{"iso_3166_1":"US","title":"8 1/2","type":""},{"iso_3166_1":"US","title":"Federico Fellini's 8 1/2","type":""},{"iso_3166_1":"HU","title":"8 és 1/2","type":""},{"iso_3166_1":"HU","title":"Nyolc és fél","type":""},{"iso_3166_1":"BR","title":"Oito e Meio","