{"adult":false,"backdrop_path":"/xyVURBvbRIzsGJlD0h8vybkXjLs.jpg","belongs_to_collection":null,"budget":900000,"genres":[{"id":18,"name":"Dramat"},{"id":10752,"name":"Wojenny"}],"homepage":"","id":19067,"imdb_id":"tt0075968","origin_country":["GB"],"original_language":"en","original_title":"The Duellists","overview":"Strasburg, rok 1800. Napoleon Bonaparte został władcą Francji. Porucznik Armand d'Hubert (Keith Carradine) dostaje zadanie, by odnaleźć porucznika Gabriela Ferauda (Harvey Keitel) i przekazać mu informację od dowództwa, że jest osadzony w areszcie domowym. Awanturniczy Feraud uważa, że został znieważony jego honor i wyzywa d'Huberta na szable. Tak rozpoczyna się ciągnący przez całą kampanię napoleońską pojedynek. Tylko trzy powody umożliwiają odstępstwo od niego. Po pierwsze, nie można walczyć z kimś, gdy się jest w różnych miejscach, po drugie, gdy żołnierze są innego stopnia, naruszenie dyscypliny oraz wówczas, gdy państwo jest w stanie wojny.","popularity":2.6671,"poster_path":"/nqjMYlUXnmmO8Jqucow4nj9alE5.jpg","production_companies":[{"id":7049,"logo_path":null,"name":"Enigma Productions","origin_country":"GB"},{"id":4,"logo_path":"/jay6WcMgagAklUt7i9Euwj1pzTF.png","name":"Paramount Pictures","origin_country":"US"},{"id":1645,"logo_path":"/6Ry6uNBaa0IbbSs1XYIgX5DkA9r.png","name":"Scott Free Productions","origin_country":"GB"},{"id":11493,"logo_path":null,"name":"National Film Finance Corporation (NFFC)","origin_country":""}],"production_countries":[{"iso_3166_1":"GB","name":"United Kingdom"},{"iso_3166_1":"US","name":"United States of America"}],"release_date":"1977-08-31","revenue":0,"runtime":100,"softcore":false,"spoken_languages":[{"english_name":"English","iso_639_1":"en","name":"English"},{"english_name":"Russian","iso_639_1":"ru","name":"Pусский"}],"status":"Released","tagline":"","title":"Pojedynek","video":false,"vote_average":7.244,"vote_count":633,"credits":{"cast":[{"adult":false,"gender":2,"id":30613,"known_for_department":"Acting","nam