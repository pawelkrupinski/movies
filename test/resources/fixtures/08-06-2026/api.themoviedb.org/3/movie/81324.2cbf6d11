{"adult":false,"backdrop_path":"/6XG4k8Uc4VmpiyqDSwqimFmGOEM.jpg","belongs_to_collection":null,"budget":0,"genres":[{"id":12,"name":"Przygodowy"},{"id":878,"name":"Sci-Fi"},{"id":27,"name":"Horror"}],"homepage":"","id":81324,"imdb_id":"tt0095456","origin_country":["PL"],"original_language":"pl","original_title":"Klątwa Doliny Węży","overview":"Francuski pilot Bernard Traven zgłasza się do sinologa, profesora Jana Tarnasa, z prośbą o rozszyfrowanie tajskiego manuskryptu. Pismo wpadło mu w ręce, gdy został zestrzelony na laotańsko-wietnamskim pograniczu i szukał schronienia w buddyjskiej świątyni. Manuskrypt ujawnia pewną mapę, a tekst mówi o specyfiku dającym władzę nad światem. Tarnas i Traven lecą do Wietnamu, by odnaleźć Dolinę Węży. Towarzyszy im związana z kontrwywiadem dziennikarka Christine.","popularity":0.3499,"poster_path":"/qu2pP12rixmEaSCecxFeWrpaaT0.jpg","production_companies":[{"id":22089,"logo_path":null,"name":"Zespół Filmowy \"Oko\"","origin_country":"PL"},{"id":6147,"logo_path":"/A78oMmC2gHBvRrXPRHbsJocT25X.png","name":"Tallinnfilm","origin_country":"SU"},{"id":21300,"logo_path":null,"name":"Vietnam Feature Film Studio","origin_country":"VN"}],"production_countries":[{"iso_3166_1":"PL","name":"Poland"},{"iso_3166_1":"SU","name":"Soviet Union"}],"release_date":"1988-10-03","revenue":0,"runtime":99,"softcore":false,"spoken_languages":[{"english_name":"French","iso_639_1":"fr","name":"Français"},{"english_name":"Polish","iso_639_1":"pl","name":"Polski"},{"english_name":"English","iso_639_1":"en","name":"English"},{"english_name":"Vietnamese","iso_639_1":"vi","name":"Tiếng Việt"}],"status":"Released","tagline":"","title":"Klątwa Doliny Węży","video":false,"vote_average":6.0,"vote_count":34,"credits":{"cast":[{"adult":false,"gender":2,"id":121594,"known_for_department":"Acting","name":"Krzysztof Kolberger","original_name":"Krzysztof Kolberger","popularity":0.1817,"profile_path":"/xEkQfRigtf6xxYDktRcwn8DPTbI.jpg","cast_id":2,"character":"Jan Tarnas","cred