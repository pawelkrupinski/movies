{"adult":false,"backdrop_path":null,"belongs_to_collection":null,"budget":0,"genres":[{"id":99,"name":"Dokumentalny"}],"homepage":"https://awareness.org.pl/znaki-pana-sliwki/","id":1556638,"imdb_id":"tt38651183","origin_country":["PL"],"original_language":"pl","original_title":"Znaki Pana Śliwki","overview":"Wbrew oczekiwaniom rodziny Karol Śliwka opuszcza wieś i zaczyna studia artystyczne w Warszawie. Postanawia zająć się projektowaniem znaków graficznych. Swoimi pracami wypełnia komunistyczną Polskę i definiuje wizualny krajobraz kraju. Jego znaki nie wiszą w galeriach, ale są obecne w polskich domach, na polskich ulicach, w instytucjach i zakładach pracy. Jednocześnie prowadzi zwyczajne życie rodzinne, które przez lata z pasją dokumentuje.","popularity":0.5241,"poster_path":"/itOZvCQjANQno1G0aoT9RisF3Et.jpg","production_companies":[{"id":107623,"logo_path":null,"name":"Silver Frame","origin_country":"PL"},{"id":6480,"logo_path":"/qJUUNzFYXNUDaisssBTV3Zdki9R.png","name":"Telewizja Polska","origin_country":"PL"},{"id":283015,"logo_path":null,"name":"Esy-floresy studio animacji","origin_country":"PL"},{"id":125737,"logo_path":"/v4YRjUXtET5EqW2XXYB05K3yUpd.png","name":"Mazowiecki Instytut Kultury","origin_country":"PL"},{"id":283016,"logo_path":null,"name":"Ubi Ieones","origin_country":"PL"}],"production_countries":[{"iso_3166_1":"PL","name":"Poland"}],"release_date":"2026-05-16","revenue":0,"runtime":72,"softcore":false,"spoken_languages":[{"english_name":"Polish","iso_639_1":"pl","name":"Polski"}],"status":"Released","tagline":"","title":"Znaki Pana Śliwki","video":false,"vote_average":0.0,"vote_count":0,"credits":{"cast":[{"adult":false,"gender":0,"id":5727317,"known_for_department":"Acting","name":"Karol Śliwka","original_name":"Karol Śliwka","popularity":0.0214,"profile_path":null,"cast_id":1,"character":"Self","credit_id":"68e02904c1995174f68e677a","order":0},{"adult":false,"gender":2,"id":1184491,"known_for_department":"Acting","name":"Dariusz Dłużewski","orig