{"adult":false,"backdrop_path":"/3d7Zh7ZGk1TbiUA3ZGKyS3qCpBi.jpg","belongs_to_collection":null,"budget":0,"genres":[{"id":18,"name":"Dramat"}],"homepage":"","id":42199,"imdb_id":"tt0078857","origin_country":["PL"],"original_language":"pl","original_title":"Bez znieczulenia","overview":"Po powrocie z zagranicy znany dziennikarz dowiaduje się, że żona bierze z nim rozwód. Ponieważ nie zna przyczyn decyzji małżonki, nie może się z tym pogodzić. Dodatkowo zaczyna popadać w coraz większe kłopoty zawodowe. Jego wystąpienie telewizyjne i publikacje prasowe nie zyskują uznania. Na uniwersytecie zawieszono wykłady, które prowadził. Planowany od dłuższego czasu wyjazd za granicę zostaje niespodziewanie odwołany. Podczas rozprawy rozwodowej żona zaczyna obciążać męża, składając fałszywe zeznania.","popularity":0.3599,"poster_path":"/bxS0z1Ji4VVWZthMZpooi0Fcviu.jpg","production_companies":[{"id":3514,"logo_path":null,"name":"Zespół Filmowy \"X\"","origin_country":"PL"}],"production_countries":[{"iso_3166_1":"PL","name":"Poland"},{"iso_3166_1":"FR","name":"France"}],"release_date":"1978-11-27","revenue":0,"runtime":131,"softcore":false,"spoken_languages":[{"english_name":"Polish","iso_639_1":"pl","name":"Polski"}],"status":"Released","tagline":"","title":"Bez znieczulenia","video":false,"vote_average":6.8,"vote_count":16,"credits":{"cast":[{"adult":false,"gender":2,"id":1405,"known_for_department":"Acting","name":"Zbigniew Zapasiewicz","original_name":"Zbigniew Zapasiewicz","popularity":0.2369,"profile_path":"/4AuSdfnmOLTYGpRoLfUvRmBZvWG.jpg","cast_id":2,"character":"Jerzy Michałowski","credit_id":"52fe45f4c3a36847f80e3fc1","order":0},{"adult":false,"gender":1,"id":583448,"known_for_department":"Acting","name":"Ewa Dałkowska","original_name":"Ewa Dałkowska","popularity":0.2259,"profile_path":"/omvnmaSwgD2gTxKXNlTjeABqYp5.jpg","cast_id":3,"character":"Ewa Michałowska","credit_id":"52fe45f4c3a36847f80e3fc5","order":1},{"adult":false,"gender":2,"id":2829,"known_for_department":"Act