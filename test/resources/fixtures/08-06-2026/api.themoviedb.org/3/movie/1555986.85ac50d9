{"adult":false,"backdrop_path":"/d4oQqV6flvSfqoGdOSIwUlonhGO.jpg","belongs_to_collection":null,"budget":0,"genres":[{"id":10751,"name":"Family"}],"homepage":"https://www.scanbox.com/da/movies/mira/","id":1555986,"imdb_id":"tt38453860","origin_country":["DK"],"original_language":"da","original_title":"Mira","overview":"Mira, a twelve-year-old girl, loves to make arts of recycled trash and spends hours together with her best friends Naja and Louis. One day everything changes when Naja becomes best friends with the new cool girl in class. Suddenly Mira feels left out and starts to wonder if she can stay true to herself, when everything and everyone around her seem to be changing. Should she skip her upcoming arts exhibition and instead try to be more like the other girls in class, talking about love and falling in love? Growing up can be a challenge sometimes…","popularity":1.265,"poster_path":"/5HH7LJwffzXi1D2OV2YuE5TZjOB.jpg","production_companies":[{"id":51068,"logo_path":"/9mPkOd6AmUGn9QQe9R52iQ92NG0.png","name":"Toolbox Film","origin_country":"DK"}],"production_countries":[{"iso_3166_1":"DK","name":"Denmark"}],"release_date":"2025-12-11","revenue":0,"runtime":85,"softcore":false,"spoken_languages":[{"english_name":"Danish","iso_639_1":"da","name":"Dansk"}],"status":"Released","tagline":"","title":"Mira","video":false,"vote_average":6.0,"vote_count":2,"alternative_titles":{"titles":[{"iso_3166_1":"DK","title":"Mira","type":""}]}}