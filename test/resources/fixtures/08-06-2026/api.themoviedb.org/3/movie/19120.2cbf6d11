{"adult":false,"backdrop_path":"/9VeXz4mj4QaOfTNSLy0owJHkWEo.jpg","belongs_to_collection":null,"budget":0,"genres":[{"id":35,"name":"Komedia"},{"id":18,"name":"Dramat"},{"id":14,"name":"Fantasy"}],"homepage":"","id":19120,"imdb_id":"tt0059229","origin_country":["IT"],"original_language":"it","original_title":"Giulietta degli spiriti","overview":"Giulietta Boldrini (Giulietta Masina) jest bogatą mieszczanką, która jednak nie potrafi czerpać zadowolenia ze swej pozycji życiowej. Czuje się osamotniona i zaniedbywana przez swojego męża. Podejrzewa go o romans z inną kobietą. Szuka wyjaśnienia swoich podejrzeń wobec niego, uczestnicząc w seansach okultystycznych. Obsesje stają się coraz bardziej natarczywe. Kobieta ma wizje, w których jeszcze raz przeżywa sytuacje ze swojego dzieciństwa i młodości.","popularity":0.9114,"poster_path":"/vzEEzP0rhRfDlNcjpopNGybsM1K.jpg","production_companies":[{"id":1638,"logo_path":null,"name":"Francoriz Production","origin_country":"FR"},{"id":1131,"logo_path":null,"name":"Rizzoli Film","origin_country":"IT"},{"id":9387,"logo_path":null,"name":"Cineriz","origin_country":"IT"}],"production_countries":[{"iso_3166_1":"IT","name":"Italy"},{"iso_3166_1":"FR","name":"France"}],"release_date":"1965-10-22","revenue":78550,"runtime":137,"softcore":false,"spoken_languages":[{"english_name":"English","iso_639_1":"en","name":"English"},{"english_name":"Italian","iso_639_1":"it","name":"Italiano"},{"english_name":"French","iso_639_1":"fr","name":"Français"},{"english_name":"Spanish","iso_639_1":"es","name":"Español"}],"status":"Released","tagline":"","title":"Giulietta od duchów","video":false,"vote_average":7.214,"vote_count":338,"credits":{"cast":[{"adult":false,"gender":1,"id":5402,"known_for_department":"Acting","name":"Giulietta Masina","original_name":"Giulietta Masina","popularity":0.7254,"profile_path":"/z9s9wep4CJgKQ7TxpcjwLZo4g9y.jpg","cast_id":5,"character":"Giulietta Boldrini","credit_id":"52fe47bb9251416c750a3b53","order":0},{"adult":fals