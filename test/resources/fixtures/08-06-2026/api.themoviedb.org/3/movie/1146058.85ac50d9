{"adult":false,"backdrop_path":"/6qQQhhF87Rm1z2TYhXAmoPiEHME.jpg","belongs_to_collection":null,"budget":10000000,"genres":[{"id":16,"name":"Animation"},{"id":10751,"name":"Family"},{"id":12,"name":"Adventure"},{"id":35,"name":"Comedy"}],"homepage":"https://www.vivafilmco.com/ourfilms/thepoutpoutfish","id":1146058,"imdb_id":"tt12824390","origin_country":["AU"],"original_language":"en","original_title":"The Pout-Pout Fish","overview":"Living on a rundown shipwreck, Mr. Fish one day discovers a hyperactive young sea dragon Pip – who had mistaken his home for a junkyard – pilfering his belongings. The heated argument that ensues leaves both their houses in ruin. But there is hope! Embarking on a seemingly impossible quest in search of the mythical 'Shimmer' to grant them a wish, there’s only one problem: someone else is on the hunt...","popularity":3.9081,"poster_path":"/fcDXgGL14qL46It1XOozEjX5Jws.jpg","production_companies":[{"id":203200,"logo_path":"/vNXWRew4jFDFB7qtsnZZQuOxegh.png","name":"MIMO Studios","origin_country":"US"},{"id":97491,"logo_path":"/nyz2y7vjBKPAErlDRXNkdY7KeZW.png","name":"Like A Photon Creative","origin_country":"AU"},{"id":87410,"logo_path":null,"name":"Macmillan Films","origin_country":"US"},{"id":180598,"logo_path":"/fhJxQAxl66WhFW4edgETyqahHGJ.png","name":"Cosmic Dino Studio","origin_country":"AU"},{"id":202520,"logo_path":"/bpSryrByDSz8uPLCP8JqY7PGZWt.png","name":"Alceon Entertainment Partners","origin_country":"AU"},{"id":53020,"logo_path":null,"name":"Eclectik Vision","origin_country":"AU"},{"id":10950,"logo_path":"/6TdE9m9KgV2az7vNI8n95rQiYr3.png","name":"Screen Queensland","origin_country":"AU"},{"id":67631,"logo_path":"/oGDNMrzJkFEvq1AXy8x3P7mlzrI.png","name":"Sola Media","origin_country":"DE"},{"id":247617,"logo_path":"/mW6DoAEQuYPtvlbxEylniCstnA5.png","name":"Maslow Entertainment","origin_country":"AU"}],"production_countries":[{"iso_3166_1":"AU","name":"Australia"},{"iso_3166_1":"US","name":"United States of America"},{"iso_3166_1":"