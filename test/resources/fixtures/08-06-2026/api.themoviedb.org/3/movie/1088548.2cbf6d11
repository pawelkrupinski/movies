{"adult":false,"backdrop_path":"/vkaujALtN1SZGr4M54selGTImVY.jpg","belongs_to_collection":null,"budget":11700000,"genres":[{"id":18,"name":"Dramat"},{"id":35,"name":"Komedia"}],"homepage":"","id":1088548,"imdb_id":"tt28088049","origin_country":["ES"],"original_language":"es","original_title":"Amarga Navidad","overview":"Elsa, reżyserka reklamowa, ucieka przed żałobą po stracie matki, rzucając się w wir pracy, aż atak paniki zmusza ją do jej przerwania. Aby odbudować swoje życie, leci na Lanzarote, by odpocząć z przyjaciółką Patricią, która również potrzebuje chwili wytchnienia od domu. Bonifacio, jej partner, który stał się dla niej prawdziwym wsparciem w tych trudnych chwilach, pozostaje w Madrycie. Historie tej trójki bohaterów przeplatają się z historią scenarzysty i reżysera Raúla Durána, zacierając granice między rzeczywistością a fikcją w nierozerwalny, a czasem bolesny sposób.","popularity":5.9038,"poster_path":"/ji29dXqoeIsQiVnXAkzI4nzxMjr.jpg","production_companies":[{"id":49,"logo_path":"/tlzPjqJjba2WjBaNGN1SZuJmbYj.png","name":"El Deseo","origin_country":"ES"}],"production_countries":[{"iso_3166_1":"ES","name":"Spain"}],"release_date":"2026-03-20","revenue":4755643,"runtime":111,"softcore":false,"spoken_languages":[{"english_name":"Spanish","iso_639_1":"es","name":"Español"}],"status":"Released","tagline":"","title":"Gorzkie święta","video":false,"vote_average":6.479,"vote_count":73,"credits":{"cast":[{"adult":false,"gender":1,"id":724188,"known_for_department":"Acting","name":"Bárbara Lennie","original_name":"Bárbara Lennie","popularity":0.68,"profile_path":"/pEiyonuiZbpkpfdGf5inWQ8Tr1h.jpg","cast_id":6,"character":"Elsa","credit_id":"6848020fed6bc1a69f9f53b3","order":0},{"adult":false,"gender":2,"id":19803,"known_for_department":"Acting","name":"Leonardo Sbaraglia","original_name":"Leonardo Sbaraglia","popularity":0.4681,"profile_path":"/jGYgJqNEWVvp92ZPre1PEKfci5H.jpg","cast_id":7,"character":"Raúl Durán","credit_id":"68480219d994f1918f9f5431","order":