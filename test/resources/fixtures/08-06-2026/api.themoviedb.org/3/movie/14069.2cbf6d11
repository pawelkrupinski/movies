{"adult":false,"backdrop_path":"/wyVO297404vkmA8UmUofbPvO5mX.jpg","belongs_to_collection":null,"budget":0,"genres":[{"id":14,"name":"Fantasy"},{"id":16,"name":"Animacja"},{"id":18,"name":"Dramat"},{"id":878,"name":"Sci-Fi"}],"homepage":"","id":14069,"imdb_id":"tt0808506","origin_country":["JP"],"original_language":"ja","original_title":"時をかける少女","overview":"Makoto jest zwyczajną nastolatką, spędzającą większość czasu z przyjaciółmi. Kiedy pewnego dnia, spiesząc się z wizytą do ciotki, cudem unika potrącenia przez pociąg – przeskakuje w czasie do momentu sprzed wypadku. Korzystając z nowo poznanych zdolności, naprawia swoje codzienne błędy – od słabych ocen na sprawdzianach po nieudane wyznania miłości. Kiedy jednak dosięgają ją konsekwencje manipulowania czasem, Makoto musi zrobić wszystko, żeby uniknąć straszliwej przyszłości, której nie da się cofnąć.","popularity":4.0251,"poster_path":"/7AN1hPKpysFplXBsDqKjYvqIaBM.jpg","production_companies":[{"id":3464,"logo_path":"/9k0nr75nwnNeT2MHerf1OXJN0hj.png","name":"Madhouse","origin_country":"JP"},{"id":822,"logo_path":"/HF2fFP8MH9juSCoN2VtQCFQYPD.png","name":"Happinet Pictures","origin_country":"JP"},{"id":2073,"logo_path":"/tWxRSaKmRJNTcmtlXsmn5R4KOSU.png","name":"KADOKAWA","origin_country":"JP"},{"id":1194,"logo_path":"/dwkHaFLgtA7CUNbgKK0wB6bospu.png","name":"KADOKAWA Shoten","origin_country":"JP"},{"id":12541,"logo_path":null,"name":"Q-TEC","origin_country":"JP"},{"id":12540,"logo_path":null,"name":"Memory-Tech","origin_country":"JP"},{"id":15662,"logo_path":"/onTO8FymA6J6puYznAjZDsXvHYf.png","name":"Studio Chizu","origin_country":"JP"}],"production_countries":[{"iso_3166_1":"JP","name":"Japan"}],"release_date":"2006-07-15","revenue":3478290,"runtime":98,"softcore":false,"spoken_languages":[{"english_name":"Japanese","iso_639_1":"ja","name":"日本語"}],"status":"Released","tagline":"Przyszłość, która nie może czekać","title":"O dziewczynie skaczącej przez czas","video":false,"vote_average":7.8,"vote_count":2253,"credits