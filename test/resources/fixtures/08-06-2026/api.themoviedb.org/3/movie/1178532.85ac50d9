{"adult":false,"backdrop_path":"/qZmBjWUQDw0s7oUIDRT3hWkcWlO.jpg","belongs_to_collection":null,"budget":0,"genres":[{"id":10751,"name":"Family"},{"id":12,"name":"Adventure"}],"homepage":"","id":1178532,"imdb_id":"tt35705226","origin_country":["BE","FR"],"original_language":"en","original_title":"Moon le Panda","overview":"Due to his poor academic performance, twelve-year-old Tian is sent to live with his grandmother in the remote mountains of Sichuan. Far from the hustle and bustle of the city, he finds himself immersed in nature and secretly befriends a panda cub he names Moon. Together, Tian and Moon embark on a journey of discovery and overcoming challenges. The boy is forced to confront his fears and, in the process, learns valuable lessons about courage, respect, and the profound bond between humankind and nature. This experience profoundly transforms Tian's life and fosters an unexpected family reconciliation.","popularity":1.4847,"poster_path":"/2jcQNxdAt6ory848JlVGIuKbuKe.jpg","production_companies":[{"id":73974,"logo_path":null,"name":"Mai Juin Productions","origin_country":"FR"},{"id":9,"logo_path":"/nda3dTUYdDrJ6rZqBpYvY865aDv.png","name":"Gaumont","origin_country":"FR"}],"production_countries":[{"iso_3166_1":"FR","name":"France"}],"release_date":"2025-04-09","revenue":0,"runtime":99,"softcore":false,"spoken_languages":[{"english_name":"English","iso_639_1":"en","name":"English"},{"english_name":"Mandarin","iso_639_1":"zh","name":"普通话"},{"english_name":"German","iso_639_1":"de","name":"Deutsch"}],"status":"Released","tagline":"An intergalactic adventure that proves even the youngest can reach for the stars.","title":"Moon the Panda","video":true,"vote_average":6.86,"vote_count":43,"alternative_titles":{"titles":[]}}