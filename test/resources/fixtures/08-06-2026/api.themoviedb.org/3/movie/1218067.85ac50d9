{"adult":false,"backdrop_path":"/xEM4grRNMP0TMHKbk3jnmbbLw4f.jpg","belongs_to_collection":null,"budget":0,"genres":[{"id":16,"name":"Animation"},{"id":10751,"name":"Family"}],"homepage":"","id":1218067,"imdb_id":"tt28942997","origin_country":["DK"],"original_language":"da","original_title":"Da Mumbo Jumbo blev kæmpestor","overview":"When the happy little hippo, Mumbo Jumbo, accidentally turns giant his life changes for the worse - seemingly forever. Now Mumbo is forced out on a challenging journey in order to encounter an unpredictable witch. Luckily Mumbo's best friends join him. It’s still an insurmountable task, but at least the friends are facing it together. It is not easy being a small hippo, nor a giant one, and when the only way back to normal depends on the cooperation of a frank and mischievous witch, anyone can imagine that it requires a true effort. Hopefully Mumbo Jumbo will develop a strong belief in himself during the adventure. Otherwise, it will definitely be an impossible mission.","popularity":1.3833,"poster_path":"/xViXnOy9pMBlZQbEdL926mCpF0N.jpg","production_companies":[{"id":3922,"logo_path":"/uXDOnG25HLnban0UfpRVjxASMWW.png","name":"A. Film Production","origin_country":"DK"}],"production_countries":[{"iso_3166_1":"DK","name":"Denmark"}],"release_date":"2026-01-29","revenue":0,"runtime":80,"softcore":false,"spoken_languages":[{"english_name":"Danish","iso_639_1":"da","name":"Dansk"}],"status":"Released","tagline":"","title":"When Mumbo Jumbo Grew Giant","video":false,"vote_average":6.5,"vote_count":4,"alternative_titles":{"titles":[{"iso_3166_1":"PT","title":"Mumbo Jumbo","type":""},{"iso_3166_1":"DK","title":"Mumbo Jumbo","type":""},{"iso_3166_1":"DK","title":"Da Mumbo Jumbo blev kaempestor","type":""}]}}