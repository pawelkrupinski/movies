{"adult":false,"backdrop_path":null,"belongs_to_collection":null,"budget":0,"genres":[{"id":99,"name":"Documentary"}],"homepage":"","id":1556638,"imdb_id":"tt38651183","origin_country":["PL"],"original_language":"pl","original_title":"Znaki Pana Śliwki","overview":"Contrary to his family’s expectations and despite having lost one eye, Karol Śliwka leaves his rural home to study art in Warsaw. He decides to be a designer of graphic signs. He fills communist Poland with his works and defines the country’s visual landscape. His signs do not hang in galleries, but are present in Polish homes, in Polish streets, at institutions and workplaces. At the same time, he leads an ordinary family life, which he documents passionately over the years. This extremely gifted artist is still considered one of the greatest sign designers in the world.","popularity":0.5241,"poster_path":"/itOZvCQjANQno1G0aoT9RisF3Et.jpg","production_companies":[{"id":107623,"logo_path":null,"name":"Silver Frame","origin_country":"PL"},{"id":6480,"logo_path":"/qJUUNzFYXNUDaisssBTV3Zdki9R.png","name":"Telewizja Polska","origin_country":"PL"},{"id":283015,"logo_path":null,"name":"Esy-floresy studio animacji","origin_country":"PL"},{"id":125737,"logo_path":"/v4YRjUXtET5EqW2XXYB05K3yUpd.png","name":"Mazowiecki Instytut Kultury","origin_country":"PL"},{"id":283016,"logo_path":null,"name":"Ubi Ieones","origin_country":"PL"}],"production_countries":[{"iso_3166_1":"PL","name":"Poland"}],"release_date":"2026-05-16","revenue":0,"runtime":72,"softcore":false,"spoken_languages":[{"english_name":"Polish","iso_639_1":"pl","name":"Polski"}],"status":"Released","tagline":"","title":"Signs of Mr. Plum","video":false,"vote_average":0.0,"vote_count":0,"alternative_titles":{"titles":[]}}