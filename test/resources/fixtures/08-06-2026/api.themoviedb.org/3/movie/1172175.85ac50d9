{"adult":false,"backdrop_path":"/idEfX44PeWi4uObOFbNPbf2bsp0.jpg","belongs_to_collection":null,"budget":0,"genres":[{"id":10751,"name":"Family"},{"id":35,"name":"Comedy"}],"homepage":"","id":1172175,"imdb_id":"tt21630718","origin_country":["DE"],"original_language":"de","original_title":"Die unlangweiligste Schule der Welt","overview":"Action fan and prank king Max has a tough time. He attends the most boring school in the world, has trouble following all the rules and, on top of everything else, has the nerdy Frieda as a seatmate. His vibrant, bubbly nature is a thorn in the headmaster’s side – he wants to ensure law and order and numerous bans. It is exactly at the right moment that the inspector of the Boredom Control Authority shows up and an exciting and unforgettable class trip begins!","popularity":0.1365,"poster_path":"/hocCOdLsUWN0IngqlCJdy295zbt.jpg","production_companies":[],"production_countries":[{"iso_3166_1":"DE","name":"Germany"}],"release_date":"2023-10-26","revenue":0,"runtime":87,"softcore":false,"spoken_languages":[{"english_name":"German","iso_639_1":"de","name":"Deutsch"}],"status":"Released","tagline":"","title":"Mission: School of Fun","video":false,"vote_average":4.4,"vote_count":8,"alternative_titles":{"titles":[]}}