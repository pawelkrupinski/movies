{"adult":false,"backdrop_path":"/6tYyzZKgZS4dxwxZUgBaawhZdJJ.jpg","belongs_to_collection":null,"budget":0,"genres":[{"id":16,"name":"Animation"},{"id":10751,"name":"Family"},{"id":12,"name":"Adventure"}],"homepage":"","id":1645035,"imdb_id":null,"origin_country":["PL"],"original_language":"pl","original_title":"Pucio","overview":"Pucio and his family are exploring the world! Every day brings new adventures—making jam together, painting a family portrait, and even… a kayaking trip and camping in their own living room! When it’s bath time, Pucio and Bobo are joined by a cheerful toy crocodile who also desperately needs a bath! Pucio learns to share with others, make new friends, and cope with boredom on a rainy day. In every episode, Pucio proves that imagination and creativity can turn the most ordinary moments into something truly special!","popularity":0.1576,"poster_path":"/m8bHBkQEw2fk5RUx7uz7lG8jGW9.jpg","production_companies":[{"id":129928,"logo_path":"/55xk2bQk4JRJwjYW9GNrcE9lrRZ.png","name":"EGoFILM","origin_country":"PL"},{"id":250,"logo_path":"/evWKasiElVQywuKv2dI72P9twz8.png","name":"CANAL+ Polska","origin_country":"PL"},{"id":297202,"logo_path":null,"name":"Paris Hendzel Studio","origin_country":"PL"}],"production_countries":[{"iso_3166_1":"PL","name":"Poland"}],"release_date":"2026-04-17","revenue":0,"runtime":0,"softcore":false,"spoken_languages":[{"english_name":"Polish","iso_639_1":"pl","name":"Polski"}],"status":"Released","tagline":"","title":"Pucio","video":false,"vote_average":0.0,"vote_count":0,"alternative_titles":{"titles":[]}}