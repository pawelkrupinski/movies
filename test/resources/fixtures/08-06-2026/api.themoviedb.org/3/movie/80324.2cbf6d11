{"adult":false,"backdrop_path":"/yVywZerF7Blnq4lZcGTl9OtRvEr.jpg","belongs_to_collection":null,"budget":0,"genres":[{"id":10749,"name":"Romans"},{"id":35,"name":"Komedia"}],"homepage":"","id":80324,"imdb_id":"tt0054119","origin_country":["PL"],"original_language":"pl","original_title":"Niewinni czarodzieje","overview":"Historia przypadkowego spotkania młodego lekarza i dziewczyny, którzy poznają się w piwnicy jazzowej i spędzają ze sobą noc. Akcja rozgrywa się głównie w czterech ścianach mieszkania, a tło społeczne zostaje ledwo zarysowane. Niewiele też dowiadujemy się o samych bohaterach, poza tym, że noszą imiona Pelagia i Bazyli. Młodzi ludzie przybierają wobec siebie maski obojętności, ukrywając pod nimi rodzące się uczucie. Prowadzą grę pozorów i zwodniczych gestów, ulegając przy tym coraz silniejszej wzajemnej fascynacji, której jednak w ramach konwencji gry - starają się oprzeć. A wszystko to zatopione w nostalgiczno - egzystencjalnym klimacie.","popularity":0.3782,"poster_path":"/hQRD3Gh69SR5izkp8V1W3wHZV8B.jpg","production_companies":[{"id":257646,"logo_path":null,"name":"Zespół Filmowy Kadr","origin_country":"PL"}],"production_countries":[{"iso_3166_1":"PL","name":"Poland"}],"release_date":"1960-12-17","revenue":0,"runtime":87,"softcore":false,"spoken_languages":[{"english_name":"Polish","iso_639_1":"pl","name":"Polski"},{"english_name":"Italian","iso_639_1":"it","name":"Italiano"}],"status":"Released","tagline":"","title":"Niewinni czarodzieje","video":false,"vote_average":7.0,"vote_count":43,"credits":{"cast":[{"adult":false,"gender":2,"id":1413,"known_for_department":"Acting","name":"Tadeusz Łomnicki","original_name":"Tadeusz Łomnicki","popularity":0.3699,"profile_path":"/zvNZuMOi06S1LaScRDmIGPHQ2Yn.jpg","cast_id":1017,"character":"'Bazyli'","credit_id":"55a5293e92514147eb001767","order":0},{"adult":false,"gender":1,"id":589242,"known_for_department":"Acting","name":"Krystyna Stypułkowska","original_name":"Krystyna Stypułkowska","popularity":0.0978,"pro