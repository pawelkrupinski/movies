{"adult":false,"backdrop_path":"/mCpwRayjXMFzKHbjbzc5JRKfq1O.jpg","belongs_to_collection":null,"budget":10000000,"genres":[{"id":27,"name":"Horror"},{"id":9648,"name":"Tajemnica"},{"id":878,"name":"Sci-Fi"}],"homepage":"","id":1083381,"imdb_id":"tt26657236","origin_country":["US"],"original_language":"en","original_title":"Backrooms","overview":"Clark natrafia w podziemiach swojego sklepu na przejście do niepokojącej, na pierwszy rzut oka pustej plątaniny niekończących się korytarzy. Kiedy opowiada o tym swojej terapeutce, kobieta uznaje, że mogą to być omamy zapowiadające pogorszenie jego stanu psychicznego. Sytuacja zmienia się, gdy Clark przestaje przychodzić na wizyty — zaniepokojona terapeutka postanawia odkryć, co się z nim stało. W trakcie poszukiwań trafia do rzeczywistości, gdzie czas traci sens, przestrzeń ulega dziwnym przemianom, a poza granicą widzialności kryje się coś nienaturalnego.","popularity":233.0619,"poster_path":"/9ACgXR7wZhlPY2DrU5eUXafADkD.jpg","production_companies":[{"id":76907,"logo_path":"/ygMQtjsKX7BZkCQhQZY82lgnCUO.png","name":"Atomic Monster","origin_country":"US"},{"id":2575,"logo_path":"/9YJrHYlcfHtwtulkFMAies3aFEl.png","name":"21 Laps Entertainment","origin_country":"US"},{"id":41077,"logo_path":"/1ZXsGaFPgrgS6ZZGS37AqD5uU12.png","name":"A24","origin_country":"US"},{"id":262307,"logo_path":"/Yt9QqQjZzvdZCRLN5vGoi3dc8n.png","name":"Phobos","origin_country":"CA"},{"id":251729,"logo_path":"/lKT1JrDNMwC9M3HvQQCofbiYtRr.png","name":"The North Road Company","origin_country":"US"}],"production_countries":[{"iso_3166_1":"US","name":"United States of America"},{"iso_3166_1":"CA","name":"Canada"}],"release_date":"2026-05-27","revenue":212657858,"runtime":111,"softcore":false,"spoken_languages":[{"english_name":"English","iso_639_1":"en","name":"English"}],"status":"Released","tagline":"","title":"Backrooms. Bez wyjścia","video":false,"vote_average":6.8,"vote_count":384,"credits":{"cast":[{"adult":false,"gender":2,"id":5294,"known_for_departm