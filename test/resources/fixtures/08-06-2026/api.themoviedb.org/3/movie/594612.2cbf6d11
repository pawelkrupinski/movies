{"adult":false,"backdrop_path":null,"belongs_to_collection":null,"budget":0,"genres":[{"id":16,"name":"Animacja"}],"homepage":"","id":594612,"imdb_id":"tt3044360","origin_country":["PL"],"original_language":"pl","original_title":"Liebling","overview":"Czym jest utrata pamięci? W labiryncie strachu bliski staje się nieznajomym, a dom pułapką. Poruszając się po omacku, śladem znajomych przedmiotów i kształtów bohaterka stara się wrócić do życia, które kiedyś było jej własnym. Najnowsza plastelinowa animacja Izabeli Plucińskiej jest przejmującym obrazem zagubienia i wyobcowania oraz próby poskładania całości z nieprzystających do siebie fragmentów.","popularity":0.0621,"poster_path":null,"production_companies":[{"id":102250,"logo_path":null,"name":"ClayTraces","origin_country":"DE"}],"production_countries":[{"iso_3166_1":"DE","name":"Germany"},{"iso_3166_1":"PL","name":"Poland"}],"release_date":"2013-04-11","revenue":0,"runtime":7,"softcore":false,"spoken_languages":[{"english_name":"Polish","iso_639_1":"pl","name":"Polski"}],"status":"Released","tagline":"","title":"Kochanie","video":false,"vote_average":6.0,"vote_count":1,"credits":{"cast":[{"adult":false,"gender":0,"id":2809785,"known_for_department":"Writing","name":"Justyna Celeda","original_name":"Justyna Celeda","popularity":0.0453,"profile_path":null,"cast_id":2,"character":"(głos)","credit_id":"661d27974ca67601641c2f99","order":0},{"adult":false,"gender":1,"id":1047047,"known_for_department":"Directing","name":"Izabela Plucińska","original_name":"Izabela Plucińska","popularity":0.1378,"profile_path":null,"cast_id":3,"character":"(głos)","credit_id":"661d27a16d1bb2017c38ec62","order":1},{"adult":false,"gender":0,"id":4654099,"known_for_department":"Acting","name":"Agata Rojek","original_name":"Agata Rojek","popularity":0.0143,"profile_path":null,"cast_id":4,"character":"(głos)","credit_id":"661d27b2fd4a9601866c3cc5","order":2},{"adult":false,"gender":1,"id":589344,"known_for_department":"Directing","name":"Anna