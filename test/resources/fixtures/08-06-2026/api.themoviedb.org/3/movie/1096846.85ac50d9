{"adult":false,"backdrop_path":"/7VaR9bGnX9PSgtiAPl6D5TchWeW.jpg","belongs_to_collection":null,"budget":0,"genres":[{"id":18,"name":"Drama"}],"homepage":"","id":1096846,"imdb_id":"tt27679443","origin_country":["IL","IT"],"original_language":"en","original_title":"Reading Lolita in Tehran","overview":"As Islamic morality squads stage arbitrary raids in Tehran and as fundamentalists seize hold of the universities, Azar Nafisi, an inspired teacher, secretly gathers six of her most committed female students to read forbidden western classics. Unaccustomed to being asked to speak their minds, they soon removed their veils, their stories intertwining with the novels they read: just like the heroines of Nabokov, F. Scott Fitzgerald, Henry James or Jane Austen, the women in Nafisi’s living room dare to dream, hope and love as we experience the complexity of the lives of individuals facing political, moral and personal siege.","popularity":1.4334,"poster_path":"/r4f3uSsiTpFFMH0PUiT0gNShqUh.jpg","production_companies":[{"id":2167,"logo_path":null,"name":"Eran Riklis Productions","origin_country":"IL"},{"id":36067,"logo_path":"/r8PzYwMEhQzo8kRh8bAOHIXVJs7.png","name":"Topia Communications","origin_country":"IL"},{"id":119307,"logo_path":"/k1nWCHBaM2CFxoPLdUM3v2rkF4a.png","name":"Rosamont","origin_country":"IT"},{"id":12377,"logo_path":"/yL9lfoO2IX6sssqEJuifsOPgcxP.png","name":"Minerva Pictures","origin_country":"IT"},{"id":14016,"logo_path":"/snclwsIZQbgvqYCBJP8fqNlCA5y.png","name":"MiC","origin_country":"IT"},{"id":16,"logo_path":"/7690NQfOfnbvrY3vFgyMO2Pc8WS.png","name":"United King Films","origin_country":"IL"},{"id":155990,"logo_path":"/py9VaywwK6KVi94YwrxSKVg1gkh.png","name":"RAI Cinema","origin_country":"IT"},{"id":20782,"logo_path":"/tTfJjcJHmVPBbPv3q1ATtaX5mFf.png","name":"WestEnd Films","origin_country":"GB"}],"production_countries":[{"iso_3166_1":"IL","name":"Israel"},{"iso_3166_1":"IT","name":"Italy"}],"release_date":"2024-11-21","revenue":0,"runtime":108,"softcore"