{"adult":false,"backdrop_path":"/1S81PpyGwS8eVx4W75uSKzMw4B0.jpg","belongs_to_collection":null,"budget":10000000,"genres":[{"id":18,"name":"Drama"}],"homepage":"","id":404,"imdb_id":"tt0166896","origin_country":["US"],"original_language":"en","original_title":"The Straight Story","overview":"Retired farmer and widower Alvin Straight learns one day that his distant brother Lyle has suffered a stroke and may not recover. Alvin is determined to make things right with Lyle while he still can, but his brother lives in Wisconsin, while Alvin is stuck in Iowa with no car and no driver's license. He then has the idea of making the trip on his old lawnmower, thus beginning a picturesque and at times deeply spiritual odyssey.","popularity":2.6249,"poster_path":"/tT9cMiVDdtlcdZxOoFy3VRmEoKk.jpg","production_companies":[{"id":635,"logo_path":"/ikp5Hokscs88jMWSkM9dB98U3Ak.png","name":"Les Films Alain Sarde","origin_country":"FR"},{"id":637,"logo_path":"/zetmQfFrJTN3AlGI7utt5bWcRex.png","name":"Picture Factory","origin_country":"US"},{"id":183,"logo_path":"/eadyph99FClrWlnE0jPniwOcvvw.png","name":"Le Studio Canal+","origin_country":"FR"},{"id":6705,"logo_path":"/iNB1FCwT4XjO6wkN3PnpPnwr9GX.png","name":"Film4 Productions","origin_country":"GB"}],"production_countries":[{"iso_3166_1":"US","name":"United States of America"},{"iso_3166_1":"GB","name":"United Kingdom"},{"iso_3166_1":"FR","name":"France"}],"release_date":"1999-10-15","revenue":6418028,"runtime":112,"softcore":false,"spoken_languages":[{"english_name":"English","iso_639_1":"en","name":"English"}],"status":"Released","tagline":"A true story that proves a little determination goes a very, very long way.","title":"The Straight Story","video":false,"vote_average":7.741,"vote_count":1797,"alternative_titles":{"titles":[{"iso_3166_1":"IT","title":"Una Storia Vera","type":""},{"iso_3166_1":"BR","title":"Um História Real","type":""},{"iso_3166_1":"FR","title":"Une histoire vraie","type":""},{"iso_3166_1":"ES","title":"The Strai