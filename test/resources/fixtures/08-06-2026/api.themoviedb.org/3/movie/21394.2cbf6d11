{"adult":false,"backdrop_path":"/hZ7oCK4pWbsnHwX6OXhw0VgjSSl.jpg","belongs_to_collection":{"id":610785,"name":"Dzieci z Bullerbyn - Kolekcja","poster_path":"/zK6LeMrK8cNaOaiGyV6Yqw3fYD.jpg","backdrop_path":null},"budget":0,"genres":[{"id":10751,"name":"Familijny"}],"homepage":"","id":21394,"imdb_id":"tt0090610","origin_country":["SE"],"original_language":"sv","original_title":"Alla vi barn i Bullerbyn","overview":"\"Dzieci z Bullerbyn\" to chyba najbardziej znana w Polsce książka Astrid Lindgren.Film \"Dzieci z Bullerbyn\" w przezabawny, a zarazem ciepły sposób, opowiada o sympatycznych przygodach sześciorga dzieci, które mieszkają w maleńkiej wiosce - wiosce, w której są tylko trzy zagrody. O życiu w nich opowiada jedna z dziewczynek - Lisa. Widz ma także okazję zapoznać się z wieloma interesującymi zwyczajami szwedzkimi, tradycjami obchodzenia świąt czy po prostu z codziennym życiem na wsi. Film na podstawie tej książki, wyreżyserowany został przez Lasse Hallstroma","popularity":1.0118,"poster_path":"/np7soGqMReq2fdaed4VrKL9vdFD.jpg","production_companies":[{"id":6181,"logo_path":"/gYyww91VI1jdH89xpZgFFc8zN3F.png","name":"SF Studios","origin_country":"SE"}],"production_countries":[{"iso_3166_1":"SE","name":"Sweden"}],"release_date":"1986-12-06","revenue":0,"runtime":90,"softcore":false,"spoken_languages":[{"english_name":"Swedish","iso_639_1":"sv","name":"svenska"}],"status":"Released","tagline":"","title":"Dzieci z Bullerbyn","video":false,"vote_average":6.3,"vote_count":48,"credits":{"cast":[{"adult":false,"gender":1,"id":87490,"known_for_department":"Acting","name":"Anna Sahlin","original_name":"Anna Sahlin","popularity":0.2939,"profile_path":"/lQOWEIg8uwdRiwi2wbymroE9fGZ.jpg","cast_id":4,"character":"Anna","credit_id":"52fe4418c3a368484e00f0bf","order":0},{"adult":false,"gender":2,"id":87491,"known_for_department":"Acting","name":"Henrik Larsson","original_name":"Henrik Larsson","popularity":0.1493,"profile_path":"/sFGZyidU9iT7gpvurpbTTdzBKUs.jpg","cast_id":40