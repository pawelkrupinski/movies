{"adult":false,"backdrop_path":"/lILGmH0HWOXziENZIFcOdZTJIuh.jpg","belongs_to_collection":null,"budget":0,"genres":[{"id":18,"name":"Drama"}],"homepage":"","id":198782,"imdb_id":"tt0062529","origin_country":["PL"],"original_language":"pl","original_title":"Żywot Mateusza","overview":"A man who is socially inept and out of touch with the world lives with his sister in a small farmhouse. The overly sensitive man lives off his hard-working sibling, taking odd jobs as he gets them to secure his meager earnings. When he brings home a woodcutter from the forest, the sister and the newcomer fall in love. Terrified over a life without his sister, the man can't cope.","popularity":0.3039,"poster_path":"/bLCcu3AfD7BZdHZKFeU4dg1LDGV.jpg","production_companies":[{"id":21778,"logo_path":"/pKaywrtWfuwLKmocmexmgYLsHhf.png","name":"Lodz Film School","origin_country":"PL"},{"id":56351,"logo_path":"/oa6JRQYgJIxve2RM9HZ9aYZ8O7Q.png","name":"Zespół Filmowy \"Start\"","origin_country":"PL"}],"production_countries":[{"iso_3166_1":"PL","name":"Poland"}],"release_date":"1968-02-16","revenue":0,"runtime":76,"softcore":false,"spoken_languages":[{"english_name":"Polish","iso_639_1":"pl","name":"Polski"}],"status":"Released","tagline":"","title":"Matthew's Days","video":false,"vote_average":6.125,"vote_count":11,"alternative_titles":{"titles":[{"iso_3166_1":"ES","title":"Los días de Mateo","type":""},{"iso_3166_1":"XG","title":"Das Leben des Matthäus","type":""},{"iso_3166_1":"FR","title":"Les jours de Mathieu","type":""},{"iso_3166_1":"NO","title":"Fuglane","type":""}]}}