{"adult":false,"backdrop_path":"/1F9eXHH8AZRVKSBIMpYWxWyjCNW.jpg","belongs_to_collection":null,"budget":0,"genres":[{"id":99,"name":"Dokumentalny"}],"homepage":"https://sofilms.pl/filmy_dystrybucja/dziecko-z-pylu/","id":1421597,"imdb_id":"tt19815868","origin_country":["PL"],"original_language":"pl","original_title":"Dziecko z pyłu","overview":"Sang to jedno z setek tysięcy dzieci pozostawionych przez amerykańskich żołnierzy po wojnie w Wietnamie. Stygmatyzowany i opuszczony, przez całe życie tęskni za ojcem, którego nigdy nie miał. Niespodziewanie odnajduje go – jest ciężko chory i mieszka w Stanach Zjednoczonych. Spotkanie z ojcem to życiowe marzenie Sanga, lecz cena jest wielka. Jedyny sposób, aby go zobaczyć, to na stałe przenieść się do USA, zostawiając dorosłą córkę, wnuka i ukochaną żonę.","popularity":0.0379,"poster_path":"/mG7PSpF6sKxhxROmEGpPGTGGst.jpg","production_companies":[{"id":82294,"logo_path":"/z2WExPhsX9E8NGruZrEWosQoC86.png","name":"FIXAFILM","origin_country":"PL"},{"id":6480,"logo_path":"/qJUUNzFYXNUDaisssBTV3Zdki9R.png","name":"Telewizja Polska","origin_country":"PL"},{"id":97568,"logo_path":"/t1KnXZeHO3bVYGjs2nUJGQc5n8i.png","name":"Ginestra Film","origin_country":"SE"},{"id":159283,"logo_path":null,"name":"Lonely Production","origin_country":"CZ"},{"id":122740,"logo_path":"/c0XQNpfyvFfyK9WxdADpl3wPYk5.png","name":"MX35","origin_country":"PL"},{"id":265728,"logo_path":null,"name":"Ya Man Studio","origin_country":"PL"},{"id":275687,"logo_path":null,"name":"Clubhouse Films","origin_country":""},{"id":62165,"logo_path":"/9i15HMPXjW657H4BnrMkeQcbktL.png","name":"Al Jazeera","origin_country":"QA"}],"production_countries":[{"iso_3166_1":"PL","name":"Poland"},{"iso_3166_1":"VN","name":"Vietnam"},{"iso_3166_1":"SE","name":"Sweden"},{"iso_3166_1":"CZ","name":"Czech Republic"},{"iso_3166_1":"QA","name":"Qatar"}],"release_date":"2026-04-17","revenue":0,"runtime":93,"softcore":false,"spoken_languages":[{"english_name":"English","iso_639_1":"en","name":"Eng