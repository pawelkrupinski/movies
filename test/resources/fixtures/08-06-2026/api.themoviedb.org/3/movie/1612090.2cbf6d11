{"adult":false,"backdrop_path":null,"belongs_to_collection":{"id":1360252,"name":"Kicia Kocia - Kolekcja","poster_path":null,"backdrop_path":null},"budget":0,"genres":[{"id":16,"name":"Animacja"},{"id":10751,"name":"Familijny"},{"id":14,"name":"Fantasy"}],"homepage":"https://dystrybucja.mlodehoryzonty.pl/film/kicia-kocia-w-podrozy/","id":1612090,"imdb_id":null,"origin_country":["PL"],"original_language":"pl","original_title":"Kicia Kocia w podróży","overview":"Rezolutną Kicię Kocię czeka dużo nowych przeżyć! Ukochana bohaterka książek dla dzieci zabierze widzów na afrykańską sawannę, lotnisko i budowę placu zabaw! Nie będzie jednak sama! Będą jej towarzyszyć wierni przyjaciele – Pacek, Adelka i Julianek! Wybiorą się razem na ciekawą wycieczkę do lasu, gdzie będą poznawać jego mieszkańców. Nauczą się także segregacji śmieci oraz w świetnych humorach pójdą na swój pierwszy spektakl do teatru! Czeka ich sporo dobrej zabawy! Przyłączycie się?","popularity":0.0495,"poster_path":"/cA22Hl3YzuLqKM3t8SkdFdmESC6.jpg","production_companies":[{"id":129928,"logo_path":"/55xk2bQk4JRJwjYW9GNrcE9lrRZ.png","name":"EGoFILM","origin_country":"PL"},{"id":297202,"logo_path":null,"name":"Paris Hendzel Studio","origin_country":"PL"}],"production_countries":[{"iso_3166_1":"PL","name":"Poland"}],"release_date":"2026-02-20","revenue":0,"runtime":45,"softcore":false,"spoken_languages":[{"english_name":"Polish","iso_639_1":"pl","name":"Polski"}],"status":"Released","tagline":"","title":"Kicia Kocia w podróży","video":false,"vote_average":0.0,"vote_count":0,"credits":{"cast":[{"adult":false,"gender":1,"id":442488,"known_for_department":"Acting","name":"Dominika Kluźniak","original_name":"Dominika Kluźniak","popularity":0.2491,"profile_path":"/5gJBuNJGOSuGY3nM0hBquWbTniP.jpg","cast_id":10,"character":"Kicia Kocia (voice)","credit_id":"695f91c0b1aa2a8bb3276b58","order":0},{"adult":false,"gender":1,"id":1209861,"known_for_department":"Acting","name":"Lidia Sadowa","original_name":"Lidia Sadowa","p