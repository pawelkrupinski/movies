{"adult":false,"backdrop_path":null,"belongs_to_collection":null,"budget":0,"genres":[{"id":99,"name":"Dokumentalny"}],"homepage":"","id":1609655,"imdb_id":null,"origin_country":["PL"],"original_language":"pl","original_title":"444","overview":"Czy można biec bez przerwy setki kilometrów, nieprzerwanie stawiać czoła zmęczeniu, warunkom atmosferycznym i presji psychicznej?  Łukasz Wróbel, ultramaratończyk, zmagając się z osobistymi słabościami i przeciwnościami losu, pokazuje, że siła tkwi nie tylko w ciele, ale przede wszystkim w umyśle. Jego niezwykła determinacja i wewnętrzna motywacja stają się inspiracją dla tych, którzy pragną przełamać własne ograniczenia.","popularity":0.0416,"poster_path":null,"production_companies":[{"id":285232,"logo_path":null,"name":"Jagielka Pictures","origin_country":""}],"production_countries":[{"iso_3166_1":"PL","name":"Poland"}],"release_date":"2026-01-30","revenue":0,"runtime":90,"softcore":false,"spoken_languages":[{"english_name":"Polish","iso_639_1":"pl","name":"Polski"}],"status":"Released","tagline":"","title":"444","video":false,"vote_average":0.0,"vote_count":0,"credits":{"cast":[],"crew":[{"adult":false,"gender":0,"id":5916756,"known_for_department":"Directing","name":"Krzysztof Jagiełka","original_name":"Krzysztof Jagiełka","popularity":0.0,"profile_path":null,"credit_id":"695a486ca00713496acc9530","department":"Directing","job":"Director"}]}}