{"adult":false,"backdrop_path":"/jQH5gsn4ElMKVhaDyilfI4QtV4P.jpg","belongs_to_collection":{"id":264664,"name":"Józef Szwejk - Kolekcja","poster_path":"/bzTz9qev4kISbO2JUAEdn7SnZfu.jpg","backdrop_path":"/sD4Fx0m1V4ET0tzG91JTDFInM6v.jpg"},"budget":0,"genres":[{"id":35,"name":"Komedia"},{"id":10752,"name":"Wojenny"}],"homepage":"","id":123513,"imdb_id":"tt0049147","origin_country":["XC"],"original_language":"cs","original_title":"Dobrý voják Švejk","overview":"Szwejk, zwolniony wcześniej z wojska z powodu notorycznego idiotyzmu, wiedzie spokojny żywot w praskiej dzielnicy Vinohrady, utrzymując się z handlu nierasowymi psami. Lecz w dniu zamachu na arcyksięcia Ferdynanda, do drzwi naszego bohatera stuka Historia... Okazuje się wówczas, że przypomniała sobie o nim administracja cesarstwa austro-węgierskiego, wcielając go na nowo do służby wojskowej. Szwejk, z niezwykłą (z pozoru) gorliwością stosuje się do oficjalnych patriotycznych haseł, kompromitując przy tym ich bezdenną głupotę i powodując nieustanne katastrofy.","popularity":0.5379,"poster_path":"/9m4yoxdmcZcMKULFWS4gKZHszmF.jpg","production_companies":[{"id":1931,"logo_path":"/5erHhgvym2cTORao8ajtn2gbiTH.png","name":"Filmové studio Barrandov","origin_country":"XC"}],"production_countries":[{"iso_3166_1":"XC","name":"Czechoslovakia"}],"release_date":"1957-08-23","revenue":0,"runtime":108,"softcore":false,"spoken_languages":[{"english_name":"Czech","iso_639_1":"cs","name":"Český"}],"status":"Released","tagline":"","title":"Dobry wojak Szwejk","video":false,"vote_average":7.5,"vote_count":43,"credits":{"cast":[{"adult":false,"gender":2,"id":73557,"known_for_department":"Acting","name":"Rudolf Hrušínský","original_name":"Rudolf Hrušínský","popularity":0.284,"profile_path":"/xbOll9C0VYLTRmQz7jqdkRFEDyU.jpg","cast_id":1,"character":"Josef Švejk","credit_id":"52fe4a97c3a368484e15c3f1","order":0},{"adult":false,"gender":1,"id":1182481,"known_for_department":"Acting","name":"Eva Svobodová","original_name":"Eva Svobodová","