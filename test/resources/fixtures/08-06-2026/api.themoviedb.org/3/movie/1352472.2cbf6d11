{"adult":false,"backdrop_path":"/r8glJHQQmnJSalM21q5TwNbkhyJ.jpg","belongs_to_collection":null,"budget":0,"genres":[{"id":99,"name":"Dokumentalny"}],"homepage":"https://telemark.com.pl/silver/","id":1352472,"imdb_id":"tt38552697","origin_country":["PL"],"original_language":"pl","original_title":"Silver","overview":"Reżyserka zabiera widzów do podziemnego piekła boliwijskiej kopalni. Film jest wstrząsającym portretem biedy i wyzysku, dotykającego wszystkich mieszkańców Potosí. Od najmłodszych lat szkoli się dzieci z wiedzy o hołubionej górze, a po lekcjach oswaja z rychłym wejściem do jej wnętrza. Katorżnicza praca, niemalże bez zabezpieczeń w poszukiwaniu pożądanego srebra, nieraz kończy się trwałym kalectwem, a nawet śmiercią. To zabójcze oblicze góry nie przeszkadza zamożnym turystom w jej eksploracji i dodawaniu stamtąd relacji czy postów na media społecznościowe, których nie dałoby się tworzyć bez wydobywanego tam surowca.","popularity":0.6366,"poster_path":"/e01azX00v76Ydr5jPrRBYetL32x.jpg","production_companies":[{"id":109147,"logo_path":"/fmdKelaoaLILbNpXAq2T4JDWG1S.png","name":"Telemark","origin_country":"PL"},{"id":29063,"logo_path":"/52xiL9iqq2iPbn6yuFuzkJc4Cpy.png","name":"Piraya Film","origin_country":"NO"},{"id":120219,"logo_path":null,"name":"IV Films","origin_country":"FI"}],"production_countries":[{"iso_3166_1":"PL","name":"Poland"},{"iso_3166_1":"NO","name":"Norway"},{"iso_3166_1":"FI","name":"Finland"}],"release_date":"2025-11-14","revenue":0,"runtime":79,"softcore":false,"spoken_languages":[{"english_name":"Spanish","iso_639_1":"es","name":"Español"}],"status":"Released","tagline":"","title":"Silver","video":false,"vote_average":0.0,"vote_count":0,"credits":{"cast":[],"crew":[{"adult":false,"gender":1,"id":2267633,"known_for_department":"Directing","name":"Natalia Koniarz","original_name":"Natalia Koniarz","popularity":0.1004,"profile_path":null,"credit_id":"66dab8cc73cc999985275efe","department":"Directing","job":"Director"},{"adult":false,"gende