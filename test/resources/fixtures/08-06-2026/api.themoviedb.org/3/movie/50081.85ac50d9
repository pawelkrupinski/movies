{"adult":false,"backdrop_path":"/lGfrl0eF189HifRGYPumrGUAqkt.jpg","belongs_to_collection":null,"budget":0,"genres":[{"id":99,"name":"Documentary"},{"id":12,"name":"Adventure"}],"homepage":"http://www.imax.com/borntobewild/","id":50081,"imdb_id":"tt1680059","origin_country":["US"],"original_language":"en","original_title":"Born to Be Wild","overview":"Born to Be Wild observes various orphaned jungle animals and their day-to-day behavioural interactions with the individuals who rescue them and raise them to adulthood. The film unfurls in two separate geographic spheres. Half of it takes place in the rain forests of Borneo, where celebrated primatologist Dr. Birute Galdikas assists baby orangutans; the other half takes place on the arid savannahs of Kenya, where zoologist Dame Daphne Sheldrick works with baby elephant calves.","popularity":0.3895,"poster_path":"/78qdFtASdnBSOiqSvazDgxGcQHk.jpg","production_companies":[{"id":3447,"logo_path":"/yBdvUlunhXyUowuy0XaEPuBtYTo.png","name":"IMAX","origin_country":"CA"}],"production_countries":[{"iso_3166_1":"US","name":"United States of America"}],"release_date":"2011-04-08","revenue":7732325,"runtime":40,"softcore":false,"spoken_languages":[{"english_name":"English","iso_639_1":"en","name":"English"}],"status":"Released","tagline":"Born to be loved. Born to be free.","title":"Born to Be Wild","video":false,"vote_average":7.1,"vote_count":71,"alternative_titles":{"titles":[{"iso_3166_1":"HU","title":"A vadon kölykei 3D","type":""},{"iso_3166_1":"MX","title":"Nacidos Para Ser Libres","type":""},{"iso_3166_1":"US","title":"IMAX - Born to Be Wild - 3D","type":"3D version"},{"iso_3166_1":"IT","title":"Born to Be Wild 3D","type":""},{"iso_3166_1":"FR","title":"IMAX - Born to Be Wild 3D","type":"3D version"},{"iso_3166_1":"JP","title":"BORN TO BE WILD 野生に生きる","type":""},{"iso_3166_1":"US","title":"IMAX: Born to Be Wild","type":""},{"iso_3166_1":"CA","title":"Nés pour être libres 3D","type":""},{"iso_3166_1":"CN","title":"IMAX - 回归野性