{"adult":false,"backdrop_path":"/oq8HM9TOSbH54Xy0OBJGzYrtUC7.jpg","belongs_to_collection":null,"budget":1500000,"genres":[{"id":35,"name":"Comedy"}],"homepage":"","id":11830,"imdb_id":"tt0092048","origin_country":["JP"],"original_language":"ja","original_title":"タンポポ","overview":"In this humorous paean to the joys of food, a pair of truck drivers happen onto a decrepit roadside shop selling ramen noodles. The widowed owner, Tampopo, begs them to help her turn her establishment into a paragon of the \"art of noodle-soup making\". Interspersed are satirical vignettes about the importance of food to different aspects of human life.","popularity":3.2331,"poster_path":"/ArYdSuX3zY9fMsE4LqmBl7xJq5R.jpg","production_companies":[{"id":13255,"logo_path":null,"name":"New Century Producers","origin_country":"JP"},{"id":64128,"logo_path":"/srpI97njD5i4alMFBeCHbzifxdZ.png","name":"Itami Productions","origin_country":"JP"}],"production_countries":[{"iso_3166_1":"JP","name":"Japan"}],"release_date":"1985-11-23","revenue":0,"runtime":115,"softcore":false,"spoken_languages":[{"english_name":"Japanese","iso_639_1":"ja","name":"日本語"}],"status":"Released","tagline":"The first Japanese Noodle Western.","title":"Tampopo","video":false,"vote_average":7.8,"vote_count":432,"alternative_titles":{"titles":[{"iso_3166_1":"US","title":"Dandelion","type":"literal translation"},{"iso_3166_1":"BR","title":"Tampopo - Os Brutos Também Comem Spaghetti","type":""},{"iso_3166_1":"DE","title":"Tampopo - Magische Nudeln","type":""},{"iso_3166_1":"KR","title":"탄포포","type":""},{"iso_3166_1":"NL","title":"Paardenbloem","type":""},{"iso_3166_1":"RU","title":"Одуванчик","type":""},{"iso_3166_1":"US","title":"Tampopo: A Ramen Western","type":"reissued title"},{"iso_3166_1":"FR","title":"Pissenlit","type":""},{"iso_3166_1":"KR","title":"담뽀뽀","type":""},{"iso_3166_1":"KR","title":"담포포","type":""},{"iso_3166_1":"JP","title":"Tanpopo","type":""}]}}