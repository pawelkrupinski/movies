{"adult":false,"backdrop_path":"/hlS23ABq7d8BwAeB9LKfZ2Xum8L.jpg","belongs_to_collection":null,"budget":0,"genres":[{"id":18,"name":"Dramat"},{"id":53,"name":"Thriller"}],"homepage":"","id":11502,"imdb_id":"tt0056291","origin_country":["PL"],"original_language":"pl","original_title":"Nóż w wodzie","overview":"Dziennikarz Andrzej (Leon Niemczyk) i jego atrakcyjna żona Krystyna (Jolanta Umecka) wyjeżdżają na jednodniowy rejs jachtem. Po drodze nad jezioro zabierają młodego autostopowicza (Zygmunt Malanowicz), a następnie zapraszają go na jacht. Na wodzie dochodzi do rywalizacji między mężczyznami w zakresie siły, intelektu i poglądów życiowych. Andrzej preferujący dostatnie, łatwe mieszczańskie życie konfrontuje się z młodym idealistą i buntownikiem.","popularity":1.1244,"poster_path":"/rEROSauyj7eMfg1YUVI7LLp2EuZ.jpg","production_companies":[{"id":42243,"logo_path":null,"name":"Zespół Filmowy \"Kamera\"","origin_country":"PL"}],"production_countries":[{"iso_3166_1":"PL","name":"Poland"}],"release_date":"1962-03-09","revenue":0,"runtime":94,"softcore":false,"spoken_languages":[{"english_name":"Polish","iso_639_1":"pl","name":"Polski"}],"status":"Released","tagline":"","title":"Nóż w wodzie","video":false,"vote_average":7.278,"vote_count":475,"credits":{"cast":[{"adult":false,"gender":2,"id":28834,"known_for_department":"Acting","name":"Leon Niemczyk","original_name":"Leon Niemczyk","popularity":0.8774,"profile_path":"/e1Zb5lIptXAPowqqOVUpvLzRonm.jpg","cast_id":1,"character":"Andrzej","credit_id":"52fe444c9251416c7502fd1f","order":0},{"adult":false,"gender":1,"id":69632,"known_for_department":"Acting","name":"Jolanta Umecka","original_name":"Jolanta Umecka","popularity":0.1227,"profile_path":"/nqQOIgYlxcZH0Pz9p1DJ6zzpVYF.jpg","cast_id":2,"character":"Krystyna","credit_id":"52fe444c9251416c7502fd23","order":1},{"adult":false,"gender":2,"id":22931,"known_for_department":"Acting","name":"Zygmunt Malanowicz","original_name":"Zygmunt Malanowicz","popularity":0.124,"profile_