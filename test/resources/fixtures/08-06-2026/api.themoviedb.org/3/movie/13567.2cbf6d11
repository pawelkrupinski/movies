{"adult":false,"backdrop_path":"/nQbvPYjj3U3pz8alPpHIdvVIoHx.jpg","belongs_to_collection":{"id":47391,"name":"Sleepaway Camp Collection","poster_path":"/fJpfeO2d3MjXsKWQqnorvRkHTWm.jpg","backdrop_path":"/51coSlxdbEgBtsoRVOOhvs21XlK.jpg"},"budget":350000,"genres":[{"id":27,"name":"Horror"}],"homepage":"","id":13567,"imdb_id":"tt0086320","origin_country":["US"],"original_language":"en","original_title":"Sleepaway Camp","overview":"Akcja filmu rozgrywa się w obozie Arawak. Pewnego pięknego dnia ojciec wraz z dziećmi postanowił wybrać się na rejs żaglówką po jeziorze. Ich sielankową atmosferę zakłóca młodzież szalejąca na motorówkach. Przez nieuwagę jednego z nich motorówka trafia w łódź. Woda wokół łodzi zrobiła się czerwona, co oznaczało tylko jedno - mężczyzna nie przeżył tego wypadku. Po wielu latach do obozu ponownie przyjeżdżają dzieciaki. Zaczyna dochodzić do dziwnych wydarzeń, w których giną ludzie.","popularity":2.581,"poster_path":"/lZ7KjSyHjP4ula5ybiXuQcDvZLg.jpg","production_companies":[{"id":2775,"logo_path":null,"name":"American Eagle","origin_country":"US"},{"id":180144,"logo_path":null,"name":"U.S. Films","origin_country":""}],"production_countries":[{"iso_3166_1":"US","name":"United States of America"}],"release_date":"1983-11-18","revenue":11000000,"runtime":85,"softcore":false,"spoken_languages":[{"english_name":"English","iso_639_1":"en","name":"English"}],"status":"Released","tagline":"","title":"Uśpiony obóz","video":false,"vote_average":6.283,"vote_count":784,"credits":{"cast":[{"adult":false,"gender":2,"id":50762,"known_for_department":"Acting","name":"Mike Kellin","original_name":"Mike Kellin","popularity":0.7824,"profile_path":"/p73cZcdM1JNqsKzk3yYv9NN1I2p.jpg","cast_id":8,"character":"Mel","credit_id":"52fe457c9251416c750581b5","order":0},{"adult":false,"gender":1,"id":1178530,"known_for_department":"Acting","name":"Katherine Kamhi","original_name":"Katherine Kamhi","popularity":0.4543,"profile_path":"/lqtNpf8V3enu0nvufC2j3oQ3iUE.jpg","cast_id