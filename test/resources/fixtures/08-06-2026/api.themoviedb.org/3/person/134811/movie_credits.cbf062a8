anego przez niego baru.","popularity":1.613,"poster_path":"/1duhrzljtMxci8w1TQDG8vA5SUO.jpg","release_date":"1982-02-20","softcore":false,"video":false,"vote_average":5.412,"vote_count":17,"credit_id":"63699147ea84c7007add491a","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/9fUxbG2s2kGq33ukqWAZtTSA9YY.jpg","genre_ids":[18,27,14],"id":169930,"title":"聖母観音大菩薩","original_language":"ja","original_title":"聖母観音大菩薩","overview":"","popularity":0.9463,"poster_path":"/xxZQolFEysxKm2Y3ccYEwARB9jB.jpg","release_date":"1977-06-25","softcore":false,"video":false,"vote_average":4.556,"vote_count":9,"credit_id":"56941b0d9251414b6400000c","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/9fUxbG2s2kGq33ukqWAZtTSA9YY.jpg","genre_ids":[18,27,14],"id":169930,"title":"聖母観音大菩薩","original_language":"ja","original_title":"聖母観音大菩薩","overview":"","popularity":0.9463,"poster_path":"/xxZQolFEysxKm2Y3ccYEwARB9jB.jpg","release_date":"1977-06-25","softcore":false,"video":false,"vote_average":4.556,"vote_count":9,"credit_id":"56941b239251414b78000006","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":null,"genre_ids":[18],"id":374162,"title":"腹貸し女","original_language":"ja","original_title":"腹貸し女","overview":"","popularity":0.2413,"poster_path":"/tGsb52GRD3KnLDcqtJbHfYAUeT.jpg","release_date":"1968-03-01","softcore":false,"video":false,"vote_average":4.8,"vote_count":5,"credit_id":"56941b459251414b6400000f","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":null,"genre_ids":[10402],"id":930587,"title":"永遠のサバンナ 薔薇のしっぽ","original_language":"ja","original_title":"永遠のサバンナ 薔薇のしっぽ","overview":"","popularity":0.0702,"poster_path":"/eOcwSFcnwROQfetaXCq7fbKx5ks.jpg","release_date":"1990-05-24","softcore":false,"video":true,"vote_average":0.0,"vote_count":0,"credit_id":"61eeda4ea402c100997fa45a","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":null,"genre_ids":[18],"id":39