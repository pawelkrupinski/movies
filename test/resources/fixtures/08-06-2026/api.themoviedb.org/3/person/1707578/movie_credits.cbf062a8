Fxx2WfIT9Qbjm7Ox.jpg","release_date":"2014-10-05","softcore":false,"video":false,"vote_average":9.0,"vote_count":2,"credit_id":"58277150c3a368360f01ea4e","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/7EmlGYtS0lqMNfBuVGgSXT94ZPE.jpg","genre_ids":[35,18],"id":404776,"title":"Nada S.A.","original_language":"es","original_title":"Nada S.A.","overview":"","popularity":0.1404,"poster_path":"/5tbZrtkWOKeFxx2WfIT9Qbjm7Ox.jpg","release_date":"2014-10-05","softcore":false,"video":false,"vote_average":9.0,"vote_count":2,"credit_id":"58277159c3a368360401e1a9","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":"/rIRR4MaluxpLLLwBOL5sJFGVQos.jpg","genre_ids":[35,27],"id":464832,"title":"Zabójczy Bóg","original_language":"es","original_title":"Matar a Dios","overview":"Carlos, jego brat, ojciec i żona Ana przygotowują się do Sylwestra, którego mają wspólnie spędzić w wynajętym, odizolowanym domu na wsi. Przyjęcie psują jednak odwiedziny niezapowiedzianego gościa. Osobliwy, niski i bezdomny mężczyzna twierdzi, że jest Bogiem i zapowiada, że o świcie cała ludzkość zginie. Informuje, że Carlos z rodziną zostali wybrani, aby wskazać dwie osoby, które jako jedyne unikną zagłady. Muszą to zrobić zanim zegar wybije północ. Relacje rodzinne zostają wystawione na próbę i ujawniają się prawdziwe intencje wydawałoby się normalnej rodziny.","popularity":0.3883,"poster_path":"/fJHIW6xmKZJTsTCXsWKt3s1ZLt9.jpg","release_date":"2017-10-11","softcore":false,"video":false,"vote_average":5.837,"vote_count":86,"credit_id":"595dc22e9251415a4004eddb","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":null,"genre_ids":[35,27],"id":484086,"title":"RIP","original_language":"en","original_title":"RIP","overview":"","popularity":0.13,"poster_path":"/8uZdaTdHiwuoiAPoz9KEHJfo11v.jpg","release_date":"2017-10-12","softcore":false,"video":false,"vote_average":7.5,"vote_count":2,"credit_id":"59f626809251414d20038410","department":"Directin