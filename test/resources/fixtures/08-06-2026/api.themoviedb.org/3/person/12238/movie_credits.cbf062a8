0px1fxTkNnU.jpg","release_date":"1937-02-02","softcore":false,"video":false,"vote_average":7.0,"vote_count":2,"credit_id":"604fe11f2cefc20054fb585c","department":"Editing","job":"Editor"},{"adult":false,"backdrop_path":"/dRHfCeAoJ6SsMffQ6lavNU9E55z.jpg","genre_ids":[18,36,10752],"id":826,"title":"Most na rzece Kwai","original_language":"en","original_title":"The Bridge on the River Kwai","overview":"Akcja epickiego filmu toczy się w Birmie w latach II wojny światowej. Ukazuje on brawurową akcję alianckich komandosów, którzy wyruszają z misją wysadzenia mostu zbudowanego przez brytyjskich jeńców na polecenie Japończyków.","popularity":3.2111,"poster_path":"/kjfZ4BPZT1jZlqTdyH3B8sAdMqE.jpg","release_date":"1957-10-11","softcore":false,"video":false,"vote_average":7.823,"vote_count":2370,"credit_id":"52fe427dc3a36847f8022ac7","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/vKvoOlhhaZCsiGQDvaZQqyGq1oA.jpg","genre_ids":[18,10749],"id":851,"title":"Spotkanie","original_language":"en","original_title":"Brief Encounter","overview":"Laura, nieśmiała mężatka poznaje sympatycznego, też żonatego lekarza Alec`a. Miejscem spotkań niemłodej już pary jest hałaśliwy dworzec kolejowy.Stukot kół wagonów, gwizdy parowozów docierające do dworcowej restauracji wzbudzają w Laurze nostalgię i marzenia o dalekich podróżach i wyjazdach, kontrastujących z nudnym, nieciekawym otoczeniem. Jednakże wzajemne relacje między Laurą a Alec`iem kończą się wzajemnym, obustronnym wyrzeczeniem, spowodowanym czy to troską o najbliższych, czy też faktem iż spełnienie marzeń i pragnień mogłoby sprofanować wzajemne uczucie Alec`a i Laury.","popularity":1.5787,"poster_path":"/1Vh9YxavG9BgXcHCYMfnaJtR16i.jpg","release_date":"1945-11-24","softcore":false,"video":false,"vote_average":7.705,"vote_count":703,"credit_id":"52fe4282c3a36847f8024547","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/y3sPNxqVBIt97EZX568OpAWBpcl.jpg","genre_ids":[18,10749,10752],"id":907,"title":"Doktor Żywago","original_language":"en","original_title":"Doctor Zhivago","overview":"Jurij Żywago ma osiem lat, gdy umiera jego matka. Wychowują go przyjaciele rodziców. Po latach Jurij bierze ślub z ich córką, Tanią. Rozpoczyna studia medyczne. Pewnego dnia poznaje w tramwaju Larę, na którą od razu zwraca uwagę. Nie mogą być razem, jednak po latach znów się spotkają. Podczas wojny Żywago pełni obowiązki lekarza w szpitalu, w którym Lara jest pielęgniarką. Oboje są w związkach małżeńskich i mimo płomiennego uczucia ponownie muszą się rozstać.","popularity":3.7929,"poster_path":"/b0wo3KzY2rJmDt7h47vAD6ginOb.jpg","release_date":"1965-12-22","softcore":false,"video":false,"vote_average":7.553,"vote_count":1272,"credit_id":"52fe428bc3a36847f8026f77","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/z30x999Uku15xcFbe5s3hLvQPDl.jpg","genre_ids":[12,36,10752],"id":947,"title":"Lawrence z Arabii","original_language":"en","original_title":"Lawrence of Arabia","overview":"W sztabie brytyjskim w Kairze 29-letni Lawrence otrzymuje specjalne zadanie. Ma nawiązać kontakt z emirem Fajsalem i prosić o pomoc wojskową, by wzmocnić arabską rewoltę przeciwko Turkom. Okazuje się, że musiałby zdarzyć się cud, by znowu porwać ludzi do walki. Lawrence dokonuje tej nieprawdopodobnej rzeczy. Wraz z niewielkim oddziałem szejka Alego rusza do boju.","popularity":7.3447,"poster_path":"/6MIbdAdmVxjnTcR9f3suEZ1qGB0.jpg","release_date":"1962-12-11","softcore":false,"video":false,"vote_average":8.0,"vote_count":3420,"credit_id":"52fe4291c3a36847f8028f43","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/cySQNHMxuWvNiIp2hZPjTaJFLwa.jpg","genre_ids":[18,12,80,35],"id":10949,"title":"Oliver Twist","original_language":"en","original_title":"Oliver Twist","overview":"","popularity":2.8679,"poster_path":"/wkMdDqXI58MuW99wi9kotC8kCVM.jpg","release_date":"1948-06-28","softcore":false,"video":false,"vote_average":7.6,"vote_count":253,"credit