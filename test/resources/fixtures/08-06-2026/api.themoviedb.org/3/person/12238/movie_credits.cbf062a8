:"/1GeeKCUu77eBU1ut8hTBQRmb7Iq.jpg","genre_ids":[35,18,10749],"id":16410,"title":"Hobson's Choice","original_language":"en","original_title":"Hobson's Choice","overview":"","popularity":1.1076,"poster_path":"/kbP7EgoiOw2bIypai50JWRsqP7p.jpg","release_date":"1954-04-19","softcore":false,"video":false,"vote_average":7.377,"vote_count":163,"credit_id":"5713f76fc3a368673d00805c","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":"/fQd28Ir5kmuDztMtad8cbroi5t6.jpg","genre_ids":[35,53,10749,9648,80],"id":165057,"title":"The Ghost Camera","original_language":"en","original_title":"The Ghost Camera","overview":"","popularity":0.2556,"poster_path":"/jNXjRFGkQp0nRMwiPwv4P55DCXC.jpg","release_date":"1933-01-31","softcore":false,"video":false,"vote_average":6.265,"vote_count":17,"credit_id":"574d8c23c3a36873de0016c4","department":"Editing","job":"Editor"},{"adult":false,"backdrop_path":"/sDwCcdC38mhzl9ryfpvkhroMWjR.jpg","genre_ids":[10752,18],"id":43780,"title":"Jeden z naszych samolotów zaginął","original_language":"en","original_title":"One of Our Aircraft Is Missing","overview":"Akcja filmu rozgrywa się podczas II wojny światowej. Nocny atak bombowy na Stuttgart kończy się uszkodzeniem jednego z angielskich samolotów. Sześcioosobowa załoga zmuszona jest do ewakuacji. Żołnierze wyskakują na spadochronach, lądując w okolicach jeziora Zuiderzee, które znajduje się na terenie okupowanej przez hitlerowców Holandii. Niestety jeden z nich zaginął. Początkowym reakcjom miejscowej ludności towarzyszy dystans i brak zaufania, bowiem nie są oni do końca przekonani z kim właśnie mają do czynienia.","popularity":0.4115,"poster_path":"/fDL8iat0Yhii2dKRc4nQEEWVhvQ.jpg","release_date":"1942-04-24","softcore":false,"video":false,"vote_average":6.64,"vote_count":43,"credit_id":"573fef3f92514177ef000b74","department":"Editing","job":"Editor"},{"adult":false,"backdrop_path":null,"genre_ids":[18,28],"id":264924,"title":"Money for Speed","original_language":"en","original_title":"Money for Speed","overview":"","popularity":0.1158,"poster_path":"/qzcFABDtYVyYiATUQVgLxCZwTO8.jpg","release_date":"1933-03-01","softcore":false,"video":false,"vote_average":10.0,"vote_count":1,"credit_id":"57519895c3a3685c4700050a","department":"Editing","job":"Editor"},{"adult":false,"backdrop_path":null,"genre_ids":[18],"id":1069642,"title":"Song of the Plough","original_language":"en","original_title":"Song of the Plough","overview":"","popularity":0.2784,"poster_path":"/tyEzsoDIsmhpAIcGWakYXZb6faP.jpg","release_date":"1933-12-04","softcore":false,"video":false,"vote_average":8.0,"vote_count":1,"credit_id":"63b599b15ad76b007dc9af2c","department":"Editing","job":"Editor"},{"adult":false,"backdrop_path":"/9IoVS8XRJWhgYTPUQpE7N1lVUyQ.jpg","genre_ids":[18],"id":192980,"title":"Escape Me Never","original_language":"en","original_title":"Escape Me Never","overview":"","popularity":0.1759,"poster_path":"/q8gUSVzLhoj8kErXzPfSctWzflS.jpg","release_date":"1935-05-24","softcore":false,"video":false,"vote_average":6.0,"vote_count":8,"credit_id":"65e13e1e41a561018682fb54","department":"Editing","job":"Editor"},{"adult":false,"backdrop_path":null,"genre_ids":[10752,28,18],"id":426429,"title":"The Crouching Beast","original_language":"en","original_title":"The Crouching Beast","overview":"","popularity":0.2266,"poster_path":"/3rWvt1h92fTmz0c5FQfp2NeNlMj.jpg","release_date":"1935-08-29","softcore":false,"video":false,"vote_average":9.0,"vote_count":1,"credit_id":"582dd273c3a3687739008b2d","department":"Editing","job":"Editor"},{"adult":false,"backdrop_path":"/vKvoOlhhaZCsiGQDvaZQqyGq1oA.jpg","genre_ids":[18,10749],"id":851,"title":"Spotkanie","original_language":"en","original_title":"Brief Encounter","overview":"Laura, nieśmiała mężatka poznaje sympatycznego, też żonatego lekarza Alec`a. Miejscem spotkań niemłodej już pary jest hałaśliwy dworzec kolejowy.Stukot kół wagonów, gwizdy parowozów docierające do dworcowej restauracji wzbudzają w Laurze nostalgię i marzenia o dalekich podróżach i wyjazdach, kontrastujących z nudnym, nieciekawym otoczeniem. Jednakże wzajemne relacje między Laurą a Alec`iem kończą się wzajemnym, obustronnym wyrzeczeniem, spowodowanym czy to troską o najbliższych, czy też faktem iż spełnienie marzeń i pragnień mogłoby sprofanować wzajemne uczucie Alec`a i Laury.","popularity":1.5787,"poster_path":"/1Vh9YxavG9BgXcHCYMfnaJtR16i.jpg","release_date":"1945-11-24","softcore":false,"video":false,"vote_average":7.705,"vote_count":703,"credit_id":"63c8f8f3142ef1008a543d4c","department":"Crew","job":"Additional Writing"},{"adult":false,"backdrop_path":null,"genre_ids":[35],"id":468518,"title":"The Night Porter","original_language":"en","original_title":"The Night Porter","overview":"","popularity":0.0989,"poster_path":"/mUieBNQHwe5sA76wod9gHxKFmHJ.jpg","release_date":"1930-03-25","softcore":false,"video":false,"vote_average":7.0,"vote_count":1,"credit_id":"63f5415dfc31d3007c4bc391","department":"Editing","job":"Editor"},{"adult":false,"backdrop_path":"/5a8ZLqFVLKTam95IQCqaWP2OMCy.jpg","genre_ids":[18],"id":476435,"title":"These Charming People","original_language":"en","original_title":"These Charming People","overview":"","popularity":0.1337,"poster_path":"/bOfXssvQGrCXaH5tvkf1ZKoorrO.jpg","release_date":"1931-07-23","softcore":false,"video":false,"vote_average":10.0,"vote_count":1,"credit_id":"59bf9f1992514147200129f8","department":"Editing","job":"Editor"},{"adult":false,"backdrop_path":null,"genre_ids":[18],"id":1113185,"title":"The King of Paris","original_language":"en","original_title":"The King of Paris","overview":"","popularity":0.0938,"poster_path":null,"release_date":"1934-11-05","softcore":false,"video":false,"vote_average":8.0,"vote_count":1,"credit_id":"6439ba51d7dcd20534eae862","department":"Editing","job":"Editor"},{"adult":false,"backdrop_path":"/1am89cK1ygeLvEAJO9cozOzEBql.jpg","genre_ids":[80,18],"id":129133,"title":"Tiger Bay","original_language":"en","original_title":"Tiger Bay","overview":"","popularity":0.2564,"poster_path":"/nfYPHnfmAGrWUjtEel4PiBrhOkS.jpg","release_date":"1934-09-01","softcore":false,"video":false,"vote_average":6.583,"vote_count":6,"credit_id":"6443ab47b3f6f5049c9e7f0f","department":"Editing","job":"Editor"},{"adult":false,"backdrop_path":null,"genre_ids":[35,10749,10402],"id":487676,"title":"Ball at Savoy","original_language":"en","original_title":"Ball at Savoy","overview":"","popularity":0.1866,"poster_path":"/eMAHgCRSdIQS1aNjaCpc2jzUklv.jpg","release_date":"1936-01-09","softcore":false,"video":false,"vote_average":7.0,"vote_count":2,"credit_id":"5a0f5f0892514138e401aa22","department":"Editing","job":"Editor"},{"adult":false,"backdrop_path":"/nvuaUT8kDUyjsRUcNemwuJjTVWD.jpg","genre_ids":[10752,53],"id":21735,"title":"49th Parallel","original_language":"en","original_title":"49th Parallel","overview":"Na początku II wojny światowej niemiecki U-Boot zostaje zatopiony w kanadyjskiej Zatoce Hudsona. Mając nadzieję na uniknięcie schwytania, mała grupa niemieckich żołnierzy pod dowództwem porucznika Hirtha próbuje przekroczyć granicę ze Stanami Zjednoczonymi, które jeszcze nie przystąpiły do ​​wojny i są oficjalnie neutralne. Po drodze niemieccy żołnierze spotykają odważnych mężczyzn, takich jak francusko-kanadyjski traper, Johnnie, przywódca huteryckiej społeczności rolniczej, Peter, autor, Philip i żołnierz, Andy Brock.","popularity":0.7359,"poster_path":"/m4YTQv9fHYB2nZ7M2Al6wzOmrYe.jpg","release_date":"1941-11-24","softcore":false,"video":false,"vote_average":6.963,"vote_count":120,"credit_id":"5a47f6c0c3a3681919004d69","department":"Editing","job":"Editor"},{"adult":false,"backdrop_path":"/f6JjKDXn66XgNnYjBcKiwO4h3A7.jpg","genre_ids":[18,36],"id":2428,"title":"Opowieść wszech czasów","original_language":"en","original_title":"The Greatest Story Ever Told","overview":"Opowieść rozpoczyna się w niewielkim Betlejem. Tam pewnego dnia rodzi się mały chłopiec, którego matka nazwała Jezus. Król Herod gości w tym czasie trzech mędrców: Baltazara, Kacpra i Melchiora, którzy opowiadają mu historię, że narodził się przyszły król żydowski. Herod niezwłocznie wydaje rozkaz zabicia nowo narodzonych dzieci płci męskiej. Mały Jezus przypadkowo unika jatki, ponieważ ktoś ostrzegł jego ojca Józefa przed zagrożeniem i cała rodzina zbiegła do pobliskiego Egiptu. Dopiero po śmierci króla Heroda uchodźcy powracają do rodzinnego kraju...","popularity":2.239,"poster_path":"/75rZGSYeIUIf2oCEbhPqHtYxXff.jpg","release_date":"1965-04-09","softcore":false,"video":false,"vote_average":6.4,"vote_count":213,"credit_id":"646936bd2bcf6700e3babbf3","department":"Directing","job":"Second Unit Director"},{"adult":false,"backdrop_path":"/vhexJUk3sTEldSl3cI3eRzt6SZ5.jpg","genre_ids":[18,12,36],"id":15927,"title":"Podróż do Indii","original_language":"en","original_title":"A Passage to India","overview":"Angielka, Mrs. Moore, wyrusza statkiem do Indii Zachodnich, by odwiedzić syna pracującego w tamtejszym zarządzie kolonialnym. Towarzyszy jej Adela Quested, narzeczona syna. W czasie podróży dziewczyna poznaje doktora Aziza, indyjskiego lekarza, który próbuje złagodzić jej niechęć wobec obcej kultury. Poruszona spotkaniami Adela powoli zaczyna uwalniać się od uprzedzeń rasowych, jednak jej pochodzenie nie pozwala wyrwać się z przyjętych konwenansów.","popularity":1.3669,"poster_path":"/4rQK9biNSV4AFWwKdMKPD7raORo.jpg","release_date":"1984-12-14","softcore":false,"video":false,"vote_average":6.842,"vote_count":326,"credit_id":"5ada58af0e0a262d30001785","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":"/vhexJUk3sTEldSl3cI3eRzt6SZ5.jpg","genre_ids":[18,12,36],"id":15927,"title":"Podróż do Indii","original_language":"en","original_title":"A Passage to India","overview":"Angielka, Mrs. Moore, wyrusza statkiem do Indii Zachodnich, by odwiedzić syna pracującego w tamtejszym zarządzie kolonialnym. Towarzyszy jej Adela Quested, narzeczona syna. W czasie podróży dziewczyna poznaje doktora Aziza, indyjskiego lekarza, który próbuje złagodzić jej niechęć wobec obcej kultury. Poruszona spotkaniami Adela powoli zaczyna uwalniać się od uprzedzeń rasowych, jednak jej pochodzenie nie pozwala wyrwać się z przyjętych konwenansów.","popularity":1.3669,"poster_path":"/4rQK9biNSV4AFWwKdMKPD7raORo.jpg","release_date":"1984-12-14","softcore":false,"video":false,"vote_average":6.842,"vote_count":326,"credit_id":"5ada58e90e0a262d48001969","department":"Editing","job":"Editor"},{"adult":false,"backdrop_path":null,"genre_ids":[53,35],"id":520018,"title":"Spy for a Day","original_language":"en","original_title":"Spy for a Day","overview":"","popularity":0.0972,"poster_path":"/yg1aoVilOKmTnFB0BeKPomUpr2n.jpg","release_date":"1940-04-26","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"5add7bb0c3a368527c00857d","department":"Editing","job":"Editor"},{"adult":false,"backdrop_path":"/ycw1LTBimIrYIKegutP0SGULZG8.jpg","genre_ids":[18,10749,10752],"id":51619,"title":"Bariera dźwięku","original_language":"en","original_title":"The Sound Barrier","overview":"Opowieść o grupie pilotów testujących prototypy samolotów odrzutowych, o ich fascynacji możliwościami techniki, pasji latania, nadziei, strachu i śmierci. Tony Garthwait jest oblatywaczem samolotów u swego teścia. Gdy ginie w katastrofie, jego zrozpaczona żona stara się uchronić przed śmiercią innych pilotów.","popularity":0.657,"poster_path":"/cExgxdISr0gEvVr74mmpEL4yLh4.jpg","release_date":"1952-07-22","softcore":false,"video":false,"vote_average":6.508,"vote_count":59,"credit_id":"5aef5d280e0a261d92008c5c","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":null,"genre_ids":[18,10749],"id":1152095,"title":"Quinneys","original_language":"en","original_title":"Quinneys","overview":"","popularity":0.7284,"poster_path":null,"release_date":"1927-12-01","softcore":false,"video":false,"vote_average":8.0,"vote_count":1,"credit_id":"64b185514e4dff011c7c0316","department":"Production","job":"Production Runner"},