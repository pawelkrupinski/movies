ększej sławy. Ten intymny film prezentuje unikatowe materiały zza kulis, nakręcone przez Davida i Alberta Mayslesów, odrestaurowane w 4K. Dokument zawiera nowe i archiwalne wywiady z Beatlesami, a także z fanami, których życie odmieniła muzyka zespołu.","popularity":0.9205,"poster_path":"/ny9fI756vTYVG3PrJwBUwXOeSBO.jpg","release_date":"2024-11-24","softcore":false,"video":false,"vote_average":6.5,"vote_count":49,"character":"Self","credit_id":"6749f7bed35a8e98497e7bec","order":6},{"adult":false,"backdrop_path":"/nxFtN5lN2n4o5MiYX0PpoEUsnuG.jpg","genre_ids":[99],"id":874649,"title":"The Sleeper Must Awaken: Making Dune","original_language":"en","original_title":"The Sleeper Must Awaken: Making Dune","overview":"","popularity":0.4117,"poster_path":"/ckG5ngpwF661V9kjHbOhd055ZIW.jpg","release_date":"2021-10-14","softcore":false,"video":false,"vote_average":4.0,"vote_count":2,"character":"Self (voice) (archive footage)","credit_id":"678c1226a93ce48bca431445","order":17},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":1420200,"title":"David Lynch Teaches Creativity and Film","original_language":"en","original_title":"David Lynch Teaches Creativity and Film","overview":"","popularity":0.0404,"poster_path":"/44knGGqsuHZLkyCSOH3YldpxpiG.jpg","release_date":"2019-03-18","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"character":"Himself","credit_id":"678d5ca2afcb32c499433c58","order":0},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":669330,"title":"Retour à Mulholland Drive","original_language":"fr","original_title":"Retour à Mulholland Drive","overview":"","popularity":0.1665,"poster_path":"/205WQbfskjaBhF6Or19KExqBXJu.jpg","release_date":"2003-06-17","softcore":false,"video":false,"vote_average":8.0,"vote_count":1,"character":"Self","credit_id":"678d85dedbcff33a9c6539ab","order":1},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":1424036,"title":"Love, Death, Elvis & Oz: The Making of Wild at Heart","original_language":"en","