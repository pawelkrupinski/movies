00950dfe","department":"Writing","job":"Characters"},{"adult":false,"backdrop_path":"/8IQb7JHS8yrFPO2SEeISGydWwNY.jpg","genre_ids":[10402],"id":267246,"title":"Michael Jackson: Dangerous - The Short Films","original_language":"en","original_title":"Michael Jackson: Dangerous - The Short Films","overview":"","popularity":0.7857,"poster_path":"/5wqvRs93dk8knxUbuKKOFBVwf4q.jpg","release_date":"1993-09-28","softcore":false,"video":true,"vote_average":8.2,"vote_count":41,"credit_id":"66fb42598aa734b376a65b36","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/mZr25o5KF6nUjDZaYaoIMWluedu.jpg","genre_ids":[53,18,9648],"id":284457,"title":"Twin Peaks: Brakujące elementy","original_language":"en","original_title":"Twin Peaks: The Missing Pieces","overview":"Zabawa z płomieniami kończy się poparzeniem, flirt ze złem – splugawieniem, a każdorazowe odwiedzenie świata Laury Palmer – kolejnymi pytaniami. „Twin Peaks: Brakujące elementy” – choć nie udzielają odpowiedzi – podrzucają garść bezcennych wskazówek.","popularity":1.5399,"poster_path":"/m3y72zg8JvmUVEXoLIQP7fmEpAm.jpg","release_date":"2014-07-16","softcore":false,"video":true,"vote_average":7.217,"vote_count":272,"credit_id":"66ff045f67c6fb09fff7e95d","department":"Writing","job":"Characters"},{"adult":false,"backdrop_path":"/jYctAvKZB6Fz0u6svgsggk5VkNB.jpg","genre_ids":[16,27],"id":1398841,"title":"Fire (Pożar)","original_language":"en","original_title":"Fire (Pożar)","overview":"","popularity":0.0933,"poster_path":"/125StUYlNjr6eGPzSX0nt0LfmFN.jpg","release_date":"2015-03-28","softcore":false,"video":false,"vote_average":6.5,"vote_count":4,"credit_id":"67543afeab6cc3a4c8fca941","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/xlJy4lQlCuwrsXFKQ70m4hzsPzs.jpg","genre_ids":[16,27],"id":1419341,"title":"Waiting for Mr. Lynch","original_language":"en","original_title":"Waiting for Mr. Lynch","overview":"","popularity":0.0486,"poster_path":"/c3yrPEaKVrz7WcnJy5g6tYknW3v.jpg",