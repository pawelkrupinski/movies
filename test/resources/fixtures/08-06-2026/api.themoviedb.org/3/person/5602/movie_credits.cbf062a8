":"Henry Spencer, zostaje zaproszony na kolację do rodziców swej dziewczyny, której nie widział przez pół roku. Spotkanie przebiega w nietypowej atmosferze, nagle Henry dowiaduje się, że jego ukochana urodziła mu dziecko. Potomek okazuje się jednak dziwnym stworkiem, który ma niewiele wspólnego z normalnym dzieckiem. Narzeczona szybko pozostawia Henry'ego samego z 'problemem', co stanowi dla bohatera początek dziwnych wydarzeń.","popularity":4.6728,"poster_path":"/u5TI2vpGySYIB7was52m6baReRP.jpg","release_date":"1977-09-28","softcore":false,"video":false,"vote_average":7.341,"vote_count":2739,"credit_id":"6198fb685c071b0065f36160","department":"Sound","job":"Sound Effects"},{"adult":false,"backdrop_path":null,"genre_ids":[10752,99,18],"id":341961,"title":"Les Français vus par","original_language":"fr","original_title":"Les Français vus par","overview":"","popularity":1.541,"poster_path":"/n9XvRGI9OH5FDFWmCOFjxxnGTlL.jpg","release_date":"1988-10-26","softcore":false,"video":false,"vote_average":6.947,"vote_count":19,"credit_id":"5564bb2092514119460052eb","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":null,"genre_ids":[27],"id":916790,"title":"Kitsune","original_language":"en","original_title":"Kitsune","overview":"","popularity":0.31,"poster_path":"/1xMpAUBtAqi2pzwsOG1VUC1d9mO.jpg","release_date":"2016-10-29","softcore":false,"video":false,"vote_average":5.0,"vote_count":1,"credit_id":"61bb698e223e200042aff16f","department":"Crew","job":"Thanks"},{"adult":false,"backdrop_path":"/4KeE9os5PVbaEg02OJ4Vt1aXDXQ.jpg","genre_ids":[35],"id":359115,"title":"Out Yonder — Neighbor Boy","original_language":"en","original_title":"Out Yonder — Neighbor Boy","overview":"","popularity":0.2651,"poster_path":"/oV23w4rcYQxRHDHppTs2OJk1hjS.jpg","release_date":"2002-02-11","softcore":false,"video":false,"vote_average":6.2,"vote_count":15,"credit_id":"55f0ec459251416705000760","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/j42xjJ1XbV