cy, poprzez ich wspomnienia obserwujemy bohatera podczas prób teatralnych, retrospekcje pozwalają nam wniknąć w jego skomplikowane relacje z matką.","popularity":1.1246,"poster_path":"/sUS8WNlJblq2GMCFPKBHzhu0XDC.jpg","release_date":"2010-07-08","softcore":false,"video":false,"vote_average":6.058,"vote_count":226,"credit_id":"5f028474d0b434003369b234","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/1v2BU2dq4GVJia03rEkJDB9BOLe.jpg","genre_ids":[27,18],"id":24007,"title":"More Things That Happened","original_language":"en","original_title":"More Things That Happened","overview":"","popularity":0.2097,"poster_path":"/eTFhJnie3s8xdAPwOo09yg3NaNh.jpg","release_date":"2007-08-14","softcore":false,"video":false,"vote_average":6.2,"vote_count":27,"credit_id":"5f12cfec2afb2500353c5e5b","department":"Editing","job":"Editor"},{"adult":false,"backdrop_path":"/nzSau7oFFm7tVcfkJIZKfctz0UZ.jpg","genre_ids":[16,27],"id":44239,"title":"The Alphabet","original_language":"en","original_title":"The Alphabet","overview":"","popularity":0.5411,"poster_path":"/thTiEL6egntN6g0qefN1Kie3HdI.jpg","release_date":"1969-02-13","softcore":false,"video":false,"vote_average":6.5,"vote_count":246,"credit_id":"5f9793b3d2f5b500387e5702","department":"Camera","job":"Director of Photography"},{"adult":false,"backdrop_path":"/nzSau7oFFm7tVcfkJIZKfctz0UZ.jpg","genre_ids":[16,27],"id":44239,"title":"The Alphabet","original_language":"en","original_title":"The Alphabet","overview":"","popularity":0.5411,"poster_path":"/thTiEL6egntN6g0qefN1Kie3HdI.jpg","release_date":"1969-02-13","softcore":false,"video":false,"vote_average":6.5,"vote_count":246,"credit_id":"5f9793fe5bce9e0036ae2051","department":"Visual Effects","job":"Animation"},{"adult":false,"backdrop_path":"/qJGioJgsqpoDUiAztWcxCB3vn2b.jpg","genre_ids":[99],"id":381071,"title":"My Beautiful Broken Brain","original_language":"en","original_title":"My Beautiful Broken Brain","overview":"Codzienne zmagania, porażki i