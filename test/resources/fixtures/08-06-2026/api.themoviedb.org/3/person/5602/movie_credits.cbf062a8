 w jednym z najbardziej oryginalnych filmów ostatnich lat.","popularity":1.0676,"poster_path":"/qXyYf6scdXweVjiPCyKYjPLKHN8.jpg","release_date":"2018-09-07","softcore":false,"video":false,"vote_average":7.553,"vote_count":19,"character":"Self","credit_id":"67ff6b8861b1c4bb32999ede","order":10},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":1476959,"title":"David Lynch: The Virtual Life","original_language":"en","original_title":"David Lynch: The Virtual Life","overview":"","popularity":0.0357,"poster_path":"/ghdnkOeNvNSnhYp6FP04Ni5bJzo.jpg","release_date":"2020-11-01","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"character":"himself","credit_id":"681af92057e7fd7cc38093bc","order":0},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":1555011,"title":"The Hanging of Stuart Cornfeld","original_language":"en","original_title":"The Hanging of Stuart Cornfeld","overview":"","popularity":0.3579,"poster_path":"/8jrS0d0vxSMLnR85pDmAZfH3X9B.jpg","release_date":"2025-10-23","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"character":"","credit_id":"68dc428ef1b9ec124dc77230","order":5},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":1563317,"title":"David Lynch: The Idea Dictates Everything","original_language":"fr","original_title":"David Lynch: The Idea Dictates Everything","overview":"","popularity":0.1121,"poster_path":"/yN29qZQRhSqJxOTQfoZDHouxAHB.jpg","release_date":"2021-01-07","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"character":"David Lynch","credit_id":"68efee7c0a798cfb388a250e","order":0},{"adult":false,"backdrop_path":"/2bEjjdsJRnTpz7P3lKYvfgy2pza.jpg","genre_ids":[99],"id":1261119,"title":"Продавцы планктона","original_language":"ru","original_title":"Продавцы планктона","overview":"","popularity":1.8101,"poster_path":"/cNwK4d3ZWHi8xUHpDyvam0qfo9n.jpg","release_date":"2017-10-29","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"character":"Self (archive footage