[27,53,9648,18,14],"id":1730,"title":"Inland Empire","original_language":"en","original_title":"Inland Empire","overview":"Aktorka przejmuję osobowość swojej postaci w filmie. Z czasem świat, w którym żyje, staję się przerażający i surrealistyczny.","popularity":4.4185,"poster_path":"/vjzdIiVzvEAQ8J0wlwQBZf0iaiH.jpg","release_date":"2006-12-06","softcore":false,"video":false,"vote_average":7.0,"vote_count":1263,"credit_id":"598c680792514107d6012473","department":"Sound","job":"Sound Designer"},{"adult":false,"backdrop_path":"/1S81PpyGwS8eVx4W75uSKzMw4B0.jpg","genre_ids":[18],"id":404,"title":"Prosta historia","original_language":"en","original_title":"The Straight Story","overview":"Alvin Straight jest starym człowiekiem wiodącym spokojne i ciche życie w małym prowincjonalnym miasteczku. Kiedy dowiaduje się, że jego brat, z którym przed wielu laty stracił kontakt, jest umierający, wyrusza w podróż. Na małym traktorku - kosiarce do trawy przemierza kilka Stanów, żeby pod koniec życia pogodzić się z bratem.","popularity":2.6249,"poster_path":"/e7abp7WpxjiFMiDDItuPd0PgELy.jpg","release_date":"1999-10-15","softcore":false,"video":false,"vote_average":7.741,"vote_count":1797,"credit_id":"598c6961c3a368736c01255e","department":"Sound","job":"Sound Designer"},{"adult":false,"backdrop_path":"/9qUFxfSsdqJsTKlLL0RcqnjlzY1.jpg","genre_ids":[99],"id":474897,"title":"Lamp","original_language":"en","original_title":"Lamp","overview":"","popularity":0.1023,"poster_path":"/9c3QRLximYLoCRZEj8pHQoE401A.jpg","release_date":"2003-09-09","softcore":false,"video":false,"vote_average":4.8,"vote_count":10,"credit_id":"59b4603892514128230030ec","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/pobx2GQtySIaT0dusjpyIJOTMby.jpg","genre_ids":[27,10402],"id":561930,"title":"Ant Head","original_language":"en","original_title":"Ant Head","overview":"","popularity":0.1012,"poster_path":"/As21djgyTuJltqUbr0ZeH45QqwT.jpg","release_date":"2018-11-14","softcore":false,"video":