":true,"vote_average":8.894,"vote_count":170,"credit_id":"5d26464c69d2804fb10015f9","department":"Writing","job":"Scenario Writer"},{"adult":false,"backdrop_path":"/uAwtoDqBjkGp9txuS3f1cv13iyo.jpg","genre_ids":[35,10749],"id":268259,"title":"Goosed","original_language":"en","original_title":"Goosed","overview":"","popularity":1.7659,"poster_path":"/i3FNyqhEfooztXDRnO2MIynukwa.jpg","release_date":"1999-09-28","softcore":false,"video":false,"vote_average":3.7,"vote_count":10,"credit_id":"5d803629eb64f10013c8f0b3","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/3NKNb8uDQ192oiTLN2Aq5rmmJzg.jpg","genre_ids":[14,18,27],"id":29135,"title":"No Such Thing","original_language":"en","original_title":"No Such Thing","overview":"","popularity":0.2968,"poster_path":"/2RYZU5QTXISHqRKuTKMVTdpg9f5.jpg","release_date":"2002-03-29","softcore":false,"video":false,"vote_average":6.045,"vote_count":67,"credit_id":"5db07f73ecaef5001125bf57","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/8vroa5RYUxD7Nv7vUGUoxZTyz7P.jpg","genre_ids":[80,18],"id":2148,"title":"Cotton Club","original_language":"en","original_title":"The Cotton Club","overview":"Tytułowy \"Cotton Club\" jest nie tylko popularnym klubem jazzowym, ale również miejscem, w którym krzyżują się drogi mafijnych bossów. Tu załatwia się ciemne interesy, prowadzi negocjacje. Młody, świetnie zapowiadający się muzyk jazzowy, Dixi Dwyer pewnej nocy przypadkowo ratuje życie jednemu z najgroźniejszych gangsterów w mieście, Dutchowi Schultzowi. Wdzięczny Dutch proponuje mu pracę. Wkrótce Dixie zakochuje się w kochance gangstera i tak zaczynają się jego kłopoty.","popularity":2.3158,"poster_path":"/tLq6OzzyQS1AEh9jdSWbnm0x2j6.jpg","release_date":"1984-12-14","softcore":false,"video":false,"vote_average":6.515,"vote_count":442,"credit_id":"5d99e45d0d294400183d2733","department":"Writing","job":"Story"},{"adult":false,"backdrop_path":"/1QQZbcIZU9tF3fOZRV8fr1Wb3De.jpg","genre_ids":[35,18,10749],"id":9719,"title":"Pumpkin","original_language":"en","original_title":"Pumpkin","overview":"","popularity":0.8907,"poster_path":"/25qW6cO2zqYBpqTw8BBIhBIUpl4.jpg","release_date":"2002-06-28","softcore":false,"video":false,"vote_average":5.765,"vote_count":117,"credit_id":"5e16073dd8af670016c4c726","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/tSPT36ZKlP2WVHJLM4cQPLSzv3b.jpg","genre_ids":[18,80],"id":238,"title":"Ojciec chrzestny","original_language":"en","original_title":"The Godfather","overview":"Akcja filmu toczy się pod koniec II wojny światowej w Ameryce. Don Vito Corleone jest głową jednej z pięciu mafijnych rodzin w Nowym Jorku. Wraz z pomocą synów Sonny'ego i Freda oraz Toma Hagena -który oferuje swoje usługi w zakresie prawnym - cieszą się uznaniem wśród wielu znanych i ważnych osobistości. Wszystko zaczyna się komplikować, gdy Don Vito odmawia współpracy w handlu narkotykami.","popularity":44.5504,"poster_path":"/g1BqW6xfiztwUVSQY9hevjtYyMr.jpg","release_date":"1972-03-14","softcore":false,"video":false,"vote_average":8.687,"vote_count":23004,"credit_id":"5e92505cccb15f00136de455","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/kGzFbGhp99zva6oZODW5atUtnqi.jpg","genre_ids":[18,80],"id":240,"title":"Ojciec chrzestny II","original_language":"en","original_title":"The Godfather Part II","overview":"Ta mistrzowska kontynuacja \"Ojca chrzestnego\" opisuje losy dwóch pokoleń rodu Corleone w bezwzględnym dążeniu do władzy. Francis Ford Coppola podzielił swą powieść na dwie części: w pierwszej przedstawił losy młodego Don Vito, zagranego bezbłędnie przez Roberta De Niro, w drugiej -  przejmowanie przez Michaela (Al Pacino) władzy w mafijnej rodzinie. Ponownie, gromadząc na planie wielu znakomitych artystów, Coppola stworzył bez wątpienia najlepszy sequel w dziejach kina.","popularity":28.5329,"poster_path":"/sWQjhhK9AidSLExyn7M26Tz4V6U.jpg","release_date":"1974-12-20","softcore":false,"video":false,"vote_average":8.572,"vote_count":13948,"credit_id":"5e92517a8e87020016cb1d0e","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/kGzFbGhp99zva6oZODW5atUtnqi.jpg","genre_ids":[18,80],"id":240,"title":"Ojciec chrzestny II","original_language":"en","original_title":"The Godfather Part II","overview":"Ta mistrzowska kontynuacja \"Ojca chrzestnego\" opisuje losy dwóch pokoleń rodu Corleone w bezwzględnym dążeniu do władzy. Francis Ford Coppola podzielił swą powieść na dwie części: w pierwszej przedstawił losy młodego Don Vito, zagranego bezbłędnie przez Roberta De Niro, w drugiej -  przejmowanie przez Michaela (Al Pacino) władzy w mafijnej rodzinie. Ponownie, gromadząc na planie wielu znakomitych artystów, Coppola stworzył bez wątpienia najlepszy sequel w dziejach kina.","popularity":28.5329,"poster_path":"/sWQjhhK9AidSLExyn7M26Tz4V6U.jpg","release_date":"1974-12-20","softcore":false,"video":false,"vote_average":8.572,"vote_count":13948,"credit_id":"5e9251c384448e00128f09b1","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":"/ppgWL2gsYIPaWDkSL91kweJL9eN.jpg","genre_ids":[99],"id":695352,"title":"Henri Langlois vu par...","original_language":"fr","original_title":"Henri Langlois vu par...","overview":"","popularity":0.3195,"poster_path":"/4TrDrBXQgYnlKMFx7tLMn2l7kuE.jpg","release_date":"2014-07-27","softcore":false,"video":false,"vote_average":4.0,"vote_count":1,"credit_id":"5ea1b0279cc67b0025289b55","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/cSbcBpduXYQ6XfdoSQaTo23jF1u.jpg","genre_ids":[28,18],"id":28881,"title":"Wiatr","original_language":"en","original_title":"Wind","overview":"Młody, obiecujący żeglarz zostaje dokooptowany na próbę do ekipy amerykańskiej, startującej w Pucharze Świata. Debiut nie wypada najlepiej, załoga przegrywa z jego winy, co gorsza na korzyść Australijczyków. Ambitny sportowiec nie rezygnuje z kolejnych mistrzostw. Czy tym razem zajmie miejsce na podium?","popularity":2.6109,"poster_path":"/kg4xfPKKlzHKNNfrZkdaDPz2VHa.jpg","release_date":"1992-09-11","softcore":false,"video":false,"vote_average":6.198,"vote_count":43,"credit_id":"5ec569866c84920021296116","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/2wOvyxAUiP76qqLIsayMPMhUi8g.jpg","genre_ids":[10751,12,35,18],"id":15170,"title":"Buddy","original_language":"en","original_title":"Buddy","overview":"","popularity":1.3486,"poster_path":"/88l3mMtQcHE5JW8gJmQJm9fmpAH.jpg","release_date":"1997-06-06","softcore":false,"video":false,"vote_average":5.0,"vote_count":77,"credit_id":"5ee3ae46d20c870020306ac8","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/iOhj9IPNRppo5oiJbYSniYtAffZ.jpg","genre_ids":[10752,18,36],"id":28368,"title":"Kamienne ogrody","original_language":"en","original_title":"Gardens of Stone","overview":"Opowieść o żołnierzach z reprezentacyjnej kompanii towarzyszącej ceremoniom pogrzebowym. Oddziałem dowodzą doświadczeni frontowi weterani. Jest wśród nich sierżant Clell Hazard, który z niepokojem obserwuje jednego z podkomendnych, szeregowca Jacka Willowa. Od wybuchu wojny w Wietnamie kompania honorowa ma pełne ręce roboty - do Arlington przybywa coraz więcej trumien wojennych bohaterów. Tymczasem Willow marzy, aby trafić na front. Sierżant Hazard próbuje mu przekazać, że walka to nie romantyczna przygoda, lecz okrutna rzeź.","popularity":1.167,"poster_path":"/aPnIZBdS4vsFsRMIDeC7PEm403t.jpg","release_date":"1987-05-05","softcore":false,"video":false,"vote_average":6.222,"vote_count":126,"credit_id":"5effc3275437f5003894817e","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/uoGTKAi4qTk4lfOlbSkVKZA72lG.jpg","genre_ids":[35,18],"id":27834,"title":"CQ","original_language":"en","original_title":"CQ","overview":"W 1969 roku, w Paryżu, Paul, młody Amerykanin, pragnie zostać filmowcem. Planuje nakręcić filmowy pamiętnik w stylu „cinéma vérité” ze swojego życia. Obecnie Paul jest montażystą filmu „Dragonfly”, fabularnego filmu science fiction, którego akcja rozgrywa się w 2001 roku: piękna Valentine gra główną rolę, ubrana w różową skórę. Reżyser „Dragonfly” to ekstrawagancki twórca. Jego namiętność do Valentine wpływa na jego osąd, zwłaszcza jeśli chodzi o zakończenie filmu. Zniesmaczony Enzo, producent, zwalnia filmowca i zatrudnia na jego miejsce młodego i aroganckiego, cudownego reżysera, Felixa De Marco. Paul zazdrości mu sukcesu, ale po wypadku samochodowym Felix wycofuje się. Enzo prosi Paula o ratowanie zdjęć do filmu. Pomimo strachu, zgadza się.","popularity":1.6814,"poster_path":"/aFAPOT77Jh7lNWYtojC6nxi4CpJ.jpg","release_date":"2001-05-12","softcore":false,"video":false,"vote_average":5.904,"vote_count":73,"credit_id":"601f9550681888003eb69c75","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":null,"genre_ids":[18,53,10770],"id":291539,"title":"Outrage","original_language":"en","original_title":"Outrage","overview":"","popularity":1.9206,"poster_path":"/6olERBNAVGkwYu1Z5qhuvB9xlT7.jpg","release_date":"1998-01-04","softcore":false,"video":false,"vote_average":5.6,"vote_count":5,"credit_id":"601ff8850c2710003ff0174b","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/5QEqz09x8tU3QS0VaNVhpZjuh8k.jpg","genre_ids":[18,10749],"id":41291,"title":"One from the Heart","original_language":"en","original_title":"One from the Heart","overview":"","popularity":1.3723,"poster_path":"/5EyIQksa8C9tm82rHIJYGQXZ5Vs.jpg","release_date":"1982-02-11","softcore":false,"video":false,"vote_average":6.0,"vote_count":208,"credit_id":"66fdeb79e48014914684c38d","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":"/nZJhuZMSlL21rm5HrrLWWIV6drP.jpg","genre_ids":[14,18,9648],"id":7797,"title":"Młodość stulatka","original_language":"en","original_title":"Youth Without Youth","overview":"Bukareszt, 1938 rok. Nad miastem szaleje burza. W pewnego starszego człowieka uderza piorun. To profesor Dominik Matei. Udaje mu się przeżyć. Co więcej, mężczyzna odzyskuje młodość, a jego zdolności intelektualne osiągają poziom niedostępny dla przeciętnego człowieka. Jak to możliwe? Na to pytanie nauka nie zna odpowiedzi.  Matei zaś pragnie tylko jednego – chce posiąść wiedzę absolutną. Osobą Profesora zaczynają się tymczasem interesować naziści. Widzą w nim obiekt przydatny w prowadzonych przez Trzecią Rzeszę eksperymentach medycznych.","popularity":1.1075,"poster_path":"/yeetdqfiqdFwBIKai0CqLfDDIEB.jpg","release_date":"2007-10-26","softcore":false,"video":false,"vote_average":6.138,"vote_count":239,"credit_id":"67004948925fdf925b7ce43f","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":"/l9x37Pvu2JR7TE04fRqxjBMW2qV.jpg","genre_ids":[18],"id":11928,"title":"Tetro","original_language":"en","original_title":"Tetro","overview":"Osiemnastoletni Bennie przybywa do Buenos Aires, by odwiedzić swojego brata. Przy okazji tej wizyty na jaw wychodzą długo skrywane rodzinne sekrety. [filmweb.pl]","popularity":1.4738,"poster_path":"/hp6QmD4MgXxs2iKbag3CaC9XzDV.jpg","release_date":"2009-06-11","softcore":false,"video":false,"vote_average":6.7,"vote_count":210,"credit_id":"670dcf5542e1391c5666e2e8","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":"/sfhhJmKJBidavKSnCd8ZIMFOOup.jpg","genre_ids":[18],"id":1235499,"title":"The Last Showgirl","original_language":"en","original_title":"The Last Showgirl","overview":"Shelly (Pamela Anderson) czuje się w szczytowej formie, jednak świat postrzega ją – kobietę po pięćdziesiątce – jako kogoś, kto lata swojej świetności ma dawno za sobą. Swoją pracę traktuje nie tylko jako formę rozrywki, ale przede wszystkim pasję oraz sztukę, korzeniami sięgającą do francuskiej burleski. Liczące sobie trzy dekady show ma jednak zniknąć z afisza i zostać zastąpione nową formułą z młodszymi tancerkami. Shelly staje więc przed dylematem: co zrobić dalej ze swoim życiem, skoro jej największy atut – ciało – przestało być atrakcyjne? Może to szansa, aby naprawić nadszarpnięte relacje z córką? Jak jeszcze raz pokazać światu, na co ją stać?","popularity":1.2574,"poster_path":"/d1CJaP0KJVM9pBkCh8up5MeZfGV.jpg","release_date":"2024-12-13","softcore":false,"video":false,"vote_average":6.438,"vote_count":282,"credit_id":"67b6b128e484fc215419efe2","department":"Crew","job":"Thanks"},{"adult":false,"backdrop_path":null,"genre_ids":[10751,10402,18],"id":1417675,"title":"Brother Verses Brother","original_language":"en","original_title":"Brother Verses Brother","overview":"","popularity":0.0707,"poster_path":"/852gxenWteTCrsf8YqFebdTA8eH.jpg","release_date":"2025-03-08","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"67ce9c1e856e13cb3d11141d","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/5QEqz09x8tU3QS0VaNVhpZjuh8k.jpg","genre_ids":[18,10749],"id":41291,"title":"One from the Heart","original_language":"en","original_title":"One from the Heart","overview":"","popularity":1.3723,"poster_path":"/5EyIQksa8C9tm82rHIJYGQXZ5Vs.jpg","release_date":"1982-02-11","softcore":false,"video":false,"vote_average":6.0,"vote_count":208,"credit_id":"67f440747b43bdce20ad559a","department":"Crew","job":"Presenter"},{"adult":false,"backdrop_path":"/dvareNwtZqPGoEt2eIrPAGqiLfL.jpg","genre_ids":[99],"id":24348,"title":"Powaqqatsi","original_language":"en","original_title":"Powaqqatsi","overview":"Powaqqatsi to sekwencja zdjęć nakręconych w Azji, Afryce i Ameryce Południowej. W pierwszej części filmu pokazane są obrazy \"dziewiczego\" i nieskażonego jeszcze zachodnią cywilizacją świata. Ten obraz jest później skonfrontowany z wielkimi zatłoczonymi aglomeracjami Azji i Ameryki Południowej, slamsami i zanieczyszczeniami. Tytuł filmu oznacza w indiańskim języku Hopi istotę, która by podążać dalej pochłania życiowe siły innych.","popularity":0.6643,"poster_path":"/xh8Pvtq4dYry9B4uRT3VbmSI4Wi.jpg","release_date":"1988-04-29","softcore":false,"video":false,"vote_average":7.271,"vote_count":181,"credit_id":"67f9a3e9cce7690230ad8dd3","department":"Crew","job":"Presenter"},{"adult":false,"backdrop_path":"/qNokCHKSkOZVgzAaNsmVYnGFWTS.jpg","genre_ids":[878,10402],"id":1500440,"title":"Captain EO","original_language":"en","original_title":"Captain EO","overview":"","popularity":0.7106,"poster_path":"/b7sZDYAMU9Ph42GiyTF8nyKVUKp.jpg","release_date":"1986-09-12","softcore":false,"video":false,"vote_average":7.889,"vote_count":36,"credit_id":"6853415ebb81c493c20cf01b","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/qNokCHKSkOZVgzAaNsmVYnGFWTS.jpg","genre_ids":[878,10402],"id":1500440,"title":"Captain EO","original_language":"en","original_title":"Captain EO","overview":"","popularity":0.7106,"poster_path":"/b7sZDYAMU9Ph42GiyTF8nyKVUKp.jpg","release_date":"1986-09-12","softcore":false,"video":false,"vote_average":7.889,"vote_count":36,"credit_id":"68534172e899fc13ff0cf06e","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/qNokCHKSkOZVgzAaNsmVYnGFWTS.jpg","genre_ids":[878,10402],"id":1500440,"title":"Captain EO","original_language":"en","original_title":"Captain EO","overview":"","popularity":0.7106,"poster_path":"/b7sZDYAMU9Ph42GiyTF8nyKVUKp.jpg","release_date":"1986-09-12","softcore":false,"video":false,"vote_average":7.889,"vote_count":36,"credit_id":"68534198e7d389b29479adaf","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":"/dNKFETDDujxm2PUN873Jwiw5VML.jpg","genre_ids":[27,14,9648],"id":1232569,"title":"Pinocchio Unstrung","original_language":"en","original_title":"Pinocchio: Unstrung","overview":"Śledzimy losy Jamesa, gdy jego dziadek, Geppetto, przedstawia mu pozornie magiczną lalkę, z którą zostaje najlepszym przyjacielem. Jednak James, nieświadomy naiwności Pinokia, gdy wprowadza go w świat, lalka wyrusza na krucjatę, by wyeliminować wszystko, co „złe”.","popularity":5.8223,"poster_path":"/sqhfUrPEeAlFf684FsVa8v1GYCD.jpg","release_date":"2026-06-24","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"6861cdb56e7c294367fdcc75","department":"Crew","job":"Thanks"},{"adult":false,"backdrop_path":"/dvareNwtZqPGoEt2eIrPAGqiLfL.jpg","genre_ids":[99],"id":24348,"title":"Powaqqatsi","original_language":"en","original_title":"Powaqqatsi","overview":"Powaqqatsi to sekwencja zdjęć nakręconych w Azji, Afryce i Ameryce Południowej. W pierwszej części filmu pokazane są obrazy \"dziewiczego\" i nieskażonego jeszcze zachodnią cywilizacją świata. Ten obraz jest później skonfrontowany z wielkimi zatłoczonymi aglomeracjami Azji i Ameryki Południowej, slamsami i zanieczyszczeniami. Tytuł filmu oznacza w indiańskim języku Hopi istotę, która by podążać dalej pochłania życiowe siły innych.","popularity":0.6643,"poster_path":"/xh8Pvtq4dYry9B4uRT3VbmSI4Wi.jpg","release_date":"1988-04-29","softcore":false,"video":false,"vote_average":7.271,"vote_count":181,"credit_id":"687148362ac14e0b4c1055c9","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":null,"genre_ids":[10749,35,10402],"id":1266134,"title":"Glimpses of the Moon","original_language":"en","original_title":"Glimpses of the Moon","overview":"","popularity":0.3541,"poster_path":null,"release_date":"","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"6876ab400d03abf7256eeca5","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/6CRHoIGM25wZXpGgQzetmmnALzN.jpg","genre_ids":[9648,14,27],"id":78381,"title":"Twixt","original_language":"en","original_title":"Twixt","overview":"Hal Baltimore jest podrzędnym, nie stroniącym od alkoholu pisarzem. Poznajemy go w momencie, w którym przyszło mu podpisywać swoją książkę w małej mieścinie Swan Valley. Miejscowy szeryf opowiada mu o tajemniczej masakrze z przeszłości i sugeruje, że może pomóc Halowi we wspólnym napisaniu o tym książki. Mimo początkowej odmowy, po serii niepokojących snów odnośnie historii miasta, w których często pojawia się Edgar Allan Poe , pisarz decyduje się zgłębić tę historię.","popularity":1.3809,"poster_path":"/jSn7DVovIFeTSiwwoziSYpJFaaS.jpg","release_date":"2011-09-10","softcore":false,"video":false,"vote_average":5.106,"vote_count":329,"credit_id":"6876ab6fb605d870d4798154","department":"Sound","job":"Songs"},{"adult":false,"backdrop_path":"/61TkJ1U9zBF6C7JczCswA8BQ3AT.jpg","genre_ids":[35,18],"id":20912,"title":"Ona mnie nienawidzi","original_language":"en","original_title":"She Hate Me","overview":"Jack Armstrong jest vice prezesem znanej i szanowanej firmy farmaceutycznej na rynku Progeia. Ta sama firma jednak zaczyna mieć problemy. Jack nie pomaga w ich rozwiązaniu a wręcz przeciwnie. Pragnie wyjaśnić bardzo kontrowersyjną sprawę dzięki czemu zostaje zwolniony i zaczyna mieć poważne problemy. Jego oszczędności zostały zamrożone, dowiaduje się, że jego ex narzeczona jest lesbijką i na domiar złego zapragnęła mieć dziecko... właśnie z nim. Wraz z partnerką proponują mu 5 tysięcy dolarów. Nie mając pieniędzy na koncie, zgadza się. Interes się rozkręca...","popularity":1.0796,"poster_path":"/jjfzD3AEABBuJRnCJAZhUuwQvPi.jpg","release_date":"2004-07-30","softcore":false,"video":false,"vote_average":5.154,"vote_count":123,"credit_id":"68ac00fe99963babd29db1a8","department":"Crew","job":"Thanks"},{"adult":false,"backdrop_path":"/6CRHoIGM25wZXpGgQzetmmnALzN.jpg","genre_ids":[9648,14,27],"id":78381,"title":"Twixt","original_language":"en","original_title":"Twixt","overview":"Hal Baltimore jest podrzędnym, nie stroniącym od alkoholu pisarzem. Poznajemy go w momencie, w którym przyszło mu podpisywać swoją książkę w małej mieścinie Swan Valley. Miejscowy szeryf opowiada mu o tajemniczej masakrze z przeszłości i sugeruje, że może pomóc Halowi we wspólnym napisaniu o tym książki. Mimo początkowej odmowy, po serii niepokojących snów odnośnie historii miasta, w których często pojawia się Edgar Allan Poe , pisarz decyduje się zgłębić tę historię.","popularity":1.3809,"poster_path":"/jSn7DVovIFeTSiwwoziSYpJFaaS.jpg","release_date":"2011-09-10","softcore":false,"video":false,"vote_average":5.106,"vote_count":329,"credit_id":"68b7a27b5107ff83b51baf1d","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":"/cQtFpE3cyWw2AWdRb5VGU9glOj8.jpg","genre_ids":[36,10752,18,28],"id":27329,"title":"สุริโยไท","original_language":"th","original_title":"สุริโยไท","overview":"","popularity":0.7769,"poster_path":"/5dwSM3LpzahEyY0OEwv4JHZ4Zxh.jpg","release_date":"2001-08-17","softcore":false,"video":false,"vote_average":5.8,"vote_count":23,"credit_id":"68bed422fcc5260ee09c08a3","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/2Cf8V0iQx0c52IxeLdxOvjI2bBf.jpg","genre_ids":[35,80,18],"id":11293,"title":"Papierowy księżyc","original_language":"en","original_title":"Paper Moon","overview":"Ryan O'Neal gra wygadanego oszusta Mosesa Praya, który w dobie Wielkiego Kryzysu przemierza Kansas z ładunkiem luksusowo wydanych Biblii i listą świeżych wdów, którym zamierza je wcisnąć. Dziewięcioletnia, ćmiąca papierosa za papierosem Addie jest sierotą, która przyczepiła się do Mosesa w nadziei, że pokaże hochsztaplerowi jeden czy dwa swoje triki. Madeline Kahn kreśli zabawną kreację neurotycznej Trixie Delight, która podróżuje wraz z nimi do chwili, gdy Addie nie wpadnie na pomysł, że może ona zakłócić bezpośrednie relacje Addie z Mosesem do czego, oczywiście, dojść nie może.","popularity":1.7545,"poster_path":"/qRrXYEW9dQSOns3hyQuPaC4UlbO.jpg","release_date":"1973-05-09","softcore":false,"video":false,"vote_average":7.9,"vote_count":825,"credit_id":"68dded81fea56a2848bdfa76","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/3K91XbePXbxLqN6d4Ntq4AvJTxg.jpg","genre_ids":[99],"id":944234,"title":"Jerry Brown: The Shape of Things to Come","original_language":"en","original_title":"Jerry Brown: The Shape of Things to Come","overview":"","popularity":0.1192,"poster_path":"/8qpNF5TJ8rJQa5abXPAHmIofIue.jpg","release_date":"1980-03-28","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"68eabe952e0c8e3df81a24a6","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/7qsKE8GsgjreeQ2mTLd5oKZ7Tbf.jpg","genre_ids":[28,18,36,10752],"id":11953,"title":"Sobowtór","original_language":"ja","original_title":"影武者","overview":"XVI-wieczna Japonia. Shingen, przywódca klanu Takeda, mający opinię niezwyciężonego, podczas oblężenia zamku Noda zostaje śmiertelnie ranny. Wiedząc, że jego syn Katsuyori nie posiada takiego jak on autorytetu i może doprowadzić do upadku rodu, umierający Shingen nakazuje utrzymać fakt swojej śmierci w tajemnicy. Jego miejsce ma zająć w tym czasie sobowtór. Wybór pada na Kagemushę. Mistyfikacja zostaje przeprowadzona z powodzeniem. Jednak wkrótce szpiedzy zaczynają coś podejrzewać.","popularity":2.8023,"poster_path":"/4sGatMoY0DXboNOOp9ir6PfsNZl.jpg","release_date":"1980-04-26","softcore":false,"video":false,"vote_average":7.8,"vote_count":737,"credit_id":"68ebda2aad8db28a55645eae","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/z9bZUl7ZDRibq9koRdVskI75FN7.jpg","genre_ids":[28,10752,27,18,36],"id":1588432,"title":"Apocalypse Retold!","original_language":"en","original_title":"Apocalypse Retold!","overview":"","popularity":0.0907,"poster_path":"/j1HlcNZp9nGYaOJkcZgqTndjsXc.jpg","release_date":"","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"6927d9c333220d1d62d9cf49","department":"Writing","job":"Original Concept"},{"adult":false,"backdrop_path":"/geLtI8aPjZMd1NIDXD51kunZEab.jpg","genre_ids":[99,35],"id":84765,"title":"Mababangong Bangungot","original_language":"tl","original_title":"Mababangong Bangungot","overview":"","popularity":0.231,"poster_path":"/lkGgP0AxBgwn2hE7WxOapc3ZQe6.jpg","release_date":"1979-01-08","softcore":false,"video":false,"vote_average":7.3