zyzn z trzech różnych epok. Trzy życia ściśle ze sobą powiązane seksualnością i pożądaniem, bólem i dziedzictwem, inspirowane jednym z ostatnich niedokończonych dzieł Federico Garcii Lorci.","popularity":3.2979,"poster_path":"/td0vmSt3XrrJEDQ97eP5XVubHsu.jpg","release_date":"2026-10-02","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"6a10afb46d4b252e38e16569","department":"Production","job":"Associate Producer"}],"id":309}