,"popularity":0.0905,"poster_path":"/zfkXdsU9CWlnAezPzA8UNKQ0Iyt.jpg","release_date":"1976-01-01","softcore":false,"video":false,"vote_average":7.0,"vote_count":1,"credit_id":"64b58f7c12197e00ff023b21","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":null,"genre_ids":[35],"id":1153169,"title":"Sea caritativo","original_language":"es","original_title":"Sea caritativo","overview":"","popularity":0.0905,"poster_path":"/zfkXdsU9CWlnAezPzA8UNKQ0Iyt.jpg","release_date":"1976-01-01","softcore":false,"video":false,"vote_average":7.0,"vote_count":1,"credit_id":"64b58f73e0ca7f01253e68c2","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":null,"genre_ids":[],"id":1153174,"title":"Las tres ventajas de Ponte","original_language":"es","original_title":"Las tres ventajas de Ponte","overview":"","popularity":0.0748,"poster_path":"/mqCqyqTzHqSoeeCpRcQJ6MEYSUC.jpg","release_date":"1977-01-01","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"64b5923c0e4fc8519fec5f92","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":null,"genre_ids":[],"id":1153175,"title":"Complementos","original_language":"es","original_title":"Complementos","overview":"","popularity":0.1562,"poster_path":"/z4YT0N4BeQ09s8ZIlD245DQLWqf.jpg","release_date":"1977-01-01","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"64b592a3e0ca7f01442b33b9","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":null,"genre_ids":[],"id":1153175,"title":"Complementos","original_language":"es","original_title":"Complementos","overview":"","popularity":0.1562,"poster_path":"/z4YT0N4BeQ09s8ZIlD245DQLWqf.jpg","release_date":"1977-01-01","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"64b5929bac416100e2400bcd","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":null,"genre_ids":[],"id":1153174,"title":"Las tres ventajas de Ponte","original_language":"es","original_title":"Las tres ventajas de Ponte","overview":"","popularity":0.0748,"poster_path":"/mqCqyqTzHqSoeeCpRcQJ6MEYSUC.jpg","release_date":"1977-01-01","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"64b59231378062011c8c517d","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/gRxlzFYDKdzNnhu8OFIKm3i9b6f.jpg","genre_ids":[18,80],"id":507505,"title":"Anioł","original_language":"es","original_title":"El Ángel","overview":"Film oparty na prawdziwej historii seryjnego mordercy Carlosa Robledo Pucha zwanego \"Aniołem śmierci\". Wibrujące rock-n-rollem Buenos Aires, lata 70-te. 17-letni Carlitos o twarzy anioła (Lorenzo Ferro) przemierza ulice, jakby należały do niego. Od najmłodszych lat wykorzystuje wszelkie okazje by kraść. To fascynacja, której nie chce się oprzeć. Kiedy w nowej szkole spotyka Ramona (Chino Darín) natychmiast stają się przyjaciółmi.","popularity":0.7794,"poster_path":"/8y4LQSu4DdtJVtrKjaSDrXpxWhd.jpg","release_date":"2018-08-09","softcore":false,"video":false,"vote_average":7.377,"vote_count":576,"credit_id":"5b7c7ba29251414a060055da","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/s1K8dZkKIhhsrdUPE27AWaiK4fQ.jpg","genre_ids":[18],"id":44413,"title":"Święta dziewczyna","original_language":"es","original_title":"La niña santa","overview":"Amalia śpiewa w prowincjonalnym chórze. Podobnie jak jej koleżanki zadaje sobie pytania dotyczące wiary i religii. Gdy do hotelu, w którym mieszka razem z matką, przyjeżdża na konferencję doktor Jano, dziewczyna przekonana jest, iż ma do spełnienia misję uratować tego człowieka przed grzechem. Sprawa jest jednak skomplikowana. Mężczyzna uwodzi jej matkę, ale jednocześnie utrzymuje dość niepokojący związek z nią samą.","popularity":0.5757,"poster_path":"/yKIKks94EwFpDNFt5ZAPh3qpBpA.jpg","release_date":"2004-05-06","softcore":false,"video":false,"vote_average":6.6,"vote_count":102,"credit_id":"5c2f5985c3a3680b8ca2818e","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/9JqIR7bBO0uofsJiONgYAX2yw1R.jpg","genre_ids":[18,36],"id":326382,"title":"Zama","original_language":"es","original_title":"Zama","overview":"Tytułowy bohater Diego de Zama to zarządca rezydujący na peryferiach XVIII-wiecznej hiszpańskiej kolonii. Żyje w stanie ciągłego oczekiwania na awans, pragnie wykazać się przed mocodawcami i zostać przez nich dostrzeżony. Wypatrując przyszłości, nie dostrzega jednak wartości tego, co dzieje się wokół niego. Jest więźniem urzędu, człowiekiem uporczywie przywiązanym do rytuałów, patrzącym na siebie przez pryzmat swojej pozycji społecznej. Tropikalny upał i wilgoć szybko jednak demaskują pustkę przywiezionych z Europy norm. Im rozpaczliwiej bohater trzyma się sztywnych reguł, których w jego mniemaniu przestrzegać powinien urzędnik, kolonizator i dumny biały mężczyzna, tym więcej czeka go upokorzeń.","popularity":0.7775,"poster_path":"/v6zIZzxjvf6ZFSJoMF2hmAHsGbL.jpg","release_date":"2017-09-28","softcore":false,"video":false,"vote_average":6.545,"vote_count":177,"credit_id":"5c2f5a31c3a3682919a6d3c9","department":"Production","job":"Co-Producer"},{"adult":false,"backdrop_path":"/mhhzbMnIIdVFOeBzKtLXk66Vbo3.jpg","genre_ids":[99],"id":500850,"title":"El silencio de otros","original_language":"es","original_title":"El silencio de otros","overview":"","popularity":0.4841,"poster_path":"/yji89RudI5fK3QD04oE5vpampqa.jpg","release_date":"2019-01-25","softcore":false,"video":false,"vote_average":8.0,"vote_count":87,"credit_id":"5c622d41c3a3684f97d6faa9","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/o1JapnInSBCgedfWnj15ytjGC70.jpg","genre_ids":[18],"id":519010,"title":"Ból i blask","original_language":"es","original_title":"Dolor y gloria","overview":"Salvador Mallo, kultowy hiszpański reżyser filmowy, który stroni od mediów i usilnie strzeże swojej prywatności, przeżywa na nowo najważniejsze momenty swojego życia. Wraca myślami do dzieciństwa, przywołuje obrazy pierwszej wielkiej miłości i bólu rozstania. Wspomina pierwsze spotkanie z kinem, które stało się sensem jego życia.","popularity":2.2089,"poster_path":"/bbNZxjH0cRbBMoigBkdOPyOqJKs.jpg","release_date":"2019-03-22","softcore":false,"video":false,"vote_average":7.374,"vote_count":1918,"credit_id":"5c936a790e0a261042e87548","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":"/v0Np18yaYujbzH5oKR03opkiEZa.jpg","genre_ids":[35,18],"id":645693,"title":"Nieva en Benidorm","original_language":"es","original_title":"Nieva en Benidorm","overview":"","popularity":0.4115,"poster_path":"/haxULWxuggMZbKl3fh5xyYgHjzn.jpg","release_date":"2020-12-11","softcore":false,"video":false,"vote_average":5.6,"vote_count":33,"credit_id":"5dc291b9a9b9a400111b8ad7","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/aB1QtsJE3AZN3TNp4iX3Dt2eWs3.jpg","genre_ids":[18],"id":671577,"title":"Ludzki głos","original_language":"en","original_title":"The Human Voice","overview":"Pedro Almodóvar w swoim pierwszym anglojęzycznym filmie inspiruje się monodramem Jeana Cocteau i daje pole do popisu Tildzie Swinton. Miniatura hiszpańskiego mistrza trwa zaledwie 30 minut, ale z miejsca stała się sensacją niedawnego festiwalu w Wenecji. \"Ludzki głos\" to błyskotliwy monolog (a właściwie fragment dialogu) Swinton o samotności, tęsknocie, zaczynaniu życia od nowa. Almodóvar bawi się kinem, tworzy umowną przestrzeń, mruga do nas, a my toniemy w jego uniwersum zafrasowani i uśmiechnięci jednocześnie. \"Ludzki głos\" to także komentarz do pandemicznego zamknięcia – pełen smutku, ironii i nadziei (zdjęcia powstawały w trakcie hiszpańskiego lockdownu). W perfekcyjnie zrealizowanym filmie znajdziemy wszystko to, za co kochamy kino jednego z najbardziej cenionych w filmowym świecie reżyserów – Almodóvarowskie kolory, świetne kostiumy, czułość, inteligencję i przewrotny humor.","popularity":0.8807,"poster_path":"/uWmubgPZt8A4rhRZGfusJTgunUF.jpg","release_date":"2020-09-03","softcore":false,"video":false,"vote_average":6.7,"vote_count":252,"credit_id":"5e4160d79603310015ef9a36","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":null,"genre_ids":[35],"id":712756,"title":"Dos putas, o Historia de Amor que Termina en Boda","original_language":"pt","original_title":"Dos putas, o Historia de Amor que Termina en Boda","overview":"","popularity":0.158,"poster_path":"/w2JFyUNzBvLkxos5RDBIvcbOJWm.jpg","release_date":"1974-02-01","softcore":false,"video":false,"vote_average":6.5,"vote_count":2,"credit_id":"5eda6cb821c4ca0020eeba9a","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/aB1QtsJE3AZN3TNp4iX3Dt2eWs3.jpg","genre_ids":[18],"id":671577,"title":"Ludzki głos","original_language":"en","original_title":"The Human Voice","overview":"Pedro Almodóvar w swoim pierwszym anglojęzycznym filmie inspiruje się monodramem Jeana Cocteau i daje pole do popisu Tildzie Swinton. Miniatura hiszpańskiego mistrza trwa zaledwie 30 minut, ale z miejsca stała się sensacją niedawnego festiwalu w Wenecji. \"Ludzki głos\" to błyskotliwy monolog (a właściwie fragment dialogu) Swinton o samotności, tęsknocie, zaczynaniu życia od nowa. Almodóvar bawi się kinem, tworzy umowną przestrzeń, mruga do nas, a my toniemy w jego uniwersum zafrasowani i uśmiechnięci jednocześnie. \"Ludzki głos\" to także komentarz do pandemicznego zamknięcia – pełen smutku, ironii i nadziei (zdjęcia powstawały w trakcie hiszpańskiego lockdownu). W perfekcyjnie zrealizowanym filmie znajdziemy wszystko to, za co kochamy kino jednego z najbardziej cenionych w filmowym świecie reżyserów – Almodóvarowskie kolory, świetne kostiumy, czułość, inteligencję i przewrotny humor.","popularity":0.8807,"poster_path":"/uWmubgPZt8A4rhRZGfusJTgunUF.jpg","release_date":"2020-09-03","softcore":false,"video":false,"vote_average":6.7,"vote_count":252,"credit_id":"5f27e91fd94035003561c377","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":null,"genre_ids":[],"id":734008,"title":"Sexo Va, Sexo Viene","original_language":"en","original_title":"Sexo Va, Sexo Viene","overview":"","popularity":0.0692,"poster_path":"/9CW3CWYPzLqUXsJJTZ2gG4U9T1y.jpg","release_date":"1977-12-30","softcore":false,"video":false,"vote_average":7.0,"vote_count":2,"credit_id":"5f3a71fc22df2e00385e7846","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":null,"genre_ids":[],"id":734008,"title":"Sexo Va, Sexo Viene","original_language":"en","original_title":"Sexo Va, Sexo Viene","overview":"","popularity":0.0692,"poster_path":"/9CW3CWYPzLqUXsJJTZ2gG4U9T1y.jpg","release_date":"1977-12-30","softcore":false,"video":false,"vote_average":7.0,"vote_count":2,"credit_id":"5f3a720e7390c0003964cb62","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":"/w81qHqr1CdbdRco8jpmu6lXMqyk.jpg","genre_ids":[18],"id":766798,"title":"Matki równoległe","original_language":"es","original_title":"Madres paralelas","overview":"Janis jest doświadczoną fotografką, która poświęca się w pełni pracy zawodowej. Pewnego dnia zachodzi przypadkiem w ciążę z żonatym mężczyzną, co wywraca jej życie do góry nogami. Ana to z kolei pochodząca z rozbitej rodziny młoda dziewczyna, która chciałaby zapomnieć jak najszybciej o chłopaku, który ją zapłodnił. Spotykają się na oddziale porodowym i z miejsca nawiązują silną więź, wzmocnioną faktem, że obie rodzą niemal w tym samym czasie. Matki równoległe to historia dwóch samotnych kobiet, które nie podejrzewają, że losy ich i ich dzieci będą splatały się w zupełnie niespodziewanych momentach ich życia.","popularity":2.1393,"poster_path":"/tHuEkAEygmedmF0nnx2pZVIw88M.jpg","release_date":"2021-10-08","softcore":false,"video":false,"vote_average":6.798,"vote_count":1039,"credit_id":"5fb933393c887d003ea7bd1f","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/bkqrIv8a5PhQSXBSBW5qWvE7fiC.jpg","genre_ids":[35],"id":492912,"title":"Folle... Folle... ¡Fólleme Tín!","original_language":"es","original_title":"Folle... Folle... ¡Fólleme Tín!","overview":"","popularity":0.3282,"poster_path":"/u9t25jSOwvY0Gi4Fs0pWYLtpQw0.jpg","release_date":"1978-12-16","softcore":false,"video":false,"vote_average":4.167,"vote_count":6,"credit_id":"601f0e75e27260003e717e4c","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":"/9Xx0BCkxDsF47niAPsb8lQ0O9Qu.jpg","genre_ids":[18,35],"id":1088514,"title":"W pokoju obok","original_language":"es","original_title":"La habitación de al lado","overview":"Ingrid, autorka bestsellerów, odnawia relację ze swoją przyjaciółką Marthą, dziennikarką wojenną, z którą straciła kontakt na wiele lat. Obie kobiety zanurzają się w swojej przeszłości, dzieląc się wspomnieniami, anegdotami, sztuką, filmami — jednak Martha ma prośbę, która wystawi na próbę ich nowo wzmocnioną więź.","popularity":2.9754,"poster_path":"/aFeEXvKtKZ9wY3EMsR7yp9Izfej.jpg","release_date":"2024-10-07","softcore":false,"video":false,"vote_average":6.7,"vote_count":680,"credit_id":"67869de6db4fe022ad4e9b3c","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":"/kOUV5WbisWMg56d8eB45ZHEVxYq.jpg","genre_ids":[18,53],"id":1151272,"title":"Sirāt","original_language":"es","original_title":"Sirāt","overview":"W Maroku, w masywie pustyni Saghro, Louis, któremu towarzyszy syn Stéphane, poszukuje swojej najstarszej córki Mariny, która zaginęła. Zbierają się tam różnorodne grupy imprezowiczów szukających kolejnej imprezy na krańcu afrykańskiego kontynentu. Wyruszają więc w ognistą odyseję w głąb pustyni Sahary, lustra piasku, które stawia bohaterów w obliczu ich własnych ograniczeń.","popularity":7.2638,"poster_path":"/edcxhFv2S8oD2fsZTNUK1xvJvzE.jpg","release_date":"2025-06-06","softcore":false,"video":false,"vote_average":6.842,"vote_count":669,"credit_id":"67f80954d4c444a1cc998a04","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":null,"genre_ids":[10402],"id":1541675,"title":"Queen of the Falls","original_language":"en","original_title":"Queen of the Falls","overview":"","popularity":0.2466,"poster_path":null,"release_date":"","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"6914d6b5b83adf228eac2155","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/njHtlpln6iBMonTkXGI7plRMaIM.jpg","genre_ids":[35,18],"id":8220,"title":"Pośród ciemności","original_language":"es","original_title":"Entre tinieblas","overview":"Yolanda zarabia na życie śpiewając wieczorami w zapuszczonym, nocnym klubie. Niestety, po tym jak jej chłopak umiera z przedawkowania narkotyków, w obawie przed policją zmuszona jest szukać schronienia w klasztorze. Czy w zakonie znajdzie azyl? Pedro Almodovar zaproponował kolejną, interesującą komedię. Jak w poprzednich dziełach, tak i teraz przekorny Hiszpan - postmodernista opowiada, bawi ale przede wszystkim prowokuje.","popularity":0.9448,"poster_path":"/c3BXtVcw7YuwhjfSmya6HnEePEt.jpg","release_date":"1983-10-03","softcore":false,"video":false,"vote_average":6.593,"vote_count":209,"credit_id":"69581337a00713496acc8cba","department":"Sound","job":"Songs"},{"adult":false,"backdrop_path":"/9aCRXFWT1rd1nZDcEtWILKb2Sap.jpg","genre_ids":[18,10749],"id":64,"title":"Porozmawiaj z nią","original_language":"es","original_title":"Hable con ella","overview":"Młody pielęgniarz Benigno i czterdziestoparoletni pisarz Marco po raz pierwszy spotykają się w teatrze. Pomimo ciemności, Benigno zauważa łzy płynące po twarzy Marco, jednak nie ma odwagi, by go zagadnąć. Jakiś czas potem obaj mężczyźni znów się spotykają, tym razem w szpitalu, gdzie pracuje Benigno. Lydia, dziewczyna Marco, która jest zawodowym torreadorem, po wypadku na arenie znajduje się w stanie śpiączki. Benigno natomiast opiekuje się Alicią, młodą uczennicą szkoły baletowej, także pogrążoną w śpiączce. Kiedy Marco przechodzi obok pokoju Alicii, Benigno nie waha się go zaczepić. To początek wyjątkowej przyjaźni...","