.5,"vote_count":4,"credit_id":"652c1f97358da701406cd481","department":"Visual Effects","job":"Key Animation"},{"adult":false,"backdrop_path":"/dzMhad0fWj0Ds9viupza6wT8QRt.jpg","genre_ids":[16],"id":508884,"title":"毛虫のボロ","original_language":"ja","original_title":"毛虫のボロ","overview":"","popularity":0.6646,"poster_path":"/1hSkWvzTKxEyDPqQCoi6fbVsOFW.jpg","release_date":"2018-03-21","softcore":false,"video":false,"vote_average":7.0,"vote_count":6,"credit_id":"617a3b62e9da6900434a4922","department":"Art","job":"Storyboard Artist"},{"adult":false,"backdrop_path":"/a0GM57AnJtNi7lMOCamniiyV10W.jpg","genre_ids":[16,14,18],"id":508883,"title":"Chłopiec i czapla","original_language":"ja","original_title":"君たちはどう生きるか","overview":"Podczas II wojny światowej i bombardowania Tokio jedenastoletni Mahito Maki traci matkę. Ojciec chłopca żeni się niebawem z Natsuko, młodszą siostrą swojej zmarłej żony i przenosi się z rodziną do domu na wsi. Przygnębiony Mahito, pełen niepokoju w związku z nową sytuacją, niechętnie zaczyna odkrywać okolicę. Tak poznaje tajemniczą, mówiącą ludzkim głosem czaplę siwą i trafia na opuszczoną wieżę w pobliskim lesie, do której wejście rozpoczyna ciąg zaskakujących i cudownych wydarzeń.","popularity":8.9368,"poster_path":"/n2ArOgkidv17tIHnt9X6EnhvLpW.jpg","release_date":"2023-07-14","softcore":false,"video":false,"vote_average":7.405,"vote_count":2640,"credit_id":"617a3b4ee9da6900434a48f6","department":"Art","job":"Storyboard Artist"},{"adult":false,"backdrop_path":"/eDuBJ9Lf8empaGgXHe4ciUR7iFM.jpg","genre_ids":[16],"id":709447,"title":"マダラン界","original_language":"ja","original_title":"マダラン界","overview":"","popularity":0.2364,"poster_path":"/oVPoKHSyMptyV6bPIOzTK63iZMd.jpg","release_date":"2007-04-18","softcore":false,"video":false,"vote_average":7.0,"vote_count":1,"credit_id":"617a3b73f2cf2500619701cc","department":"Art","job":"Storyboard Artist"},{"adult":false,"backdrop_path":"/xtAT3ivZ4gCuR47JcwhgxhBqfUC.jpg","genre_ids":[16,9648,12,35,10770],"id":332324,"title":"名探偵ホームズ: 青い紅玉 / 海底の財宝","original_language":"ja","original_title":"名探偵ホームズ: 青い紅玉 / 海底の財宝","overview":"","popularity":0.633,"poster_path":"/n4sY5KkhPwW6IhvYXaS0ZPPexXK.jpg","release_date":"1984-03-11","softcore":false,"video":true,"vote_average":6.6,"vote_count":4,"credit_id":"5510abc9c3a36801d200007f","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/uAfhsySkr1UzQg1zdg3dZQRz9Fd.jpg","genre_ids":[16,10751,35],"id":10193,"title":"Toy Story 3","original_language":"en","original_title":"Toy Story 3","overview":"Andy stał się już dużym chłopcem i wybiera się na studia. Pragnie zabrać wraz ze sobą swą ulubioną zabawkę z dzieciństwa Kowboja Chudego, a resztę jego podopiecznych mama chłopca postanawia oddać do miejskiego przedszkola. W obawie o los swoich przyjaciół Chudy postanawia ich nie opuszczać. W przedszkolu zabawki nawiązują nowe znajomości, oraz napotykają na niebezpieczeństwo ze strony niesfornych przedszkolaków. Od tej pory Chudy wraz z przyjaciółmi robią wszystko by się stamtąd wydostać i wrócić do domu.","popularity":24.657,"poster_path":"/AbbXspMOwdvwWZgVN0nabZq03Ec.jpg","release_date":"2010-06-16","softcore":false,"video":false,"vote_average":7.806,"vote_count":15739,"credit_id":"5617049dc3a3680fb60008e9","department":"Crew","job":"Thanks"},{"adult":false,"backdrop_path":"/7Z7WVzJsSReG8B0CaPk0bvWD7tK.jpg","genre_ids":[14,16,10751],"id":51739,"title":"Tajemniczy świat Arrietty","original_language":"ja","original_title":"借りぐらしのアリエッティ","overview":"Shao jest kilkunastoletnim chłopcem, który od urodzenia ciężko choruje na serce i ma wkrótce przejść operację będącą ostatnią szansą na uratowanie jego życia. Jego rodzice rozstali się, a matka pracuje za granicą. Aby chłopiec spokojnie odpoczął przed zabiegiem, jego ciotka (siostra babci) zabiera go do swojego otoczonego zielenią domu na przedmieściach. Tam pozostaje pod opieką niemłodej już gosposi Haru. Shao szybko odkrywa, że w domu mieszkają maleńcy ludzie, którzy utrzymują się podkradając (choć sami nazywają to „pożyczaniem”) różne drobiazgi z domu, takie jak pojedyncze kostki cukru, szpilki czy chusteczki higieniczne. Mali ludzie panicznie boją się tych dużych i starają się żyć w maksymalnej izolacji. Mimo to Shao udaje się nawiązać kontakt ze swoją rówieśniczką z rodziny małych ludzi, imieniem Arrietty.","popularity":6.8143,"poster_path":"/2Jkv1qMiDMygjZaXzvHBB85nQHn.jpg","release_date":"2010-07-16","softcore":false,"video":false,"vote_average":7.668,"vote_count":3172,"credit_id":"657dab957ad08c06f44f92dc","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":"/938lqhAQaO3hmLg44VbUR7OqlMs.jpg","genre_ids":[16,18,36,10749],"id":149870,"title":"Zrywa się wiatr","original_language":"ja","original_title":"風立ちぬ","overview":"Od najmłodszych lat Jiro zafascynowany jest samolotami zaprojektowanymi przez włoskiego inżyniera lotnictwa Gianni Caproniego. Chłopiec śni o lataniu i podniebnych przygodach. Niestety, wrodzona wada wzroku nie pozwala mu na karierę pilota. Udaje mu się jednak zostać jednym z największych i najbardziej kreatywnych konstruktorów samolotów w całej Azji.","popularity":4.1528,"poster_path":"/3bIxQuItLeBAkOUBqyvaCI8emgw.jpg","release_date":"2013-07-20","softcore":false,"video":false,"vote_average":7.791,"vote_count":3374,"credit_id":"657da9a9fd140b074c824e3e","department":"Writing","job":"Comic Book"},{"adult":false,"backdrop_path":"/jBKNKgAz8qudiWuPirebcy0sDIZ.jpg","genre_ids":[16,18],"id":375079,"title":"ユキの太陽","original_language":"ja","original_title":"ユキの太陽","overview":"","popularity":0.6472,"poster_path":"/pL9bbqQvZTymfThzAtzHwzx9e6A.jpg","release_date":"1972-12-29","softcore":false,"video":false,"vote_average":5.915,"vote_count":71,"credit_id":"56d087bec3a3681e440074b1","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/fCf8WfsRJEDFf1N6gA6o4ICRYp.jpg","genre_ids":[16,12,35,80],"id":15371,"title":"Lupin Trzeci: Zamek Cagliostro","original_language":"ja","original_title":"ルパン三世 カリオストロの城","overview":"Lupin, jego pomocnik Jigen i samuraj o imieniu Goemon wyruszają do zamku hrabiego Cagliostro, aby przyjrzeć się prowadzonemu tam procederowi fałszowania pieniędzy.","popularity":4.0333,"poster_path":"/169MlJFokbOUFrIWoAWugvRjb0A.jpg","release_date":"1979-07-06","softcore":false,"video":false,"vote_average":7.507,"vote_count":1141,"credit_id":"620232d84df29100cdf3f9ef","department":"Art","job":"Storyboard Artist"},{"adult":false,"backdrop_path":"/4qwGWjjqEGPiWKXYWL15BrXldmM.jpg","genre_ids":[16,10751,35],"id":21036,"title":"パンダコパンダ","original_language":"ja","original_title":"パンダコパンダ","overview":"","popularity":1.704,"poster_path":"/6hLytFOeqLX5dvwYNG0Zr3yGb16.jpg","release_date":"1972-12-17","softcore":false,"video":false,"vote_average":6.3,"vote_count":93,"credit_id":"638a171869eb9000cab5e2d1","department":"Visual Effects","job":"Key Animation"},{"adult":false,"backdrop_path":"/zmYkGaak1X76lkP4Q9zobaOa70J.jpg","genre_ids":[35,14,16],"id":695839,"title":"パンダコパンダ","original_language":"ja","original_title":"パンダコパンダ","overview":"","popularity":1.9919,"poster_path":"/aVpmtxegetfS75boajcUBiooSa1.jpg","release_date":"1972-12-17","softcore":false,"video":false,"vote_average":7.7,"vote_count":3,"credit_id":"63cbf9869a643500872acc7b","department":"Art","job":"Concept Artist"},{"adult":false,"backdrop_path":"/zmYkGaak1X76lkP4Q9zobaOa70J.jpg","genre_ids":[35,14,16],"id":695839,"title":"パンダコパンダ","original_language":"ja","original_title":"パンダコパンダ","overview":"","popularity":1.9919,"poster_path":"/aVpmtxegetfS75boajcUBiooSa1.jpg","release_date":"1972-12-17","softcore":false,"video":false,"vote_average":7.7,"vote_count":3,"credit_id":"63cbfaaf09dda40083846972","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":"/a3kswBaNMLawrUUSEQM9gVjdh63.jpg","genre_ids":[10751,16,12,35],"id":34834,"title":"どうぶつ宝島","original_language":"ja","original_title":"どうぶつ宝島","overview":"","popularity":0.9339,"poster_path":"/9aV7LFv7cH4YbyaAkNNHDyvbVLL.jpg","rel