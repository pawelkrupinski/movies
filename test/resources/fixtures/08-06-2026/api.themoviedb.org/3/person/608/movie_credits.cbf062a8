inal_language":"ja","original_title":"毛虫のボロ","overview":"","popularity":0.6646,"poster_path":"/1hSkWvzTKxEyDPqQCoi6fbVsOFW.jpg","release_date":"2018-03-21","softcore":false,"video":false,"vote_average":7.0,"vote_count":6,"credit_id":"66917505ce5b19b3ef43dc84","department":"Writing","job":"Original Story"},{"adult":false,"backdrop_path":"/o8CNEAWtee8q2Z19hYuM97VHt8U.jpg","genre_ids":[16,35,10751],"id":123867,"title":"パンダコパンダ 雨ふりサーカスの巻","original_language":"ja","original_title":"パンダコパンダ 雨ふりサーカスの巻","overview":"","popularity":0.9338,"poster_path":"/wh3NlPr1iIOueJXazyNkhT4V01I.jpg","release_date":"1973-03-17","softcore":false,"video":false,"vote_average":6.378,"vote_count":45,"credit_id":"669176e172ed78434b3c34ea","department":"Writing","job":"Original Story"},{"adult":false,"backdrop_path":"/x5ufEAM7bS7DVXaovApamQh5BNE.jpg","genre_ids":[16,14,12],"id":37933,"title":"Opowieści z Ziemiomorza","original_language":"ja","original_title":"ゲド戦記","overview":"Bohaterem filmu jest Ged, Mag, który staje przed wyzwaniem znalezienia przyczyn tajemniczych wydarzeń dziejących się wokół. Wszyscy bowiem zachowują się w sposób niezrozumiale dziwny; Królestwo pogrąża się w chaosie, a do świata ludzi przenikają smoki, które dotąd nie miały tam dostępu. Ged wyrusza w podróż, która ma doprowadzić go do rozwiązania tych tajemniczych zdarzeń. Wyprawa ta przyniesie mu wiele przygód, ale i niebezpieczeństwo utraty mocy.","popularity":3.4473,"poster_path":"/sSZ4J67dHYQg9lXIJnkf4LEzylo.jpg","release_date":"2006-07-29","softcore":false,"video":false,"vote_average":6.532,"vote_count":1489,"credit_id":"66917491735d0d509e6e1b17","department":"Writing","job":"Original Story"},{"adult":false,"backdrop_path":"/4qwGWjjqEGPiWKXYWL15BrXldmM.jpg","genre_ids":[16,10751,35],"id":21036,"title":"パンダコパンダ","original_language":"ja","original_title":"パンダコパンダ","overview":"","popularity":1.704,"poster_path":"/6hLytFOeqLX5dvwYNG0Zr3yGb16.jpg","release_date":"1972-12-17","softcore":false,"video":false,"vote_average":6.3