":"La voz eterna","original_language":"es","original_title":"La voz eterna","overview":"","popularity":0.0873,"poster_path":null,"release_date":"","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"63a1a66cbe6d8800d9cdd27e","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":null,"genre_ids":[37],"id":417608,"title":"Bouncer","original_language":"en","original_title":"Bouncer","overview":"","popularity":0.1088,"poster_path":null,"release_date":"","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"57e54e61925141064e003f35","department":"Writing","job":"Story"},{"adult":false,"backdrop_path":"/vcZg3tjspOOIKlDQGfXZtxOqrBt.jpg","genre_ids":[18,14],"id":137698,"title":"Taniec rzeczywistości","original_language":"es","original_title":"La danza de la realidad","overview":"","popularity":0.5697,"poster_path":"/8xdVWZAJqvqtOUReGrUf2iWfIzb.jpg","release_date":"2013-06-19","softcore":false,"video":false,"vote_average":7.198,"vote_count":207,"credit_id":"58c5d41ec3a3684130006342","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":null,"genre_ids":[18,14],"id":464582,"title":"Apolinar","original_language":"es","original_title":"Apolinar","overview":"","popularity":1.1342,"poster_path":"/3LKnyqVmwVbz61IzVHGpy6Ual0n.jpg","release_date":"1972-01-01","softcore":false,"video":false,"vote_average":6.333,"vote_count":3,"credit_id":"595b9b9892514121f003a875","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/aqgkUysvSUVOMFwEK5NWArN1nob.jpg","genre_ids":[16,12],"id":11572,"title":"Kaena: Zagłada Światów","original_language":"fr","original_title":"Kaena, la prophétie","overview":"Film opowiada o przygodach młodej dziewczyny o imieniu Kaena, która zamieszkuje w mieście znajdującym się na szczycie wysokiego na kilkadziesiąt kilometrów drzewa. Pewnego dnia drzewo zaczyna umierać a Kaena wyrusza na wyprawę za zamiarem powstrzymania tego procesu. Jako pierwsza mieszkanka od lat schodzi z drzewa i na ziemi poznaje zupełnie nowy świat.  Najdroższa europejcka produkcja w całości zrealizowana przy użyciu grafiki komputerowej.","popularity":0.8016,"poster_path":"/32D5MTSeRgBUKbKpGIDJllgtHPs.jpg","release_date":"2003-06-04","softcore":false,"video":false,"vote_average":5.944,"vote_count":98,"credit_id":"595b62d9c3a36828a105cd6b","department":"Writing","job":"Dialogue"},{"adult":false,"backdrop_path":"/qoEwJ3Z9okEclRrC7Sim4dVAeDy.jpg","genre_ids":[10749,12,14],"id":33257,"title":"Fando i Lis","original_language":"es","original_title":"Fando y Lis","overview":"","popularity":0.5121,"poster_path":"/crseWwhek9yKSf86BmYG8rCOtKp.jpg","release_date":"1972-06-08","softcore":false,"video":false,"vote_average":6.79,"vote_count":145,"credit_id":"595b631e9251410c5604ed18","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":"/7wfbTbbTchECQtbFosCaNO1O0fC.jpg","genre_ids":[18],"id":464578,"title":"Pubertinaje","original_language":"es","original_title":"Pubertinaje","overview":"","popularity":0.2365,"poster_path":"/jOOgIMC2VK8rBXLseunj1XfKZKG.jpg","release_date":"1978-02-10","softcore":false,"video":false,"vote_average":6.3,"vote_count":3,"credit_id":"595b9515c3a3680dec0272e6","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/qoEwJ3Z9okEclRrC7Sim4dVAeDy.jpg","genre_ids":[10749,12,14],"id":33257,"title":"Fando i Lis","original_language":"es","original_title":"Fando y Lis","overview":"","popularity":0.5121,"poster_path":"/crseWwhek9yKSf86BmYG8rCOtKp.jpg","release_date":"1972-06-08","softcore":false,"video":false,"vote_average":6.79,"vote_count":145,"credit_id":"595b630ec3a368253c04a8e6","department":"Writing","job":"Dialogue"},{"adult":false,"backdrop_path":null,"genre_ids":[14,18],"id":1063575,"title":"La voz eterna","original_language":"es","original_title":"La voz eterna","overview":"","popularity":0.0873,"poster_path":null,"release_date":"","softcore":false,"video":false,"vote_average":0.0,"vote_count"