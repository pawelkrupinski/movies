,"job":"Writer"},{"adult":false,"backdrop_path":"/X7FNy7ISNsqQQqh23q068JDgi7.jpg","genre_ids":[18],"id":280840,"title":"Mama","original_language":"es","original_title":"ma ma","overview":"Gdy Magda dowiaduje się, że choruje na raka piersi, zmienia gruntownie swoje życie.","popularity":0.5637,"poster_path":"/ut8AkTc8shknVEkwZwaH4lSpStQ.jpg","release_date":"2015-09-11","softcore":false,"video":false,"vote_average":6.213,"vote_count":160,"credit_id":"53bbeb760e0a26196b002cf6","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/rqw6g8Z118vNAbONWcDNo0jPqTk.jpg","genre_ids":[35],"id":102391,"title":"Gente Pez","original_language":"es","original_title":"Gente Pez","overview":"","popularity":0.2325,"poster_path":"/e9kcuRphWnArEk93cazTiZdUfyR.jpg","release_date":"2001-08-03","softcore":false,"video":false,"vote_average":4.313,"vote_count":16,"credit_id":"54863055c3a36826190001f7","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/6bnIUcZpK8FVwJ2JeZ8f59HKb1R.jpg","genre_ids":[18,36],"id":329718,"title":"Finding Altamira","original_language":"en","original_title":"Altamira","overview":"Rok 1878. Marcelino Sanz de Sautuola (Antonio Banderas) dokonuje odkrycia zabytkowych rysunków na ścianie jaskini znajdującej się w północnej Hiszpanii. Eksperci nie chcą uznać paleolitycznych malunków z Altamiry za autentyczne, sądząc, że naukowiec dokonał fałszerstwa. Sautuola musi walczyć o uznanie swojego znaleziska oraz odzyskanie dobrego imienia. Film oparty na faktach.","popularity":0.839,"poster_path":"/eBxW87UkTzLwUF2YQJIBlQtbau3.jpg","release_date":"2016-04-01","softcore":false,"video":false,"vote_average":5.8,"vote_count":141,"credit_id":"54fe037f92514112b9000333","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/yS7ZitOZjg8FrDUOhY8WYS1WTsa.jpg","genre_ids":[99],"id":1019182,"title":"Tequila. Sexo, Drogas y Rock and Roll","original_language":"es","original_title":"Tequila. Sexo, Drogas y Rock and Roll","overview":"","popularity":0.1056,"poster_path":"/6Qyj8W7QPBLm1gOKiz4qISl1H9s.jpg","release_date":"2022-11-25","softcore":false,"video":false,"vote_average":8.5,"vote_count":2,"credit_id":"630fd05e1511aa007ba2b23b","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/wIk6HgsIyEJTnfxSm0HniJDrcsg.jpg","genre_ids":[99],"id":359746,"title":"The Propaganda Game","original_language":"es","original_title":"The Propaganda Game","overview":"Dokument w stylu pamiętnika. Widzowie podążają śladami filmowca Álvaro Longorii, który odwiedza Koreę Północną i bada machinę propagandową państwa.","popularity":0.6039,"poster_path":"/rDuEM9FHmRCmdrpQlkBacxLmxqF.jpg","release_date":"2015-10-03","softcore":false,"video":false,"vote_average":6.93,"vote_count":150,"credit_id":"55f624c09251413ed900110b","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/l2VqHMBEwAYZh6DeAZSlOzAXw7N.jpg","genre_ids":[35,18],"id":933419,"title":"Champions","original_language":"en","original_title":"Champions","overview":"Były trener niższej ligi koszykówki otrzymuje od sądu polecenie kierowania drużyną zawodników z niepełnosprawnością intelektualną.","popularity":3.0871,"poster_path":"/i46Gke8Kg3uH2K5eM0rDo4HzPtq.jpg","release_date":"2023-03-09","softcore":false,"video":false,"vote_average":6.704,"vote_count":503,"credit_id":"61f8d0cdfe6c1800688aa5f3","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":1231886,"title":"Esperanza","original_language":"es","original_title":"Esperanza","overview":"","popularity":0.1534,"poster_path":"/f4eaod5mV3AykRVQZZ46IJut7E2.jpg","release_date":"2016-01-01","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"65a66092988afd01228996e7","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":1231886,"title":"Esperanza","original_language":"es","original_title":"Esperanza","overview":"","popularity":0.1534,"poster_path":"/f4eaod5mV3AykRVQZZ46IJut7E2.jpg","release_date":"2016-01-01","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"65a660835a991500c4057518","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/vvSI2mzFDkiEwQV5MeJONLqD1zI.jpg","genre_ids":[10751,14,35],"id":893164,"title":"Cuidado con lo que deseas","original_language":"es","original_title":"Cuidado con lo que deseas","overview":"","popularity":0.3764,"poster_path":"/9iqZ4cES3tuLyHcnURNMwiDaJUb.jpg","release_date":"2021-11-12","softcore":false,"video":false,"vote_average":4.543,"vote_count":23,"credit_id":"63a46c8920ecaf0091b74ba9","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":"/49gNFL6rq4IBqj3MmFYvMRP8No4.jpg","genre_ids":[18],"id":1053583,"title":"8","original_language":"es","original_title":"8","overview":"Octavio i Adela urodzili się tego samego dnia, 14 kwietnia 1931 roku. Przez kolejne 8 dekad ich losy będą się przeplatać intensywnymi spotkaniami i nieporozumieniami w 8 odcinkach. To namiętna historia miłosna między odważną i waleczną kobietą a mężczyzną, który mierzy się ze swoimi sprzecznościami. Będą musieli zmierzyć się z faktem, że pochodzą z rodzin po przeciwnych stronach barykady w kraju powoli zmierzającym ku wojnie domowej, a w tle będzie historia Hiszpanii i Europy.","popularity":1.1476,"poster_path":"/u7wk4bVgcQAWc2lXeRRVaH8k5AP.jpg","release_date":"2025-03-21","softcore":false,"video":false,"vote_average":7.3,"vote_count":14,"credit_id":"65db747c9b6e470186012115","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/xlEwMw3GB7NWmk75v1uwOwmAY4m.jpg","genre_ids":[53,18],"id":112631,"title":"Daniel & Ana","original_language":"es","original_title":"Daniel & Ana","overview":"","popularity":3.4429,"poster_path":"/iAeeBBZs2Z8qm2J41wL2mTrQ1HR.jpg","release_date":"2009-10-14","softcore":false,"video":false,"vote_average":6.754,"vote_count":114,"credit_id":"63d40f52594c9400db57c8bd","department":"Production","job":"Associate Producer"},{"adult":false,"backdrop_path":"/teljQG7QGmMVD97XQe3cqtvdkPS.jpg","genre_ids":[99],"id":25783,"title":"Comandante","original_language":"en","original_title":"Comandante","overview":"","popularity":0.3603,"poster_path":"/gJjwog4k9ricwM9oi0rc0CsOrXr.jpg","release_date":"2003-02-14","softcore":false,"video":false,"vote_average":6.562,"vote_count":47,"credit_id":"5961c5c69251410c560c7515","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/ypIhTpeUEz79irm0N7izB6fNst9.jpg","genre_ids":[99],"id":41223,"title":"Persona Non Grata","original_language":"en","original_title":"Persona Non Grata","overview":"","popularity":0.2378,"poster_path":"/hC6Z2Ea5HSIIIjumBnud4RF63Az.jpg","release_date":"2003-06-05","softcore":false,"video":false,"vote_average":6.091,"vote_count":11,"credit_id":"5961c7229251410a590cdd84","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/rqt9cHzdysTREBUFvNQrI02pkrw.jpg","genre_ids":[99],"id":41217,"title":"Looking for Fidel","original_language":"en","original_title":"Looking for Fidel","overview":"","popularity":0.2637,"poster_path":"/feZvDedyfW5OSZuGyDGfqoWes4I.jpg","release_date":"2004-04-14","softcore":false,"video":false,"vote_average":6.1,"vote_count":16,"credit_id":"5961c80d92514121f00b330a","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/yS7ZitOZjg8FrDUOhY8WYS1WTsa.jpg","genre_ids":[99],"id":1019182,"title":"Tequila. Sexo, Drogas y Rock and Roll","original_language":"es","original_title":"Tequila. Sexo, Drogas y Rock and Roll","overview":"","popularity":0.1056,"poster_path":"/6Qyj8W7QPBLm1gOKiz4qISl1H9s.jpg","release_date":"2022-11-25","softcore":false,"video":false,"vote_average":8.5,"vote_count":2,"credit_id":"6429f899c0442901f002bf79","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":"/gJqQxpe03aIRZZjy8A4nbLtBpch.jpg","genre_ids":[80,9648,53],"id":401545,"title":"Wszyscy wiedzą","original_language":"es","original_title":"Todos lo saben","overview":"Po wielu latach nieobecności Laura wraz z dwójką dzieci powraca do rodzinnego miasteczka w Hiszpanii na wesele siostry. Podczas hucznej zabawy spotyka Paco, swoją wielką, pierwszą miłość. Imprezę przerywa zniknięcie Irene, nastoletniej córki Laury. Przy okazji poszukiwań na jaw wychodzą rodzinne tajemnice, o których wszyscy woleliby zapomnieć. W upalnym, sennym miasteczku pod powierzchnią czai się mrok. Wszyscy są podejrzani.","popularity":2.0604,"poster_path":"/egp0RFK1GjZ6uSjrMprBQfeyXlo.jpg","release_date":"2018-05-09","softcore":false,"video":false,"vote_average":6.54,"vote_count":1038,"credit_id":"5a80b7289251414107023497","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/wVyHzMadmXs5FsQWnRjg3oGTIjY.jpg","genre_ids":[10751,12,35],"id":99770,"title":"Asteriks i Obeliks: W służbie Jej Królewskiej Mości","original_language":"fr","original_title":"Astérix & Obélix : Au service de Sa Majesté","overview":"Rok 50 p.n.e. Juliusz Cezar zmierza w stronę Brytanii. Królowa Brytów, Kordelia, wysyła agenta, sir Mentafiksa, z tajną misją, by ma odnalazł galijską wioskę mającą licencję na opieranie się Rzymowi. Tajna broń jej mieszkańców to inteligencja i spryt niepozornego Asteriksa oraz siła jego nieodłącznego kompana, niezbyt rozgarniętego Obeliksa. Dająca nadludzką siłę magiczna mikstura ma pomóc Galom rozprawić się z Rzymianami. Tymczasem w wiosce zjawia się antypatyczny Skandalix, który pod opieką Asteriksa i Obeliksa ma stać się porządnym Galem.","popularity":2.2262,"poster_path":"/KxFWcimVEUHnu6QZ7xzVk5lDpl.jpg","release_date":"2012-10-17","softcore":false,"video":false,"vote_average":5.119,"vote_count":1407,"credit_id":"649decd65aba32011c20d1f0","department":"Production","job":"Co-Producer"},{"adult":false,"backdrop_path":"/cDqzwdmo0zvgosGAqeo9nWLGFYh.jpg","genre_ids":[99],"id":549599,"title":"Dwie Katalonie","original_language":"es","original_title":"Dos Cataluñas","overview":"Ustawodawcy i aktywiści o sprzecznych poglądach opowiadają o skomplikowanej katalońskiej polityce oraz walce o niezależność od Hiszpanii.","popularity":0.26,"poster_path":"/pZQyN2nsOhWCdPzFEEj5nS9PLfL.jpg","release_date":"2018-09-28","softcore":false,"video":false,"vote_average":6.5,"vote_count":29,"credit_id":"5bad8dfe92514150f1045626","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/9aGXzWG9jYTatDkx8sjm78wvn5Y.jpg","genre_ids":[99],"id":1157090,"title":"La vida de Brianeitor","original_language":"es","original_title":"La vida de Brianeitor","overview":"","popularity":0.1564,"poster_path":"/mztC4I6KESqzsAFBLm9yizcscuM.jpg","release_date":"2023-10-11","softcore":false,"video":false,"vote_average":8.0,"vote_count":3,"credit_id":"64c2b3921cfe3a0eb0a819cc","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/9aGXzWG9jYTatDkx8sjm78wvn5Y.jpg","genre_ids":[99],"id":1157090,"title":"La vida de Brianeitor","original_language":"es","original_title":"La vida de Brianeitor","overview":"","popularity":0.1564,"poster_path":"/mztC4I6KESqzsAFBLm9yizcscuM.jpg","release_date":"2023-10-11","softcore":false,"video":false,"vote_average":8.0,"vote_count":3,"credit_id":"64c2b3ce13a3200139f16577","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":562021,"title":"Ni distintos ni diferentes: Campeones","original_language":"es","original_title":"Ni distintos ni diferentes: Campeones","overview":"","popularity":0.0893,"poster_path":"/mrLWbEVLJLh4XgAeqwsDRqD8YRV.jpg","release_date":"2018-11-16","softcore":false,"video":true,"vote_average":6.8,"vote_count":4,"credit_id":"5bed7eed9251413ccf0147df","department":"Production","job":"Production Director"},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":562021,"title":"Ni distintos ni diferentes: Campeones","original_language":"es","original_title":"Ni distintos ni diferentes: Campeones","overview":"","popularity":0.0893,"poster_path":"/mrLWbEVLJLh4XgAeqwsDRqD8YRV.jpg","release_date":"2018-11-16","softcore":false,"video":true,"vote_average":6.8,"vote_count":4,"credit_id":"5bed7e6f9251413cdb015700","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/abQxLSkGxpHyUxRjRXACt8NbiGf.jpg","genre_ids":[18,10749],"id":48650,"title":"Noc w Rzymie","original_language":"es","original_title":"Habitación en Roma","overview":"Pośród tajemniczych uliczek nocnego Rzymu, przecinają się drogi dwóch nieznajomych cudzoziemek. Pochodząca z Hiszpanii Alba przybyła  tutaj w sprawach zawodowych, Rosjanka Natasha odwiedza siostrę bliźniaczkę. Między kobietami zachodzi silne przyciąganie i wzajemna fascynacja. Jednocześnie są ostatnie chwile w Wiecznym Mieście dla obu. Dziewczyny decydują się spędzić wspólnie tę letnią noc w pokoju hotelowym.","popularity":55.5714,"poster_path":"/4kF4qRXFd7MqX2bAJX3e3zQSxhV.jpg","release_date":"2010-05-07","softcore":false,"video":false,"vote_average":6.4,"vote_count":828,"credit_id":"5be3c04ac3a36810c6026e6e","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/nrFUKaLXvayDCIuqUFUm8z6Qqu.jpg","genre_ids":[99],"id":624802,"title":"Sanctuary","original_language":"en","original_title":"Sanctuary","overview":"","popularity":0.3846,"poster_path":"/219IjM8dwp0RQsvJqqJ70k4Xrr4.jpg","release_date":"2019-09-11","softcore":false,"video":false,"vote_average":7.2,"vote_count":5,"credit_id":"5d5c27098d22fc001718a567","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/wIk6HgsIyEJTnfxSm0HniJDrcsg.jpg","genre_ids":[99],"id":359746,"title":"The Propaganda Game","original_language":"es","original_title":"The Propaganda Game","overview":"Dokument w stylu pamiętnika. Widzowie podążają śladami filmowca Álvaro Longorii, który odwiedza Koreę Północną i bada machinę propagandową państwa.","popularity":0.6039,"poster_path":"/rDuEM9FHmRCmdrpQlkBacxLmxqF.jpg","release_date":"2015-10-03","softcore":false,"video":false,"vote_average":6.93,"vote_