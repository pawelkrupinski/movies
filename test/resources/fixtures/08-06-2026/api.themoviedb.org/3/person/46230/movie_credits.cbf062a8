al_title":"De droomproducenten","overview":"","popularity":0.1891,"poster_path":"/bDgvhpPVpBsPnQ6WURXpxmV8Z1e.jpg","release_date":"1984-01-01","softcore":false,"video":false,"vote_average":10.0,"vote_count":1,"character":"Self","credit_id":"69fa2e0421e4a1b5f3c3a898","order":6}],"crew":[{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":939570,"title":"毛沢東--その生涯と文化大革命--","original_language":"ja","original_title":"毛沢東--その生涯と文化大革命--","overview":"","popularity":0.5474,"poster_path":"/2USqzV5WKJ9l8m83hAZV8rbqm1Y.jpg","release_date":"1969-06-08","softcore":false,"video":false,"vote_average":8.0,"vote_count":1,"credit_id":"620d4e67c8a5ac00688ef40a","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/48z4fEXAVwYXUnp8SVuQ94ohsRl.jpg","genre_ids":[18,36,53],"id":20617,"title":"Tabu","original_language":"ja","original_title":"御法度","overview":"Tabu to rozgrywająca się w Kioto, u schyłku epoki szogunów, opowieść o narodzinach zakazanej miłości, która przyczynia się do powstania konfliktu między grupą młodych wojowników, uczniów elitarnej szkoły dla samurajów. Był to okres, gdy tradycyjna sztuka walki samurajów zaczęła stopniowo zanikać ze względu na rozwój nowoczesnej broni. W tej akademii o niezwykle surowym rygorze, gdzie najmniejsze wykroczenia przeciwko kodeksowi samurajów były karane śmiercią, pojawia się 18-letni wojownik Sozaburo Kano. W jego przybyciu nie byłoby nic dziwnego, gdyby nie to, że chłopak roztacza wokół siebie tajemniczy urok. Jego uwodzicielskie zachowanie wywołuje w szkole poruszenie i zakłóca spokojne dotąd życie uczniów. Choć przełożeni szybko dostrzegają olbrzymi talent Kano, nie podoba im się charakter jego kontaktów z innymi uczniami. Chłopiec o zimnych, sprytnych oczach roztacza wokół siebie aurę seksualnej dwuznaczności.","popularity":2.1506,"poster_path":"/irMTJ8sy1X7XpuXVrWOwPOhXUgY.jpg","release_date":"1999-12-18","softcore":false,"video":false,"vote_average":6.584,"vote_count":125,"credit_id":"52fe43efc3a368484e006c2f","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/g3L6tOvJIRWSkxnhmoEW1SKEvW3.jpg","genre_ids":[18,10749],"id":5879,"title":"Imperium zmysłów","original_language":"ja","original_title":"愛のコリーダ","overview":"Zainspirowana prawdziwymi wydarzeniami opowieść, rozgrywająca się w przedwojennej Japonii, której bohaterami są kochankowie, gotowi poświęcić życie w imię intensyfikacji własnych doznań. Wnikliwa wiwisekcja niezwykłej namiętności, przeradzającej się w obsesję seksualną.","popularity":16.9661,"poster_path":"/vJwOxu5O0vvantzsa3VfDkFKrlU.jpg","release_date":"1976-09-15","softcore":false,"video":false,"vote_average":6.595,"vote_count":735,"credit_id":"52fe4429c3a36847f8085cd3","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/6NaWU3u3OwHMcEyNOLrXhFYr7Th.jpg","genre_ids":[18,36,10752],"id":11948,"title":"Wesołych świąt, pułkowniku Lawrence","original_language":"ja","original_title":"戦場のメリークリスマス","overview":"","popularity":3.7531,"poster_path":"/3RNAbiWmDNGHpdOVoTxhUyuB2Rt.jpg","release_date":"1983-05-28","softcore":false,"video":false,"vote_average":7.3,"vote_count":522,"credit_id":"52fe44a69251416c7503c479","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":"/6NaWU3u3OwHMcEyNOLrXhFYr7Th.jpg","genre_ids":[18,36,10752],"id":11948,"title":"Wesołych świąt, pułkowniku Lawrence","original_language":"ja","original_title":"戦場のメリークリスマス","overview":"","popularity":3.7531,"poster_path":"/3RNAbiWmDNGHpdOVoTxhUyuB2Rt.jpg","release_date":"1983-05-28","softcore":false,"video":false,"vote_average":7.3,"vote_count":522,"credit_id":"52fe44a69251416c7503c473","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/tVLqORYuiFdYqMQblBRdUf5mhQR.jpg","genre_ids":[18],"id":42720,"title":"白昼の通り魔","original_language":"ja","original_title":"白昼の通り魔","overview":"","popularity":0.7877,"poster_path":"/7TmMjNusKnBmzsNSujuEIpYGoha.jpg","release_date":"1966-07-15","softcore":false,"video":false,"vote_ave