{"cast":[],"crew":[{"adult":false,"backdrop_path":null,"genre_ids":[18],"id":629435,"title":"19.91","original_language":"pl","original_title":"19.91","overview":"Cicha i skromna w środkach opowieść o spotkaniu 19-letniej Jette z Niemiec z 91-letnią Polką – panią Zosią. W ramach rocznego wolontariatu jaki Jette realizuje w Warszawie regularnie odwiedza panią Zosię, która swoje nastoletnie lata spędziła w obozie koncentracyjnym w Auschwitz oraz obozie pracy w Ravebsbrück.","popularity":0.0071,"poster_path":"/zhb6K1RdvwozzQmP6jyivS1gDGl.jpg","release_date":"2019-05-27","softcore":false,"video":false,"vote_average":8.0,"vote_count":1,"credit_id":"6526a346629b2c0139a7bf8d","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/anJFct7NNAEAR9qEIHfWZNtem9Z.jpg","genre_ids":[18,35],"id":498068,"title":"Whatever Happens Next","original_language":"de","original_title":"Whatever Happens Next","overview":"","popularity":0.1611,"poster_path":"/3zf4SOseLbonuWJndrxiHOXAkbm.jpg","release_date":"2018-11-08","softcore":false,"video":false,"vote_average":6.7,"vote_count":6,"credit_id":"64051b0c383df2007bc82004","department":"Directing","job":"First Assistant Director"},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":1454157,"title":"Kumotry","original_language":"pl","original_title":"Kumotry","overview":"","popularity":0.0352,"poster_path":"/j9ffjMchBjiGctula3iODL1eqAi.jpg","release_date":"2026-06-12","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"67e31fa77b7313b5aef082fc","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":1454157,"title":"Kumotry","original_language":"pl","original_title":"Kumotry","overview":"","popularity":0.0352,"poster_path":"/j9ffjMchBjiGctula3iODL1eqAi.jpg","release_date":"2026-06-12","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"67ff71e6ef5ae687cbd996d0","department":"Writing","job":"Screenplay"}],"id":3950587}