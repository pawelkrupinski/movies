iew":"","popularity":0.2672,"poster_path":"/oS5k9b0FOodu3ltAXGHzZ1IuWBI.jpg","release_date":"2020-01-17","softcore":false,"video":false,"vote_average":6.5,"vote_count":2,"credit_id":"644656e27648410840bf9568","department":"Sound","job":"Songs"},{"adult":false,"backdrop_path":"/wpmZWHcWEwe5J4ikm2Pos5OC0M6.jpg","genre_ids":[16,35,9648,53],"id":10797,"title":"Terkel ma Kłopoty","original_language":"da","original_title":"Terkel i knibe","overview":"Zwariowana komedia o tajemniczych wielbicielach, psychopatycznych zabójcach i przyjaźniach wystawionych na próbę.","popularity":0.9606,"poster_path":"/mBX8r1JbsIPtcY0s18ijU1L8vcw.jpg","release_date":"2004-04-02","softcore":false,"video":false,"vote_average":6.6,"vote_count":136,"credit_id":"668c7961454ff88b140cf800","department":"Writing","job":"Story"},{"adult":false,"backdrop_path":null,"genre_ids":[14,16,35],"id":1154516,"title":"Quark the Dragon Slayer","original_language":"en","original_title":"Quark the Dragon Slayer","overview":"","popularity":0.1317,"poster_path":"/5SAmwUKWhW1PAaAQn0uNTOVxt0X.jpg","release_date":"1989-12-20","softcore":false,"video":true,"vote_average":0.0,"vote_count":0,"credit_id":"64ba19eeab6849011c074b91","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/youmOAJwM4XCoHAgeYNXACA7Buc.jpg","genre_ids":[16,12,35,10751],"id":676685,"title":"Panda i afrykańska banda","original_language":"nl","original_title":"Pandabeer in Afrika","overview":"Zabawna i żądna przygód panda Pang wyrusza z Chin do Afryki, aby uratować swoją najlepszą przyjaciółkę, smoczycę Jielong, z rąk podstępnych porywaczy. W trakcie obfitującej w niespodzianki podróży po nieznanym lądzie, Pang odkryje zupełnie zdumiewający świat równikowej przyrody oraz stawi czoła wrednym hipopotamom, knującym spisek hienom i podstępnym gorylom. Polegając na swoim sprycie i ekipie nowopoznanych kumpli, sympatyczna panda zrobi wszystko, aby odnaleźć smoka, a przy okazji – uratować leśne domy afrykańskich przyjaciół przed zbliżającym się niebezpieczeństwem.","popularity":1.5152,"poster_path":"/rY5niHhIVfpSOxHpWwF9dZOVlPb.jpg","release_date":"2024-03-15","softcore":false,"video":false,"vote_average":7.069,"vote_count":80,"credit_id":"66c98685985b2154aeb31bd0","department":"Writing","job":"Story"},{"adult":false,"backdrop_path":"/t4PrbvPywtHbxWNnFjPUYsVAbbC.jpg","genre_ids":[10751,16],"id":329892,"title":"Albert","original_language":"da","original_title":"Albert","overview":"","popularity":1.6274,"poster_path":"/6qkRhSuCTaKUbxi7MUYcAceavoL.jpg","release_date":"2015-02-26","softcore":false,"video":false,"vote_average":5.4,"vote_count":21,"credit_id":"5c011e0f0e0a2636ce07b560","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":"/lvjFOp3CzLpNOzA6cgNSzG0VtEM.jpg","genre_ids":[16],"id":572973,"title":"Little Wolf's Book of Badness","original_language":"en","original_title":"Little Wolf's Book of Badness","overview":"","popularity":0.2598,"poster_path":"/oWo6b2Dl2iubRBVYz7J4u2gYkix.jpg","release_date":"2003-12-08","softcore":false,"video":false,"vote_average":8.0,"vote_count":5,"credit_id":"5c3084f5c3a36819bba44bdd","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/1ub6gziZwqLRnurXYJcYuc5mY2P.jpg","genre_ids":[16,10751],"id":581168,"title":"Alfons Åberg - Med styrke-säcken","original_language":"sv","original_title":"Alfons Åberg - Med styrke-säcken","overview":"","popularity":0.117,"poster_path":"/e8TrSCTWcPlIhc0iKNqlaaWG2Qm.jpg","release_date":"2013-01-01","softcore":false,"video":true,"vote_average":0.0,"vote_count":0,"credit_id":"5c6033e392514174c2b805c3","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/iGc0QpTIGOppOA7HRf7lx74MCkQ.jpg","genre_ids":[12,16,10751],"id":586947,"title":"Sipsik","original_language":"et","original_title":"Sipsik","overview":"","popularity":0.2672,"poster_path":"/oS5k9b0FOodu3ltAXGHzZ1IuWBI.jpg","release_date":"2020-01-17","softcore":false,"video":false,"vote_average":6.5,"vote_count":2,"credit_id":"5c82d0920e0a26430560887c","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/zKOKHpcDMdHAZ9IbA0XsNXy3Fzr.jpg","genre_ids":[16,10751,35],"id":490594,"title":"Magiczny dywan","original_language":"da","original_title":"Hodja fra Pjort","overview":"Hodżia mieszka w maleńkiej wiosce wraz ze swoją rodziną. Jednak chciałby zobaczyć wielki świat, którym jest dla niego miasto gdzie mieszka sułtan. Pewnego razu dostaje szansę i od razu z niej korzysta. Stary El Faza powierza mu magiczny, latający dywan i misję odnalezienia swej zaginionej wnuczki. Hodżia wraz ze swą przyjaciółką Rają ruszają na spotkanie przygody.","popularity":0.7098,"poster_path":"/bLvZmOsQgOQtu6non4zqnndyJTw.jpg","release_date":"2018-02-08","softcore":false,"video":false,"vote_average":6.1,"vote_count":44,"credit_id":"5ca3759fc3a3682b2d110546","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":"/zKOKHpcDMdHAZ9IbA0XsNXy3Fzr.jpg","genre_ids":[16,10751,35],"id":490594,"title":"Magiczny dywan","original_language":"da","original_title":"Hodja fra Pjort","overview":"Hodżia mieszka w maleńkiej wiosce wraz ze swoją rodziną. Jednak chciałby zobaczyć wielki świat, którym jest dla niego miasto gdzie mieszka sułtan. Pewnego razu dostaje szansę i od razu z niej korzysta. Stary El Faza powierza mu magiczny, latający dywan i misję odnalezienia swej zaginionej wnuczki. Hodżia wraz ze swą przyjaciółką Rają ruszają na spotkanie przygody.","popularity":0.7098,"poster_path":"/bLvZmOsQgOQtu6non4zqnndyJTw.jpg","release_date":"2018-02-08","softcore":false,"video":false,"vote_average":6.1,"vote_count":44,"credit_id":"5ca375a90e0a2605b48e886d","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/youmOAJwM4XCoHAgeYNXACA7Buc.jpg","genre_ids":[16,12,35,10751],"id":676685,"title":"Panda i afrykańska banda","original_language":"nl","original_title":"Pandabeer in Afrika","overview":"Zabawna i żądna przygód panda Pang wyrusza z Chin do Afryki, aby uratować swoją najlepszą przyjaciółkę, smoczycę Jielong, z rąk podstępnych porywaczy. W trakcie obfitującej w niespodzianki podróży po nieznanym lądzie, Pang odkryje zupełnie zdumiewający świat równikowej przyrody oraz stawi czoła wrednym hipopotamom, knującym spisek hienom i podstępnym gorylom. Polegając na swoim sprycie i ekipie nowopoznanych kumpli, sympatyczna panda zrobi wszystko, aby odnaleźć smoka, a przy okazji – uratować leśne domy afrykańskich przyjaciół przed zbliżającym się niebezpieczeństwem.","popularity":1.5152,"poster_path":"/rY5niHhIVfpSOxHpWwF9dZOVlPb.jpg","release_date":"2024-03-15","softcore":false,"video":false,"vote_average":7.069,"vote_count":80,"credit_id":"5e544b7da76ac50011a71fc8","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/iGc0QpTIGOppOA7HRf7lx74MCkQ.jpg","genre_ids":[12,16,10751],"id":586947,"title":"Sipsik","original_language":"et","original_title":"Sipsik","overview":"","popularity":0.2672,"poster_path":"/oS5k9b0FOodu3ltAXGHzZ1IuWBI.jpg","release_date":"2020-01-17","softcore":false,"video":false,"vote_average":6.5,"vote_count":2,"credit_id":"5fd75c7f64765400405512cd","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":"/o1j7fmpHPV38u0rkFOfPyRZjToZ.jpg","genre_ids":[16,10751,28,35],"id":1218032,"title":"Super Charlie","original_language":"sv","original_title":"Super Charlie","overview":"Wille zawsze marzył o zostaniu superbohaterem i walce z przestępczością u boku ojca. Ten sen zostaje zniszczony, gdy rodzi się jego młodszy brat, Charlie. Charlie przyciąga całą uwagę, a na dodatek ma supermoce. Gdy superzłoczyńcą i zły naukowiec wprowadzają plan obalenia miasta, Wille i Charlie muszą odłożyć na bok swoje różnice i pracować razem jako zespół. Czy niemowlę i jego zazdrosny brat mogą uratować miasto?","popularity":2.1394,"poster_path":"/7uixILsszbBjDyoJOJbPdWbbPvl.jpg","release_date":"2024-12-25","softcore":false,"video":false,"vote_average":6.5,"vote_count":18,"credit_id":"6877a26c660d52beabcce2f1","department":"Production","job":"Co-Producer"},{"adult":false,"backdrop_path":"/4GTigFnSCANLWLBkgVgAhfEf2we.jpg","genre_ids":[12,16,14],"id":12646,"title":"Valhalla","original_language":"da","original_title":"Valhalla","overview":"","popularity":1.9136,"poster_path":"/xxtRD332Pv55ZMVcGhecvnFXkRW.jpg","release_date":"1986-05-12","softcore":false,"video":false,"vote_average":6.788,"vote_count":52,"credit_id":"6900ef7f5ff7b06155bbfb4a","department":"Visual Effects","job":"Animation"},{"adult":false,"backdrop_path":"/2GBUz0Z4YyKi2ojHylPIT6yBBl1.jpg","genre_ids":[10751,14,16,12],"id":13225,"title":"Dolina paproci","original_language":"en","original_title":"FernGully: The Last Rainforest","overview":"Nietoperz Batty, Crysta, Pips i Żuczki muszą uratować swój tajemniczy świat przed złym, diabolicznym Hexxusem. Crysta, ignorując ostrzeżenia przyjaciół, wyrusza na wyprawę poza granice Doliny Paproci. Poznaje Zaka - prawdziwego człowieka. Zak pomagał przy niszczeniu Doliny, lecz ujrzawszy jej prawdziwe piękno i poznawszy jej magię postanawia ją ocalić. Jednak może już być na to za późno...","popularity":2.5903,"poster_path":"/Z4XMgqIY6yT6QpoBISIlHzh8ol.jpg","release_date":"1992-04-10","softcore":false,"video":false,"vote_average":6.392,"vote_count":637,"credit_id":"692744df000b8dd82ca758a9","department":"Visual Effects","job":"Animation"},{"adult":false,"backdrop_path":"/a2kY2WzuR4xGXPcfFFB0JQdagnC.jpg","genre_ids":[16,10751,12],"id":33539,"title":"Pewnego razu w Lesie","original_language":"en","original_title":"Once Upon a Forest","overview":"Mysz, kret, jeż i borsuk mieszkają w lesie, który zostaje skażony trującym gazem. Borsuk zaczyna chorować. Trójka przyjaciół rusza na poszukiwanie lekarstwa.","popularity":2.0246,"poster_path":"/aGmed955Bv1ok2YBjjhAA71b7OF.jpg","release_date":"1993-06-18","softcore":false,"video":false,"vote_average":6.594,"vote_count":138,"credit_id":"6927494f28ff7986ca30cfca","department":"Visual Effects","job":"Animation"},{"adult":false,"backdrop_path":null,