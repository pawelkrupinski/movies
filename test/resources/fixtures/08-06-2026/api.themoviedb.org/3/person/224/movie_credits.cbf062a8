er":18},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":373892,"title":"David Cronenberg: I Have to Make the Word Be Flesh","original_language":"en","original_title":"David Cronenberg: I Have to Make the Word Be Flesh","overview":"","popularity":0.0473,"poster_path":null,"release_date":"1999-10-20","softcore":false,"video":false,"vote_average":7.8,"vote_count":5,"character":"","credit_id":"567a84cdc3a3685bc7001eb1","order":0},{"adult":false,"backdrop_path":null,"genre_ids":[18],"id":163104,"title":"Blue","original_language":"en","original_title":"Blue","overview":"","popularity":0.2549,"poster_path":"/3qjKfdN1fDn3TJccsjtQ0mVysqr.jpg","release_date":"1992-01-10","softcore":false,"video":false,"vote_average":6.0,"vote_count":12,"character":"","credit_id":"56d82a8092514175a30019d3","order":1},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":395919,"title":"Take One: Fear on Film","original_language":"en","original_title":"Take One: Fear on Film","overview":"","popularity":0.1409,"poster_path":"/s87qv1F5A2Ea8AjBzqzCWmCOC7L.jpg","release_date":"1982-01-01","softcore":false,"video":false,"vote_average":7.0,"vote_count":1,"character":"Self","credit_id":"5728c9ebc3a3681d9f000417","order":2},{"adult":false,"backdrop_path":"/pkZyudy6PLofZUQhNhoPH49Qxah.jpg","genre_ids":[18,53],"id":11306,"title":"Krytyczna terapia","original_language":"en","original_title":"Extreme Measures","overview":"Symptomy dziwnej, nie znanej choroby, na którą umiera bezdomny pacjent nowoczesnego szpitala w Nowym Jorku, przykuwają uwagę doktora Guya Luthana. Zawodowa ciekawość szybko przeradza się w podejrzenia, że w szpitalu dzieje się coś niepokojącego. Słuszność tych obaw potwierdzi prywatne śledztwo Luthana, które naprowadzi go na trop tajemniczej afery. Wybitny neurolog, dr Lawrence Myrick przeprowadza pod osłoną FBI eksperymenty medyczne na ludziach, które z punktu widzenia etyki lekarskiej wydają się co najmniej dwuznaczne, gdyż ratując jednym pacjentom życie, odbierają je innym. Luthan ma w związku z tym dylematy moralne, zaś Myrick niszczy bez skrupułów jego karierę, próbując również odebrać mu życie.","popularity":2.0422,"poster_path":"/mM9Nd03aWtjFlg8t5kw3SqxoIBb.jpg","release_date":"1996-09-27","softcore":false,"video":false,"vote_average":6.0,"vote_count":352,"character":"Hospital Lawyer","credit_id":"58203349c3a368555f00eb39","order":51},{"adult":false,"backdrop_path":"/eBS1nvaQ7BMdsSlkoLyKapf0FEY.jpg","genre_ids":[27,878,9648],"id":837,"title":"Wideodrom","original_language":"en","original_title":"Videodrome","overview":"Właściciel stacji kablowej ogląda filmy pełne realistycznego okrucieństwa, po czym bez względu na konsekwencje poszukuje źródła tych nagrań.","popularity":4.5048,"poster_path":"/qqqkiZSU9EBGZ1KiDmfn07S7qvv.jpg","release_date":"1983-02-04","softcore":false,"video":false,"vote_average":7.248,"vote_count":2473,"character":"Max Renn (Helmet Scenes) (uncredited)","credit_id":"584fd47f9251416e480076ac","order":19},{"adult":false,"backdrop_path":"/rNxqquM6jUrm9rIBGtHc2NevC7y.jpg","genre_ids":[35,10751],"id":16299,"title":"The Stupids","original_language":"en","original_title":"The Stupids","overview":"","popularity":1.2776,"poster_path":"/uR0EPkE66y2DU21NOZAu6xtfpQL.jpg","release_date":"1996-08-08","softcore":false,"video":false,"vote_average":4.871,"vote_count":85,"character":"Postal Supervisor","credit_id":"58626c6bc3a3681a6b03fa3c","order":14},{"adult":false,"backdrop_path":null,"genre_ids":[18],"id":413243,"title":"Ape Sodom","original_language":"en","original_title":"Ape Sodom","overview":"","popularity":0.1432,"poster_path":"/4BrhkKMbJOdXwaZb3chw5YXYJA7.jpg","release_date":"2016-09-23","softcore":false,"video":false,"vote_average":3.0,"vote_count":4,"character":"Narrator","credit_id":"58df4c95c3a3683d3e005209","order":1},{"adult":false,"backdrop_path":"/its1MQOatIfsiCRC0mMrVQF56Rz.jpg","genre_ids":[27],"id":278995,"title":"The Nest","original_language":"en","original_title":"The Nest","overview":"","popularity":0.2