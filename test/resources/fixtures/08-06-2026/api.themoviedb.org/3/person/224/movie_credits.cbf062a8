ath":"/7OYydiMyh9MIxkO8UPItgEF9oqG.jpg","genre_ids":[27,35],"id":104404,"title":"From the Drain","original_language":"en","original_title":"From the Drain","overview":"","popularity":0.22,"poster_path":"/8FxwoYoKroUmiZVJB8TlSu9xn6r.jpg","release_date":"1967-06-01","softcore":false,"video":false,"vote_average":4.5,"vote_count":27,"credit_id":"52fe4a34c3a36847f81c09ad","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/kOOSq0dgTCC3uOausmISwtQPWmS.jpg","genre_ids":[35],"id":100607,"title":"Camera","original_language":"en","original_title":"Camera","overview":"","popularity":0.273,"poster_path":"/eeQFid2pEldA9gBrTHUpe5s4Ow0.jpg","release_date":"2000-09-01","softcore":false,"video":false,"vote_average":6.114,"vote_count":44,"credit_id":"52fe49ddc3a36847f81aa851","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/kpzMKQyKbtaxf9OpJo0fiosSCMK.jpg","genre_ids":[878,9648,27,53],"id":970947,"title":"Zza grobu","original_language":"en","original_title":"The Shrouds","overview":"W niesamowitej, zwodniczo spokojnej niedalekiej przyszłości technoprzedsiębiorca imieniem Karsh (Vincent Cassel) opracował nowe oprogramowanie, które pozwoli osobom pogrążonym w żałobie być świadkiem stopniowego rozkładu bliskich zmarłych i pochowanych w ziemi. Podczas gdy Karsh wciąż nie może się otrząsnąć po stracie żony (Diane Kruger) spowodowanej chorobą nowotworową i wdał się w osobliwy związek seksualny z siostrą swojej żony (również Kruger), fala zdewastowanych grobów, w których wykorzystano jego technologię, zaczyna sprawiać, że jego przedsiębiorstwo ma problem, co prowadzi go do odkrycia potencjalnie rozległego spisku.","popularity":3.0165,"poster_path":"/7JdUJJM3YsqaVYphRHU2NL3zt30.jpg","release_date":"2025-04-03","softcore":false,"video":false,"vote_average":5.8,"vote_count":235,"credit_id":"627157636f53e11b4bbeb445","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/ytwTVas9vms9dh510TX5i25gV7e.jpg","genre_ids":[18],"id":157851,"title":"Mapy gwiazd","original_language":"en","original_title":"Maps to the Stars","overview":"Autor bestsellerowych poradników dr Stafford Weiss jest szanowanym nestorem hollywoodzkiej dynastii. Choć zbił fortunę na doradzaniu innym, nie do końca radzi sobie z sytuacją we własnym domu. Jego żona Cristina (Olivia Williams) większość czasu poświęca karierze ich 13-letniego syna Benjiego od kilku lat mającego poważane problemy z narkotykami. Ich dorastająca córka Agatha (Mia Wasikowska), u której lekarze zdiagnozowali piromanię, zaprzyjaźnia się z Jeromem (Robert Pattinson) – młodym szoferem, któremu marzy się aktorska kariera. Czy przepustką do niej będzie romans z pacjentką Stafforda, aktorką Havaną Segrand (Julianne Moore), która od lat nie potrafi poradzić sobie ze sławą swojej zmarłej matki?","popularity":1.7196,"poster_path":"/40i5TaN83L4MCO2irWvdO9nUkRm.jpg","release_date":"2014-05-21","softcore":false,"video":false,"vote_average":6.2,"vote_count":1147,"credit_id":"52fe4bd59251416c910e715d","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/2N7JcTx7QvlEYsxGMgxMuAglmgY.jpg","genre_ids":[18],"id":237730,"title":"Transfer","original_language":"en","original_title":"Transfer","overview":"","popularity":0.3329,"poster_path":"/ghbcTtbrW97uvn7irHMZJ09Srjr.jpg","release_date":"1966-01-01","softcore":false,"video":false,"vote_average":5.2,"vote_count":19,"credit_id":"52fe4e6fc3a36847f828fd97","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/ix3qcVapHwEjLxwaLyCCD0LqJbi.jpg","genre_ids":[18],"id":993716,"title":"Preludes","original_language":"en","original_title":"Preludes","overview":"","popularity":0.3997,"poster_path":"/g8VVnPW9lH4yZH7YUut3lIXQtkM.jpg","release_date":"2000-11-15","softcore":false,"video":true,"vote_average":0.0,"vote_count":0,"credit_id":"62bc8e5f7ef3812768ed1e7b","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/its1MQOatIfsiCRC0mMrVQF56Rz.jpg","genre_ids":[27],"id