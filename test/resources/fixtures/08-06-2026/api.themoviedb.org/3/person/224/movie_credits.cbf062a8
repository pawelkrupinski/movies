a go gnębi, a kobieta jego marzeń nie dostrzega. Mimo to Simon czuje, że nie jest w stanie zmienić tych rzeczy. Przybycie nowego współpracownika, Jamesa, burzy spokój mężczyzny. James jest fizycznie podobny do Simona, ale stanowi jego całkowite przeciwieństwo.","popularity":1.625,"poster_path":"/7kNcpmP1Pe9fWLKEbEOX5GEWueC.jpg","release_date":"2014-04-03","softcore":false,"video":false,"vote_average":6.5,"vote_count":1084,"credit_id":"61c7be3c48333a001c331e4b","department":"Crew","job":"Thanks"},{"adult":false,"backdrop_path":"/2N7JcTx7QvlEYsxGMgxMuAglmgY.jpg","genre_ids":[18],"id":237730,"title":"Transfer","original_language":"en","original_title":"Transfer","overview":"","popularity":0.3329,"poster_path":"/ghbcTtbrW97uvn7irHMZJ09Srjr.jpg","release_date":"1966-01-01","softcore":false,"video":false,"vote_average":5.2,"vote_count":19,"credit_id":"56ae9f84925141480d0001bb","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":null,"genre_ids":[18],"id":413243,"title":"Ape Sodom","original_language":"en","original_title":"Ape Sodom","overview":"","popularity":0.1432,"poster_path":"/4BrhkKMbJOdXwaZb3chw5YXYJA7.jpg","release_date":"2016-09-23","softcore":false,"video":false,"vote_average":3.0,"vote_count":4,"credit_id":"58df45a6c3a3683cbe0048ab","department":"Crew","job":"Additional Dialogue"},{"adult":false,"backdrop_path":"/oOaCe4UzDbXs5iUennkaVwRPE2U.jpg","genre_ids":[27],"id":1094746,"title":"Four Unloved Women, Adrift on a Purposeless Sea, Experience the Ecstasy of Dissection","original_language":"it","original_title":"Four Unloved Women, Adrift on a Purposeless Sea, Experience the Ecstasy of Dissection","overview":"","popularity":0.2083,"poster_path":"/aeVYh2YPjNSKcGT67JdP8Cd4NGS.jpg","release_date":"2023-03-24","softcore":false,"video":false,"vote_average":5.14,"vote_count":25,"credit_id":"640287ed9653f60081804cb7","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":"/oOaCe4UzDbXs5iUennkaVwRPE2U.jpg","genre_ids":[27],"id":1094746,