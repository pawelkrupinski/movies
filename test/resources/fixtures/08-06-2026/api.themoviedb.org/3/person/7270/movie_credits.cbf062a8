03-11-29","softcore":false,"video":false,"vote_average":3.5,"vote_count":2,"character":"Self","credit_id":"682500921b561641f04b4f79","order":38},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":1561037,"title":"On the Rungs of Jacob's Ladder","original_language":"en","original_title":"On the Rungs of Jacob's Ladder","overview":"","popularity":0.0816,"poster_path":null,"release_date":"2025-10-13","softcore":false,"video":false,"vote_average":10.0,"vote_count":1,"character":"Self","credit_id":"68eadf2138cbf017cb786b9f","order":2},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":1623261,"title":"Carolco, un rêve hollywoodien","original_language":"fr","original_title":"Carolco, un rêve hollywoodien","overview":"","popularity":0.1012,"poster_path":"/gc5tuyJVnTiG6Lc07uoaTvrcrkk.jpg","release_date":"2026-06-20","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"character":"","credit_id":"69b3f14df1d78d951fcbdbbe","order":10}],"crew":[{"adult":false,"backdrop_path":"/k6BDdDhWeTlj0LVUL5eADZtR0cz.jpg","genre_ids":[18,10749],"id":535,"title":"Flashdance","original_language":"en","original_title":"Flashdance","overview":"Osiemnastoletnia Alex pracuje w hucie w Pittsburghu jako spawaczka, a wieczorami dorabia jako tancerka w nocnym barze. Robi wszystko, aby dostać się do prestiżowej szkoły baletowej. Jej przyjaciółka, Hanna, umacnia ją w tym dążeniu. Po drodze do osiągnięcia dojrzałości i niezależności Alex uczy się, jak odnaleźć w sobie wewnętrzną siłę, która pomoże jej urzeczywistnić marzenia.","popularity":4.3101,"poster_path":"/ziiy6ORt8BlxWFXskBChBMInvDA.jpg","release_date":"1983-04-14","softcore":false,"video":false,"vote_average":6.5,"vote_count":1605,"credit_id":"52fe424ec3a36847f801406b","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/oubk1SEFtg3Q8eOncFvGQVa6OoP.jpg","genre_ids":[18,9648,27],"id":2291,"title":"Drabina Jakubowa","original_language":"en","original_title":"Jacob's Ladder","overview":"Jakub Singer (Tim Robbins) walczy z dręczącymi go koszmarnymi wspomnieniami z wojny w Wietnamie. Z dnia na dzień czuje się coraz gorzej, dookoła siebie widzi demony. Gdy spotyka przyjaciół z batalionu, dowiaduje się, że ci również doświadczają tego rodzaju wizji. Mężczyźni przypuszczają, że przyczyna zbiorowej halucynacji tkwi w wydarzeniu, które miało miejsce w Wietnamie w delcie Mekongu. Podejrzewając wojsko o przeprowadzanie tajnych eksperymentów, byli żołnierze postanawiają dochodzić prawdy w sądzie...","popularity":3.563,"poster_path":"/g0uIDGtZy6EEbP8PlCVtWvYUzCN.jpg","release_date":"1990-11-02","softcore":false,"video":false,"vote_average":7.367,"vote_count":1897,"credit_id":"52fe434ac3a36847f80491bb","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/cf7jOkeY8tqSnVRzAbdlUKQynhe.jpg","genre_ids":[18,10749],"id":10068,"title":"9 1/2 tygodnia","original_language":"en","original_title":"Nine 1/2 Weeks","overview":"Elizabeth właścicielka galerii sztuki spotyka w Nowym Jorku Johna, przystojnego maklera giełdowego, który uwodzi ją i zabiera w podróż do krainy namiętności, perwersji i ... koszmarów. Elizabeth musi wybrać, pomiędzy zatraceniem się w namiętności, a zdrowym rozsądkiem, a może i zdrowiem psychicznym.","popularity":7.9033,"poster_path":"/63Z5b47Ucy4O87pL1v8omUFd1wK.jpg","release_date":"1986-02-09","softcore":false,"video":false,"vote_average":6.118,"vote_count":1132,"credit_id":"52fe431a9251416c750038bd","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/8g8WtAAEGRramjw9G4ivYQV8OaR.jpg","genre_ids":[10749,18],"id":4478,"title":"Niemoralna Propozycja","original_language":"en","original_title":"Indecent Proposal","overview":"David (Woody Harrelson) i Diana Murphy (Demi Moore) stają przed wyjątkową okazją zakończenia swoich finansowych problemów. Jeśli tylko przyjmą ofertę milionera Johna Gage'a (Robert Redford)... JEDNA NOC Z DIANĄ. NIC WIĘCEJ. Oto czego Gage pragnie w zamian. Czy jednak David i Diana zgodzą się? A jeśli tak, czy ich małżeństwo przetrwa taką próbę?  FILM, KTÓREMU SIĘ NIE OPRZESZ. „Niemoralna Propozycja\" to pełna namiętności i kontrowersji próba spojrzenia na współczesną miłość i moralność podjęta przez twórców „Fatalnego Zauroczenia\": reżysera (Adrian Lyne) i współproducentki (Sherry Lansing). Robert Redford, Demi Moore, Woody Harrelson w „najbardziej zadziwiającej i wyjątkowej historii miłosnej jaką kiedykolwiek oglądaliście\".  [opis dystrybutora dvd]","popularity":10.0555,"poster_path":"/meiqwQ816Yr6BVolcZykiHInapw.jpg","release_date":"1993-04-07","softcore":false,"video":false,"vote_average":6.41,"vote_count":1618,"credit_id":"52fe43c5c3a36847f806e375","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/egVj5Y9f79xPnyAQJmeDR0Uwow3.jpg","genre_ids":[53,18,10749],"id":2251,"title":"Niewierna","original_language":"en","original_title":"Unfaithful","overview":"Edward i Connie Sumnerowie są małżeństwem w średnim wieku, które wiedzie dostatnie i wydawałoby się szczęśliwe życie. Jednak pewnego dnia w artystycznej dzielnicy Soho Connie poznaje młodego i przystojnego Francuza - Paula Martela, z którym nawiązuje namiętny romans. Odnajduje w nim to, czego brakowało jej w życiu - smak przygody, odrobinę tajemnicy i element ryzyka. Gdy mąż odkrywa prawdę, postanawia stawić czoła rywalowi.","popularity":18.3537,"poster_path":"/zf3PNvUnKwdbCInAkVqxXP2rTQx.jpg","release_date":"2002-05-10","softcore":false,"video":false,"vote_average":6.7,"vote_count":1723,"credit_id":"52fe4345c3a36847f80478e7","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/egVj5Y9f79xPnyAQJmeDR0Uwow3.jpg","genre_ids":[53,18,10749],"id":2251,"title":"Niewierna","original_language":"en","original_title":"Unfaithful","overview":"Edward i Connie Sumnerowie są małżeństwem w średnim wieku, które wiedzie dostatnie i wydawałoby się szczęśliwe życie. Jednak pewnego dnia w artystycznej dzielnicy Soho Connie poznaje młodego i przystojnego Francuza - Paula Martela, z którym nawiązuje namiętny romans. Odnajduje w nim to, czego brakowało jej w życiu - smak przygody, odrobinę tajemnicy i element ryzyka. Gdy mąż odkrywa prawdę, postanawia stawić czoła rywalowi.","popularity":18.3537,"poster_path":"/zf3PNvUnKwdbCInAkVqxXP2rTQx.jpg","release_date":"2002-05-10","softcore":false,"video":false,"vote_average":6.7,"vote_count":1723,"credit_id":"52fe4345c3a36847f80478f9","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/2UlBdiveZcOVrlNe5MYcI6TYeA7.jpg","genre_ids":[53,18,10749],"id":10998,"title":"Fatalne zauroczenie","original_language":"en","original_title":"Fatal Attraction","overview":"Dan Gallagher był szczęśliwym mężem i ojcem. Pewnego dnia spędza pełen namiętności weekend z nieznajomą kobietą. Okazuje się ona być osobą chorą psychicznie, która zrobi wszystko, żeby tylko Gallagher nie wrócił do swojej żony i dziecka. Kobieta jest gotowa posunąć się do ostateczności.","popularity":3.6325,"poster_path":"/tUueSdo58p5sv8jyYfiRD4HAF2O.jpg","release_date":"1987-09-18","softcore":false,"video":false,"vote_average":6.844,"vote_count":1691,"credit_id":"52fe43df9251416c75021661","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/tmw8jussxvWW3uv0KtUAaHa6ceo.jpg","genre_ids":[18,53],"id":32020,"title":"Lisice","original_language":"en","original_title":"Foxes","overview":"Los Angeles, film opowiada o Jeanie i jej nastoletnich koleżankach: Annie, Madge i Dierdre. Spędzają one wiele czasu ze sobą. Dierdre lubi flirtować, dziewczyna z nadwagą - Madge jest nieśmiała. Jeanie jest dojrzałą opiekunką grupy. Jeanie obawia sie o Annie, której złe relacje z ojcem prowokuja ją do samodestruktywnych czynów. Madge zakochała się w bogatym Jayu i kiedy opuszcza on miastao na kilka dni, dziewczęta przejmują kontrolę nad jego domem. Organizuja przyjęcie, ale nie wszystko wychodzi tak jak miało. Annie trafia do szpitala, a Jay jest wściekły. Kiedy Annie wychodzi ze szpitala, Jeanie wyrusza, aby ją znaleźć.","popularity":2.2445,"poster_path":"/4BML3pbeopzTbwMNFhUWX0MerGE.jpg","release_date":"1980-02-29","softcore":false,"video":false,"vote_average":5.964,"vote_count":101,"credit_id":"52fe44b19251416c91019967","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/kToac37LEGYzfmL87uc4YQWOadG.jpg","genre_ids":[80,18,53],"id":465929,"title":"Back Roads","original_language":"en","original_title":"Back Roads","overview":"Film śledzi losy nastolatka, którego matka odsiaduje w więzieniu wyrok za zabicie jego obelżywego ojca. Teraz on sam musi opiekować się swoimi trzema młodszymi siostrami. Historia dzieje się na wsi górniczej w zachodniej Pensylwanii.","popularity":1.0359,"poster_path":"/va3CVH59k7b79JLl4t2TLJAh0fZ.jpg","release_date":"2019-11-15","softcore":false,"video":false,"vote_average":5.767,"vote_count":60,"credit_id":"59651f599251410a59111bd1","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/kToac37LEGYzfmL87uc4YQWOadG.jpg","genre_ids":[80,18,53],"id":465929,"title":"Back Roads","original_language":"en","original_title":"Back Roads","overview":"Film śledzi losy nastolatka, którego matka odsiaduje w więzieniu wyrok za zabicie jego obelżywego ojca. Teraz on sam musi opiekować się swoimi trzema młodszymi siostrami. Historia dzieje się na wsi górniczej w zachodniej Pensylwanii.","popularity":1.0359,"poster_path":"/va3CVH59k7b79JLl4t2TLJAh0fZ.jpg","release_date":"2019-11-15","softcore":false,"video":false,"vote_average":5.767,"vote_count":60,"credit_id":"5c0ce5e30e0a2638bc09ff36","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":"/lcITbesmy0IBO6TXTAgQHJE6Asx.jpg","genre_ids":[18,9648,53],"id":619979,"title":"Głęboka woda","original_language":"en","original_title":"Deep Water","overview":"Vic i Melinda sprawiają wrażenie pary idealnej, jeśli nie liczyć jednego: Melinda lubi flirtować i romansować. Vic wydaje się tym nie przejmować, jednak sprawy przyjmują nieoczekiwany obrót, gdy jeden z kochanków Melindy znika, a Vic sugeruje jej kolejnemu wielbicielowi, że stoi za tym zniknięciem. Pogłoski zaczynają krążyć. Jest tylko kwestią czasu, kiedy Vic naprawdę ubrudzi ręce krwią...","popularity":10.6959,"poster_path":"/7e3mVhiDyfOdPj11l1cAs4v41kl.jpg","release_date":"2022-03-17","softcore":false,"video":false,"vote_average":5.821,"vote_count":1643,"credit_id":"5d438dbda9117f0013eed18e","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/b9diKSmofRcgjbUxDrSPms82yAN.jpg","genre_ids":[18],"id":9769,"title":"Lolita","original_language":"en","original_title":"Lolita","overview":"Kontrowersyjna opowieść o dojrzałym, przebiegłym i zakłamanym Humbercie, który żeni się z postarzałą Charlotte, rywalizuje z demonicznym Quiltym i daje się uwieść beztroskiej trzynastolatce, która nosi to 'urocze, liryczne, melodyjne imię' - Lolita.","popularity":14.7427,"poster_path":"/9INcC14WZjCMKGE360VXmklCLdZ.jpg","release_date":"1997-09-27","softcore":false,"video":false,"vote_average":7.1,"vote_count":1970,"credit_id":"5eb5bd3ffd7aa4001d5b071d","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":null,"genre_ids":[18],"id":726846,"title":"The Table","original_language":"en","original_title":"The Table","overview":"","popularity":0.1446,"poster_path":"/gZRmTIH1eyZZvGPkwZxg6jsCJDV.jpg","release_date":"1973-01-01","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"5f19065351e6ab0038d5038d","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":null,"genre_ids":[18],"id":726846,"title":"The Table","original_language":"en","original_title":"The Table","overview":"","popularity":0.1446,"poster_path":"/gZRmTIH1eyZZvGPkwZxg6jsCJDV.jpg","release_date":"1973-01-01","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"5f19065bdb952d003593c9a9","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":null,"genre_ids":[18],"id":726848,"title":"Mr. Smith","original_lang