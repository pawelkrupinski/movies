"overview":"","popularity":0.473,"poster_path":"/vJBoZEeYiItkuhoL64abMDIpybo.jpg","release_date":"2023-01-24","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"63c82d48142ef100a04a56bc","department":"Writing","job":"Story"},{"adult":false,"backdrop_path":null,"genre_ids":[],"id":1075883,"title":"L'estate è finita - Appunti su Furio","original_language":"it","original_title":"L'estate è finita - Appunti su Furio","overview":"","popularity":0.473,"poster_path":"/vJBoZEeYiItkuhoL64abMDIpybo.jpg","release_date":"2023-01-24","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"63c828a97a97ab00d3a6a0a4","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/7NrxEv1RD6xoJs0C0lJca0qerfw.jpg","genre_ids":[35],"id":696826,"title":"Il regno","original_language":"it","original_title":"Il regno","overview":"","popularity":0.3511,"poster_path":"/uloF2FMGVkp87Bctp0KdJc7KPAk.jpg","release_date":"2020-06-26","softcore":false,"video":false,"vote_average":5.6,"vote_count":69,"credit_id":"66510d735a83fb575f4b5919","department":"Crew","job":"Thanks"},{"adult":false,"backdrop_path":null,"genre_ids":[],"id":536570,"title":"La santa che dorme","original_language":"en","original_title":"La santa che dorme","overview":"","popularity":0.0743,"poster_path":"/avgyk23cOSwRtYi8btnDG62rGoO.jpg","release_date":"2016-05-19","softcore":false,"video":false,"vote_average":5.2,"vote_count":4,"credit_id":"5b4fbb180e0a264b8401a517","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/2stEL3ibnjg9B9Rjr0U4CyuYc5Z.jpg","genre_ids":[18],"id":1442922,"title":"Un anno di scuola","original_language":"it","original_title":"Un anno di scuola","overview":"Wrzesień 2007, Triest. Fred, energiczna i odważna osiemnastoletnia Szwedka, przybywa do miasta, aby ukończyć ostatni rok w technikum. Okazuje się jedyną dziewczyną w klasie wyłącznie męskiej i przyciąga uwagę wszystkich, a zwłaszcza trójki przyjaciół: Antero, czarującego i powściągliwego; Pasiniego, efektownego uwodziciela; oraz Mitisa, dobrodusznego i opiekuńczego. Cała trójka należy do siebie, odkąd pamiętają. Przybycie Fred burzy ich jednolitość, wystawiając ich przyjaźń na próbę. Podczas gdy każde z nich skrycie jej pragnie, Fred pragnie dołączyć do grupy, ale ona jest nieustannie proszona o poświęcenie czegoś z siebie, aby stać się jedną z nich.","popularity":1.0536,"poster_path":"/8kGEfpIabMiaWpdMkTcNFclld5W.jpg","release_date":"2026-04-09","softcore":false,"video":false,"vote_average":7.3,"vote_count":13,"credit_id":"67c6b022644eec7114c07b37","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/6KrcT1J2jxGzBDwbsrFIWUXpDUA.jpg","genre_ids":[18],"id":837745,"title":"Piccolo corpo","original_language":"it","original_title":"Piccolo corpo","overview":"","popularity":0.2419,"poster_path":"/i5ifhHu7TBvG0oTMfJ4wA4h9r2m.jpg","release_date":"2022-02-16","softcore":false,"video":false,"vote_average":7.0,"vote_count":57,"credit_id":"68c54a9bb9b31ee06daa3bc1","department":"Writing","job":"Story"},{"adult":false,"backdrop_path":"/2stEL3ibnjg9B9Rjr0U4CyuYc5Z.jpg","genre_ids":[18],"id":1442922,"title":"Un anno di scuola","original_language":"it","original_title":"Un anno di scuola","overview":"Wrzesień 2007, Triest. Fred, energiczna i odważna osiemnastoletnia Szwedka, przybywa do miasta, aby ukończyć ostatni rok w technikum. Okazuje się jedyną dziewczyną w klasie wyłącznie męskiej i przyciąga uwagę wszystkich, a zwłaszcza trójki przyjaciół: Antero, czarującego i powściągliwego; Pasiniego, efektownego uwodziciela; oraz Mitisa, dobrodusznego i opiekuńczego. Cała trójka należy do siebie, odkąd pamiętają. Przybycie Fred burzy ich jednolitość, wystawiając ich przyjaźń na próbę. Podczas gdy każde z nich skrycie jej pragnie, Fred pragnie dołączyć do grupy, ale ona jest nieustannie proszona o poświęcenie czegoś z siebie, aby stać się jedną z nich.","popularity":1.0536,"poster_path":"/8kGEfpIabMiaWpdMkTcNFclld5W.jpg","relea