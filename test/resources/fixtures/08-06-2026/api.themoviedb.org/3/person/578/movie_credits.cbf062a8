c9Q.jpg","genre_ids":[99],"id":1547936,"title":"The Force Is with Them: The Legacy of 'Star Wars'","original_language":"en","original_title":"The Force Is with Them: The Legacy of 'Star Wars'","overview":"","popularity":0.3484,"poster_path":"/4QNNtt45uldnsHs35QMIMXfMSTl.jpg","release_date":"2004-09-12","softcore":false,"video":false,"vote_average":8.0,"vote_count":2,"character":"Self","credit_id":"68caeb01afd9146d62e36341","order":2},{"adult":false,"backdrop_path":"/tpCJEJRXQ0IGeQDngjCepYydXgM.jpg","genre_ids":[99,36],"id":44345,"title":"The Cutting Edge: The Magic of Movie Editing","original_language":"en","original_title":"The Cutting Edge: The Magic of Movie Editing","overview":"","popularity":1.789,"poster_path":"/eiMCb4qnOvbIdKjW91S1pdAuSl9.jpg","release_date":"2004-10-12","softcore":false,"video":false,"vote_average":7.0,"vote_count":113,"character":"Self","credit_id":"69370fd901b2768aaceb171f","order":26},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":1597579,"title":"American Gangster Special","original_language":"en","original_title":"American Gangster Special","overview":"","popularity":0.6973,"poster_path":null,"release_date":"","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"character":"Self","credit_id":"693c8e01e5d00de99e619aba","order":0}],"crew":[{"adult":false,"backdrop_path":"/hJ5R9d6QuH3tzr8L8neZZTuzNXm.jpg","genre_ids":[878,18,53],"id":78,"title":"Łowca androidów","original_language":"en","original_title":"Blade Runner","overview":"\"Blade Runner\" opowiada o historii jednego z Łowców Androidów, Ricka Deckarda. Replikanci, bo tak nazwano tych androidów, byli używani do niebezpiecznych badań i kolonizacji innych planet. Po krwawym buncie zespołu androidów na pozaziemskiej kolonii, Replikanci nie mogli przebywać legalnie na Ziemi. Są oni owładnięci panicznym strachem przed nieuchronną śmiercią i za wszelką cenę starają się dotrzeć do ich konstruktorów - jedynych ludzi mogących przedłużyć ich życie. Replikanci zostali bowiem zabezpieczeni przed długotrwałym życiem ze względu na rozwijające się w nich uczucia. Specjalny oddział policji - tytułowi \"Łowcy Androidów\" - są detektywami, którzy mają za zadanie odnaleźć i wyeliminować zbiegłych androidów. Akcja rozgrywa się w Los Angeles w 2019 roku gdy jeden z najlepszych Łowców zostaje ranny podczas wykonywania testu Voigta-Kampffa na jednym z androidów i właśnie Deckard przejmuje jego zadanie - wyeliminowanie zbiegłych androidów typu Nexus-6.","popularity":12.0525,"poster_path":"/ulibbSdDYniRyx110vhrJyNd3GL.jpg","release_date":"1982-06-25","softcore":false,"video":false,"vote_average":7.938,"vote_count":15004,"credit_id":"52fe4214c3a36847f8002595","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/jhk6D8pim3yaByu1801kMoxXFaX.jpg","genre_ids":[28,18,12],"id":98,"title":"Gladiator","original_language":"en","original_title":"Gladiator","overview":"Generał Maximus zakończył kolejną udaną wyprawę wojenną. Zmuszony do ucieczki przez zazdrosnego o jego wpływy u Cesarza dziedzica tronu Commodusa, Maximus trafia do niewoli i zostaje gladiatorem. Powraca do Rzymu z zamiarem pomszczenia śmierci syna i żony. Wie, że jedyną siłą potężniejszą od samego Cesarza jest wola ludu, może dokonać swej zemsty, zostając największym bohaterem całego Imperium. \"Gladiator\" to epicka opowieść o odwadze i zemście osadzona w realiach Cesarstwa Rzymskiego roku 180 n.e.","popularity":21.9455,"poster_path":"/1f0U34P6OFPXvfQta556VfXZqiC.jpg","release_date":"2000-05-04","softcore":false,"video":false,"vote_average":8.2,"vote_count":20923,"credit_id":"52fe4217c3a36847f800340d","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/cEobq5QrnOJjO6giDs8q4RxmMKh.jpg","genre_ids":[27,878],"id":348,"title":"Obcy: 8 pasażer Nostromo","original_language":"en","original_title":"Alien","overview":"W pierwszym rozdziale przerażającej sagi \"Obcy\", załoga statku Nostromo odpowiada na sygnał wołania o pomoc pochodzący z opustoszałej planety i odkrywa śmiercionośną formę życia, która wykorzystuje ludzkie ciało do swego rozwoju. Teraz wszyscy na pokładzie muszą walczyć nie tylko o życie, lecz także o przetrwanie całego gatunku ludzkiego.","popularity":21.2719,"poster_path":"/nJmcM3Kw0vOeaErYu9pIzKs9ZRW.jpg","release_date":"1979-05-25","softcore":false,"video":false,"vote_average":8.17,"vote_count":16401,"credit_id":"52fe423bc3a36847f800e117","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/eA15zhxnhQSg4k5MUbbTERIU23Z.jpg","genre_ids":[18,80,12],"id":1541,"title":"Thelma i Louise","original_language":"en","original_title":"Thelma & Louise","overview":"Dwie przyjaciółki, które po tragicznym wypadku w przydrożnym barze ruszają w desperacką podróż przez amerykański południowy zachód. Ścigane przez zdeterminowanego detektywa, spotykają przystojnego autostopowicza, przeżywają moc ekscytujących przygód i nareszcie żyją na wysokich obrotach... do czasu.","popularity":7.0328,"poster_path":"/vbRAGLzbC75QfiKD1lKjmnQGuph.jpg","release_date":"1991-05-24","softcore":false,"video":false,"vote_average":7.603,"vote_count":3875,"credit_id":"52fe42fbc3a36847f8031a83","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/qIgplWrPzo2dpgDDqZKUYRQUOCP.jpg","genre_ids":[28,12,18,36],"id":1492,"title":"1492: Wyprawa do raju","original_language":"en","original_title":"1492: Conquest of Paradise","overview":"W 1491 roku Krzysztof Kolumb (Gerard Depardieu) poszukuje źródeł finansowania wyprawy, której celem ma być odkrycie nowej drogi morskiej do Indii. Przybywa z księdzem Marcheną (Fernando Rey) na uniwersytet w Salamance, gdzie poznaje Sancheza (Armand Assante) doradcę królowej Izabeli (Sigourney Weaver). Dzięki wsparciu bankiera Santangela (Frank Langella) i wstawiennictwu Sancheza, spotyka się z królową i zwraca się do niej o patronat nad swoją podróżą badawczą. 3 sierpnia 1492 roku Kolumb wypływa w morze, dowodząc trzema statkami: Pintą, Niną i Santa Marią. Podczas długiego rejsu załogi statków zaczynają się buntować, a ich kapitanowie, Pinzon (Tcheky Kayro) i Mendez (Kevin Dunn), okazują niezadowolenie. Gdy Kolumb decyduje się zawrócić, na  horyzoncie pojawia się nieznany ląd.","popularity":3.2384,"poster_path":"/bGpdmXpglytexmAZCUyWqZ6PFAl.jpg","release_date":"1992-08-09","softcore":false,"video":false,"vote_average":6.3,"vote_count":919,"credit_id":"52fe42f9c3a36847f80310e3","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/8itHQecANtOevcCdr3AhVxFCYkw.jpg","genre_ids":[18,28,12,36,10752],"id":1495,"title":"Królestwo niebieskie","original_language":"en","original_title":"Kingdom of Heaven","overview":"Akcja filmu toczy się w czasach wypraw krzyżowych. Po stracie żony i syna, kowal Balian traci także wiarę w Boga. Jego życie zmieniają jednak odwiedziny słynnego rycerza, Godfryda z Ibelinu, ojca Baliana. Obaj wyruszają w drogę do Ziemi Świętej, w której panuje chwilowy rozejm między chrześcijanami i muzułmanami. Podczas tej podróży, pod wpływem ojca, Balian przeistacza się w prawdziwego rycerza. W Jerozolimie spotyka go jednak kolejna tragedia...","popularity":17.2222,"poster_path":"/tDMMmAHTBx23voum8kRq8DEH7tT.jpg","release_date":"2005-05-03","softcore":false,"video":false,"vote_average":7.049,"vote_count":4975,"credit_id":"52fe42fac3a36847f80312e7","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/qIgplWrPzo2dpgDDqZKUYRQUOCP.jpg","genre_ids":[28,12,18,36],"id":1492,"title":"1492: Wyprawa do raju","original_language":"en","original_title":"1492: Conquest of Paradise","overview":"W 1491 roku Krzysztof Kolumb (Gerard Depardieu) poszukuje źródeł finansowania wyprawy, której celem ma być odkrycie nowej drogi morskiej do Indii. Przybywa z księdzem Marcheną (Fernando Rey) na uniwersytet w Salamance, gdzie poznaje Sancheza (Armand Assante) doradcę królowej Izabeli (Sigourney Weaver). Dzięki wsparciu bankiera Santangela (Frank Langella) i wstawiennictwu Sancheza, spotyka się z królową i zwraca się do niej o patronat nad swoją podróżą badawczą. 3 sierpnia 1492 roku Kolumb wypływa w morze, dowodząc trzema statkami: Pintą, Niną i Santa Marią. Podczas długiego rejsu załogi statków zaczynają się buntować, a ich kapitanowie, Pinzon (Tcheky Kayro) i Mendez (Kevin Dunn), okazują niezadowolenie. Gdy Kolumb decyduje się zawrócić, na  horyzoncie pojawia się nieznany ląd.","popularity":3.2384,"poster_path":"/bGpdmXpglytexmAZCUyWqZ6PFAl.jpg","release_date":"1992-08-09","softcore":false,"video":false,"vote_average":6.3,"vote_count":919,"credit_id":"52fe42fac3a36847f8031105","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/eA15zhxnhQSg4k5MUbbTERIU23Z.jpg","genre_ids":[18,80,12],"id":1541,"title":"Thelma i Louise","original_language":"en","original_title":"Thelma & Louise","overview":"Dwie przyjaciółki, które po tragicznym wypadku w przydrożnym barze ruszają w desperacką podróż przez amerykański południowy zachód. Ścigane przez zdeterminowanego detektywa, spotykają przystojnego autostopowicza, przeżywają moc ekscytujących przygód i nareszcie żyją na wysokich obrotach... do czasu.","popularity":7.0328,"poster_path":"/vbRAGLzbC75QfiKD1lKjmnQGuph.jpg","release_date":"1991-05-24","softcore":false,"video":false,"vote_average":7.603,"vote_count":3875,"credit_id":"52fe42fbc3a36847f8031a8f","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/8itHQecANtOevcCdr3AhVxFCYkw.jpg","genre_ids":[18,28,12,36,10752],"id":1495,"title":"Królestwo niebieskie","original_language":"en","original_title":"Kingdom of Heaven","overview":"Akcja filmu toczy się w czasach wypraw krzyżowych. Po stracie żony i syna, kowal Balian traci także wiarę w Boga. Jego życie zmieniają jednak odwiedziny słynnego rycerza, Godfryda z Ibelinu, ojca Baliana. Obaj wyruszają w drogę do Ziemi Świętej, w której panuje chwilowy rozejm między chrześcijanami i muzułmanami. Podczas tej podróży, pod wpływem ojca, Balian przeistacza się w prawdziwego rycerza. W Jerozolimie spotyka go jednak kolejna tragedia...","popularity":17.2222,"poster_path":"/tDMMmAHTBx23voum8kRq8DEH7tT.jpg","release_date":"2005-05-03","softcore":false,"video":false,"vote_average":7.049,"vote_count":4975,"credit_id":"52fe42fac3a36847f80312db","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/o6f1sJ0ZYg6TA2tMgoHdupB68QB.jpg","genre_ids":[28,10752,36],"id":855,"title":"Helikopter w ogniu","original_language":"en","original_title":"Black Hawk Down","overview":"W 1993 r. do Somalii wysłano elitarne oddziały amerykańskich żołnierzy. Powierzono im kluczową misją pojmania miejscowego dygnitarza wojskowego, pod którego rządami zmarły z głodu setki tysięcy Somalijczyków. Operacja nie powiodła się i Amerykanie zmuszeni byli walczyć o życie stawiając czoła przeważającym siłom wroga.","popularity":12.7427,"poster_path":"/zlBd7flRDRSS7nBl6pV4OfV4BFa.jpg","release_date":"2001-12-28","softcore":false,"video":false,"vote_average":7.394,"vote_count":6368,"credit_id":"52fe4282c3a36847f8024877","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/o6f1sJ0ZYg6TA2tMgoHdupB68QB.jpg","genre_ids":[28,10752,36],"id":855,"title":"Helikopter w ogniu","original_language":"en","original_title":"Black Hawk Down","overview":"W 1993 r. do Somalii wysłano elitarne oddziały amerykańskich żołnierzy. Powierzono im kluczową misją pojmania miejscowego dygnitarza wojskowego, pod którego rządami zmarły z głodu setki tysięcy Somalijczyków. Operacja nie powiodła się i Amerykanie zmuszeni byli walczyć o życie stawiając czoła przeważającym siłom wroga.","popularity":12.7427,"poster_path":"/zlBd7flRDRSS7nBl6pV4OfV4BFa.jpg","release_date":"2001-12-28","softcore":false,"video":false,"vote_average":7.394,"vote_count":6368,"credit_id":"52fe4282c3a36847f802485f","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/4xAxAvrcnelGOBA5mQsW0aEHpqW.jpg","genre_ids":[18,28,53],"id":4105,"title":"Czarny Deszcz","original_language":"en","original_title":"Black Rain","overview":"Podczas rutynowego patrolu dwaj nowojorscy policjanci, Nick Conklin i Charlie Vincent, są świadkami porachunków miejscowej mafii z wysłannikami japońskiej yakuzy. W pościgu ujmują sprawcę zabójstwa. Muszą go eskortować do Japonii, gdzie mają go przekazać policji. Po przybyciu na miejsce gangster ucieka. Conklin postanawia go odnaleźć, chociaż miejscowa policja odradza mu samotny rekonesans. Wkrótce Charlie zostaje zamordowany w zasadzce zastawionej przez mafię, Conklin przeżywa wstrząs. Postanawia pomścić śmierć przyjaciela.","popularity":3.3427,"poster_path":"/rN9iXmsuaS5cE2NjzNSCALAfYaM.jpg","release_date":"1989-09-22","softcore":false,"video":false,"vote_average":6.585,"vote_count":1236,"credit_id":"52fe43adc3a36847f8066ff9","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/bs65jUGHevSDmfKF5LgVyWtPK4o.jpg","genre_ids":[28,18,10752],"id":4421,"title":"G.I. Jane","original_language":"en","original_title":"G.I. Jane","overview":"Porucznik Jordan O'Neil jest pierwszą kobietą, która mimo niechętnego stanowiska Pentagonu dostaje zgodę na wstąpienie do elitarnej formacji komandosów Navy Seals, utworzonej z inicjatywy prezydenta Kennedy'ego w celu zwalczania terroryzmu. Początkowo jest traktowana protekcjonalnie. Kiedy jednak goli sobie głowę i nalega, by traktowano ją na równi z innymi, koledzy postanawiają udowodnić jej, że zawsze będzie gorsza. Nie szczędzą jej szykan oraz upokorzeń. Celuje w nich zwłaszcza sadystyczny sierżant John Urgayle.","popularity":4.0658,"poster_path":"/wez1hjcZPwCR1iSlaZwM8DwAw1h.jpg","release_date":"1997-08-19","softcore":false,"video":false,"vote_average":6.5,"vote_count":1853,"credit_id":"52fe43c1c3a36847f806d113","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/bs65jUGHevSDmfKF5LgVyWtPK4o.jpg","genre_ids":[28,18,10752],"id":4421,"title":"G.I. Jane","original_language":"en","original_title":"G.I. Jane","overview":"Porucznik Jordan O'Neil jest pierwszą kobietą, która mimo niechętnego stanowiska Pentagonu dostaje zgodę na wstąpienie do elitarnej formacji komandosów Navy Seals, utworzonej z inicjatywy prezydenta Kennedy'ego w celu zwalczania terroryzmu. Początkowo jest traktowana protekcjonalnie. Kiedy jednak goli sobie głowę i nalega, by traktowano ją na równi z innymi, koledzy postanawiają udowodnić jej, że zawsze będzie gorsza. Nie szczędzą jej szykan oraz upokorzeń. Celuje w nich zwłaszcza sadystyczny sierżant John Urgayle.","popularity":4.0658,"poster_path":"/wez1hjcZPwCR1iSlaZwM8DwAw1h.jpg","release_date":"1997-08-19","softcore":false,"video":false,"vote_average":6.5,"vote_count":1853,"credit_id":"52fe43c1c3a36847f806d107","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/kpVQHZrBLUsB35S1pTbP8apgT5W.jpg","genre_ids":[18,12],"id":10534,"title":"Sztorm","original_language":"en","original_title":"White Squall","overview":"Film oparty na faktach. Jest to historia człowieka, który zabiera na ośmiomiesięczny rejs szkoleniowy kadetów ze szkoły morskiej. Podczas rejsu w łódź uderza ogromy sztorm, który łączy członków wyprawy w walce o życie. Film często określany jako \"Stowarzyszenie Umarłych Poetów\" na morzu.","popularity":3.5462,"poster_path":"/5xF4qy44Lvv68glS7eHWH7laTqt.jpg","release_date":"1996-02-02","softcore":false,"video":false,"vote_average":6.3,"vote_count":407,"credit_id":"52fe43829251416c7501325d","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/kpVQHZrBLUsB35S1pTbP8apgT5W.jpg","genre_ids":[18,12],"id":10534,"title":"Sztorm","original_language":"en","original_title":"White Squall","overview":"Film oparty na faktach. Jest to historia człowieka, który zabiera na ośmiomiesięczny rejs szkoleniowy kadetów ze szkoły morskiej. Podczas rejsu w łódź uderza ogromy sztorm, który łączy członków wyprawy w walce o życie. Film często określany jako \"Stowarzyszenie Umarłych Poetów\" na morzu.","popularity":3.5462,"poster_path":"/5xF4qy44Lvv68glS7eHWH7laTqt.jpg","release_date":"1996-02-02","softcore":false,"video":false,"vote_average":6.3,"vote_count":407,"credit_id":"52fe43829251416c75013281","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/5r2BZajlRZqnOc6s2BS0aiFDcne.jpg","genre_ids":[18,37],"id":4512,"title":"Zabójstwo Jesse'ego Jamesa przez tchórzliwego Roberta Forda","original_language":"en","original_title":"The Assassination of Jesse James by the Coward Robert Ford","overview":"W 1880 roku w Ameryce wszyscy znają Jesse'ego Jamesa. Jest najbardziej poszukiwanym przestępcą, ściganym przez prawo w dziesięciu stanach. Jest również największym bohaterem, uważanym przez ludzi za ówczesnego Robin Hooda. Robert Ford? Nikt go nie zna. Jeszcze nie. Jednak ambitny 19-latek zamierza to zmienić. Zaprzyjaźni się z Jessem, wstąpi do jego gangu. I jeśli to nie przyniesie mu sławy znajdzie inny, bardziej nikczemny sposób.  Przyjaźń, która przerodziła się w rywalizację, poszukiwanie sławy, które stało się obsesją. To wszystko znajdziesz w wyprodukowanej przez Ridleya Scotta epickiej opowieści z pasjonującą rolą Brada Pitta (zdobywca nagrody dla Najlepszego Aktora na Festiwalu Filmów w Wenecji) jako Jesse'ego i Caseya Afflecka jako młodego przestępcy, który jest coraz bliżej upragnionego celu... i coraz dalej od swojego człowieczeństwa.","popularity":3.7263,"poster_path":"/7d3wNFCS4wRBort8mc834AuCRH5.jpg","release_date":"2007-09-20","softcore":false,"video":false,"vote_average":7.062,"vote_count":2777,"credit_id":"52fe43c7c3a36847f806ef11","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/uiaJDAgrBu0QJXyzBK1ycg9dEZ2.jpg","genre_ids":[18,80],"id":4982,"title":"Amerykański gangster","original_language":"en","original_title":"American Gangster","overview":"Frank Lucas człowiek, który wie czym jest poczucie honoru, ale i znający zasady ulicy, postanawia uporządkować chaotyczne podziemie narkotykowe Harlemu. Na jego drodze stanie jednak Richie Roberts, nieprzekupny gliniarz, który poprzysiągł zniszczyć warte setki milionów dolarów narkotykowe imperium. Dwie silne osobowości po dwóch stronach barykady. Oto, jak wyglądało ich legendarne starcie.","popularity":6.5701,"poster_path":"/qr26554LrAlNfeYpbErrkkKXsUw.jpg","release_date":"2007-11-02","softcore":false,"video":false,"vote_average":7.594,"vote_count":6047,"credit_id":"52fe43ebc3a36847f80783a3","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/uiaJDAgrBu0QJXyzBK1ycg9dEZ2.jpg","genre_ids":[18,80],"id":4982,"title":"Amerykański gangster","original_language":"en","original_title":"American Gangster","overview":"Frank Lucas człowiek, który wie czym jest poczucie honoru, ale i znający zasady ulicy, postanawia uporządkować chaotyczne podziemie narkotykowe Harlemu. Na jego drodze stanie jednak Richie Roberts, nieprzekupny gliniarz, który poprzysiągł zniszczyć warte setki milionów dolarów narkotykowe imperium. Dwie silne osobowości po dwóch stronach barykady. Oto, jak wyglądało ich legendarne starcie.","popularity":6.5701,"poster_path":"/qr26554LrAlNfeYpbErrkkKXsUw.jpg","release_date":"2007-11-02","softcore":false,"video":false,"vote_average":7.594,"vote_count":6047,"credit_id":"52fe43ebc3a36847f8078391","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/gxJnDz2W566PRdYKCaJrp1FpRRI.jpg","genre_ids":[28,12,36,18],"id":20662,"title":"Robin Hood","original_language":"en","original_title":"Robin Hood","overview":"Film opowiada o losach doskonałego łucznika, który walczył u boku króla Ryszarda przeciw Francuzom. Po śmierci władcy Robin trafia do Nottingham, podporządkowanego chciwemu szeryfowi. Tam bohater zakochuje się w Lady Marion, która wątpi w jego tożsamość i szlachetne intencje. Robin zbiera grupę wyrzutków, żeby zapobiec wojnie domowej i przywrócić Anglii dawną świetność.","popularity":5.6062,"poster_path":"/79AXjQDNwOMORFEL0LCusJWxNJJ.jpg","release_date":"2010-05-12","softcore":false,"video":false,"vote_average":6.4,"vote_count":5018,"credit_id":"52fe43f2c3a368484e0076a7","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/gxJnDz2W566PRdYKCaJrp1FpRRI.jpg","genre_ids":[28,12,36,18],"id":20662,"title":"Robin Hood","original_language":"en","original_title":"Robin Hood","overview":"Film opowiada o losach doskonałego łucznika, który walczył u boku króla Ryszarda przeciw Francuzom. Po śmierci władcy Robin trafia do Nottingham, podporządkowanego chciwemu szeryfowi. Tam bohater zakochuje się w Lady Marion, która wątpi w jego tożsamość i szlachetne intencje. Robin zbiera grupę wyrzutków, żeby zapobiec wojnie domowej i przywrócić Anglii dawną świetność.","popularity":5.6062,"poster_path":"/79AXjQDNwOMORFEL0LCusJWxNJJ.jpg","release_date":"2010-05-12","softcore":false,"video":false,"vote_average":6.4,"vote_count":5018,"credit_id":"52fe43f2c3a368484e0076bf","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/4lCritA97pEdHCTEerfrkv3BMDH.jpg","genre_ids":[18,10749,53],"id":31650,"title":"Osaczona","original_language":"en","original_title":"Someone to Watch Over Me","overview":"Claire Gregory, nowojorska osobowość z wyższej półki, jest świadkiem morderstwa w luksusowym klubie nocnym. Do jej ochrony zostaje przydzielony detektyw Mike Keegan, niedawno awansowany.","popularity":0.9956,"poster_path":"/tU975TslsyNJH9NYOyCtWUdAa0K.jpg","release_date":"1987-10-09","softcore":false,"video":false,"vote_average":5.891,"vote_count":216,"credit_id":"52fe44939251416c91015891","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/7HiMvoDSYW4fyu4rkmWH6pcKKuF.jpg","genre_ids":[35,18,80,53],"id":7270,"title":"Naciągacze","original_language":"en","original_title":"Matchstick Men","overview":"Fałszerz Roy i jego protegowany są o krok od sfinalizowania dealu życia, kiedy nieoczekiwany przyjazd nastoletniej córki Roya kompletnie dezorganizuje ich życie i stawia pod dużym znakiem zapytania powodzenie ich planu.","popularity":2.5759,"poster_path":"/2GhiBT1Tke7fG7w2I2dHirNtcfj.jpg","release_date":"2003-09-12","softcore":false,"video":false,"vote_average":7.007,"vote_count":1980,"credit_id":"52fe4475c3a36847f8097553","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/yNhmsmCqK6bTl4xUT28fJ1r6f61.jpg","genre_ids":[35,18,10749],"id":11931,"title":"Siostry","original_language":"en","original_title":"In Her Shoes","overview":"Maggie jest beztroska, lubi imprezy i flirtowanie; Rose to poważna prawniczka, ukrywająca się przed światem w pięknie urządzonym mieszkaniu. Są siostrami - nic ich nie łączy poza rozmiarem butów i DNA. Gdy między nimi wybucha otwarty konflikt, obie przekonane są, że już nigdy się do siebie nie odezwą - aż nagle odkrywają, że mają wspaniałą babcię, o której myślały, że dawno nie żyje. Z jej pomocą Maggie i Rose uczą się żyć w zgodzie nawzajem i z samymi sobą.","popularity":2.5514,"poster_path":"/goH4HXQdRIXW5J1P9a03THKRVuq.jpg","release_date":"2005-10-07","softcore":false,"video":false,"vote_average":6.2,"vote_count":1290,"credit_id":"52fe44a39251416c7503bc57","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/3g8rLMw0SbA0h2GHiOCBoqFTXVq.jpg","genre_ids":[12,14],"id":11976,"title":"Legenda","original_language":"en","original_title":"Legend","overview":"Okrutny władca ciemności postanawia pogrążyć Ziemię w mroku z pomocą odrażających goblinów. Ale musi zabić mieszkające na niej jednorożce. Wysyła więc najgroźniejszego ze sług, Bliksa, aby zabił dwa ostatnie zwierzęta. Księżniczce Lili, która bawi się w lesie z przyjacielem, Jackiem, udaje się zbliżyć do jednorożców. Wówczas Blix zabija jednego z nich, a drugiego jednorożca i Lili zabiera do podziemnej krainy. Urzeczywistnia się tragiczny plan. Słońce gaśnie, Ziemię skuwa mróz. Jack postanawia ratować księżniczkę i sprowadzić z powrotem światło.","popularity":4.5208,"poster_path":"/ohsJr7PyXjliFm9Z6Xx0fdsyKj1.jpg","release_date":"1985-08-28","softcore":false,"video":false,"vote_average":6.247,"vote_count":1383,"credit_id":"52fe44ae9251416c7503d3bf","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/6ghc2ySuEnTW8h3YgZZufk2SOTv.jpg","genre_ids":[28,18,53],"id":12113,"title":"W Sieci Kłamstw","original_language":"en","original_title":"Body of Lies","overview":"Trwa polowanie CIA na niebezpiecznego przywódcę serii ataków terrorystycznych. Roger Ferris to człowiek agencji, który działa w terenie, przemieszczając się z miejsca na miejsce w pogoni za informacjami, które pozwolą mu uprzedzać zagrożenie. Oko na niebie - satelitarne łącze obserwuje Ferrisa. Po drugiej stronie łącza znajduje się Ed Hoffman, kontrolujący przebieg zdarzeń z odległości tysięcy kilometrów. I gdy Ferris zbliża się do celu, odkrywa, że zaufanie może stanowić śmiertelne zagrożenie, lecz jest konieczne do przetrwania.","popularity":3.5148,"poster_path":"/xFfeqKoM3l6c0O0XWBMPyENNJRN.jpg","release_date":"2008-10-09","softcore":false,"video":false,"vote_average":6.632,"vote_count":3325,"credit_id":"52fe44b79251416c7503e97d","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/6ghc2ySuEnTW8h3YgZZufk2SOTv.jpg","genre_ids":[28,18,53],"id":12113,"title":"W Sieci Kłamstw","original_language":"en","original_title":"Body of Lies","overview":"Trwa polowanie CIA na niebezpiecznego przywódcę serii ataków terrorystycznych. Roger Ferris to człowiek agencji, który działa w terenie, przemieszczając się z miejsca na miejsce w pogoni za informacjami, które pozwolą mu uprzedzać zagrożenie. Oko na niebie - satelitarne łącze obserwuje Ferrisa. Po drugiej stronie łącza znajduje się Ed Hoffman, kontrolujący przebieg zdarzeń z odległości tysięcy kilometrów. I gdy Ferris zbliża się do celu, odkrywa, że zaufanie może stanowić śmiertelne zagrożenie, lecz jest konieczne do przetrwania.","popularity":3.5148,"poster_path":"/xFfeqKoM3l6c0O0XWBMPyENNJRN.jpg","release_date":"2008-10-09","softcore":false,"video":false,"vote_average":6.632,"vote_count":3325,"credit_id":"52fe44b79251416c7503e93f","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/dV5AKLfihrUTfAqh7dj9MG3OUWl.jpg","genre_ids":[35,18,10749],"id":9726,"title":"Dobry rok","original_language":"en","original_title":"A Good Year","overview":"Film, który rozpocznie się w Londyn, ale swój finał ma rozkwitającej złotem jesiennej Prowansji.  Max Skiner drapieżny rekin londyńskiej finansjery, dostaje wiadomość o śmierci wuja i przypadającej mu w spadku posiadłości z winnicą na południu Francji. Między jedną transakcją a drugą, gdzie wystarczy wstrzymać oddech na kilka minut, zablefować, zaszarżować z kursem, zmylić konkurencję by zarobić grube miliony, Max podejmuje decyzję o odwiedzeniu posiadłości. Na początku wygląda to na krótki wyjazd, sprowadzający się do spotkania z prawnikami i notariuszami, potem rozpoczyna się wielka sentymentalna podróż w przeszłość. I nieoczekiwane spotkanie zupełnie nowej przyszłości.","popularity":3.4299,"poster_path":"/mC8V9M7n527FTmxfaZCjY1ktc8R.jpg","release_date":"2006-09-09","softcore":false,"video":false,"vote_average":6.692,"vote_count":1643,"credit_id":"52fe4523c3a36847f80be745","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/dV5AKLfihrUTfAqh7dj9MG3OUWl.jpg","genre_ids":[35,18,10749],"id":9726,"title":"Dobry rok","original_language":"en","original_title":"A Good Year","overview":"Film, który rozpocznie się w Londyn, ale swój finał ma rozkwitającej złotem jesiennej Prowansji.  Max Skiner drapieżny rekin londyńskiej finansjery, dostaje wiadomość o śmierci wuja i przypadającej mu w spadku posiadłości z winnicą na południu Francji. Między jedną transakcją a drugą, gdzie wystarczy wstrzymać oddech na kilka minut, zablefować, zaszarżować z kursem, zmylić konkurencję by zarobić grube miliony, Max podejmuje decyzję o odwiedzeniu posiadłości. Na początku wygląda to na krótki wyjazd, sprowadzający się do spotkania z prawnikami i notariuszami, potem rozpoczyna się wielka sentymentalna podróż w przeszłość. I nieoczekiwane spotkanie zupełnie nowej przyszłości.","popularity":3.4299,"poster_path":"/mC8V9M7n527FTmxfaZCjY1ktc8R.jpg","release_date":"2006-09-09","softcore":false,"video":false,"vote_average":6.692,"vote_count":1643,"credit_id":"52fe4523c3a36847f80be74b","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/3Nb9AQaq3elLNCUBxG8VprmqfhZ.jpg","genre_ids":[80,18,53],"id":9740,"title":"Hannibal","original_language":"en","original_title":"Hannibal","overview":"Milioner Mason Verger informuje FBI, że chce przekazać na ręce Clarice Starling materiały, które mogą pomóc w schwytaniu Hannibala Lectera. Przed laty Verger został przez niego potwornie okaleczony. Teraz żyje tylko chęcią krwawego odwetu na doktorze. Agentka Starling ma posłużyć do wywabienia Lectera z kryjówki. Inspektor Pazzi wpada na trop Hannibala. Funkcjonariusz postanawia sprzedać tę informację Vergerowi. Ten stawia jednak warunek - Pazzi dostanie 3 miliony dolarów, jeśli dostarczy odcisk palca domniemanego Lectera.","popularity":1.7024,"poster_path":"/hFRQ7LcCyFOdu6ZfTIZt0o0cMI5.jpg","release_date":"2001-02-08","softcore":false,"video":false,"vote_average":6.779,"vote_count":5197,"credit_id":"52fe4525c3a36847f80bef3b","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/3Nb9AQaq3elLNCUBxG8VprmqfhZ.jpg","genre_ids":[80,18,53],"id":9740,"title":"Hannibal","original_language":"en","original_title":"Hannibal","overview":"Milioner Mason Verger informuje FBI, że chce przekazać na ręce Clarice Starling materiały, które mogą pomóc w schwytaniu Hannibala Lectera. Przed laty Verger został przez niego potwornie okaleczony. Teraz żyje tylko chęcią krwawego odwetu na doktorze. Agentka Starling ma posłużyć do wywabienia Lectera z kryjówki. Inspektor Pazzi wpada na trop Hannibala. Funkcjonariusz postanawia sprzedać tę informację Vergerowi. Ten stawia jednak warunek - Pazzi dostanie 3 miliony dolarów, jeśli dostarczy odcisk palca domniemanego Lectera.","popularity":1.7024,"poster_path":"/hFRQ7LcCyFOdu6ZfTIZt0o0cMI5.jpg","release_date":"2001-02-08","softcore":false,"video":false,"vote_average":6.779,"vote_count":5197,"credit_id":"52fe4525c3a36847f80bef5f","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/u1OtWduhkRvGreEMWOMHDrzi29Z.jpg","genre_ids":[99],"id":674882,"title":"The Donut King","original_language":"en","original_title":"The Donut King","overview":"","popularity":0.1787,"poster_path":"/8eN5x0DkXB4ByG2mLIopETdTwVg.jpg","release_date":"2020-08-24","softcore":false,"video":false,"vote_average":6.9,"vote_count":19,"credit_id":"608f7ecaede1b00077486a17","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":null,"genre_ids":[53],"id":960177,"title":"Outside","original_language":"en","original_title":"Outside","overview":"","popularity":0.877,"poster_path":null,"release_date":"","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"624ff534383df2006485ee3c","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/dDJS3OCmFMn8KQJCL9UC8XHpmsQ.jpg","genre_ids":[18],"id":49457,"title":"Boy and Bicycle","original_language":"en","original_title":"Boy and Bicycle","overview":"","popularity":0.2649,"poster_path":"/l8APEAGZk3FT7tLS6MypcozryVw.jpg","release_date":"1965-01-01","softcore":false,"video":false,"vote_average":5.605,"vote_count":38,"credit_id":"52fe4796c3a36847f813dad7","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/xyVURBvbRIzsGJlD0h8vybkXjLs.jpg","genre_ids":[18,10752],"id":19067,"title":"Pojedynek","original_language":"en","original_title":"The Duellists","overview":"Strasburg, rok 1800. Napoleon Bonaparte został władcą Francji. Porucznik Armand d'Hubert (Keith Carradine) dostaje zadanie, by odnaleźć porucznika Gabriela Ferauda (Harvey Keitel) i przekazać mu informację od dowództwa, że jest osadzony w areszcie domowym. Awanturniczy Feraud uważa, że został znieważony jego honor i wyzywa d'Huberta na szable. Tak rozpoczyna się ciągnący przez całą kampanię napoleońską pojedynek. Tylko trzy powody umożliwiają odstępstwo od niego. Po pierwsze, nie można walczyć z kimś, gdy się jest w różnych miejscach, po drugie, gdy żołnierze są innego stopnia, naruszenie dyscypliny oraz wówczas, gdy państwo jest w stanie wojny.","popularity":3.2058,"poster_path":"/nqjMYlUXnmmO8Jqucow4nj9alE5.jpg","release_date":"1977-08-31","softcore":false,"video":false,"vote_average":7.244,"vote_count":633,"credit_id":"52fe47b79251416c750a3239","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/rzOCr1VCQa0BUU9x34JbwzM5mRo.jpg","genre_ids":[18,36,10770],"id":50008,"title":"Obywatel Welles","original_language":"en","original_title":"RKO 281","overview":"Orson Welles po zrobieniu kariery w Nowym Jorku przybywa do Hollywood, by kręcić filmy. Ma opinię geniusza, a więc jego pierwszy film też musi być genialny - trzeba tylko znaleźć właściwy temat. Po przyjęciu na zamku milionera Williama Hearsta Welles zdecydował, że nakręci film właśnie o nim. Przekonał do współpracy scenarzystę Hermana Mankiewicza, a studio RKO zgodziło się sfinansować projekt. Kiedy jednak Hearst dowiaduje się, o kim ma być ten film, rozpoczyna walkę, której celem jest unicestwienie „Obywatela Kane'a“, zanim ktokolwiek go obejrzy.","popularity":2.2486,"poster_path":"/v8Z4ENMOAT5OpiMeS1PBNPui3X0.jpg","release_date":"1999-11-20","softcore":false,"video":false,"vote_average":6.5,"vote_count":101,"credit_id":"52fe47b5c3a36847f8143e4f","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/jAXel5sHK1bnv9lL1U4HOkdxuD9.jpg","genre_ids":[878,28,12],"id":487186,"title":"Halo: Nightfall","original_language":"en","original_title":"Halo: Nightfall","overview":"","popularity":1.4827,"poster_path":"/liLQ8EFzHN06eFZ9KQMDK6cmGaK.jpg","release_date":"2014-02-05","softcore":false,"video":false,"vote_average":6.742,"vote_count":188,"credit_id":"60a753a09a64c1006e24e4cc","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/sM42bpH73dmf3kJrE8xr4kztYqR.jpg","genre_ids":[878,9648,27],"id":70981,"title":"Prometeusz","original_language":"en","original_title":"Prometheus","overview":"Mamy rok 2089, zespół archeologów pod kierownictwem Elizabeth Shaw (Noomi Rapace) odkrywa tajemnicze piktogramy, które są według nich dziełem starożytnej cywilizacji. By dowiedzieć się więcej o autorach znaków, wyruszają supernowoczesnym statkiem kosmicznym o nazwie \"Prometeusz\" do odległego zakątka naszego wszechświata. Otóż całą wyprawę finansuje korporacja Weyland Industries, którą na statku reprezentuje bezwzględna Meredith Vickers (Charlize Theron). Naukowcy wierzą, że uda im się nawiązać pokojowe kontakty z Obcymi, ale okazuję się, że twórcy znaków są bardzo niebezpieczni. Shaw i jej towarzysze będą musieli stoczyć walkę o własne życie i przyszłość całej ludzkiej rasy.","popularity":11.09,"poster_path":"/rSiDg2yE4kqcBkbqJvnA9dAsjaw.jpg","release_date":"2012-05-30","softcore":false,"video":false,"vote_average":6.597,"vote_count":13271,"credit_id":"52fe481dc3a368484e0e9d95","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/sM42bpH73dmf3kJrE8xr4kztYqR.jpg","genre_ids":[878,9648,27],"id":70981,"title":"Prometeusz","original_language":"en","original_title":"Prometheus","overview":"Mamy rok 2089, zespół archeologów pod kierownictwem Elizabeth Shaw (Noomi Rapace) odkrywa tajemnicze piktogramy, które są według nich dziełem starożytnej cywilizacji. By dowiedzieć się więcej o autorach znaków, wyruszają supernowoczesnym statkiem kosmicznym o nazwie \"Prometeusz\" do odległego zakątka naszego wszechświata. Otóż całą wyprawę finansuje korporacja Weyland Industries, którą na statku reprezentuje bezwzględna Meredith Vickers (Charlize Theron). Naukowcy wierzą, że uda im się nawiązać pokojowe kontakty z Obcymi, ale okazuję się, że twórcy znaków są bardzo niebezpieczni. Shaw i jej towarzysze będą musieli stoczyć walkę o własne życie i przyszłość całej ludzkiej rasy.","popularity":11.09,"poster_path":"/rSiDg2yE4kqcBkbqJvnA9dAsjaw.jpg","release_date":"2012-05-30","softcore":false,"video":false,"vote_average":6.597,"vote_count":13271,"credit_id":"52fe481dc3a368484e0e9ddb","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/g8ArhdKmms7TKGX1SgvXf5d1RXG.jpg","genre_ids":[28,12,18,53],"id":75174,"title":"Przetrwanie","original_language":"en","original_title":"The Grey","overview":"Ridley Scott (\"Helikopter w ogniu\", \"Gladiator\", \"Robin Hood\") zaprasza na prawdziwą szkołę przetrwania! W sercu Alaski rozbija się samolot. Na miejscu ginie 117 pasażerów, a tylko ośmiu udaje się przeżyć. Na skutym lodem odludziu, bez kontaktu ze światem, bez ciepłej odzieży i jedzenia, każdy z nich musi się zmierzyć z siłami natury i samym sobą. Uznani za zaginionych, ścigani przez stado wygłodniałych wilków, nie mieliby żadnych szans na przetrwanie, gdyby nie jeden z nich. Jeszcze wczoraj chciał umrzeć, dziś będzie walczył, by przeżyć za wszelką cenę. Wszystko dla pewnej kobiety.  [opis dystrybutora dvd]","popularity":4.7871,"poster_path":"/inGuwtO18iPD5FGTGxwjUwPbBB0.jpg","release_date":"2012-01-26","softcore":false,"video":false,"vote_average":6.574,"vote_count":4121,"credit_id":"52fe48f3c3a368484e11332f","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/isxWigGBWpXtc2xOxybiYWxHzWm.jpg","genre_ids":[27,53,878],"id":838484,"title":"Wybieraj albo umieraj","original_language":"en","original_title":"Choose or Die","overview":"Dwoje przyjaciół skuszonych okazją zgarnięcia nieodebranej nagrody pieniężnej restartuje tajemniczą grę wideo z lat 80. i wkracza w surrealistyczny świat grozy.","popularity":1.5132,"poster_path":"/jEYE5BPFd5FuPa1judcjpW6xqKp.jpg","release_date":"2022-04-15","softcore":false,"video":false,"vote_average":5.249,"vote_count":876,"credit_id":"60c06d630721660029e2879e","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/kq99sRIMHlgIPHV8U4SHdWBZMRx.jpg","genre_ids":[18,53],"id":87499,"title":"Grupa \"Wschód\"","original_language":"en","original_title":"The East","overview":"Młoda i ambitna agentka Sarah Moss zostaje zatrudniona przez prywatną firmę wywiadowczą. Otrzymuje zadanie infiltracji niebezpiecznej grupy anarchistycznej znanej pod nazwą The East (Grupa \"Wschód\"), prowadzącej działalność przeciwko wielkim korporacjom i ich liderom, którzy, jak się wydaje, uniknęli kary za zbrodnie przeciwko ludzkości. Działalność Grupy \"Wschód\" nasila się, a Sarah coraz bardziej ją rozumie i angażuje się. Jej życie jest w niebezpieczeństwie...  [opis dystrybutora Blu-ray]","popularity":1.1332,"poster_path":"/qTJPT1jFz94vSkmiHMUxQTfQsL7.jpg","release_date":"2013-05-31","softcore":false,"video":false,"vote_average":6.546,"vote_count":861,"credit_id":"52fe49ca9251416c910b8cad","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/yFop8dQmR7hvQaA7yzRb4gDSDoL.jpg","genre_ids":[18,27,53],"id":86825,"title":"Stoker","original_language":"en","original_title":"Stoker","overview":"Ojciec kilkunastoletniej Indii Stoker ginie w tajemniczym wypadku samochodowym. Wkrótce potem do wielkiego, położonego na odludziu domu, w którym dziewczyna mieszka wraz z niezrównoważoną matką, Evelyn Stoker, wprowadza się brat zmarłego, wuj Charlie. India nie wiedziała dotąd o jego istnieniu. Początkowo jest zafascynowana Charlie'em, szybko jednak nabiera podejrzeń co do jego intencji...","popularity":2.4588,"poster_path":"/o0giW5oasaef5m9sgBuq0C7IkIa.jpg","release_date":"2013-02-28","softcore":false,"video":false,"vote_average":6.6,"vote_count":2412,"credit_id":"52fe49a39251416c910b3ac7","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/mJaIjahqXpWtDVMMLQr81yRNniG.jpg","genre_ids":[53,80,18],"id":109091,"title":"Adwokat","original_language":"en","original_title":"The Counselor","overview":"Pewien uznany prawnik, którego imię nie jest ujawnione, zostaje skuszony możliwością zarobienia łatwych pieniędzy. Mimo ostrzeżeń ze strony Westraya oraz podejrzanego charakteru sprawy, arogancja bierze górę nad rozsądkiem. Adwokat jedną nieprzemyślaną decyzją wplątuje się w tajemnicze, ciemne interesy, podejmując współpracę z ekstrawaganckim właścicielem klubu nocnego, Reinerem. Na horyzoncie pojawia się również Malkina, bezwzględna socjopatka i dziewczyna Reinera. Wraz ze swoją piękną narzeczoną, Laurą, adwokat musi zmierzyć się z niebezpieczeństwami narkotykowego podziemia, z którego ucieczka zdaje się przerastać jego możliwości.","popularity":3.7524,"poster_path":"/4Bdf4uGxwizxRJsSIk1QrwACxSR.jpg","release_date":"2013-10-25","softcore":false,"video":false,"vote_average":5.291,"vote_count":1994,"credit_id":"52fe4aaac3a36847f81db46f","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/dDJS3OCmFMn8KQJCL9UC8XHpmsQ.jpg","genre_ids":[18],"id":49457,"title":"Boy and Bicycle","original_language":"en","original_title":"Boy and Bicycle","overview":"","popularity":0.2649,"poster_path":"/l8APEAGZk3FT7tLS6MypcozryVw.jpg","release_date":"1965-01-01","softcore":false,"video":false,"vote_average":5.605,"vote_count":38,"credit_id":"627298c2c74eba0f0dec66a1","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":"/dDJS3OCmFMn8KQJCL9UC8XHpmsQ.jpg","genre_ids":[18],"id":49457,"title":"Boy and Bicycle","original_language":"en","original_title":"Boy and Bicycle","overview":"","popularity":0.2649,"poster_path":"/l8APEAGZk3FT7tLS6MypcozryVw.jpg","release_date":"1965-01-01","softcore":false,"video":false,"vote_average":5.605,"vote_count":38,"credit_id":"627298d2c04429006b2c7d2d","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/iXXPaQPfQowpQ5UvhsHLj9BgFhe.jpg","genre_ids":[27,878],"id":126889,"title":"Obcy: Przymierze","original_language":"en","original_title":"Alien: Covenant","overview":"\"Obcy: Przymierze\" to drugi rozdział nowej trylogii, którą zapoczątkował film \"Prometeusz\". Statek osadniczy \"Przymierze\" dociera na nieznaną planetę, która wydaje się być prawdziwym rajem. Członkowie ekspedycji szybko się jednak przekonują, że trafili do mrocznego, pełnego tajemnic i niebezpieczeństw świata, którego jedynym mieszkańcem jest android David (Michael Fassbender), ocalały z katastrofy \"Prometeusza\".","popularity":12.7809,"poster_path":"/uTEvJeGNUFmCMIhFXxOoGLEzUfp.jpg","release_date":"2017-05-09","softcore":false,"video":false,"vote_average":6.176,"vote_count":9425,"credit_id":"52fe4ae9c3a368484e16d6c1","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":207137,"title":"Britain in a Day","original_language":"en","original_title":"Britain in a Day","overview":"","popularity":0.4159,"poster_path":"/xp6f86NxBUAVLWig4v1Qq7lGDkq.jpg","release_date":"2012-06-10","softcore":false,"video":false,"vote_average":6.7,"vote_count":7,"credit_id":"62711697a24c50599548392a","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/hJ1jUw8irCiWwQk7BElxF92BrlK.jpg","genre_ids":[12,18,28],"id":147441,"title":"Exodus: Bogowie i królowie","original_language":"en","original_title":"Exodus: Gods and Kings","overview":"Znakomity reżyser Ridley Scott (\"Gladiator\", \"Prometeusz\") zrealizował widowiskowy film \"Exodus: Bogowie i królowie\" - epicką opowieść o  człowieku, który znalazł w sobie dość odwagi, by przeciwstawić się całemu imperium. Dzięki zastosowaniu najnowocześniejszych wizualnych efektów specjalnych, twórca ukazuje na nowo biblijną historię Mojżesza (Christian Bale), który występuje przeciwko faraonowi Ramzesowi (Joel Edgerton) i wyprowadza 400 000 niewolników z Egiptu, nawiedzonego przez dziesięć plag.","popularity":6.6821,"poster_path":"/yiceZjWmzOpHuOnmwU1eubXlttJ.jpg","release_date":"2014-12-03","softcore":false,"video":false,"vote_average":5.883,"vote_count":4852,"credit_id":"52fe4ba69251416c75109a81","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/sjsaxwNsgBbrWrJIXtCT5DNo9Mt.jpg","genre_ids":[80,53],"id":181283,"title":"System","original_language":"en","original_title":"Child 44","overview":"Stalinowska Rosja. Lew Stiepanowicz Demidow (Tom Hardy) to młody funkcjonariusz Ministerstwa Bezpieczeństwa Państwowego sprawnie pnący się po szczeblach kariery. Jest posłusznym sługą systemu, jednak pewnego dnia jego wiara w ideały Partii zostaje zachwiana. Przełożeni każą mu zatuszować sprawę okrutnego morderstwa czteroletniego chłopca. Gdy zaczynają ginąć kolejne dzieci, narażając się na gniew zwierzchników, Demidow rozpoczyna śledztwo na własną rękę.","popularity":2.6368,"poster_path":"/7ubjVQsjQB6la8CQeX21GNLhPYP.jpg","release_date":"2015-03-15","softcore":false,"video":false,"vote_average":6.286,"vote_count":1819,"credit_id":"52fe4c639251416c75118f3d","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/joXz5iPvhDvrHUejlviswMCZaEz.jpg","genre_ids":[53,18,80],"id":164457,"title":"Zrodzony w Ogniu","original_language":"en","original_title":"Out of the Furnace","overview":"Russell Baze (Christian Bale) zarabia na chleb ciężką pracą w miejscowej hucie. Wolny czas poświęca ukochanej Lenie (Zoe Saldana) i schorowanemu ojcu. Stara się także otoczyć opieką młodszego brata (Casey Affleck), którego marzeniem jest za wszelką cenę wyrwać się z serca otaczającej ich bezkresnej puszczy. Pech sprawia, że za spowodowanie wypadku Russell trafia do więzienia. Gdy wyjdzie, zmuszony będzie zrobić wszystko, by wyciągnąć brata z rąk lokalnych przestępców zajmujących się handlem narkotykami i organizacją nielegalnych walk bokserskich.  [opis dystrybutora dvd]","popularity":2.6138,"poster_path":"/55EsGmZ8clSXn9UrrKIOQ8oSHdv.jpg","release_date":"2013-11-12","softcore":false,"video":false,"vote_average":6.565,"vote_count":2129,"credit_id":"52fe4c7ac3a36847f82304b7","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/puAUfSiVrQO2DPKOobHFjqVcXPt.jpg","genre_ids":[28,35,80],"id":34544,"title":"Drużyna A","original_language":"en","original_title":"The A-Team","overview":"Są uzbrojeni, niebezpieczni… i zupełnie stuknięci! Przygotuj się na pełną akcji ostrą jazdę, w której wybuchowe kreacje tworzą Liam Neeson, Bradley Cooper, Quinton 'Rampage' Jackson i Sharlto Copley. Niesłusznie skazani przez sąd wojenny żołnierze z oddziałów specjalnych łączą siły, aby uciec z więzienia i podjąć się najtrudniejszej misji w karierze. Gdy zrealizowanie planu wymaga szalonej odwagi, doskonałego zgrania w czasie i mnóstwa materiałów wybuchowych – to robota dla Drużyny A.  [opis dystrybutora dvd]","popularity":5.6686,"poster_path":"/kjas4yHCnB2Q2tgSLsA83AL0u7O.jpg","release_date":"2010-06-09","softcore":false,"video":false,"vote_average":6.418,"vote_count":5006,"credit_id":"650555653cd12c010ccf9f37","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/yMgVnqtKhvXAjPifqyH6Im0ozSA.jpg","genre_ids":[18],"id":235093,"title":"Zabić Kennedy'ego","original_language":"en","original_title":"Killing Kennedy","overview":"Oparty na bestsellerowej książce Billa O'Reilly'ego oraz Martina Dugarda film przedstawia historię jednego z najbardziej wstrząsających wydarzeń w amerykańskiej historii. Akcja dokumentu rozpoczyna się w 1959 roku od najważniejszych punktów zwrotnych zarówno w życiu przyszłego prezydenta jak i jego zabójcy, John F. Kennedy przebywa w Waszyngtonie, gdzie ogłasza swoją kandydaturę na prezydenta, podczas gdy Lee Harvey Oswald w znajdującej się w Moskwie ambasadzie USA zrzeka się swojego amerykańskiego obywatelstwa. Te dwie historie, które dotyczą członka jednej z najbardziej zamożnych i najpotężniejszych amerykańskich rodzin USA oraz rozczarowanego byłego żołnierza amerykańskiej marynarki wojennej (Marine) i marksisty, znajdują się na katastrofalnym torze, który zmieni bieg historii. Widzowie będą obserwować zwroty i upadki obu postaci, zakończone nie jednym, a dwoma szokującymi zgonami, które wstrząsnęły całym, amerykańskim narodem.","popularity":1.3263,"poster_path":"/oKhgsXzQggIcSO4lOdj1q7cr3Lr.jpg","release_date":"2013-11-10","softcore":false,"video":false,"vote_average":5.776,"vote_count":78,"credit_id":"52fe4e3fc3a36847f8285dcb","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/bV0hIYzh6uiVE7ARNhF95yxnch4.jpg","genre_ids":[12,16,35,10751],"id":341064,"title":"The Polar Bears","original_language":"en","original_title":"The Polar Bears","overview":"","popularity":0.5559,"poster_path":"/g8izNQ8c0Ia7tErDSvb6xNsL1th.jpg","release_date":"2012-12-31","softcore":false,"video":false,"vote_average":6.3,"vote_count":3,"credit_id":"610806d57719d7002c9e6b53","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/mJaIjahqXpWtDVMMLQr81yRNniG.jpg","genre_ids":[53,80,18],"id":109091,"title":"Adwokat","original_language":"en","original_title":"The Counselor","overview":"Pewien uznany prawnik, którego imię nie jest ujawnione, zostaje skuszony możliwością zarobienia łatwych pieniędzy. Mimo ostrzeżeń ze strony Westraya oraz podejrzanego charakteru sprawy, arogancja bierze górę nad rozsądkiem. Adwokat jedną nieprzemyślaną decyzją wplątuje się w tajemnicze, ciemne interesy, podejmując współpracę z ekstrawaganckim właścicielem klubu nocnego, Reinerem. Na horyzoncie pojawia się również Malkina, bezwzględna socjopatka i dziewczyna Reinera. Wraz ze swoją piękną narzeczoną, Laurą, adwokat musi zmierzyć się z niebezpieczeństwami narkotykowego podziemia, z którego ucieczka zdaje się przerastać jego możliwości.","popularity":3.7524,"poster_path":"/4Bdf4uGxwizxRJsSIk1QrwACxSR.jpg","release_date":"2013-10-25","softcore":false,"video":false,"vote_average":5.291,"vote_count":1994,"credit_id":"530037d79251416ae11fb468","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/hJ1jUw8irCiWwQk7BElxF92BrlK.jpg","genre_ids":[12,18,28],"id":147441,"title":"Exodus: Bogowie i królowie","original_language":"en","original_title":"Exodus: Gods and Kings","overview":"Znakomity reżyser Ridley Scott (\"Gladiator\", \"Prometeusz\") zrealizował widowiskowy film \"Exodus: Bogowie i królowie\" - epicką opowieść o  człowieku, który znalazł w sobie dość odwagi, by przeciwstawić się całemu imperium. Dzięki zastosowaniu najnowocześniejszych wizualnych efektów specjalnych, twórca ukazuje na nowo biblijną historię Mojżesza (Christian Bale), który występuje przeciwko faraonowi Ramzesowi (Joel Edgerton) i wyprowadza 400 000 niewolników z Egiptu, nawiedzonego przez dziesięć plag.","popularity":6.6821,"poster_path":"/yiceZjWmzOpHuOnmwU1eubXlttJ.jpg","release_date":"2014-12-03","softcore":false,"video":false,"vote_average":5.883,"vote_count":4852,"credit_id":"5319bf5192514177b1002687","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/fvFrMDT1aKd1bap493IT2KqTLC7.jpg","genre_ids":[10749,18],"id":434203,"title":"Nowość","original_language":"en","original_title":"Newness","overview":"Martin i Gaby poznają się przez aplikację randkową i chcą stworzyć stały związek. Wkradająca się do niego nuda podpowiada im niekonwencjonalne rozwiązanie.","popularity":5.8401,"poster_path":"/vySlYPqOrI5s8Nu6bzpGKQbotVy.jpg","release_date":"2017-11-03","softcore":false,"video":false,"vote_average":6.054,"vote_count":626,"credit_id":"610ed0257719d70072cc5fcd","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/tE2f15kR174d2YxqtEjzoxPpFmR.jpg","genre_ids":[99],"id":852390,"title":"Kipchoge: The Last Milestone","original_language":"en","original_title":"Kipchoge: The Last Milestone","overview":"","popularity":0.3363,"poster_path":"/lMYPMCPVlGj2BVkN4nb1aNcQS08.jpg","release_date":"2021-07-20","softcore":false,"video":false,"vote_average":7.8,"vote_count":17,"credit_id":"611433ce9b6e47007d76b718","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/cmmOLD0UOrw8rJ2WBb3rvEUhkE1.jpg","genre_ids":[18,10749],"id":9044,"title":"Tristan i Izolda","original_language":"en","original_title":"Tristan & Isolde","overview":"Tristan, walcząc w turnieju jako reprezentant swojego władcy, zdobywa rękę pięknej Izoldy. Okazuje się, że jest ona kobietą, która niedawno ocaliła mu życie i z wzajemnością go pokochała.","popularity":2.394,"poster_path":"/31bnlyOtlsxPxGUWfJuoLNJFDuP.jpg","release_date":"2006-04-07","softcore":false,"video":false,"vote_average":6.7,"vote_count":846,"credit_id":"537f469bc3a3680592003202","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/7d1AQ4jhwtjnyLMumN4n0pFv1g.jpg","genre_ids":[99],"id":288706,"title":"Italy in a Day - Un giorno da italiani","original_language":"it","original_title":"Italy in a Day - Un giorno da italiani","overview":"","popularity":0.2971,"poster_path":"/ubZY9TR8OsdHGE7uegCt8dfMi59.jpg","release_date":"2014-09-02","softcore":false,"video":false,"vote_average":7.7,"vote_count":52,"credit_id":"53fb0df8c3a368735e00472e","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/lzMS0CI3FLQYC5EgJoWeIaEt0lm.jpg","genre_ids":[878,18,12],"id":286217,"title":"Marsjanin","original_language":"en","original_title":"The Martian","overview":"Potężna burza piaskowa sprawia, że sześcioosobowa marsjańska ekspedycja, w której skład wchodzi Mark Watney (Matt Damon), musi ratować się ucieczką z Czerwonej Planety. Kiedy ciężko ranny Mark odzyskuje przytomność, stwierdza, że został na Marsie sam w zdewastowanym przez wichurę obozie, z minimalnymi zapasami powietrza i żywności, a na dodatek bez łączności z Ziemią. Co gorsza, zarówno pozostali członkowie ekspedycji, jak i sztab w Houston uważają go za martwego, nikt więc nie zorganizuje wyprawy ratunkowej; zresztą, nawet gdyby wyruszyli po niego niemal natychmiast, dotarliby na Marsa długo po tym, jak zabraknie mu powietrza, wody i żywności. Czyżby to był koniec? Nic z tego. Mark rozpoczyna heroiczną walkę o przetrwanie, w której równie ważną rolę co naukowa wiedza, zdolności techniczne i pomysłowość odgrywają niezłomna determinacja i umiejętność zachowania dystansu wobec siebie i świata, który nie zawsze gra fair…","popularity":14.8314,"poster_path":"/qS3n6AJD302spmHx5TSs88ICAMo.jpg","release_date":"2015-09-30","softcore":false,"video":false,"vote_average":7.7,"vote_count":21238,"credit_id":"53e88b1ac3a368399f0035c5","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/9KEMuH2H3eqSvr8bjZikYOUePpt.jpg","genre_ids":[35,80,18],"id":31776,"title":"Where the Money Is","original_language":"en","original_title":"Where the Money Is","overview":"","popularity":0.8552,"poster_path":"/s6FODEWgJ9XDwKunGLWEmexguUs.jpg","release_date":"2000-04-14","softcore":false,"video":false,"vote_average":6.0,"vote_count":83,"credit_id":"61574900d2147c008d02dc20","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/254iY5CzFzjnjkP0lUkLpOLvXar.jpg","genre_ids":[80,9648,53],"id":881164,"title":"Dusiciel z Bostonu","original_language":"en","original_title":"Boston Strangler","overview":"\"Dusiciel z Bostonu\" to thriller kryminalny w reżyserii wielokrotnie nagrodzonego Matta Ruskina. To oparta na faktach historia pionierskich reporterek, które w latach 60. nagłośniły sprawę wstrząsających morderstw Dusiciela z Bostonu. Loretta McLaughlin, dziennikarka gazety \"Record American\", jako pierwsza odkrywa powiązania między zabójstwami. Gdy liczba ofiar rośnie, Loretta wraz z przyjaciółką z redakcji, Jean Cole, próbują rozwikłać sprawę, mimo że na każdym kroku muszą borykać się z seksizmem. Mimo to bohaterki za wszelką ceną usiłują dociec prawdy, ryzykując własnym życiem.","popularity":2.382,"poster_path":"/Ap8IK2UsR7RwZkJCWI0Mmwd5S2B.jpg","release_date":"2023-03-16","softcore":false,"video":false,"vote_average":6.642,"vote_count":841,"credit_id":"615b42606ee3d70028cb8210","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/7Zw68eF8z2baBkYFRxcswBYF6Da.jpg","genre_ids":[18],"id":321741,"title":"Wstrząs","original_language":"en","original_title":"Concussion","overview":"Dramat, którego powstanie zainspirował artykuł w magazynie \"GQ\", przedstawiający dowody na powiązanie mikrowstrząsów oraz urazów głowy sportowców z ich późniejszymi samobójstwami. Na związek między tymi zdarzeniami wpadł dr Bennett Omalu (Will Smith), który połączył urazy, na jakie narażeni są sportowcy, z \"przewlekłą traumatyczną encefalopatią\", której objawy często doprowadzają do depresji i śmierci samobójczej.  [opis dystrybutora dvd]","popularity":3.8019,"poster_path":"/yJUvMhZJw1C3MfWlUuWyhS16HLp.jpg","release_date":"2015-11-12","softcore":false,"video":false,"vote_average":7.075,"vote_count":2720,"credit_id":"54c88589c3a36874ac0054a4","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":null,"genre_ids":[],"id":318017,"title":"Le court des grands","original_language":"fr","original_title":"Le court des grands","overview":"","popularity":0.4104,"poster_path":"/yCl3tjFHnTd0cvNSps5gqC2gBf4.jpg","release_date":"2005-11-30","softcore":false,"video":true,"vote_average":8.0,"vote_count":1,"credit_id":"54b685ed9251414edc00000a","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/bA3Zc9GXeLT4NBSfFOnheqghzoS.jpg","genre_ids":[99,18],"id":66150,"title":"Dzień z życia","original_language":"en","original_title":"Life in a Day","overview":"","popularity":0.5471,"poster_path":"/g4Kze731McN2WkcN0OLwi1CMa8u.jpg","release_date":"2011-01-27","softcore":false,"video":false,"vote_average":7.201,"vote_count":251,"credit_id":"55160e4b9251417f4e0003d4","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":null,"genre_ids":[35],"id":335989,"title":"Mind MGMT","original_language":"en","original_title":"Mind MGMT","overview":"","popularity":0.1474,"poster_path":null,"release_date":"","softcore":false,"video":false,"vote_average":10.0,"vote_count":1,"credit_id":"552f0ab4c3a368220e000465","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/lzMS0CI3FLQYC5EgJoWeIaEt0lm.jpg","genre_ids":[878,18,12],"id":286217,"title":"Marsjanin","original_language":"en","original_title":"The Martian","overview":"Potężna burza piaskowa sprawia, że sześcioosobowa marsjańska ekspedycja, w której skład wchodzi Mark Watney (Matt Damon), musi ratować się ucieczką z Czerwonej Planety. Kiedy ciężko ranny Mark odzyskuje przytomność, stwierdza, że został na Marsie sam w zdewastowanym przez wichurę obozie, z minimalnymi zapasami powietrza i żywności, a na dodatek bez łączności z Ziemią. Co gorsza, zarówno pozostali członkowie ekspedycji, jak i sztab w Houston uważają go za martwego, nikt więc nie zorganizuje wyprawy ratunkowej; zresztą, nawet gdyby wyruszyli po niego niemal natychmiast, dotarliby na Marsa długo po tym, jak zabraknie mu powietrza, wody i żywności. Czyżby to był koniec? Nic z tego. Mark rozpoczyna heroiczną walkę o przetrwanie, w której równie ważną rolę co naukowa wiedza, zdolności techniczne i pomysłowość odgrywają niezłomna determinacja i umiejętność zachowania dystansu wobec siebie i świata, który nie zawsze gra fair…","popularity":14.8314,"poster_path":"/qS3n6AJD302spmHx5TSs88ICAMo.jpg","release_date":"2015-09-30","softcore":false,"video":false,"vote_average":7.7,"vote_count":21238,"credit_id":"554b7164c3a3685e63001f32","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":null,"genre_ids":[53,878,27],"id":715003,"title":"First Ascent","original_language":"en","original_title":"First Ascent","overview":"","popularity":0.1453,"poster_path":null,"release_date":"","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"61960975eb14fa002b54f372","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/7eaLWxA98VoqtaYIli6DOVURHsm.jpg","genre_ids":[18],"id":339976,"title":"Siła nadziei","original_language":"en","original_title":"American Woman","overview":"Po tym, jak jej nastoletnia córka znika bez śladu z małego miasteczka w Pensylwanii, 32-letnia kobieta musi sama zająć się wychowywaniem wnuka. Akcja rozciąga się na 11 lat historii, od momentu zaginięcia, przez udrękę i cierpienie, aż do odkrycia prawdy.","popularity":1.9153,"poster_path":"/jNK6NoDOJIC70abBGFITXcyO88n.jpg","release_date":"2018-06-07","softcore":false,"video":false,"vote_average":6.336,"vote_count":165,"credit_id":"55527e509251412d46000b59","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":null,"genre_ids":[18,53,10770],"id":912395,"title":"Orpheus","original_language":"en","original_title":"Orpheus","overview":"","popularity":0.4727,"poster_path":null,"release_date":"2006-01-01","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"61ae08b2aafebd009518407f","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/8t2wI3IZVWucJaULiYLlWTrQ6bS.jpg","genre_ids":[99,18],"id":170039,"title":"Lincoln: Historia zamachu","original_language":"en","original_title":"Killing Lincoln","overview":"Odtworzenie ostatnich dni szesnastego prezydenta Stanów Zjednoczonych Abrahama Lincolna, który zginął z rąk Johna Wilkesa Bootha 14 kwietnia 1865 roku w Teatrze Forda. Fabularyzowany dokument prezentuje historię spisku przeciwko głowie państwa, a także kulisy samego zamachu.","popularity":1.0228,"poster_path":"/zqlOXMsJ0sSyForOe93BSfNW3Pi.jpg","release_date":"2013-02-16","softcore":false,"video":false,"vote_average":5.912,"vote_count":57,"credit_id":"61b622ada3d027001d2de7b6","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/qB9wshRySHgN2MibLOlsW6YalqD.jpg","genre_ids":[9648,53,80],"id":945729,"title":"Duchy w Wenecji","original_language":"en","original_title":"A Haunting in Venice","overview":"Akcja filmu rozgrywa się tuż po zakończeniu II wojny światowej w Wenecji w wigilię Wszystkich Świętych. Herkules Poirot, spędzający dobrowolnie emeryturę w najwspanialszym mieście świata, bierze udział w seansie spirytystycznym odbywającym się w popadającym w ruinę pałacu. Kiedy jeden z uczestników spotkania zostaje zamordowany, detektyw będzie zmuszony rozwiązać zagadkę jego śmierci, zagłębiając się w świat cieni i tajemnic nawiedzonej posiadłości.","popularity":4.176,"poster_path":"/9WL35fkBGyNsoxYP0ZVSkYE9Vst.jpg","release_date":"2023-09-13","softcore":false,"video":false,"vote_average":6.6,"vote_count":2836,"credit_id":"63455f19d55c3d007dece57b","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/7QFjhacXWKylFgExrnxjkRk1lbE.jpg","genre_ids":[18,878],"id":365065,"title":"Zero","original_language":"en","original_title":"Zero","overview":"","popularity":0.9998,"poster_path":null,"release_date":"2015-09-03","softcore":false,"video":false,"vote_average":4.8,"vote_count":6,"credit_id":"562a5650c3a3681b5900239f","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":null,"genre_ids":[28,12,10752,18],"id":447436,"title":"War Party","original_language":"en","original_title":"War Party","overview":"","popularity":0.4472,"poster_path":null,"release_date":"","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"61c418b8bb1057004134a315","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/mTOrGSfDC7CmZBtN8FVGDrSfaNB.jpg","genre_ids":[],"id":126444,"title":"Cinema16: British Short Films","original_language":"en","original_title":"Cinema16: British Short Films","overview":"","popularity":0.5349,"poster_path":"/iY1FDQM6taKwO7bG6YH09nE8NSs.jpg","release_date":"2003-05-05","softcore":false,"video":true,"vote_average":5.167,"vote_count":6,"credit_id":"634e9d740745e1007c66ac72","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":null,"genre_ids":[28,53],"id":1218403,"title":"Bomb","original_language":"en","original_title":"Bomb","overview":"","popularity":0.2602,"poster_path":null,"release_date":"","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"657cb07aea3949013899173d","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":null,"genre_ids":[28,53],"id":1218403,"title":"Bomb","original_language":"en","original_title":"Bomb","overview":"","popularity":0.2602,"poster_path":null,"release_date":"","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"657cb22163e6fb00c6e9878e","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/7HiMvoDSYW4fyu4rkmWH6pcKKuF.jpg","genre_ids":[35,18,80,53],"id":7270,"title":"Naciągacze","original_language":"en","original_title":"Matchstick Men","overview":"Fałszerz Roy i jego protegowany są o krok od sfinalizowania dealu życia, kiedy nieoczekiwany przyjazd nastoletniej córki Roya kompletnie dezorganizuje ich życie i stawia pod dużym znakiem zapytania powodzenie ich planu.","popularity":2.5759,"poster_path":"/2GhiBT1Tke7fG7w2I2dHirNtcfj.jpg","release_date":"2003-09-12","softcore":false,"video":false,"vote_average":7.007,"vote_count":1980,"credit_id":"5670367d9251415ec5012881","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":null,"genre_ids":[37],"id":1223630,"title":"Freewalkers","original_language":"en","original_title":"Freewalkers","overview":"","popularity":0.2008,"poster_path":null,"release_date":"","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"658dc7f020e6a572138b47ca","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":null,"genre_ids":[37],"id":1223630,"title":"Freewalkers","original_language":"en","original_title":"Freewalkers","overview":"","popularity":0.2008,"poster_path":null,"release_date":"","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"658dc7f955c1f4612139fd36","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":380367,"title":"Annabel's: A String of Naked Lightbulbs","original_language":"en","original_title":"Annabel's: A String of Naked Lightbulbs","overview":"","popularity":0.3109,"poster_path":null,"release_date":"2015-03-11","softcore":false,"video":false,"vote_average":3.0,"vote_count":1,"credit_id":"56ae1b019251416357001910","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/jhk6D8pim3yaByu1801kMoxXFaX.jpg","genre_ids":[28,18,12],"id":98,"title":"Gladiator","original_language":"en","original_title":"Gladiator","overview":"Generał Maximus zakończył kolejną udaną wyprawę wojenną. Zmuszony do ucieczki przez zazdrosnego o jego wpływy u Cesarza dziedzica tronu Commodusa, Maximus trafia do niewoli i zostaje gladiatorem. Powraca do Rzymu z zamiarem pomszczenia śmierci syna i żony. Wie, że jedyną siłą potężniejszą od samego Cesarza jest wola ludu, może dokonać swej zemsty, zostając największym bohaterem całego Imperium. \"Gladiator\" to epicka opowieść o odwadze i zemście osadzona w realiach Cesarstwa Rzymskiego roku 180 n.e.","popularity":21.9455,"poster_path":"/1f0U34P6OFPXvfQta556VfXZqiC.jpg","release_date":"2000-05-04","softcore":false,"video":false,"vote_average":8.2,"vote_count":20923,"credit_id":"569fd21dc3a3683413001914","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/xJO5o209Ok1p0uJafkk1WHtrUJH.jpg","genre_ids":[18,9648,53],"id":35052,"title":"Pęknięcia","original_language":"en","original_title":"Cracks","overview":"Akcja filmu toczy się w latach trzydziestych ubiegłego wieku. Zwarta grupa przyjaciółek uczy się w angielskiej, elitarnej szkole dla dziewcząt. Łączy je wspólna pasja – pływanie oraz jedna z nauczycielek, Panna G (Eva Green), która jest niezwykle charyzmatyczną i enigmatyczną kobietą. Pewnego dnia w szkole pojawia się nowa uczennica – Fiamma (María Valverde). Dziewczyna w szybkim czasie skupia na sobie uwagę Panny G, co niezbyt podoba się reszcie drużyny pływackiej…","popularity":2.2605,"poster_path":"/pSVWV04CAWfswP6rqiKJWv0XWzE.jpg","release_date":"2009-12-04","softcore":false,"video":false,"vote_average":6.638,"vote_count":435,"credit_id":"5695500ac3a36871780003fa","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/ch0kqAxTI6VMgDNPWCiN0ZFCwfs.jpg","genre_ids":[53,27],"id":931628,"title":"Ofiarowanie","original_language":"en","original_title":"A Sacrifice","overview":"Historia amerykańskiego psychologa społecznego Bena Monroe, który bada lokalną berlińską sektę powiązaną z niepokojącymi wydarzeniami. Gdy on pogrąża się w pracy, jego zbuntowana nastoletnia córka Mazzy zostaje wplątana w kontakt z tajemniczym miejscowym chłopcem, który wprowadza ją na undergroundową scenę imprezową…","popularity":1.4541,"poster_path":"/ihXINKQfzdaVKvZwZqmchy20uVD.jpg","release_date":"2024-06-28","softcore":false,"video":false,"vote_average":5.6,"vote_count":133,"credit_id":"61f2d395df294515b83e9792","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/iXXPaQPfQowpQ5UvhsHLj9BgFhe.jpg","genre_ids":[27,878],"id":126889,"title":"Obcy: Przymierze","original_language":"en","original_title":"Alien: Covenant","overview":"\"Obcy: Przymierze\" to drugi rozdział nowej trylogii, którą zapoczątkował film \"Prometeusz\". Statek osadniczy \"Przymierze\" dociera na nieznaną planetę, która wydaje się być prawdziwym rajem. Członkowie ekspedycji szybko się jednak przekonują, że trafili do mrocznego, pełnego tajemnic i niebezpieczeństw świata, którego jedynym mieszkańcem jest android David (Michael Fassbender), ocalały z katastrofy \"Prometeusza\".","popularity":12.7809,"poster_path":"/uTEvJeGNUFmCMIhFXxOoGLEzUfp.jpg","release_date":"2017-05-09","softcore":false,"video":false,"vote_average":6.176,"vote_count":9425,"credit_id":"575d852f9251415dd20035e0","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/uub6fTaLGatAvbXHYVn3yZOgedb.jpg","genre_ids":[27,878,53],"id":377264,"title":"Morgan","original_language":"en","original_title":"Morgan","overview":"Przedstawicielka wielkiej korporacji, która specjalizuje się w rozwiązywaniu ryzykownych sytuacji, wysłana zostaje do odległego, ściśle tajnego laboratorium, by wyjaśnić sprawę przerażającego wypadku. Na miejscu przekonuje się, że za wypadkiem stoi z pozoru niewinna „istota ludzka”, która kryje w sobie zarówno niezwykły potencjał, jak i ogromne zagrożenie.","popularity":2.8837,"poster_path":"/iqEFG5ldyeLIFPp7mMI7ZmS7Upm.jpg","release_date":"2016-09-01","softcore":false,"video":false,"vote_average":5.817,"vote_count":1597,"credit_id":"5765441692514177dc00035a","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/jdaZ4QUC3YajBIUrqwdxv5YasD3.jpg","genre_ids":[18,10749,878],"id":301875,"title":"Przebudzeni","original_language":"en","original_title":"Equals","overview":"W niedalekiej przyszłości ludzkość osiągnęła stan idealnej równowagi. Nikt już nie toczy wojen, zbrodnia to pojęcie z przeszłości, a choroby i głód całkowicie zlikwidowano. Ten cudowny stan udało się osiągnąć dzięki wyeliminowaniu z życia wszelkich emocji. Gdy jednak w idealnym społeczeństwie wybucha tajemnicza epidemia przywracająca ludziom uczucia, władze wypowiadają wojnę \"zarazie\". Zainfekowani są wyszukiwani, po czym znikają w niejasnych okolicznościach. Za najbardziej niebezpiecznych uznaje się tych, którzy zaczynają odczuwać coś, co kiedyś nazywano miłością...","popularity":2.3308,"poster_path":"/5t2bLXl3JCvhiOWDq4u4us1IInd.jpg","release_date":"2015-07-15","softcore":false,"video":false,"vote_average":6.118,"vote_count":1448,"credit_id":"576ebbeac3a36873ea0007e8","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":411021,"title":"India In a Day","original_language":"en","original_title":"India In a Day","overview":"","popularity":0.3688,"poster_path":"/svQWTKuxFP2z3eZcazemAF7EYIY.jpg","release_date":"2016-09-09","softcore":false,"video":false,"vote_average":6.0,"vote_count":1,"credit_id":"57adb1c7925141587c00547c","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":null,"genre_ids":[18],"id":1245855,"title":"Children of the Jungle","original_la