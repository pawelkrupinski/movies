arity":0.3262,"poster_path":"/hltR3MiH1dvVQyD4Zu85IsZ9ma9.jpg","release_date":"2016-07-17","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"character":"","credit_id":"578bfe00c3a3685a98003391","order":9},{"adult":false,"backdrop_path":"/igfo3Wt9QvXEGMPvkh8bRSel9r2.jpg","genre_ids":[99],"id":1455575,"title":"Stranger Things: The First Shadow — za kulisami","original_language":"en","original_title":"Behind the Curtain: Stranger Things: The First Shadow","overview":"Zajrzyj za kulisy z obsadą i ekipą nagradzanej sztuki teatralnej „Stranger Things: The First Shadow”, która poszerza uniwersum Hawkins.","popularity":0.8738,"poster_path":"/7jQIbTMx2BlZrYGyOS94YUNcGjV.jpg","release_date":"2025-04-14","softcore":false,"video":false,"vote_average":7.3,"vote_count":30,"character":"Self - Director","credit_id":"67ff00579d1f778ab8999686","order":6},{"adult":false,"backdrop_path":"/mHTKJDiKXUV5hahTyssDNS12MRz.jpg","genre_ids":[99],"id":1531209,"title":"The Real 'Billy Elliot' Diaries","original_language":"en","original_title":"The Real 'Billy Elliot' Diaries","overview":"","popularity":0.1893,"poster_path":"/6EziQHBzsFU2WdpAQ2i7KT8XTAY.jpg","release_date":"2005-09-05","softcore":false,"video":false,"vote_average":7.0,"vote_count":1,"character":"Self","credit_id":"68a126fefa176f585ded14dc","order":1}],"crew":[{"adult":false,"backdrop_path":"/urzflyf41uySpgciGHdQzpcaMOY.jpg","genre_ids":[18,35,10402],"id":71,"title":"Billy Elliot","original_language":"en","original_title":"Billy Elliot","overview":"Billy Elliot to 11-latek wychowywany w górniczej rodzinie, gdzie prym wiodą surowy ojciec i brat. By wykrzesać w dorastającym chłopcu wzorzec męskości, ojciec zaprowadza go na trening boksu. Jednak Billy nie pała pasją do tego sportu. Przez przypadek trafia na lekcję tańca klasycznego, gdzie okazuje się, że ma wielki talent. Zaczyna naukę baletu pod czujnym okiem niespełnionej primadonny, pani Wilkinson, która marzy, by Billy został tancerzem Królewskiej Akademii Tańca. Czy mu się to uda i jak zareaguje ojciec, gdy dowie się, że jego syn zamienił rękawice bokserską na atłasowe baletki?","popularity":3.7402,"poster_path":"/mYtqgWCJiXpDeZwjVcC3OQGD8IR.jpg","release_date":"2000-09-28","softcore":false,"video":false,"vote_average":7.595,"vote_count":4092,"credit_id":"52fe4213c3a36847f80020eb","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/3oHFSEr4TRnsyTxWGrmY8Xi2FrR.jpg","genre_ids":[18],"id":590,"title":"Godziny","original_language":"en","original_title":"The Hours","overview":"Historia życia trzech kobiet, z których jedna to żyjąca w czasach współczesnych w Nowym Jorku wydawczyni książek; druga, typowa żona i matka, żyjąca pod koniec lat 40.; trzecia to postać autentyczna - Virginia Woolf, znana pisarka ogarnięta obsesją samobójczą. Trzy różne kobiety, trzy różne epoki. Jest jednak coś, co je połączy, coś, co zmieni ich życie na zawsze.","popularity":2.8946,"poster_path":"/kgNdH4nw9ECaDAYxFzPQ89Wv0MZ.jpg","release_date":"2002-12-27","softcore":false,"video":false,"vote_average":7.3,"vote_count":1871,"credit_id":"52fe4258c3a36847f8017291","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/waMGsUEoHfYj3A1uRMUUgpBa71d.jpg","genre_ids":[18,10749],"id":8055,"title":"Lektor","original_language":"en","original_title":"The Reader","overview":"Oparty na bestsellerowej powieści o tym samym tytule „Lektor”, to hipnotyzująca historia pełnej tajemnic miłości, której akcja toczy się w targanych wojną i powojennych Niemczech. Hanna (Kate Winslet) udziela pomocy Michaelowi Bergowi (David Kross), który zasłabł na ulicy, wracając ze szkoły. W ten sposób krzyżują się losy młodego wrażliwego ucznia i pięknej, choć starszej od niego kobiety, którą jest zafascynowany od pierwszej chwili. To przypadkowe spotkanie staje się początkiem namiętnego romansu, zakończonego nagłym i tajemniczym zniknięciem kobiety. Mija osiem lat. Michael jest studentem prawa i śledzi procesy nazistowskich zbrodniarzy. W tych właśnie, jakże odmiennych, okolicznościach spotyka ponownie swoją dawną kochankę. Hanna oskarżona jest o popełnienie odrażających zbrodni","popularity":7.0214,"poster_path":"/qWSSuk7BukVyeFJGlU5ul1uMWaJ.jpg","release_date":"2008-12-10","softcore":false,"video":false,"vote_average":7.469,"vote_count":3393,"credit_id":"52fe448ec3a36847f809cda3","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/pQQYGl6JzyUzzd6TxjkVah3H8wq.jpg","genre_ids":[18,36],"id":821881,"title":"Pływaczki","original_language":"en","original_title":"The Swimmers","overview":"W 2016 roku dwie młode siostry wyruszają w ryzykowną podróż z ogarniętej wojną Syrii na olimpiadę w Rio, wystawiając na próbę zdolności pływackie — i serca.","popularity":1.9237,"poster_path":"/u9MiJ6zLpDw4s3qZz93WDVwTUIo.jpg","release_date":"2022-09-08","softcore":false,"video":false,"vote_average":7.42,"vote_count":646,"credit_id":"608210e40f0da5007abc6638","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/6C1t83zS4TgYmRUVdYVF0UC2aA8.jpg","genre_ids":[10402,18,36],"id":298931,"title":"Billy Elliot: The Musical Live","original_language":"en","original_title":"Billy Elliot: The Musical Live","overview":"","popularity":1.3775,"poster_path":"/cVe13jzHzWNOpv02xdDuozbIJBm.jpg","release_date":"2014-09-28","softcore":false,"video":true,"vote_average":8.114,"vote_count":70,"credit_id":"608532bb9a8a8a00589c0bbb","department":"Directing","job":"Stage Director"},{"adult":false,"backdrop_path":"/hTc55dlCPMP4oqrUU66GjKjSblp.jpg","genre_ids":[18],"id":64685,"title":"Strasznie głośno, niesamowicie blisko","original_language":"en","original_title":"Extremely Loud & Incredibly Close","overview":"Przejmujący i prawdziwy film Stephena Daldry'ego (\"Godziny\", \"Billy Elliot\") nominowany w dwóch kategoriach do Oscara. W rolach głównych zdobywcy Nagrody Akademii Tom Hanks i Sandra Bullock oraz dwukrotnie nominowany do Oscara Max von Sydow. W swoim najnowszym obrazie twórca mierzy się z jedną z największych traum współczesnego świata - zamachami z 11 września. To nie jest opowieść o 11 września, to historia o każdym dniu później.","popularity":2.1184,"poster_path":"/hpG3xxFKmhAB4aSOYliksEoD2eN.jpg","release_date":"2011-12-25","softcore":false,"video":false,"vote_average":7.0,"vote_count":2135,"credit_id":"52fe46e4c3a368484e0a9877","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/lCgtMtu6fb5QCjfjiIgHZh0gTqy.jpg","genre_ids":[18],"id":49463,"title":"Eight","original_language":"en","original_title":"Eight","overview":"","popularity":0.2937,"poster_path":"/lPUeV11VB1h3uxAS9gEClRJO8gw.jpg","release_date":"1998-10-02","softcore":false,"video":false,"vote_average":5.923,"vote_count":13,"credit_id":"52fe4796c3a36847f813dbfd","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/gEVeQNyfGzwV010MAGkBCmpwU7i.jpg","genre_ids":[18,35],"id":837548,"title":"Together","original_language":"en","original_title":"Together","overview":"Lockdown zmusza małżeństwo do zastanowienia się nad sobą i swoim związkiem.","popularity":0.5263,"poster_path":"/oeocQg0Bhmy0pqqRy50wEo0iwFB.jpg","release_date":"2021-08-27","softcore":false,"video":false,"vote_average":5.8,"vote_count":118,"credit_id":"60c4b14f5b4fed00791eb91c","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/qC1H8Yq1rUvScwE5SoBFSuzsfVo.jpg","genre_ids":[18,36],"id":209149,"title":"National Theatre Live: The Audience","original_language":"en","original_title":"National Theatre Live: The Audience","overview":"","popularity":1.1224,"poster_path":"/suj6ShOEIWysMf3dqBgmDWggWvi.jpg","release_date":"2013-06-12","softcore":false,"video":true,"vote_average":8.3,"vote_count":11,"credit_id":"60cdc2fb5ed9620040bab377","department":"Directing","job":"Stage Director"},{"adult":false,"backdrop_path":"/dwFZb1ddwY3TYUVKrkuCNs7Iy2c.jpg","genre_ids":[12,80,18,53,9648],"id":206563,"title":"Śmieć","original_language":"en","original_title":"Trash","overview":"\"Śmieć\" to opowieść o prawdziwej przyjaźni, która może pokonać wszystkie przeszkody. Trzech chłopców utrzymuje się ze zbierania śmieci na jednym z wielkich wysypisk. Jeden z nich Raphael pewnego dnia znajduje coś bardzo wyjątkowego. Policja poszukuje tego oferując nagrodę, jednak chłopcy postanawiają zatrzymać znalezisko i zaczynają się kłopoty. Ukrywają się wykorzystując swój spryt i wielką odwagę. To od nich zależy czy sekret rządzących elit ujrzy światło dzienne.","popularity":3.023,"poster_path":"/s3l40xZhG2pPnLaUflbBWqgJxr0.jpg","release_date":"2014-10-09","softcore":false,"video":false,"vote_average":7.08,"vote_count":665,"credit_id":"52fe4d20c3a368484e1d8655","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/6C1t83zS4TgYmRUVdYVF0UC2aA8.jpg","genre_ids":[10402,18,36],"id":298931,"title":"Billy Elliot: The Musical Live","original_language":"en","original_title":"Billy Elliot: The Musical Live","overview":"","popularity":1.3775,"poster_path":"/cVe13jzHzWNOpv02xdDuozbIJBm.jpg","release_date":"2014-09-28","softcore":false,"video":true,"vote_average":8.114,"vote_count":70,"credit_id":"62b476f953f8330d07224775","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/vM3QMpHuXxYCNk2hdxv4Jiie6OZ.jpg","genre_ids":[99],"id":990836,"title":"Freedom: 50 Years of Pride","original_language":"en","original_title":"Freedom: 50 Years of Pride","overview":"","popularity":0.0773,"poster_path":"/tGiezI5NlhaoDBgFmz1jYBo9xGR.jpg","release_date":"2022-07-02","softcore":false,"video":false,"vote_average":8.0,"vote_count":1,"credit_id":"62b3195353f83304d55e0e51","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/gcX0w5UFkb0G2kYRyufHRVVfIc6.jpg","genre_ids":[18],"id":282537,"title":"National Theatre Live: Skylight","original_language":"en","original_title":"National Theatre Live: Skylight","overview":"","popularity":0.3405,"poster_path":"/cHOY8X9NDRthSq7H8dFReuuuwbI.jpg","release_date":"2014-07-24","softcor