haracter":"Self","credit_id":"6890df8f64a704406861f748","order":1},{"adult":false,"backdrop_path":"/pXiarn5DevhRoVmKZu9ykhQMNxJ.jpg","genre_ids":[99,10770],"id":964270,"title":"Marilyn, femme d'aujourd'hui","original_language":"fr","original_title":"Marilyn, femme d'aujourd'hui","overview":"","popularity":0.2698,"poster_path":"/1y9GPsXPJqcu9EMvc4qljG7ETdq.jpg","release_date":"2022-04-18","softcore":false,"video":false,"vote_average":7.0,"vote_count":3,"character":"self","credit_id":"69cc41cc2c62342ec22972f7","order":6},{"adult":false,"backdrop_path":"/sVCiLpI4e1mWCfAysnoT1dfTKfF.jpg","genre_ids":[99],"id":1707480,"title":"Tutti Frutti","original_language":"fr","original_title":"Tutti Frutti","overview":"","popularity":0.3245,"poster_path":null,"release_date":"2026-06-03","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"character":"","credit_id":"6a25e24d6a039e05c09e9a38","order":1}],"crew":[{"adult":false,"backdrop_path":"/zZRbCsecON0xIiJjbMvQvuDCsCY.jpg","genre_ids":[18,10749],"id":10818,"title":"Lilie wodne","original_language":"fr","original_title":"Naissance des pieuvres","overview":"","popularity":1.8668,"poster_path":"/g5tjRY3Xhz60aQ1yO0Qcy7lok7u.jpg","release_date":"2007-05-17","softcore":false,"video":false,"vote_average":6.5,"vote_count":468,"credit_id":"52fe43bc9251416c7501c1fd","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/zZRbCsecON0xIiJjbMvQvuDCsCY.jpg","genre_ids":[18,10749],"id":10818,"title":"Lilie wodne","original_language":"fr","original_title":"Naissance des pieuvres","overview":"","popularity":1.8668,"poster_path":"/g5tjRY3Xhz60aQ1yO0Qcy7lok7u.jpg","release_date":"2007-05-17","softcore":false,"video":false,"vote_average":6.5,"vote_count":468,"credit_id":"52fe43bc9251416c7501c213","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":"/vP4LyCUQIuuLRGhfr0Xt88BNHE6.jpg","genre_ids":[18],"id":65229,"title":"Chłopczyca","original_language":"fr","original_title":"Tomboy","overview":"Laura to 10-letnia chłopczyca. Przyjazd do nowej dzielnicy stanowi dla niej wyjątkową okazję, aby ukryć swoją płeć. Przekona Lizę, nową koleżankę, oraz resztę bandy, że ma na imię Michał i że jest chłopcem jak inni. Laura na czas wakacji zupełnie zmieni się w chłopca. Wyróżniając się spośród reszty, zwróci uwagę Lizy, która powoli zakocha się w chłopcu. Laura całkowicie zapomni o swojej prawdziwej tożsamości, tak jakby lato nie miało nigdy się skończyć, a jej niepokojący sekret wyjść na jaw.","popularity":1.5639,"poster_path":"/r2YHKqzktvq34JUJnXkhYG8V1G0.jpg","release_date":"2011-04-20","softcore":false,"video":false,"vote_average":7.3,"vote_count":750,"credit_id":"52fe4702c3a368484e0b021f","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":null,"genre_ids":[35,18],"id":98585,"title":"Ivory Tower","original_language":"en","original_title":"Ivory Tower","overview":"","popularity":0.2534,"poster_path":"/8Om1ROiKgqH0rGVLekJ1e27Tp3u.jpg","release_date":"2010-08-11","softcore":false,"video":false,"vote_average":6.4,"vote_count":5,"credit_id":"52fe4a1b9251416c750dde9f","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":"/yuXZXuS4RCTnCYScrRWBCNz2ywB.jpg","genre_ids":[18,14],"id":749004,"title":"Mała mama","original_language":"fr","original_title":"Petite Maman","overview":"Czy potrafilibyśmy zaprzyjaźnić się ze swoim rodzicem, gdyby nasze wspólne drogi przecięły się w czasie, kiedy oboje byliśmy dziećmi? Taka sytuacja przytrafia się ośmioletniej Nelly, która spotyka rówieśniczkę łudząco podobną do swojej matki. To niecodzienne wydarzenie staje się punktem wyjścia do opowieści o przyjaźni, potrafiącej przekroczyć pokoleniowe bariery i zarazem studium potęgi dziecięcej wyobraźni.","popularity":1.2456,"poster_path":"/qDAGcaWvWexyTAZmV93vO0AnsFn.jpg","release_date":"2021-06-02","softcore":false,"video":false,"vote_average":7.093,"vote_count":460,"credit_id":"60f2b47de8a3e1007e38f639","department":"Costume & Make-Up","job":"Costume Designer"},{"adult":false,"backdrop_path":"/yJ9HQ4OrFouSj8kRF9opf8s7yGE.jpg","genre_ids":[18],"id":266082,"title":"Dziewczyny z bandy","original_language":"fr","original_title":"Bande de filles","overview":"Marieme (16 l.) źle czuje się w domu. Nie może dogadać się z rodzeństwem, jej matka pracuje nocami, a za dnia śpi. W szkole radzi sobie kiepsko i wygląda na to, że za chwilę z niej wyleci. Sytuacja się zmienia, kiedy Marieme poznaje Lady, charyzmatyczną szefową gangu dziewczyn z przedmieść Paryża. Zmienia imię, ciuchy i rzuca szkołę – wszystko, żeby gang ją zaakceptował. Wierzy, że to droga do wolności.","popularity":0.6693,"poster_path":"/nFHw4N7eEpbXwFkUH61P0zs1FTm.jpg","release_date":"2014-10-22","softcore":false,"video":false,"vote_average":6.5,"vote_count":399,"credit_id":"60f2b4a91d78f2002f716482","department":"Costume & Make-Up","job":"Costume Designer"},{"adult":false,"backdrop_path":"/yJ9HQ4OrFouSj8kRF9opf8s7yGE.jpg","genre_ids":[18],"id":266082,"title":"Dziewczyny z bandy","original_language":"fr","original_title":"Bande de filles","overview":"Marieme (16 l.) źle czuje się w domu. Nie może dogadać się z rodzeństwem, jej matka pracuje nocami, a za dnia śpi. W szkole radzi sobie kiepsko i wygląda na to, że za chwilę z niej wyleci. Sytuacja się zmienia, kiedy Marieme poznaje Lady, charyzmatyczną szefową gangu dziewczyn z przedmieść Paryża. Zmienia imię, ciuchy i rzuca szkołę – wszystko, żeby gang ją zaakceptował. Wierzy, że to droga do wolności.","popularity":0.6693,"poster_path":"/nFHw4N7eEpbXwFkUH61P0zs1FTm.jpg","release_date":"2014-10-22","softcore":false,"video":false,"vote_average":6.5,"vote_count":399,"credit_id":"53567267c3a36841d6002424","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/yJ9HQ4OrFouSj8kRF9opf8s7yGE.jpg","genre_ids":[18],"id":266082,"title":"Dziewczyny z bandy","original_language":"fr","original_title":"Bande de filles","overview":"Marieme (16 l.) źle czuje się w domu. Nie może dogadać się z rodzeństwem, jej matka pracuje nocami, a za dnia śpi. W szkole radzi sobie kiepsko i wygląda na to, że za chwilę z niej wyleci. Sytuacja się zmienia, kiedy Marieme poznaje Lady, charyzmatyczną szefową gangu dziewczyn z przedmieść Paryża. Zmienia imię, ciuchy i rzuca szkołę – wszystko, żeby gang ją zaakceptował. Wierzy, że to droga do wolności.","popularity":0.6693,"poster_path":"/nFHw4N7eEpbXwFkUH61P0zs1FTm.jpg","release_date":"2014-10-22","softcore":false,"video":false,"vote_average":6.5,"vote_count":399,"credit_id":"53567278c3a36841ee00247e","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":"/lp8nmsZ27vLTSyGD9ud9PF3iuUO.jpg","genre_ids":[18,14,10749],"id":266040,"title":"Bird People","original_language":"fr","original_title":"Bird People","overview":"","popularity":0.5525,"poster_path":"/2rL5Gg0g4LUNWAtrLQaqOZfGd9l.jpg","release_date":"2014-06-04","softcore":false,"video":false,"vote_average":5.9,"vote_count":102,"credit_id":"63038080dfe31d0092051209","department":"Writing","job":"Script Consultant"},{"adult":false,"backdrop_path":null,"genre_ids":[18],"id":318373,"title":"Bébé Tigre","original_language":"fr","original_title":"Bébé Tigre","overview":"","popularity":0.2902,"poster_path":"/3MNJQvfEhsK93RaJUkkBrTu4y72.jpg","release_date":"2015-01-14","softcore":false,"video":false,"vote_average":6.4,"vote_count":14,"credit_id":"6303814cdfe31d008010e92a","department":"Writing","job":"Script Consultant"},{"adult":false,"backdrop_path":"/8AHakNwId9tMg5W1WDW0qRqzef7.jpg","genre_ids":[18],"id":536666,"title":"Le vent tourne","original_language":"fr","original_title":"Le vent tourne","overview":"","popularity":0.3764,"poster_path":"/hndeRoeTSIxIZMnTHxdfCgXnjKp.jpg","release_date":"2018-09-26","softcore":false,"video":false,"vote_average":5.8,"vote_count":42,"credit_id":"630381d5097c49007aa2d1a5","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":"/vP4LyCUQIuuLRGhfr0Xt88BNHE6.jpg","genre_ids":[18],"id":65229,"title":"Chłopczyca","original_language":"fr","original_title":"Tomboy","overview":"Laura to 10-letnia chłopczyca. Przyjazd do nowej dzielnicy stanowi dla niej wyjątkową okazję, aby ukryć swoją płeć. Przekona Lizę, nową koleżankę, oraz resztę bandy, że ma na imię Michał i że jest chłopcem jak inni. Laura na czas wakacji zupełnie zmieni się w chłopca. Wyróżniając się spośród reszty, zwróci uwagę Lizy, która powoli zakocha się w chłopcu. Laura całkowicie zapomni o swojej prawdziwej tożsamości, tak jakby lato nie miało nigdy się skończyć, a jej niepokojący sekret wyjść na jaw.","popularity":1.5639,"poster_path":"/r2YHKqzktvq34JUJnXkhYG8V1G0.jpg","release_date":"2011-04-20","softcore":false,"video":false,"vote_average":7.3,"vote_count":750,"credit_id":"55944a64925141645a004035","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":"/zmcwBptmuyaRsBgIXeR0fmlgZd2.jpg","genre_ids":[18],"id":347136,"title":"Pauline","original_language":"fr","original_title":"Pauline","overview":"","popularity":0.287,"poster_path":"/tCM4h1IaDtj9rjjDarXfOk7byVB.jpg","release_date":"2009-10-01","softcore":false,"video":false,"vote_average":6.053,"vote_count":38,"credit_id":"5594b0cfc3a36870d5000f4a","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/lTOr8fcxlsLrGfe2lqZLCjhvrIH.jpg","genre_ids":[16,35,18],"id":393559,"title":"Nazywam się Cukinia","original_language":"fr","original_title":"Ma vie de courgette","overview":"Po niespodziewanej śmierci swojej mamy dziewięcioletni chłopiec zwany Cukinią zaprzyjaźnia się z sympatycznym policjantem Rajmundem i trafia do domu dziecka, w którym mieszkają inne dzieci w jego wieku. Początkowo Cukinia ma problemy z przystosowaniem się do nowego miejsca, nie zawsze dogaduje się ze wszystkimi. Stopniowo jednak znajduje sobie przyjaciół i kiedy zajdzie taka potrzeba, będzie mógł liczyć na ich wsparcie.","popularity":1.5572,"poster_path":"/g3sqKRV4tHI1vZrUqntzdVahicy.jpg","release_date":"2016-09-22","softcore":false,"video":false,"vote_average":7.8,"vote_count":1507,"credit_id":"572b2a9b92514106f70023d0","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":"/tbPB4LU2Xp4hSFl1yiYiu2Kpcfy.jpg","genre_ids":[18],"id":377154,"title":"Mając 17 lat","original_language":"fr","original_title":"Quand on a 17 ans","overview":"Damien i Thomas uczęszczają na te same zajęcia, choć dzieli ich wszystko, od różnicy klasowej i rasowej począwszy. Pierwszy to szpaner ze świetnie sytuowanej rodziny lekarki i wojskowego. Drugi jest adoptowanym chłopakiem afrykańskiego pochodzenia. Po lekcjach musi pomagać rodzicom przy gospodarstwie. Młodzi bohaterowie ze szkolnej ławy nienawidzą się do tego stopnia, że w jednej chwili potrafią przejść od obelg do rękoczynów. Przewrotny los sprawia jednak, że przez jakiś czas muszą zamieszkać pod jednym dachem. Ich niechęć z czasem przemienia się w koleżeństwo i wzajemną fascynację. Do głosu dochodzą buzujące hormony.","popularity":0.5345,"poster_path":"/aX3vrqNaDEmJE6dQwT2U9FFXRcq.jpg","release_date":"2016-02-27","softcore":false,"video":false,"vote_average":6.808,"vote_count":380,"credit_id":"576db02192514140ab00082d","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":"/lS49jyUZg9xHfelHMsmL3o3H6rq.jpg","genre_ids":[35,27,14],"id":1112466,"title":"Balkoniary","original_language":"fr","original_title":"Les femmes au balcon","overview":"Podczas gdy fala upałów doprowadza dzielnicę Marsylii do wrzenia, trzy współlokatorki z balkonu radośnie wtrącają się w życie sąsiadów. Pewnej nocy wywiązuje się konflikt, który niespodziewanie zamienia się w krwawą łaźnię.","popularity":1.0154,"poster_path":"/wTqJuLktDmwHEgBqs9RCAR7vZfx.jpg","release_date":"2024-11-15","softcore":false,"video":false,"vote_average":6.256,"vote_count":135,"credit_id":"6437acf8ab6849009825803f","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":"/ivJ5UzT6IzucLVfbZwCCwiJJoBz.jpg","genre_ids":[18,10749],"id":531428,"title":"Portret kobiety w ogniu","original_language":"fr","original_title":"Portrait de la jeune fille en feu","overview":"Opowieść o miłości wyprzedzającej swój czas i intymnej więzi zdolnej przełamać niejedno tabu, ubiera w kostium – akcja rozgrywa się w Bretanii w 1770 roku – jak najbardziej współczesne pragnienia i uczucia. Bohaterkami filmu są szykowana do aranżowanego małżeństwa arystokratka Heloiza oraz przybyła z Paryża malarka, Marianna. Ta druga ma namalować portret tej pierwszej, ale w sekrecie: Heloiza nie chce bowiem pozować, buntując się w ten sposób przeciwko przymusowemu zamążpójściu. Marianna dyskretnie obserwuje swoją modelkę, intensywnie tworzy, ale niszczy kolejne wersje obrazu. Czuje, że nie pozna prawdziwego oblicza młodej kobiety tak długo, jak sama będzie ukrywać własne.","popularity":9.8,"poster_path":"/ezwsV3AUa8l9XPWqIAL73wMO0o6.jpg","release_date":"2019-09-06","softcore":false,"video":false,"vote_average":8.1,"vote_count":2940,"credit_id":"5b2bbf57c3a3687d1a00627b","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/hLkBwTr5gn5l6yIACi36IGApwDZ.jpg","genre_ids":[99],"id":1157101,"title":"This Is How a Child Becomes a Poet","original_language":"fr","original_title":"This Is How a Child Becomes a Poet","overview":"","popularity":0.109,"poster_path":"/9pQrWyeC0Xpo3RAveelNBc4nZJJ.jpg","release_date":"2023-08-30","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"64c2cd087d5f4b011c78495f","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/ivJ5UzT6IzucLVfbZwCCwiJJoBz.jpg","genre_ids":[18,10749],"id":531428,"title":"Portret kobiety w ogniu","original_language":"fr","original_title":"Portrait de la jeune fille en feu","overview":"Opowieść o miłości wyprzedzającej swój czas i intymnej więzi zdolnej przełamać niejedno tabu, ubiera w kostium – akcja rozgrywa się w Bretanii w 1770 roku – jak najbardziej współczesne pragnienia i uczucia. Bohaterkami filmu są szykowana do aranżowanego małżeństwa arystokratka Heloiza oraz przybyła z Paryża malarka, Marianna. Ta druga ma namalować portret tej pierwszej, ale w sekrecie: Heloiza nie chce bowiem pozować, buntując się w ten sposób przeciwko przymusowemu zamążpójściu. Marianna dyskretnie obserwuje swoją modelkę, intensywnie tworzy, ale niszczy kolejne wersje obrazu. Czuje, że nie pozna prawdziwego oblicza młodej kobiety tak długo, jak sama będzie ukrywać własne.","popularity":9.8,"poster_path":"/ezwsV3AUa8l9XPWqIAL73wMO0o6.jpg","release_date":"2019-09-06","softcore":false,"video":false,"vote_average":8.1,"vote_count":2940,"credit_id":"5e1fc47d0102c900163afd41","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":"/yuXZXuS4RCTnCYScrRWBCNz2ywB.jpg","genre_ids":[18,14],"id":749004,"title":"Mała mama","original_language":"fr","original_title":"Petite Maman","overview":"Czy potrafilibyśmy zaprzyjaźnić się ze swoim rodzicem, gdyby nasze wspólne drogi przecięły się w czasie, kiedy oboje byliśmy dziećmi? Taka sytuacja przytrafia się ośmioletniej Nelly, która spotyka rówieśniczkę łudząco podobną do swojej matki. To niecodzienne wydarzenie staje się punktem wyjścia do opowieści o przyjaźni, potrafiącej przekroczyć pokoleniowe bariery i zarazem studium potęgi dziecięcej wyobraźni.","popularity":1.2456,"poster_path":"/qDAGcaWvWexyTAZmV93vO0AnsFn.jpg","release_date":"2021-06-02","softcore":false,"video":false,"vote_average":7.093,"vote_count":460,"credit_id":"5f76e0e8156cc70035500e68","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/yuXZXuS4RCTnCYScrRWBCNz2ywB.jpg","genre_ids":[18,14],"id":749004,"title":"Mała mama","original_language":"fr","original_title":"Petite Maman","overview":"Czy potrafilibyśmy zaprzyjaźnić się ze swoim rodzicem, gdyby nasze wspólne drogi przecięły się w czasie, kiedy oboje byliśmy dziećmi? Taka sytuacja przytrafia się ośmioletniej Nelly, która spotyka rówieśniczkę łudząco podobną do swojej matki. To niecodzienne wydarzenie staje się punktem wyjścia do opowieści o przyjaźni, potrafiącej przekroczyć pokoleniowe bariery i z