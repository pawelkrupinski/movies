et, Lucy, Batman wraz z przyjaciółmi wyruszą w podróż do odległych, nieodkrytych światów, w tym do dziwacznej galaktyki, w której wszystko jest musicalem. Podróż ta będzie sprawdzianem ich odwagi, kreatywności i umiejętności Master Builderskich, a ponadto ukaże, jak bardzo są wyjątkowi.","popularity":4.5829,"poster_path":"/tZhbZCZHW7Uxsqu87uiUBpnQVdj.jpg","release_date":"2019-02-06","softcore":false,"video":false,"vote_average":6.656,"vote_count":2426,"credit_id":"5f74c26035039800379b5dcd","department":"Writing","job":"Story"},{"adult":false,"backdrop_path":null,"genre_ids":[35,27,53],"id":766527,"title":"Untitled Monster Project","original_language":"en","original_title":"Untitled Monster Project","overview":"","popularity":0.1931,"poster_path":null,"release_date":"","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"5fb83a63967cc700401889bc","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/93pZwZQyKYSJV0jwb2rleTTYIp5.jpg","genre_ids":[99],"id":1179147,"title":"Welcome Space Brothers","original_language":"en","original_title":"Welcome Space Brothers","overview":"","popularity":0.3139,"poster_path":"/d8sizwBG5dmXmo0uHn98vPXhP8U.jpg","release_date":"2023-10-08","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"671c43f05d0de89042d927e4","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":null,"genre_ids":[16,35,10751],"id":461833,"title":"Dark Hoser","original_language":"en","original_title":"Dark Hoser","overview":"Batman ubiega się o przyjęcie do Ligi Sprawiedliwości Ameryki, ale jego skłonności do kultury kanadyjskiej zdradzają, że lepiej pasuje do „Ligi Sprawiedliwości Kanady”.","popularity":0.2783,"poster_path":"/8t0Cvw5tmPu2n1WpsXFZUtnEIDs.jpg","release_date":"2017-06-13","softcore":false,"video":false,"vote_average":6.1,"vote_count":8,"credit_id":"6822fd81b1dcc33af67396e2","department":"Production","job":"Executive Producer"},{"adult":false,"backd