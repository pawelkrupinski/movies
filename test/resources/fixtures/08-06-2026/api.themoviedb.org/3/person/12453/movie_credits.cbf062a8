","popularity":4.2144,"poster_path":"/uTSU2resnC2ECUwKyPVRwtMNZf5.jpg","release_date":"2025-10-01","softcore":false,"video":false,"vote_average":5.3,"vote_count":30,"credit_id":"696b121ef34f4f4177f11537","department":"Crew","job":"Thanks"},{"adult":false,"backdrop_path":"/8w7Bzp8Czm8FpHZcVTKhxTyeRhk.jpg","genre_ids":[99],"id":654086,"title":"@ in the mood for love","original_language":"zh","original_title":"@ in the mood for love","overview":"","popularity":0.7794,"poster_path":"/c6Xh8CqkKbaVRsmYfJGGiZXSjtn.jpg","release_date":"2001-12-31","softcore":false,"video":false,"vote_average":6.9,"vote_count":37,"credit_id":"69bbe92ba15bacc1cc3b9d01","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/8w7Bzp8Czm8FpHZcVTKhxTyeRhk.jpg","genre_ids":[99],"id":654086,"title":"@ in the mood for love","original_language":"zh","original_title":"@ in the mood for love","overview":"","popularity":0.7794,"poster_path":"/c6Xh8CqkKbaVRsmYfJGGiZXSjtn.jpg","release_date":"2001-12-31","softcore":false,"video":false,"vote_average":6.9,"vote_count":37,"credit_id":"69bbe92b4c9439703c0527b7","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/8w7Bzp8Czm8FpHZcVTKhxTyeRhk.jpg","genre_ids":[99],"id":654086,"title":"@ in the mood for love","original_language":"zh","original_title":"@ in the mood for love","overview":"","popularity":0.7794,"poster_path":"/c6Xh8CqkKbaVRsmYfJGGiZXSjtn.jpg","release_date":"2001-12-31","softcore":false,"video":false,"vote_average":6.9,"vote_count":37,"credit_id":"69bbe92bdd0e00361305288b","department":"Writing","job":"Writer"}],"id":12453}