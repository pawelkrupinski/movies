2E3U6eibqkabx3xp.jpg","genre_ids":[99],"id":1601912,"title":"Making of 2046","original_language":"en","original_title":"Making of 2046","overview":"","popularity":0.1431,"poster_path":"/jwkiq9yuZ2jj3y9NA7q0KporU16.jpg","release_date":"","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"character":"","credit_id":"6948528fea775d1468b1c909","order":0},{"adult":false,"backdrop_path":null,"genre_ids":[],"id":1152699,"title":"Moving Pictures: Chungking Express","original_language":"en","original_title":"Moving Pictures: Chungking Express","overview":"","popularity":0.0775,"poster_path":"/1LvitDG8RAr12jSHZBkqf5YiUlI.jpg","release_date":"","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"character":"","credit_id":"694858f9f948d17d1f81228c","order":1},{"adult":false,"backdrop_path":"/xQeOEWUScqWu7X7FtA2DH9QfZtZ.jpg","genre_ids":[18,28,10749],"id":1610150,"title":"东邪西毒：终极版","original_language":"cn","original_title":"东邪西毒：终极版","overview":"","popularity":0.3343,"poster_path":"/oJiwnFSwNmBLShTVqi7eY8qGMwS.jpg","release_date":"2008-05-18","softcore":false,"video":false,"vote_average":8.25,"vote_count":4,"character":"导演","credit_id":"695b840f7b370a3eaee41854","order":0}],"crew":[{"adult":false,"backdrop_path":"/ffQFnAUm2Uu4RU0nijpjPRf9TBT.jpg","genre_ids":[18,10749],"id":843,"title":"Spragnieni miłości","original_language":"cn","original_title":"花樣年華","overview":"Hongkong, 1962 r. Uchodźcy z Szanghaju, którzy z nadzieją na lepsze życie licznie przybywają do tej brytyjskiej kolonii, wynajmują każdy, nawet najbardziej obskurny kąt. Wyizolowani, a jednocześnie podlegający nieustannej kontroli sąsiadów, przybysze żyją w zamkniętych społecznościach, tłocząc się w ciasnych pomieszczeniach, zarówno w domach jak i w miejscach pracy. Pewnego dnia do sąsiadujących ze sobą dwóch klitek w jednym z takich przepełnionych domów wprowadzają się równocześnie - sekretarka Su Chan (Maggie Cheung) z mężem i redaktor jednej z gazet Chow Mo-Wan (Tony Leung) z żoną. Żona Chow z powodu obowiązków służbowych często przebywa poza domem. Mąż Su od dłuższego czasu jest podróży służbowej. Kolejne dni w tym ludzkim \"mrowisku\", których rytm wyznacza jedynie praca, są jałowe i nudne.","popularity":9.1249,"poster_path":"/iYypPT4bhqXfq1b6EnmxvRt6b2Y.jpg","release_date":"2000-09-29","softcore":false,"video":false,"vote_average":8.092,"vote_count":3260,"credit_id":"52fe4280c3a36847f8023f51","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/h3JAMIeywbzobkhu2rt3mQAwRR1.jpg","genre_ids":[18,878,10749],"id":844,"title":"2046","original_language":"zh","original_title":"2046","overview":"Bohaterem jest dziennikarz i pisarz Chow Mo Wan, (kontynuacja \"Spragnionych miłości\"). Minęły 4 lata  ale cały czas nie może zapomnieć o kobiecie, która stała się największą niespełnioną, miłością jego życia. Angażuje krótkie, przelotne romanse z nadzieją, że znajdzie w nich ukojenie.","popularity":3.1249,"poster_path":"/8isHlc8ZCRN3Eyx0xmAML7FMZvd.jpg","release_date":"2004-09-29","softcore":false,"video":false,"vote_average":7.226,"vote_count":1078,"credit_id":"52fe4281c3a36847f8023ff9","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":"/h3JAMIeywbzobkhu2rt3mQAwRR1.jpg","genre_ids":[18,878,10749],"id":844,"title":"2046","original_language":"zh","original_title":"2046","overview":"Bohaterem jest dziennikarz i pisarz Chow Mo Wan, (kontynuacja \"Spragnionych miłości\"). Minęły 4 lata  ale cały czas nie może zapomnieć o kobiecie, która stała się największą niespełnioną, miłością jego życia. Angażuje krótkie, przelotne romanse z nadzieją, że znajdzie w nich ukojenie.","popularity":3.1249,"poster_path":"/8isHlc8ZCRN3Eyx0xmAML7FMZvd.jpg","release_date":"2004-09-29","softcore":false,"video":false,"vote_average":7.226,"vote_count":1078,"credit_id":"52fe4281c3a36847f8023fff","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/ffQFnAUm2Uu4RU0nijpjPRf9TBT.jpg","genre_ids":[18,10749],"id":843,"title":"Spragnieni miłości","original_language":"cn","original_title":"花樣年華","overview":"Hongkong, 1962 r. Uchodźcy z Szanghaju, którzy z nadzieją na lepsze życie licznie przybywają do tej brytyjskiej kolonii, wynajmują każdy, nawet najbardziej obskurny kąt. Wyizolowani, a jednocześnie podlegający nieustannej kontroli sąsiadów, przybysze żyją w zamkniętych społecznościach, tłocząc się w ciasnych pomieszczeniach, zarówno w domach jak i w miejscach pracy. Pewnego dnia do sąsiadujących ze sobą dwóch klitek w jednym z takich przepełnionych domów wprowadzają się równocześnie - sekretarka Su Chan (Maggie Cheung) z mężem i redaktor jednej z gazet Chow Mo-Wan (Tony Leung) z żoną. Żona Chow z powodu obowiązków służbowych często przebywa poza domem. Mąż Su od dłuższego czasu jest podróży służbowej. Kolejne dni w tym ludzkim \"mrowisku\", których rytm wyznacza jedynie praca, są jałowe i nudne.","popularity":9.1249,"poster_path":"/iYypPT4bhqXfq1b6EnmxvRt6b2Y.jpg","release_date":"2000-09-29","softcore":false,"video":false,"vote_average":8.092,"vote_count":3260,"credit_id":"52fe4280c3a36847f8023f4b","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":"/ffQFnAUm2Uu4RU0nijpjPRf9TBT.jpg","genre_ids":[18,10749],"id":843,"title":"Spragnieni miłości","original_language":"cn","original_title":"花樣年華","overview":"Hongkong, 1962 r. Uchodźcy z Szanghaju, którzy z nadzieją na lepsze życie licznie przybywają do tej brytyjskiej kolonii, wynajmują każdy, nawet najbardziej obskurny kąt. Wyizolowani, a jednocześnie podlegający nieustannej kontroli sąsiadów, przybysze żyją w zamkniętych społecznościach, tłocząc się w ciasnych pomieszczeniach, zarówno w domach jak i w miejscach pracy. Pewnego dnia do sąsiadujących ze sobą dwóch klitek w jednym z takich przepełnionych domów wprowadzają się równocześnie - sekretarka Su Chan (Maggie Cheung) z mężem i redaktor jednej z gazet Chow Mo-Wan (Tony Leung) z żoną. Żona Chow z powodu obowiązków służbowych często przebywa poza domem. Mąż Su od dłuższego czasu jest podróży służbowej. Kolejne dni w tym ludzkim \"mrowisku\", których rytm wyznacza jedynie praca, są jałowe i nudne.","popularity":9.1249,"poster_path":"/iYypPT4bhqXfq1b6EnmxvRt6b2Y.jpg","release_date":"2000-09-29","softcore":false,"video":false,"vote_average":8.092,"vote_count":3260,"credit_id":"52fe4280c3a36847f8023efd","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/tj8T9OIM0E51Jf61RJbRbG6vnIJ.jpg","genre_ids":[18,10749],"id":1989,"title":"Jagodowa miłość","original_language":"cn","original_title":"藍莓之夜","overview":"Norah Jones gra zmysłową, ponętną młodą kobietę, która wyrusza w niezapomnianą podróż. Chce odkryć prawdziwą miłość. Piękne krajobrazy autostrady 66 są tłem niezwykłych spotkań bohaterki z osobami, które pomagają jej w dotarciu do celu. Pierwszy anglojęzyczny film Wong Kar Waia został nakręcony w sceneriach odmiennych od pejzaży Nowego Yorku ze szklanymi biurowcami na pierwszym planie. Opowiedziana przez niego historia jest pełna wdzięku, elegancji i oryginalności.","popularity":1.8907,"poster_path":"/9uYgt4XW0TvTkYcm9fcByJgICsk.jpg","release_date":"2007-11-28","softcore":false,"video":false,"vote_average":6.409,"vote_count":851,"credit_id":"52fe4329c3a36847f803ef1d","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/tj8T9OIM0E51Jf61RJbRbG6vnIJ.jpg","genre_ids":[18,10749],"id":1989,"title":"Jagodowa miłość","original_language":"cn","original_title":"藍莓之夜","overview":"Norah Jones gra zmysłową, ponętną młodą kobietę, która wyrusza w niezapomnianą podróż. Chce odkryć prawdziwą miłość. Piękne krajobrazy autostrady 66 są tłem niezwykłych spotkań bohaterki z osobami, które pomagają jej w dotarciu do celu. Pierwszy anglojęzyczny film Wong Kar Waia został nakręcony w sceneriach odmiennych od pejzaży Nowego Yorku ze szklanymi biurowcami na pierwszym planie. Opowiedziana przez niego historia jest pełna wdzięku, elegancji i oryginalności.","popularity":1.8907,"poster_path":"/9uYgt4XW0TvTkYcm9fcByJgICsk.jpg","release_date":"2007-11-28","softcore":false,"video":false,"vote_average":6.409,"vote_count":851,"credit_id":"52fe4329c3a36847f803eef7","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/tj8T9OIM0E51Jf61RJbRbG6vnIJ.jpg","genre_ids":[18,10749],"id":1989,"title":"Jagodowa miłość","original_language":"cn","original_title":"藍莓之夜","overview":"Norah Jones gra zmysłową, ponętną młodą kobietę, która wyrusza w niezapomnianą podróż. Chce odkryć prawdziwą miłość. Piękne krajobrazy autostrady 66 są tłem niezwykłych spotkań bohaterki z osobami, które pomagają jej w dotarciu do celu. Pierwszy anglojęzyczny film Wong Kar Waia został nakręcony w sceneriach odmiennych od pejzaży Nowego Yorku ze szklanymi biurowcami na pierwszym planie. Opowiedziana przez niego historia jest pełna wdzięku, elegancji i oryginalności.","popularity":1.8907,"poster_path":"/9uYgt4XW0TvTkYcm9fcByJgICsk.jpg","release_date":"2007-11-28","softcore":false,"video":false,"vote_average":6.409,"vote_count":851,"credit_id":"52fe4329c3a36847f803eefd","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":"/lInQVVbPjKFGX7GDcxNMXALy2Y4.jpg","genre_ids":[28,10749,80],"id":11220,"title":"Upadłe anioły","original_language":"cn","original_title":"墮落天使","overview":"Losy pięciu samotnych ludzi krzyżują się ze sobą w ciemnych ulicach Hongkongu.","popularity":5.9718,"poster_path":"/yyM9BPdwttK5LKZSLvHae7QPKo1.jpg","release_date":"1995-09-06","softcore":false,"video":false,"vote_average":7.685,"vote_count":1308,"credit_id":"52fe44139251416c75028117","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":"/lInQVVbPjKFGX7GDcxNMXALy2Y4.jpg","genre_ids":[28,10749,80],"id":11220,"title":"Upadłe anioły","original_language":"cn","original_title":"墮落天使","overview":"Losy pięciu samotnych ludzi krzyżują się ze sobą w ciemnych ulicach Hongkongu.","popularity":5.9718,"poster_path":"/yyM9BPdwttK5LKZSLvHae7QPKo1.jpg","release_date":"1995-09-06","softcore":false,"video":false,"vote_average":7.685,"vote_count":1308,"credit_id":"52fe44139251416c75028111","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/vuglA60RqvpHK9rIcG8sXaiWw1L.jpg","genre_ids":[18,35,10749],"id":11104,"title":"Chungking Express","original_language":"cn","original_title":"重慶森林","overview":"Policjant 223 po stracie ukochanej dostaje obsesji na punkcie ananasów i dat. Funkcjonariusz 633, czekając na powrót dziewczyny, nie dostrzega zakochanej w nim kobiety.","popularity":8.9802,"poster_path":"/fv0KUkKoEr1P6Z0lltVyWwtFg5e.jpg","release_date":"1994-07-14","softcore":false,"video":false,"vote_average":7.969,"vote_count":2199,"credit_id":"52fe43f89251416c750248f7","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/vuglA60RqvpHK9rIcG8sXaiWw1L.jpg","genre_ids":[18,35,10749],"id":11104,"title":"Chungking Express","original_language":"cn","original_title":"重慶森林","overview":"Policjant 223 po stracie ukochanej dostaje obsesji na punkcie ananasów i dat. Funkcjonariusz 633, czekając na powrót dziewczyny, nie dostrzega zakochanej w nim kobiety.","popularity":8.9802,"poster_path":"/fv0KUkKoEr1P6Z0lltVyWwtFg5e.jpg","release_date":"1994-07-14","softcore":false,"video":false,"vote_average":7.969,"vote_count":2199,"credit_id":"52fe43f89251416c750248fd","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":"/tEqeyPPBJfyDJl0lO08YiqefYqd.jpg","genre_ids":[18,80,10749],"id":24163,"title":"Kiedy łzy przeminą","original_language":"cn","original_title":"旺角卡門","overview":"Wah zajmuje się „windykacją” dłużników mafii, stara się równocześnie sprawować pieczę nad swym przyjacielem Fly’em. Do miasta przybywa kuzynka Ngor, która na czas swojego leczenia zamieszkuje u Waha. W specyficzny dla siebie sposób wpływa na jego życie. Kiedy wyjeżdża, Wah nie może o niej zapomnieć. W tym właśnie czasie Fly wskutek swojej niepohamowanej arogancji wdaje się w kolejne afery i kłopoty, z których Wah musi go wybawić. Rozdarty musi dokonać wyboru pomiędzy nowym spokojniejszym życiem, a braterstwem krwi…","popularity":2.4041,"poster_path":"/u8W32XGsHyRlXsab75WMXVkfPbH.jpg","release_date":"1988-06-09","softcore":false,"video":false,"vote_average":6.962,"vote_count":373,"credit_id":"52fe4487c3a368484e028009","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/tEqeyPPBJfyDJl0lO08YiqefYqd.jpg","genre_ids":[18,80,10749],"id":24163,"title":"Kiedy łzy przeminą","original_language":"cn","original_title":"旺角卡門","overview":"Wah zajmuje się „windykacją” dłużników mafii, stara się równocześnie sprawować pieczę nad swym przyjacielem Fly’em. Do miasta przybywa kuzynka Ngor, która na czas swojego leczenia zamieszkuje u Waha. W specyficzny dla siebie sposób wpływa na jego życie. Kiedy wyjeżdża, Wah nie może o niej zapomnieć. W tym właśnie czasie Fly wskutek swojej niepohamowanej arogancji wdaje się w kolejne afery i kłopoty, z których Wah musi go wybawić. Rozdarty musi dokonać wyboru pomiędzy nowym spokojniejszym życiem, a braterstwem krwi…","popularity":2.4041,"poster_path":"/u8W32XGsHyRlXsab75WMXVkfPbH.jpg","release_date":"1988-06-09","softcore":false,"video":false,"vote_average":6.962,"vote_count":373,"credit_id":"52fe4487c3a368484e02801d","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":null,"genre_ids":[],"id":819307,"title":"The Star","original_language":"cn","original_title":"The Star","overview":"","popularity":0.2146,"poster_path":null,"release_date":"","softcore":false,"video":true,"vote_average":0.0,"vote_count":0,"credit_id":"6079ddc0d8f44e0059f13531","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/smtzZRpE8hQkQNnhQg2TIRfcWcj.jpg","genre_ids":[18,28],"id":40751,"title":"Popioły czasu","original_language":"cn","original_title":"東邪西毒","overview":"Ouyang Feng to mieszkaniec White Camel Mountain. Ma ambicję, aby zostać sławnym szermierzem. Po tym, jak jego starszy brat żeni się z jego ukochaną, on przenosi się na pustynie, gdzie zakłada gospodę. Zostaje agentem dla zabójców i wynajmuje młodych, ale tanich fechmistrzów, aby wykonywali brudną robotę za innych. W karczmie również spotyka swoich przyjaciół i zawiera znajomości z innymi ludźmi, z których każdy ma inną, ciekawą historię do opowiedzenia...","popularity":2.0839,"poster_path":"/cVXqJDRqel8LuVPRqttakj8AzSH.jpg","release_date":"1994-09-17","softcore":false,"video":false,"vote_average":7.067,"vote_count":398,"credit_id":"52fe45a1c3a36847f80d1d63","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/smtzZRpE8hQkQNnhQg2TIRfcWcj.jpg","genre_ids":[18,28],"id":40751,"title":"Popioły czasu","original_language":"cn","original_title":"東邪西毒","overview":"Ouyang Feng to mieszkaniec White Camel Mountain. Ma ambicję, aby zostać sławnym szermierzem. Po tym, jak jego starszy brat żeni się z jego ukochaną, on przenosi się na pustynie, gdzie zakłada gospodę. Zostaje agentem dla zabójców i wynajmuje młodych, ale tanich fechmistrzów, aby wykonywali brudną robotę za innych. W karczmie również spotyka swoich przyjaciół i zawiera znajomości z innymi ludźmi, z których każdy ma inną, ciekawą historię do opowiedzenia...","popularity":2.0839,"poster_path":"/cVXqJDRqel8LuVPRqttakj8AzSH.jpg","release_date":"1994-09-17","softcore":false,"video":false,"vote_average":7.067,"vote_count":398,"credit_id":"52fe45a1c3a36847f80d1d6f","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":"/7DxtO5SwAU3KkEShayTgFORAWgC.jpg","genre_ids":[35,18,10749],"id":35452,"title":"渺渺","original_language":"zh","original_title":"渺渺","overview":"","popularity":0.6723,"poster_path":"/7INIx2ssFWjvjdQJ04Mpml1ELXM.jpg","release_date":"2008-11-14","softcore":false,"video":false,"vote_average":5.7,"vote_count":30,"credit_id":"52fe45a69251416c9103994b","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/20vIC3JXCFrsLwv0TpiBbK7IKh2.jpg","genre_ids":[35,18],"id":36108,"title":"Kocham kino","original_language":"fr","original_title":"Chacun son cinema ou Ce petit coup au coeur quand la lumiere s'eteint et que le film commence","overview":",,Chacun son cinéma\" to hołd złożony magii kina. Film, powstał na 60. urodziny Festiwalu w Cannes w 2007r. Obraz składa się z 33 etiud słynnych światowych reżyserów. Motywem łączącym je wszystkie jest nieśmiertelny temat kina. Pomysłodawcą obrazu jest pan Gilles Jacob.","popularity":1.7535,"poster_path":"/oqsHDWIh26sJXz9Ua3lPQhUx3lK.jpg","release_date":"2007-10-31","softcore":false,"video":false,"vote_average":6.5,"vote_count":155,"credit_id":"52fe45cd9251416c9103ee37","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/smtzZRpE8hQkQNnhQg2TIRfcWcj.jpg","genre_ids":[18,28],"id":40751,"title":"Popioły czasu","original_language":"cn","original_title":"東邪西毒","overview":"Ouyang Feng to mieszkaniec White Camel Mountain. Ma ambicję, aby zostać sławnym szermierzem. Po tym, jak jego starszy brat żeni się z jego ukochaną, on przenosi się na pustynie, gdzie zakłada gospodę. Zostaje agentem dla zabójców i wynajmuje młodych, ale tanich fechmistrzów, aby wykonywali brudną robotę za innych. W karczmie również spotyka swoich przyjaciół i zawiera znajomości z innymi ludźmi, z których każdy ma inną, ciekawą historię do opowiedzenia...","popularity":2.0839,"poster_path":"/cVXqJDRqel8LuVPRqttakj8AzSH.jpg","release_date":"1994-09-17","softcore":false,"video":false,"vote_average":7.067,"vote_count":398,"credit_id":"6084a3b4e61e6d0057156b47","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/hgqcKNJb4iJRdzVMbOkEmdbfuRy.jpg","genre_ids":[28,9648,10749],"id":38189,"title":"The Hire: The Follow","original_language":"en","original_title":"The Follow","overview":"W trzeciej części cyklu (\"The Follow\"), zrealizowanej przez Wong Kar-Wai'a, dostajemy szczegółowy instruktaż poprawnie przeprowadzonego śledzenia, bowiem Kierowca otrzymuje zlecenie: ma podążać krok w krok za żoną sławnego aktora (poruszającą się BMW Z3 roadster 3.0i), która - wg niego - ma kochanka.","popularity":0.6756,"poster_path":"/wAVZSrnlRQsNDrmwqIatzXLDjsN.jpg","release_date":"2001-05-24","softcore":false,"video":false,"vote_average":6.88,"vote_count":92,"credit_id":"52fe469d9251416c9105a0ed","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/H4mLTEtxBpjuMRNyL0MVqw1EdN.jpg","genre_ids":[28,18,36],"id":44865,"title":"Wielki mistrz","original_language":"zh","original_title":"一代宗師","overview":"Historia dwojga mistrzów kung-fu: Ip Mana z południowych Chin i Gong Er z północnych. Ich drogi krzyżują się w jego rodzinnym mieście Foshan, na dzień przed japońską inwazji w 1936 roku. Zmierzają do legendarnego Złotego Pawilonu, gdzie ma odbyć się ceremonia przejścia na emeryturę słynnego mistrza Gong Yutian, ojca Gong Er. Podczas ceremonii odbywa się ostatni pojedynek Yutiana, który pragnie zjednoczyć przedstawicieli północnego i południowego stylu sztuk walki.","popularity":3.4385,"poster_path":"/kI29JLoIH3uQkvY8cX3RqC92Ut1.jpg","release_date":"2013-01-10","softcore":false,"video":false,"vote_average":6.624,"vote_count":985,"credit_id":"52fe469fc3a36847f8109283","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/aXCuDzHvZe8UejckE0oSUsyqSAY.jpg","genre_ids":[28,14],"id":45394,"title":"九一神雕侠侣","original_language":"cn","original_title":"九一神雕侠侣","overview":"","popularity":1.1776,"poster_path":"/hGo6I5oyLMVJNDWVifsZeSnrMlr.jpg","release_date":"1991-12-19","softcore":false,"video":false,"vote_average":6.8,"vote_count":28,"credit_id":"52fe46c0c3a36847f81102c9","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":"/7ehwRyqw5k65erbI6m25P1tgLtt.jpg","genre_ids":[18,10749],"id":39850,"title":"Eros","original_language":"en","original_title":"Eros","overview":"","popularity":2.0568,"poster_path":"/bz8pWVNsbg1MMKCgp2VX6wFOXJX.jpg","release_date":"2004-12-03","softcore":false,"video":false,"vote_average":5.693,"vote_count":148,"credit_id":"52fe47369251416c9106db4f","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":"/7ehwRyqw5k65erbI6m25P1tgLtt.jpg","genre_ids":[18,10749],"id":39850,"title":"Eros","original_language":"en","original_title":"Eros","overview":"","popularity":2.0568,"poster_path":"/bz8pWVNsbg1MMKCgp2VX6wFOXJX.jpg","release_date":"2004-12-03","softcore":false,"video":false,"vote_average":5.693,"vote_count":148,"credit_id":"52fe47369251416c9106db29","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/4TvipgMIlm0Pvk3mCICAodsKP6m.jpg","genre_ids":[80,18,10749],"id":18311,"title":"Dni naszego szaleństwa","original_language":"cn","original_title":"阿飛正傳","overview":"Kameralna historia trzech kobiet (starszej damy, sprzedawczyni biletów, tancerki) i trzech mężczyzn (policjanta oraz dwóch żyjących z dnia na dzień przyjaciół), którzy próbują sobie ułożyć życie w wielkim mieście, a zarazem odnaleźć prawdziwe uczucie. Film rejestruje nieśmiałe zaloty, namiętności, zdrady, rozpady związków jak i powroty.","popularity":3.8134,"poster_path":"/24C9zdTBVmi9pohF9dJp3Ghkiem.jpg","release_date":"1990-12-15","softcore":false,"video":false,"vote_average":7.268,"vote_count":587,"credit_id":"52fe47739251416c75099cd1","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":"/2Xkd3WeAx11cHxb4Lr3wnSNDWcd.jpg","genre_ids":[18,10749],"id":18329,"title":"Happy Together","original_language":"cn","original_title":"春光乍洩","overview":"Dwaj młodzi kochankowie Ho i Lai w poszukiwaniu lepszego życia wyjeżdżają z Hongkongu do Argentyny. Wkrótce dochodzi między nimi do sprzeczki. Mężczyźni rozstają się. Lai zatrudnia się jako portier w tango barze w Buenos Aires. Odkłada pieniądze na samolot do domu. Do jego mieszkania przychodzi pobity jego były partne","popularity":3.0723,"poster_path":"/dAyUTgO1BGuEZhF3f2G8V9d8sXM.jpg","release_date":"1997-05-30","softcore":false,"video":false,"vote_average":7.576,"vote_count":799,"credit_id":"52fe47749251416c75099ed3","department":"Production","job":"Producer"},{"adult":false,