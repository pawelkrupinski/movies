na. \"Storm Catchera\" porywa pilot w hełmie majora Hollowaya. Major budzi się na odludziu, wkrótce zostaje aresztowany i oskarżony o udział w tajnej organizacji wojskowej planującej zamach na władze państwa. Holloway ucieka i porywa prywatny samolot kapitana Lucasa, wierząc, że odnalezienie \"Storm Catchera\" pozwoli rozszyfrować tajemnicę zamachu.","popularity":1.8833,"poster_path":"/nl7TMlYPSDGhWga4j6ru8RvKF7U.jpg","release_date":"1999-09-10","softcore":false,"video":false,"vote_average":3.855,"vote_count":31,"credit_id":"59c227199251417691009cdb","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/newXO50fFylEEk13pWlp4bzJ5L9.jpg","genre_ids":[27,878,28],"id":55949,"title":"Vampirella","original_language":"en","original_title":"Vampirella","overview":"","popularity":1.9545,"poster_path":"/8AhXz9r9ZlvTwakzxlSHanoCFP5.jpg","release_date":"1996-09-28","softcore":false,"video":false,"vote_average":3.856,"vote_count":59,"credit_id":"59e2f5ae92514108240093d7","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/q7Vwplt7AyJijltWbiCXWVrYxuc.jpg","genre_ids":[28,35,80],"id":86483,"title":"Big Bad Mama II","original_language":"en","original_title":"Big Bad Mama II","overview":"","popularity":1.2183,"poster_path":"/y1hfe5hLz6rRukEoK8y0GftC1QC.jpg","release_date":"1987-10-01","softcore":false,"video":false,"vote_average":4.9,"vote_count":24,"credit_id":"6641f7ac6d9d8bda3196837c","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":null,"genre_ids":[27,878],"id":1080980,"title":"Murderbot","original_language":"en","original_title":"Murderbot","overview":"","popularity":0.5792,"poster_path":"/sdycYzVrwNtyOddI2eRMAms8tks.jpg","release_date":"2023-03-31","softcore":false,"video":false,"vote_average":6.0,"vote_count":4,"credit_id":"643b2e9c4d67910469d73687","department":"Writing","job":"Story"},{"adult":false,"backdrop_path":"/1fiKvmz1yR2ritSmcT5QY4LwkGk.jpg","genre_ids":[878,27],"id":1292723,"title":"Asterion","or