5IONrtyyTTvVapObFJki.jpg","release_date":"2001-09-18","softcore":false,"video":false,"vote_average":4.639,"vote_count":18,"credit_id":"52fe45a0c3a368484e065d8f","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/NC1g6WrrSPMnZ5Ip627skD2FEG.jpg","genre_ids":[27],"id":28751,"title":"TELEFON DO PIEKŁA 2","original_language":"en","original_title":"976-Evil II","overview":"W mieście trwa seria tajemniczych morderstw. Sprawcą okazuje się dziekan Collegu Grubeck. Pomimo aresztowania, jest w stanie pojawiać się w różnych miejscach. Grubeck pała obsesyjną miłością do młodej i pięknej studentki Robin, która posiada zdolność widzenia przyszłych morderstw. Dziewczynie pomaga młody chłopak Spike. Wspólnie podejmują walkę z Grubeckiem. Dobrze zrobiony i trzymający w napięciu horror z elementami zjawisk nadprzyrodzonych.","popularity":0.8278,"poster_path":"/9NUTvPGPXmtH0BXsBAqWZTOhLrL.jpg","release_date":"1992-01-29","softcore":false,"video":false,"vote_average":4.6,"vote_count":59,"credit_id":"52fe45afc3a368484e069161","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/1ctiV8HodFkFOwIjQp3T2znHE19.jpg","genre_ids":[27,878],"id":28941,"title":"Roboty śmierci","original_language":"en","original_title":"Chopping Mall","overview":"W nowym centrum handlowym Park Plaza Mall, opinii publicznej zostają zaprezentowane trzy nowoczesne roboty , które od tej pory będą czuwać nad bezpieczeństwem całej galerii. Z początku wszystko wydaje się być pod kontrolą, niestety pewnej nocy w wyniku burzy (xd) dochodzi do przeprogramowania naszych metalowych kolegów i zmiany ich nastawiania z łagodnych ochroniarzy na strzelające laserami i materiałami wybuchowymi maszyny do zabijania. Pech sprawia, że w tym samym czasie w centrum znajduję się kilkoro nastolatków, którzy postanowili urządzić sobie małą imprezę w jednym z zamkniętych sklepów...","popularity":1.6837,"poster_path":"/liMvDFwhyX0wsVtNEnGH8YTP34w.jpg","release_date":"1986-11-14","softcore":false,"video":false,"vote_average":5.8,"vote_count":404,"credit_id":"52fe45bdc3a368484e06c215","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/1ctiV8HodFkFOwIjQp3T2znHE19.jpg","genre_ids":[27,878],"id":28941,"title":"Roboty śmierci","original_language":"en","original_title":"Chopping Mall","overview":"W nowym centrum handlowym Park Plaza Mall, opinii publicznej zostają zaprezentowane trzy nowoczesne roboty , które od tej pory będą czuwać nad bezpieczeństwem całej galerii. Z początku wszystko wydaje się być pod kontrolą, niestety pewnej nocy w wyniku burzy (xd) dochodzi do przeprogramowania naszych metalowych kolegów i zmiany ich nastawiania z łagodnych ochroniarzy na strzelające laserami i materiałami wybuchowymi maszyny do zabijania. Pech sprawia, że w tym samym czasie w centrum znajduję się kilkoro nastolatków, którzy postanowili urządzić sobie małą imprezę w jednym z zamkniętych sklepów...","popularity":1.6837,"poster_path":"/liMvDFwhyX0wsVtNEnGH8YTP34w.jpg","release_date":"1986-11-14","softcore":false,"video":false,"vote_average":5.8,"vote_count":404,"credit_id":"52fe45bdc3a368484e06c21b","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":"/bQXVakVJgn2lnoAOJguvSrwwNZZ.jpg","genre_ids":[27,53],"id":29053,"title":"Wolfhound","original_language":"en","original_title":"Wolfhound","overview":"","popularity":1.3795,"poster_path":"/eQEsnDk3z06OSeXgz8dhjbyXwPb.jpg","release_date":"2002-08-26","softcore":false,"video":false,"vote_average":3.773,"vote_count":11,"credit_id":"52fe45c3c3a368484e06d9fb","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/8JhmQlJRgj2e3qrHHyi26PI3RDf.jpg","genre_ids":[28,12,14],"id":41889,"title":"Czarownica","original_language":"en","original_title":"Sorceress","overview":"Zły czarnoksiężnik Traigon (Roberto Ballesteros) pragnie nieograniczonej mocy. Aby to osiągnąć, musi złożyć bogini Caligarze w ofierze swoje własne dziecko. Jednak jego żona nie zgadza się na to i będąc już w zaawansowanej ciąży, ucieka. Podczas ucieczki rodzi córki-bliźniaczki. Oddaje je w opiekę wojownikowi Kronowi (Martin LaSalle), który obiecuje wychować je na wielkie wojowniczki. Dwadzieścia lat później Traigon wpada na trop swych córek. Ich sprzymierzeńcami, oprócz Krona, są Wiking Baldar i barbarzyńca Erlik. Walka nie będzie łatwa - Traigon ma po swojej stronie siły ciemności.","popularity":0.8516,"poster_path":"/fXbCl3j08WviEpapDr9HWd7mI4u.jpg","release_date":"1982-03-01","softcore":false,"video":false,"vote_average":4.396,"vote_count":82,"credit_id":"52fe45e1c3a36847f80dfd73","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":"/qcnuREKTPm1wsAdWqxbYbPFYMdi.jpg","genre_ids":[53],"id":29088,"title":"Virtual Desire","original_language":"en","original_title":"Virtual Desire","overview":"","popularity":2.022,"poster_path":"/wU9nWGLLWMGVDUnzOQYNc1uja8O.jpg","release_date":"1995-10-24","softcore":false,"video":false,"vote_average":4.333,"vote_count":9,"credit_id":"52fe45c6c3a368484e06e579","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/kqksCPIDaiYfWUsoCArKe8Vtr66.jpg","genre_ids":[878,53,28],"id":29516,"title":"Fugitive Mind","original_language":"en","original_title":"Fugitive Mind","overview":"","popularity":0.6064,"poster_path":"/y5eIotJDuRiaRgcFhIh00D2sc8h.jpg","release_date":"1999-09-14","softcore":false,"video":false,"vote_average":6.2,"vote_count":10,"credit_id":"52fe45e6c3a368484e075707","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/oznt5oXAFq1qUot0feFWEsA5Agk.jpg","genre_ids":[35,27],"id":29689,"title":"The Bare Wench Project 3: Nymphs of Mystery Mountain","original_language":"en","original_title":"The Bare Wench Project 3: Nymphs of Mystery Mountain","overview":"","popularity":0.6133,"poster_path":"/uQPyGenS8BfWTNAS3iZyOXv3XGi.jpg","release_date":"2002-01-01","softcore":false,"video":false,"vote_average":4.6,"vote_count":10,"credit_id":"52fe45f3c3a368484e078567","department":