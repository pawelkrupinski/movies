iginal_title":"Munchie","overview":"Dziesięcioletni Gage jest znudzony życiem. Nie ma przyjaciół, szkoła jest dla niego beznadziejna, a na dodatek mama zakochała się w jakimś nieznośnym prawniku. Pewnego dnia Gage wybiera się na spacer i znajduję tajemniczą skrzynię, z której wyskakuje mały kosmita imieniem Munchie. Mały stworek może spaełnić wszystkie jego życzenia. Z pomocą swojego nowego przyjaciela Gage kompromituje dyrektora szkoły, daje wycisk szkolnemu tyranowi i... zamawia pizzę.","popularity":1.1364,"poster_path":"/5B0JIheq8jpXjuZfzirgqzhIb5T.jpg","release_date":"1992-05-15","softcore":false,"video":false,"vote_average":4.1,"vote_count":32,"credit_id":"5476233a925141407a00281e","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":"/kWdffGZqFJgnk6FUKIadbIkJ0d7.jpg","genre_ids":[27,10770],"id":58791,"title":"Bone Eater","original_language":"en","original_title":"Bone Eater","overview":"","popularity":1.8004,"poster_path":"/lQPHTuJOJJp1QNeAu00yR3HlaJy.jpg","release_date":"2008-02-15","softcore":false,"video":false,"vote_average":3.419,"vote_count":37,"credit_id":"61665270d7f465004247706b","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":null,"genre_ids":[35,27],"id":542440,"title":"Bikini Car Wash Massacre","original_language":"en","original_title":"Bikini Car Wash Massacre","overview":"","popularity":0.2375,"poster_path":"/p87hm2RMExd0aKEv2zcK4uizDLR.jpg","release_date":"2017-12-01","softcore":false,"video":false,"vote_average":7.0,"vote_count":3,"credit_id":"616394e71108a8002c317a20","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/A7luKytaUQ2Vz7ARMdotUA0JNQO.jpg","genre_ids":[27,878,35],"id":44809,"title":"Dinocroc vs. Supergator","original_language":"en","original_title":"Dinocroc vs. Supergator","overview":"","popularity":0.8014,"poster_path":"/nlHG4VW1Du00ySCZKy4KuLPR7nV.jpg","release_date":"2010-06-26","softcore":false,"video":false,"vote_average":4.363,"vote_count":73,"credit_id"