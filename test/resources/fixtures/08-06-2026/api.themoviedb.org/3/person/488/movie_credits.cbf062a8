 footage)","credit_id":"68b4eff637889b8c571f26b2","order":0},{"adult":false,"backdrop_path":"/hIifXiWItMMEWZQ36iYk63Wnc9Q.jpg","genre_ids":[99],"id":1547936,"title":"The Force Is with Them: The Legacy of 'Star Wars'","original_language":"en","original_title":"The Force Is with Them: The Legacy of 'Star Wars'","overview":"","popularity":0.2853,"poster_path":"/4QNNtt45uldnsHs35QMIMXfMSTl.jpg","release_date":"2004-09-12","softcore":false,"video":false,"vote_average":8.0,"vote_count":2,"character":"Self","credit_id":"68caedbf58f008883998e07a","order":10},{"adult":false,"backdrop_path":"/4lzZU04sCv2nMo3qJ4wGWG6tna7.jpg","genre_ids":[99,36],"id":32276,"title":"Easy Riders, Raging Bulls: How the Sex 'n' Drugs 'n' Rock 'n' Roll Generation Saved Hollywood","original_language":"en","original_title":"Easy Riders, Raging Bulls: How the Sex 'n' Drugs 'n' Rock 'n' Roll Generation Saved Hollywood","overview":"","popularity":1.5796,"poster_path":"/sKztDZqY6T5fhnpJKDqNsAaSLqZ.jpg","release_date":"2003-03-09","softcore":false,"video":false,"vote_average":7.143,"vote_count":63,"character":"Self","credit_id":"6937108df7a082b75beb16c5","order":47},{"adult":false,"backdrop_path":"/lHSLTzz1rW3XcfJYTyCSdaPmosr.jpg","genre_ids":[99],"id":1584125,"title":"1975: Rok, który zmienił Amerykę","original_language":"en","original_title":"Breakdown: 1975","overview":"Dokument nagrodzonego Oscarem Morgana Neville’a o roku 1975 w Ameryce. Czas niepokojów społecznych i politycznych staje się inspiracją dla szeregu przełomowych filmów.","popularity":1.8912,"poster_path":"/6LirpQnBmBpAOa5Me1lBCBBy90e.jpg","release_date":"2025-12-18","softcore":false,"video":false,"vote_average":6.796,"vote_count":27,"character":"Self - Director of JAWS (archive footage)","credit_id":"694595e7d49dde55e5fb0773","order":46},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":1599506,"title":"The E.T. Reunion","original_language":"en","original_title":"The E.T. Reunion","overview":"","popularity":0.138,"poster_path":"/70psTmDSqOGqk9OdogOpONbQ1Ik.jpg","release_date":"2002-01-01","softcore":false,"video":true,"vote_average":7.0,"vote_count":1,"character":"Self","credit_id":"694704db797990b0368cdd32","order":0},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":1601569,"title":"E.T. the Extra-Terrestrial: The 20th Anniversary Celebration","original_language":"en","original_title":"E.T. the Extra-Terrestrial: The 20th Anniversary Celebration","overview":"","popularity":0.0758,"poster_path":"/z9QCWj8EVYpAgbkSUmRccVNyIaJ.jpg","release_date":"2002-01-01","softcore":false,"video":true,"vote_average":8.0,"vote_count":1,"character":"Self","credit_id":"69470752ea4043936f2fb882","order":0},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":1601578,"title":"E.T. the Extra-Terrestrial: A Look Back","original_language":"en","original_title":"E.T. the Extra-Terrestrial: A Look Back","overview":"","popularity":0.0919,"poster_path":"/AppYvqPabjfmn5anhIoCkpu4UUB.jpg","release_date":"2002-01-01","softcore":false,"video":true,"vote_average":0.0,"vote_count":0,"character":"Self","credit_id":"69470e104e760029912fbb57","order":0},{"adult":false,"backdrop_path":"/rSuqSerMzqMtgX7fX50Hl55ficF.jpg","genre_ids":[99],"id":1492608,"title":"John Candy: Lubię siebie","original_language":"en","original_title":"John Candy: I Like Me","overview":"Reżyser Colin Hanks i producent Ryan Reynolds zapraszają na John Candy: Lubię siebie. To pełna humoru i wzruszeń opowieść o niezwykłym życiu legendarnego komika. Wspomnienia bliskich, unikatowe nagrania i niepublikowane wcześniej materiały tworzą barwny portret aktora, którego talent i serce podbiły miliony widzów na całym świecie.","popularity":1.6501,"poster_path":"/90mIqvuQX1JB3KY2jFWq6yROIdd.jpg","release_date":"2025-09-04","softcore":false,"video":false,"vote_average":7.8,"vote_count":97,"character":"Self - Director, 1941 (archive footage)","credit_id":"694bdc7bb0e2908aec8ec7a6","order":69},{"adult":false,"backdrop_path":"/vate7k6MyLQDeFYkHqCrLhRes6m.jpg","genre_ids":[99],"id":1620034,"title":"Krótka historia Martina Shorta","original_language":"en","original_title":"Marty, Life Is Short","overview":"W tym obfitującym w klasyczne klipy, nowe wywiady i pełne gwiazd domowe nagrania dokumencie Martin Short wspomina swoje radosne życie.","popularity":4.8043,"poster_path":"/z4QdUukg4FnbcwM6qeP6ZCoQZhf.jpg","release_date":"2026-05-11","softcore":false,"video":false,"vote_average":8.25,"vote_count":17,"character":"Self","credit_id":"69f89600c3a854d0e5327186","order":15},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":1351951,"title":"Maverick: The Epic Adventures of David Lean","original_language":"en","original_title":"Maverick: The Epic Adventures of David Lean","overview":"","popularity":0.4013,"poster_path":"/6I1xlVvS2ejBCnJ4SNpgtFhrAKb.jpg","release_date":"2026-05-17","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"character":"Self","credit_id":"6a1965e84cd66823706a069e","order":3}],"crew":[{"adult":false,"backdrop_path":"/f133nWlU6yUkZqqwcCXCbTEJWHr.jpg","genre_ids":[12,28],"id":87,"title":"Indiana Jones i Świątynia Zagłady","original_language":"en","original_title":"Indiana Jones and the Temple of Doom","overview":"\"Indiana Jones i Świątynia Zagłady\" przyprawi Cię o drżenie serca, bowiem właśnie tu Indy odbywa szaleńczą i niezapomnianą jazdę kopalnianą kolejką, a wszystko, by wraz z piosenkarką Willie i sprytnym chłopcem - Shortem - ocalić dzieci uwięzione w pilnie strzeżonych podziemiach. Odkryj złowieszcze, żądne krwi czarne charaktery, nietypowe posiłki i zapierające dech w piersiach sekwencje, które sprawiły, że saga Indy'ego stała się jednym z najbardziej kultowych wydarzeń filmowych wszech czasów!","popularity":8.1848,"poster_path":"/fDVwUYaRkkfe00tL8FHKXlyec8L.jpg","release_date":"1984-05-23","softcore":false,"video":false,"vote_average":7.309,"vote_count":10122,"credit_id":"52fe4215c3a36847f8002bf9","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/bInicBgSHfQiWLbnRT5jxw9Grvm.jpg","genre_ids":[12,53,878],"id":74,"title":"Wojna światów","original_language":"en","original_title":"War of the Worlds","overview":"Ray Ferrier (Tom Cruise) to rozwiedziony pracownik portowy i jednocześnie niezbyt idealny ojciec. Wkrótce po tym jak jego była żona i jej nowy małżonek wpadają do Ferriera, żeby podrzucić mu dzieciaki - nastoletniego Robbiego (Justin Chatwin) i młodszą córkę Rachel (Dakota Fanning), w mieście rozpętuje się przedziwna burza z piorunami. Chwilę później, na skrzyżowaniu nieopodal swojego domu Ray staje się świadkiem niezwykłego wydarzenia, które na zawsze odmieni życie jego samego i jego rodziny. Gigantyczna wojenna machina, osadzona na trójnogu, pojawia się nagle z głębi ziemi i zanim ktokolwiek jest w stanie zareagować, spala wszystko, co znajdzie się w zasięgu jej rażenia.","popularity":9.2394,"poster_path":"/nI2yJoa2FVpTN7A3ALRlOQ7OQaV.jpg","release_date":"2005-06-28","softcore":false,"video":false,"vote_average":6.544,"vote_count":9187,"credit_id":"52fe4213c3a36847f8002225","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/zPACwR32amTNvzId9qyapCWXYDJ.jpg","genre_ids":[12,28],"id":85,"title":"Indiana Jones i poszukiwacze zaginionej Arki","original_language":"en","original_title":"Raiders of the Lost Ark","overview":"Dr. Indiana Jones (Harrison Ford) jest archeologiem, który łączy wykłady uniwersyteckie z ekspedycjami badawczymi. Właśnie powrócił z ostatniej, w trakcie której odniósł porażkę w rywalizacji z naukowcem pracującym dla nazistów. Nie dane jest mu zająć się nauczaniem. Otrzymuje bowiem tajne zadanie od służb specjalnych. Wyrusza do Egiptu, gdzie prawdopodobnie odkryto miejsce przechowywania Arki Przymierza. Nie może dopuścić, by święte trofeum znalazło się w rękach Niemców. Pomoże mu w tym jego dawna dziewczyna, Marion (Karen Allen).","popularity":13.4079,"poster_path":"/bvDtNNt9skWNip11BNtHZHICDX2.jpg","release_date":"1981-06-12","softcore":false,"video":false,"vote_average":7.924,"vote_count":13651,"credit_id":"52fe4215c3a36847f8002a01","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/12fvZHskx57kQfNEUXJ3v0flWYQ.jpg","genre_ids":[12,28],"id":89,"title":"Indiana Jones i ostatnia krucjata","original_language":"en","original_title":"Indiana Jones and the Last Crusade","overview":"Nie ma nic bardziej ekscytującego niż staranie się dotrzymać kroku Jonesom w filmie \"Indiana Jones i ostatnia krucjata\". Nazistowscy wrogowie Indy'ego powracają i porywają mu ojca, profesora Henry'ego Jonesa, by pomógł  odnaleźć Świętego Grala. Od zagubionych miast, po skarby templariuszy i  podziemia Wenecji, odkryj źródło wiecznego życia i największą ekranową przygodę Indiany Jonesa!","popularity":8.4946,"poster_path":"/m4FpMTE4mXp9yTVwt2aOFhewNTa.jpg","release_date":"1989-05-24","softcore":false,"video":false,"vote_average":7.852,"vote_count":11071,"credit_id":"52fe4216c3a36847f8002df5","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/p96949hcwUG2BwE6MgKmw0uYNCx.jpg","genre_ids":[12,28],"id":217,"title":"Indiana Jones i Królestwo Kryształowej Czaszki","original_language":"en","original_title":"Indiana Jones and the Kingdom of the Crystal Skull","overview":"Akcja filmu rozgrywa się w czasie zimnej wojny w 1957 roku, dokładnie 19 lat po \"Ostatniej Krucjacie\". Doktor Indiana Jones (Harrison Ford) wiedzie spokojne życie, mając posadę jako wykładowca na uniwersytecie. Jednak już wkrótce znów odda się wielkiej przygodzie, gdy dowie się o zaginionych trzynastu kryształowych czaszkach. Legenda głosi, że zostały one wykonane przez kosmitów lub wysoko rozwiniętą cywilizację Majów. Nowa podróż doprowadzi go m.in. do Meksyku i dżungli w Peru. Na dodatek będą deptać mu po piętach sowieccy agenci...","popularity":6.6393,"poster_path":"/axMICADJenMq9XXfAYw26Rz48fO.jpg","release_date":"2008-05-21","softcore":false,"video":false,"vote_average":6.027,"vote_count":9028,"credit_id":"52fe4227c3a36847f800846d","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/PrMb3oeEluauy0q9ZO5xL33A6C.jpg","genre_ids":[878,28,53],"id":180,"title":"Raport mniejszości","original_language":"en","original_title":"Minority Report","overview":"Waszyngton roku 2054 - futurystyczny świat, w którym nie ma zbrodni, przyszłość można przewidzieć, a winnych ukarać, zanim popełnią planowane przestępstwo. Dowodów niedoszłych zbrodni dostarcza trójka Jasnowidzów na usługach Agencji Prewencji Departamentu Sprawiedliwości, nad której sprawnym działaniem czuwa komisarz John Anderton (Tom Cruise). Jako pierwszy ogląda obrazy przekazywane przez Jasnowidzów. Ich werdykt nie pozostawia wątpliwości - za niespełna 36 godzin John Anderton zabije człowieka, którego nawet nie zna. Rozpoczyna się szaleńczy wyścig z czasem. Anderton musi wykryć, kto go wrabia albo stanie się ofiarą \"idealnego\" systemu, który sam pomagał tworzyć. Aby wygrać musi odpowiedzieć sobie na pytanie, które jeszcze nie tak dawno nie przyszłoby mu nawet na myśl: czy Jasnowidze mogą się mylić?","popularity":8.4607,"poster_path":"/9BtQ0dL3aVb9hQLL6dCR725FFBo.jpg","release_date":"2002-06-20","softcore":false,"video":false,"vote_average":7.355,"vote_count":9639,"credit_id":"52fe4223c3a36847f8006f3d","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/o7LzVmlOSYc3EspyVMC9bsTTARc.jpg","genre_ids":[12,878],"id":329,"title":"Park Jurajski","original_language":"en","original_title":"Jurassic Park","overview":"John Hammond, ekscentryczny milioner, stworzył na wyspie Nublar, dwieście kilometrów na zachód od Kostaryki, niezwykły rezerwat. Jego atrakcją są przywołane do życia po stu milionach lat dinozaury. Ale, aby Park Jurajski mógł przyjąć turystów, grupa fachowców musi potwierdzić, że jest miejscem całkowicie bezpiecznym. Niestety brak pokory wobec natury musi zostać ukarany. Wyprawa naukowców do rezerwatu przeradza się w krwawy koszmar...","popularity":8.9769,"poster_path":"/6PahEke329HOQx1QOqlo12e4YXa.jpg","release_date":"1993-06-11","softcore":false,"video":false,"vote_average":7.969,"vote_count":17882,"credit_id":"52fe4238c3a36847f800d291","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/A4rYaPdzgocCjQ0n9LUSYUxyvpS.jpg","genre_ids":[12,28,878],"id":330,"title":"Park Jurajski: Zaginiony Świat","original_language":"en","original_title":"The Lost World: Jurassic Park","overview":"Minęły cztery lata, odkąd narodzone w wyniku eksperymentu genetycznego dinozaury sterroryzowały naukowców i gości, którzy przybyli, by podziwiać niezwykły Jurassic Park. Dr Ian Malcolm odkrywa, że John Hammond, miliarder, który sfinalizował powstanie pierwszego parku, wyhodował całe stada dinozaurów na innej wyspie w głębi oceanu. Dowiaduje się przy tym, że jego dziewczyna, paleontolog Sarah Harding, wyjechała na wyspę, by studiować zachowania dinozaurów. Przeczuwając najgorsze, wyrusza jej na ratunek. Po przybyciu na miejsce musi stawić czoła nie tylko niebezpiecznym raptorom i krwiożerczemu T-Rexowi, ale i grupie najemników, którzy chcą wywieźć gady z wyspy. Czy świat gotów jest na przyjęcie dinozaurów?","popularity":0.5442,"poster_path":"/zuv6F82bVid7HUpTY631ofsBUrG.jpg","release_date":"1997-05-23","softcore":false,"video":false,"vote_average":6.565,"vote_count":9235,"credit_id":"52fe4238c3a36847f800d3ad","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/8v8x4vVbRgrsdU3M4drnD7HQbfe.jpg","genre_ids":[12,53,878],"id":331,"title":"Park Jurajski III","original_language":"en","original_title":"Jurassic Park III","overview":"Sławny paleontolog dr Alan Grant zgadza się towarzyszyć ekscentrycznej parze milionerów w wyprawie na wyspę Isla Sorna, do miejsca, gdzie InGens prowadził niegdyś eksperymenty z prehistorycznymi dinozaurami. Jednak z pozoru zwykła wycieczka zamienia się w koszmar, kiedy dr Grant odkrywa prawdziwy powód wyprawy małżonków, a zamieszkujące wyspę dinozaury okazują się niebezpiecznymi potworami. W tym zapierającym dech w piersiach thrillerze dr Grant stanie twarzą w twarz z bestiami gorszymi niż mógł się spodziewać.","popularity":0.4086,"poster_path":"/AfKGS9PnjM8U7ovlFIXsSLPB9zt.jpg","release_date":"2001-07-18","softcore":false,"video":false,"vote_average":6.176,"vote_count":7854,"credit_id":"52fe4238c3a36847f800d4db","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/zb6fM1CX41D9rF9hdgclu0peUmy.jpg","genre_ids":[18,36,10752],"id":424,"title":"Lista Schindlera","original_language":"en","original_title":"Schindler's List","overview":"Oskar Schindler jest poważanym niemieckim przemysłowcem, który podczas II wojny światowej jest właścicielem dużej fabryki, w której w nieludzkich warunkach pracują Żydzi. Widząc cierpienie tych ludzi zaczyna ratować ich przed śmiercią w obozach koncentracyjnych. Film oparty jest na prawdziwej historii Oskara Schindlera, który podczas wojny ocalił przed śmiercią około 1100 ludzkich istnień.","popularity":23.5327,"poster_path":"/7mYojklW12jrWzvjxipWFeUnO9M.jpg","release_date":"1993-12-15","softcore":false,"video":false,"vote_average":8.569,"vote_count":17493,"credit_id":"52fe4241c3a36847f801025f","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/69Mdg9vH6yQx08DwK02RlqO9CPp.jpg","genre_ids":[28,18,10752],"id":1251,"title":"Listy z Iwo Jimy","original_language":"en","original_title":"Letters from Iwo Jima","overview":"Akcja filmu skupia sie wokół japońskiego generała Tadamichi Kuribayashi (postać historyczna), pod którego dowództwem japońscy żołnierze przez 40 dni odpierali atak armii Stanów Zjednoczonych na małą wyspę Iwo Jima. \"Red Sun, Black Sand\" to próba spojrzenia \"z perspektywy japońskiej\" na dramat pod Iwo Jima, to obraz dopełniający dzieło Eastwooda - obok wydarzeń widzianych oczami amerykańskiego żołnierza we \"Flags of Our Fathers\".","popularity":3.1637,"poster_path":"/2IX877b855bybeQjqTTDjeIAdyF.jpg","release_date":"2006-12-09","softcore":false,"video":false,"vote_average":7.5,"vote_count":2281,"credit_id":"52fe42eac3a36847f802c871","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/zb6fM1CX41D9rF9hdgclu0peUmy.jpg","genre_ids":[18,36,10752],"id":424,"title":"Lista Schindlera","original_language":"en","original_title":"Schindler's List","overview":"Oskar Schindler jest poważanym niemieckim przemysłowcem, który podczas II wojny światowej jest właścicielem dużej fabryki, w której w nieludzkich warunkach pracują Żydzi. Widząc cierpienie tych ludzi zaczyna ratować ich przed śmiercią w obozach koncentracyjnych. Film oparty jest na prawdziwej historii Oskara Schindlera, który podczas wojny ocalił przed śmiercią około 1100 ludzkich istnień.","popularity":23.5327,"poster_path":"/7mYojklW12jrWzvjxipWFeUnO9M.jpg","release_date":"1993-12-15","softcore":false,"video":false,"vote_average":8.569,"vote_count":17493,"credit_id":"52fe4241c3a36847f801024d","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/i1yf91svRHX45l9BXL8rVFzLoPH.jpg","genre_ids":[27,53,12],"id":578,"title":"Szczęki","original_language":"en","original_title":"Jaws","overview":"W niewielkiej osadzie na wyspie wybucha panika po kolejnych atakach jakiegoś stworzenia na pływających w morzu. Okazuje się, że wielki biały rekin nie chce wcale stąd odpływać. Szeryf Brody z przyjaciółmi Hooper'em i Quint'em decydują się go zabić.","popularity":15.9392,"poster_path":"/mW4LDGSvlqDGB5mKV2b25O3uINx.jpg","release_date":"1975-06-20","softcore":false,"video":false,"vote_average":7.682,"vote_count":11539,"credit_id":"52fe4255c3a36847f801601f","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/zywtNiaZ9r7azrcNdl2j0jOgrkw.jpg","genre_ids":[35,18],"id":594,"title":"Terminal","original_language":"en","original_title":"The Terminal","overview":"Gdy Viktor Navorski, turysta z Europy Wschodniej, przylatuje do Nowego Jorku, w jego ojczyźnie ma miejsce zamach stanu. Amerykańskie władze nie uznają paszportu mężczyzny, więc miejscem przymusowego pobytu staje się dla niego hala terminalu…","popularity":5.4183,"poster_path":"/iDNQgJ8KjnvnSpsn2nFTCUOofju.jpg","release_date":"2004-06-17","softcore":false,"video":false,"vote_average":7.355,"vote_count":8712,"credit_id":"52fe4259c3a36847f801761f","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/zywtNiaZ9r7azrcNdl2j0jOgrkw.jpg","genre_ids":[35,18],"id":594,"title":"Terminal","original_language":"en","original_title":"The Terminal","overview":"Gdy Viktor Navorski, turysta z Europy Wschodniej, przylatuje do Nowego Jorku, w jego ojczyźnie ma miejsce zamach stanu. Amerykańskie władze nie uznają paszportu mężczyzny, więc miejscem przymusowego pobytu staje się dla niego hala terminalu…","popularity":5.4183,"poster_path":"/iDNQgJ8KjnvnSpsn2nFTCUOofju.jpg","release_date":"2004-06-17","softcore":false,"video":false,"vote_average":7.355,"vote_count":8712,"credit_id":"52fe4259c3a36847f8017681","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/o1l6OCqA3pYDZHIc5L1s7CEzCMv.jpg","genre_ids":[28,35,878],"id":608,"title":"Faceci w czerni 2","original_language":"en","original_title":"Men in Black II","overview":"Faceci w Czerni powracają! Tommy Lee Jones i Will Smith ponownie stawiają czoła szumowinom z kosmosu, które nawiedzają naszą planetę. Ich najnowsza misja: ocalić świat przed ostateczną zagładą! Kiedy przebiegła kylothiańska kosmitka przybiera postać seksownej modelki, a zamiast reklamować elegancką bieliznę wypowiada wojnę rodzajowi ludzkiemu, agenci Kay i Jay wkraczają do akcji. Gdy kosmiczne szumowiny zajmą ich kwaterę główną, Faceci w Czerni zwrócą się o pomoc do Franka Mopsa i oddziału walecznych Robali. Wspólnie dadzą wycisk bezczelnym najeźdźcom, bo jeszcze się taki nie narodził, który by im dorównał.","popularity":8.1639,"poster_path":"/dfOTcClGU5p8lH9sulRXGm4dVFx.jpg","release_date":"2002-07-03","softcore":false,"video":false,"vote_average":6.387,"vote_count":10660,"credit_id":"52fe425dc3a36847f8018875","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/mXLVA0YL6tcXi6SJSuAh9ONXFj5.jpg","genre_ids":[12,878,10751],"id":601,"title":"E.T.","original_language":"en","original_title":"E.T. the Extra-Terrestrial","overview":"E.T. to historia wyjątkowej przyjaźni, która rozwija się między Elliottem, samotnym chłopcem żyjącym na jednym z kalifornijskich przedmieść, a mądrym przybyszem z obcej planety, który gubi się na Ziemi. Kiedy Elliott usiłuje pomóc przyjacielowi skontaktować się z jego planetą, obaj muszą unikać naukowców i agentów rządowych za wszelką cenę pragnących wykorzystać przybysza do swoich celów. Wszystko to prowadzi do wspaniałej przygody, większej od wszystkiego co mogli sobie wyobrazić.","popularity":12.1857,"poster_path":"/ihqmwPkVp5z6rwlEfC1eU45rfFH.jpg","release_date":"1982-06-11","softcore":false,"video":false,"vote_average":7.516,"vote_count":12012,"credit_id":"52fe425bc3a36847f8017def","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/o9puyKpayQoX8ikIaYtf2PfKv3.jpg","genre_ids":[28,12,35,878],"id":607,"title":"Faceci w czerni","original_language":"en","original_title":"Men in Black","overview":"Na Ziemię napływa ciągła emigracja z kosmosu. Przybysze doskonale potrafią się kamuflować przybierając wygląd zwykłych Ziemian, dlatego ludzie są nieświadomi ich obecności. Kontrolę nad tym kosmicznym napływem sprawuje specjalna, ściśle tajna jednostka. Jej członkowie charakteryzują się tajemniczością i oczywiście czarnymi garniturami. Niestety na Ziemię dostał się ogromny robal z kosmosu, który wdział się w ludzką skórę. Will Smith i Tommy Lee Jones spróbują go się pozbyć.","popularity":12.6701,"poster_path":"/AqBPg45iakSohcSUQQH1OM7huqb.jpg","release_date":"1997-07-02","softcore":false,"video":false,"vote_average":7.222,"vote_count":14851,"credit_id":"52fe425dc3a36847f8018745","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/bvkPno6U02lLyvPWCnmibq4eIaN.jpg","genre_ids":[27],"id":609,"title":"Duch","original_language":"en","original_title":"Poltergeist","overview":"Szczęśliwa rodzina przeprowadza się do wymarzonego domu. Po pewnym czasie zaczynają dziać się niezwykłe rzeczy. Upiorne drzewo stojące za oknem próbuje zjeść chłopca, a mała dziewczynka oglądając telewizję zostaje porwana przez tytułowego ducha. Rodzice dziewczynki postanawiają wezwać na pomoc parapsychologów, którzy odkrywają, że ich dom stoi na starym indiańskim cmentarzu.","popularity":6.0631,"poster_path":"/9XPfrH8kbMs947bAtjXgjsIEg8C.jpg","release_date":"1982-06-04","softcore":false,"video":false,"vote_average":7.2,"vote_count":3324,"credit_id":"52fe425dc3a36847f801896d","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":"/bvkPno6U02lLyvPWCnmibq4eIaN.jpg","genre_ids":[27],"id":609,"title":"Duch","original_language":"en","original_title":"Poltergeist","overview":"Szczęśliwa rodzina przeprowadza się do wymarzonego domu. Po pewnym czasie zaczynają dziać się niezwykłe rzeczy. Upiorne drzewo stojące za oknem próbuje zjeść chłopca, a mała dziewczynka oglądając telewizję zostaje porwana przez tytułowego ducha. Rodzice dziewczynki postanawiają wezwać na pomoc parapsychologów, którzy odkrywają, że ich dom stoi na starym indiańskim cmentarzu.","popularity":6.0631,"poster_path":"/9XPfrH8kbMs947bAtjXgjsIEg8C.jpg","release_date":"1982-06-04","softcore":false,"video":false,"vote_average":7.2,"vote_count":3324,"credit_id":"52fe425dc3a36847f8018985","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/mXLVA0YL6tcXi6SJSuAh9ONXFj5.jpg","genre_ids":[12,878,10751],"id":601,"title":"E.T.","original_language":"en","original_title":"E.T. the Extra-Terrestrial","overview":"E.T. to historia wyjątkowej przyjaźni, która rozwija się między Elliottem, samotnym chłopcem żyjącym na jednym z kalifornijskich przedmieść, a mądrym przybyszem z obcej planety, który gubi się na Ziemi. Kiedy Elliott usiłuje pomóc przyjacielowi skontaktować się z jego planetą, obaj muszą unikać naukowców i agentów rządowych za wszelką cenę pragnących wykorzystać przybysza do swoich celów. Wszystko to prowadzi do wspaniałej przygody, większej od wszystkiego co mogli sobie wyobrazić.","popularity":12.1857,"poster_path":"/ihqmwPkVp5z6rwlEfC1eU45rfFH.jpg","release_date":"1982-06-11","softcore":false,"video":false,"vote_average":7.516,"vote_count":12012,"credit_id":"52fe425bc3a36847f8017ddd","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/titl6uMe5u974sLAA2Zy1kFi4sC.jpg","genre_ids":[18,28,36,53],"id":612,"title":"Monachium","original_language":"en","original_title":"Munich","overview":"Letnie Igrzyska Olimpijskie w Monachium z 1972 roku przeszły do historii nie ze względu na rekordy sportowe jakie tam padły, ale tragedię, która rozegrała się 5 września. Tego dnia członkowie palestyńskiej organizacji \"Czarny Wrzesień\" wdarli się na teren olimpijskiej wioski biorąc do niewoli 11 członków izraelskiej reprezentacji. 21 godzin później, w wyniku nieudolnej akcji antyterrorystycznej, zginęli wszyscy sportowcy i pięciu z ośmiu porywaczy. W swoim kolejnym filmie Steven Spielberg... powraca do tragicznych wydarzeń. Opowiada jednak nie tylko o dramatycznym losie izraelskich sportowców, ale głównie o wydarzeniach, jakie nastąpiły po terrorystycznym ataku.","popularity":4.8331,"poster_path":"/ezXrUUlDy1tEFhGmdmFkadUQcaP.jpg","release_date":"2005-12-23","softcore":false,"video":false,"vote_average":7.131,"vote_count":2998,"credit_id":"52fe425dc3a36847f8018a53","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/titl6uMe5u974sLAA2Zy1kFi4sC.jpg","genre_ids":[18,28,36,53],"id":612,"title":"Monachium","original_language":"en","original_title":"Munich","overview":"Letnie Igrzyska Olimpijskie w Monachium z 1972 roku przeszły do historii nie ze względu na rekordy sportowe jakie tam padły, ale tragedię, która rozegrała się 5 września. Tego dnia członkowie palestyńskiej organizacji \"Czarny Wrzesień\" wdarli się na teren olimpijskiej wioski biorąc do niewoli 11 członków izraelskiej reprezentacji. 21 godzin później, w wyniku nieudolnej akcji antyterrorystycznej, zginęli wszyscy sportowcy i pięciu z ośmiu porywaczy. W swoim kolejnym filmie Steven Spielberg... powraca do tragicznych wydarzeń. Opowiada jednak nie tylko o dramatycznym losie izraelskich sportowców, ale głównie o wydarzeniach, jakie nastąpiły po terrorystycznym ataku.","popularity":4.8331,"poster_path":"/ezXrUUlDy1tEFhGmdmFkadUQcaP.jpg","release_date":"2005-12-23","softcore":false,"video":false,"vote_average":7.131,"vote_count":2998,"credit_id":"52fe425dc3a36847f8018a5f","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/ggC3Brchf4RqPitEh7cROFoeAWn.jpg","genre_ids":[18,80],"id":640,"title":"Złap mnie, jeśli potrafisz","original_language":"en","original_title":"Catch Me If You Can","overview":"Frank W. Abagnale pracował jako lekarz, prawnik oraz pilot wielkiej linii lotniczej - wszystko to, zanim ukończył 21 lat. Był mistrzem oszustwa, a także błyskotliwym fałszerzem. Dzięki niezwykłym zdolnościom do podrabiania podpisów na czekach, zgromadził fortunę wartą miliony dolarów. Agent FBI Carl Hanratty postawił sobie za główny cel złapanie Franka i doprowadzenie go przed oblicze sprawiedliwości. Frank jednak zawsze jest o krok przed agentem, zostawiając przynętę, która sprawia, że kontynuuje on pościg.","popularity":14.5923,"poster_path":"/di4jwznxiu03bjGV1UvKR42v6we.jpg","release_date":"2002-12-16","softcore":false,"video":false,"vote_average":7.979,"vote_count":17121,"credit_id":"52fe4262c3a36847f801a5db","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/ggC3Brchf4RqPitEh7cROFoeAWn.jpg","genre_ids":[18,80],"id":640,"title":"Złap mnie, jeśli potrafisz","original_language":"en","original_title":"Catch Me If You Can","overview":"Frank W. Abagnale pracował jako lekarz, prawnik oraz pilot wielkiej linii lotniczej - wszystko to, zanim ukończył 21 lat. Był mistrzem oszustwa, a także błyskotliwym fałszerzem. Dzięki niezwykłym zdolnościom do podrabiania podpisów na czekach, zgromadził fortunę wartą miliony dolarów. Agent FBI Carl Hanratty postawił sobie za główny cel złapanie Franka i doprowadzenie go przed oblicze sprawiedliwości. Frank jednak zawsze jest o krok przed agentem, zostawiając przynętę, która sprawia, że kontynuuje on pościg.","popularity":14.5923,"poster_path":"/di4jwznxiu03bjGV1UvKR42v6we.jpg","release_date":"2002-12-16","softcore":false,"video":false,"vote_average":7.979,"vote_count":17121,"credit_id":"52fe4262c3a36847f801a5c3","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/n7p6UTAZtkeoHkwCO42BEQaMFJY.jpg","genre_ids":[18,878,12],"id":644,"title":"A.I. Sztuczna inteligencja","original_language":"en","original_title":"A.I. Artificial Intelligence","overview":"Kiedy prototypowy robot-dziecko o imieniu David (Haley Joel Osment) zostaje zaprogramowany, by kochać, jego ludzcy rodzice nie są na to przygotowani. Porzucony w obcym i wrogim świecie David zaprzyjaźnia się ze sprytnym robotem (Jude Law) i wyrusza w spektakularną podróż, dzięki której może odkryć prawdę o sobie samym.","popularity":7.4615,"poster_path":"/btYv6NH5m4akzp0cKrpovhp1K9V.jpg","release_date":"2001-06-29","softcore":false,"video":false,"vote_average":7.057,"vote_count":6669,"credit_id":"52fe4263c3a36847f801a96b","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/n7p6UTAZtkeoHkwCO42BEQaMFJY.jpg","genre_ids":[18,878,12],"id":644,"title":"A.I. Sztuczna inteligencja","original_language":"en","original_title":"A.I. Artificial Intelligence","overview":"Kiedy prototypowy robot-dziecko o imieniu David (Haley Joel Osment) zostaje zaprogramowany, by kochać, jego ludzcy rodzice nie są na to przygotowani. Porzucony w obcym i wrogim świecie David zaprzyjaźnia się ze sprytnym robotem (Jude Law) i wyrusza w spektakularną podróż, dzięki której może odkryć prawdę o sobie samym.","popularity":7.4615,"poster_path":"/btYv6NH5m4akzp0cKrpovhp1K9V.jpg","release_date":"2001-06-29","softcore":false,"video":false,"vote_average":7.057,"vote_count":6669,"credit_id":"52fe4263c3a36847f801a977","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":"/n7p6UTAZtkeoHkwCO42BEQaMFJY.jpg","genre_ids":[18,878,12],"id":644,"title":"A.I. Sztuczna inteligencja","original_language":"en","original_title":"A.I. Artificial Intelligence","overview":"Kiedy prototypowy robot-dziecko o imieniu David (Haley Joel Osment) zostaje zaprogramowany, by kochać, jego ludzcy rodzice nie są na to przygotowani. Porzucony w obcym i wrogim świecie David zaprzyjaźnia się ze sprytnym robotem (Jude Law) i wyrusza w spektakularną podróż, dzięki której może odkryć prawdę o sobie samym.","popularity":7.4615,"poster_path":"/btYv6NH5m4akzp0cKrpovhp1K9V.jpg","release_date":"2001-06-29","softcore":false,"video":false,"vote_average":7.057,"vote_count":6669,"credit_id":"52fe4263c3a36847f801a98f","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/zrqHFQrF2HngVcEFRtW6sf1nIBD.jpg","genre_ids":[28,12,37],"id":1656,"title":"Legenda Zorro","original_language":"en","original_title":"The Legend of Zorro","overview":"Don Alejandro de la Vega prowadzi spokojne życie, ma dziesięcioletniego syna, Joaquina. Nadal jako zamaskowany jeździec – Zorro, spieszy na pomoc biednym i uciśnionym, ale dużo czasu poświęca też spokojnemu życiu rodzinnemu. Jest rok 1851 – trwają przygotowania do wejścia Kalifornii w skład USA jako 31. stanu. Don Alejandro odkrywa intrygę chciwych biznesmenów i polityków działających w tajnym stowarzyszeniu Rycerzy Aragonii, mających zamiar storpedować ten proces. Elena stawia męża przed wyborem: życie rodzinne albo czynienie sprawiedliwości. Gdy Alejandro łamie dane jej słowo i znowu zakłada maskę, Elena występuje o rozwód. Zorro krzyżuje plany bogaczy, lecz grozi mu rozpad rodziny","popularity":5.1999,"poster_path":"/v38m7Q69lHHD0ZsRrpQqw8hiIm5.jpg","release_date":"2005-10-24","softcore":false,"video":false,"vote_average":6.125,"vote_count":3088,"credit_id":"52fe4309c3a36847f8035b27","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/5oCAo7LFj2x0yByfi5JYirGnK8I.jpg","genre_ids":[28,12,18],"id":664,"title":"Twister","original_language":"en","original_title":"Twister","overview":"Farma rozpada się niczym domek z kart. Przerażone zwierzęta wirują w powietrzu. Traktory spadają z nieba jak krople deszczu. Gigantyczny zbiornika na benzynę zmienia się w śmiercionośną bombę. Zbliża się tornado, żywioł zmiatający z powierzchni ziemi wszystko, co napotka na swej drodze.\r \"Twister\" to porywający film przygodowy z rewelacyjnymi efektami specjalnymi oraz Helen Hunt i Billem Paxtonem w rolach naukowców, którzy ruszają w pościg za najgroźniejszym tornadem w historii Ameryki. Chcą umieścić w jego wnętrzu elektroniczne czujniki, a uzyskane dzięki nim dane wykorzystać do opracowania systemu wczesnego ostrzegania przed zbliżającym się huraganem. Aby tego dokonać, muszą stanąć oko w oko z cyklonem. Rozpoczyna się gra o wysoką stawkę.","popularity":6.8147,"poster_path":"/jJ8X4WPt5fJ0oOYBTXLbEF11vbq.jpg","release_date":"1996-05-10","softcore":false,"video":false,"vote_average":6.56,"vote_count":3851,"credit_id":"52fe4266c3a36847f801b8db","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/wcTDxW9JEr9cORajaQLrv8ls9Ly.jpg","genre_ids":[12,878,28],"id":1858,"title":"Transformers","original_language":"en","original_title":"Transformers","overview":"Sam Witwicky jest zwykłym licealistą, mającym swoje życie i problemy. Nie ma jednak pojęcia, jak bardzo się odmieni jego życie, gdy pewnego dnia zakupi starego Chevroleta Camaro. Pewnej nocy Sam odkrywa, że jego samochód tak naprawdę jest supernowoczesnym, zmiennokształtnym robotem, zaś na Ziemię przebywają Transformery – pochodzące z planety Cybertron żywe maszyny, które są w trakcie wojny domowej. Dwie frakcje tej niezwykłej rasy, Autoboty i Decepticony, szukają zaginionego przed wiekami źródła mocy o niezgłębionych możliwościach - Wszechiskry zwanej też \"Kością\". Transformery wierzą, że ci, którzy ją zdobędą, będą mogli wygrać wojnę, zaś kluczem do odnalezienia artefaktu jest przedmiot znajdujący się od pokoleń w posiadaniu rodziny Sama. Rozpoczyna się nowy etap wojny Transformerów, w którym Ziemia stała się polem bitwy, na którym nigdy nie wiadomo, gdzie czai się wróg...","popularity":5.1364,"poster_path":"/3qDIoKQMW8usA0VHsNTuKHxwNuK.jpg","release_date":"2007-06-27","softcore":false,"video":false,"vote_average":6.831,"vote_count":12222,"credit_id":"52fe431bc3a36847f803aba9","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/yBCekmb7vK70xUhtsRQBcTu65sB.jpg","genre_ids":[878,18],"id":840,"title":"Bliskie spotkania trzeciego stopnia","original_language":"en","original_title":"Close Encounters of the Third Kind","overview":"W grudniu 1945 roku w pobliżu Trójkąta Bermudzkiego ginie bez śladu kilka bombowców amerykańskich. Ponad 30 lat później odnajdują się, brakuje jednak ciał pilotów. Tymczasem Ron Neary, pracownik elektrowni, ma znaleźć przyczynę zakłóceń energetycznych w stanie Indiana. Na miejscu Roy dostrzega na niebie kosmiczny pojazd. Zjawisko to również obserwuje Jillian Guiler. Wkrótce nowina o UFO dociera do wszystkich mieszkańców okolicy.","popularity":9.5504,"poster_path":"/j84nJzOU5Wleb6tz5ibi8R5JlnG.jpg","release_date":"1977-12-14","softcore":false,"video":false,"vote_average":7.353,"vote_count":4647,"credit_id":"52fe427fc3a36847f80234f7","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":"/yBCekmb7vK70xUhtsRQBcTu65sB.jpg","genre_ids":[878,18],"id":840,"title":"Bliskie spotkania trzeciego stopnia","original_language":"en","original_title":"Close Encounters of the Third Kind","overview":"W grudniu 1945 roku w pobliżu Trójkąta Bermudzkiego ginie bez śladu kilka bombowców amerykańskich. Ponad 30 lat później odnajdują się, brakuje jednak ciał pilotów. Tymczasem Ron Neary, pracownik elektrowni, ma znaleźć przyczynę zakłóceń energetycznych w stanie Indiana. Na miejscu Roy dostrzega na niebie kosmiczny pojazd. Zjawisko to również obserwuje Jillian Guiler. Wkrótce nowina o UFO dociera do wszystkich mieszkańców okolicy.","popularity":9.5504,"poster_path":"/j84nJzOU5Wleb6tz5ibi8R5JlnG.jpg","release_date":"1977-12-14","softcore":false,"video":false,"vote_average":7.353,"vote_count":4647,"credit_id":"52fe427ec3a36847f8023453","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/AoGLKkPvBcZP27jwSA85fY8emvJ.jpg","genre_ids":[28,53,10770],"id":839,"title":"Pojedynek na Szosie","original_language":"en","original_title":"Duel","overview":"Komiwojażer David Mann (Dennis Weaver) przemierza samotnie wynajętym samochodem szosy na pustkowiach. W pewnym momencie spostrzega w lusterku podążającą za nim ciężarówkę-cysternę. Mann zaczyna przyspieszać, mimo to nie udaje mu się zbyt oddalić od kolosa. Przeciwnie, z każdą chwilą jego przeciwnik jest coraz bliżej. Mann czuje jego oddech na plecach. Rozpoczyna się wyścig na śmierć i życie.","popularity":5.3654,"poster_path":"/gpK4vSIjaGAkR752O0CbHGbRgpk.jpg","release_date":"1971-12-25","softcore":false,"video":false,"vote_average":7.414,"vote_count":2061,"credit_id":"52fe427ec3a36847f8023361","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/8UpJ8svNnwVtpu8n62vGke8MOJf.jpg","genre_ids":[16,10751,37,12,35],"id":10380,"title":"Amerykańska opowieść. Feiwel rusza na Zachód","original_language":"en","original_title":"An American Tail: Fievel Goes West","overview":"Fiewel rusza na Zachód to wyprodukowana przez Stevena Spielberga kontynuacja przygód dzielnej małej myszki, która zdobyła serca widzów w filmie Amerykańska Opowieść. Fiewel ulega namowom obrotnego kota i wraz z rodziną udaje się na Dziki Zachód. Aby zapobiec zdradzieckim planom oszusta, który chce z mysich osadników zrobić \"myszoburgery\", Fiewel musi zmobilizować do pomocy słynnego psiego strażnika sprawiedliwości. Pełen radości i muzyki animowany film ucieszy dzieci i rodziców.","popularity":2.462,"poster_path":"/k4aLupAkHWwHiEDwvqsZFAnUYF.jpg","release_date":"1991-11-21","softcore":false,"video":false,"vote_average":6.335,"vote_count":790,"credit_id":"52fe43639251416c7500e6bd","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/udIE8Cdon9wnYmVIOFYrBPfA2Mq.jpg","genre_ids":[14,16,35,80],"id":856,"title":"Kto wrobił Królika Rogera","original_language":"en","original_title":"Who Framed Roger Rabbit","overview":"Lata 40., przedmieścia Holywood. Po sąsiedzku z aktorami w Toon Town mieszkają rysunkowe postacie. Pewnego dnia zostaje zamordowany szef studia filmowego \"Maroon Cartoons\". Podejrzany staje się Królik Roger. Według policji chciał się on zemścić na producencie, który romansował z jego seksowną żoną, Jessicą. Roger prosi o pomoc detektywa Eddiego Valianta. Razem wpadają na trop intrygi, która może zniszczyć cały rysunkowy świat.","popularity":5.9473,"poster_path":"/pMMK2iUsHT7mdxDxng3GKd3dLFj.jpg","release_date":"1988-06-22","softcore":false,"video":false,"vote_average":7.54,"vote_count":6183,"credit_id":"52fe4282c3a36847f80249d3","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/bdD39MpSVhKjxarTxLSfX6baoMP.jpg","genre_ids":[10752,18,36],"id":857,"title":"Szeregowiec Ryan","original_language":"en","original_title":"Saving Private Ryan","overview":"Czerwiec 1944 roku, właśnie ruszył tzw. drugi front w Europie. Lądujący na plaży Omaha w Normandii oddział Rangersów kapitana Millera zostaje zdziesiątkowany. Z ocalałych żołnierzy, Miller wybiera kilku do niebezpiecznej misji. Otrzymuje rozkaz przeniknięcia za linię frontu i odnalezienia szeregowca Jamesa Ryan'a, jednego z tysięcy spadochroniarzy zrzuconych w noc poprzedzającą lądowanie aliantów na tyłach niemieckiej obrony. Dowództwo traktuje akcję prestiżowo. Trzej bracia Ryana, zginęli w walce i nie można dopuścić, aby matka straciła ostatniego syna. Miller ma odnaleźć i uratować Ryana nawet za cenę śmierci swoich ludzi...","popularity":15.7081,"poster_path":"/9GNCKzU8vUUMgexZ5npv08mPzKr.jpg","release_date":"1998-07-24","softcore":false,"video":false,"vote_average":8.226,"vote_count":17262,"credit_id":"52fe4283c3a36847f8024ac1","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/bdD39MpSVhKjxarTxLSfX6baoMP.jpg","genre_ids":[10752,18,36],"id":857,"title":"Szeregowiec Ryan","original_language":"en","original_title":"Saving Private Ryan","overview":"Czerwiec 1944 roku, właśnie ruszył tzw. drugi front w Europie. Lądujący na plaży Omaha w Normandii oddział Rangersów kapitana Millera zostaje zdziesiątkowany. Z ocalałych żołnierzy, Miller wybiera kilku do niebezpiecznej misji. Otrzymuje rozkaz przeniknięcia za linię frontu i odnalezienia szeregowca Jamesa Ryan'a, jednego z tysięcy spadochroniarzy zrzuconych w noc poprzedzającą lądowanie aliantów na tyłach niemieckiej obrony. Dowództwo traktuje akcję prestiżowo. Trzej bracia Ryana, zginęli w walce i nie można dopuścić, aby matka straciła ostatniego syna. Miller ma odnaleźć i uratować Ryana nawet za cenę śmierci swoich ludzi...","popularity":15.7081,"poster_path":"/9GNCKzU8vUUMgexZ5npv08mPzKr.jpg","release_date":"1998-07-24","softcore":false,"video":false,"vote_average":8.226,"vote_count":17262,"credit_id":"52fe4283c3a36847f8024abb","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/zJDnqXtGNHUmexiaWNa52Vslve5.jpg","genre_ids":[18,10749,36],"id":1904,"title":"Wyznania gejszy","original_language":"en","original_title":"Memoirs of a Geisha","overview":"Japonia, 1929 r. 9-letnia Chiyo i jej siostra zostają sprzedane do Gion, rozrywkowej dzielnicy Kioto. Młodsza z sióstr trafia do okiya - domu gejsz, w którym ma służyć dorosłym gejszom. Najpopularniejszą z nich jest piękna i okrutna Hatsumomo, której intrygi pozbawiają Chiyo szansy na naukę. Pewnego dnia dziewczynka spotyka tajemniczego Prezesa. Od tej chwili sensem jej życia staje się pragnienie spotkania go jeszcze raz. Ponieważ Prezes jest znawcą urody gejsz, jest tylko jeden sposób, aby się do niego zbliżyć.","popularity":4.1609,"poster_path":"/qACVuSot5efPU5HhAa7NXvQgeG3.jpg","release_date":"2005-12-06","softcore":false,"video":false,"vote_average":7.64,"vote_count":3395,"credit_id":"52fe4320c3a36847f803c44b","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/lh6MbyxwCribn3hdAo81xLdPGoV.jpg","genre_ids":[18,36],"id":873,"title":"Kolor purpury","original_language":"en","original_title":"The Color Purple","overview":"Dwie czarnoskóre siostry, 14-letnia Celie i młodsza Nettie (Akosua Busia), żyją w patologicznej relacji z ojcem, Alphonso Harrisem. Drogi ich rozchodzą się w momencie, kiedy Celie wyjeżdża z przyszłym mężem Albertem. Po 14 latach siostry się spotykają. Celie nie jest szczęśliwa w małżeństwie, ma dość cierpień oraz upokorzeń ze strony agresywnego męża, dlatego decyduje się od niego odejść.","popularity":4.4804,"poster_path":"/n3MkvpcTHEC42kaEklKZIbAubof.jpg","release_date":"1985-12-18","softcore":false,"video":false,"vote_average":7.726,"vote_count":1977,"credit_id":"52fe4285c3a36847f80257bf","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/lh6MbyxwCribn3hdAo81xLdPGoV.jpg","genre_ids":[18,36],"id":873,"title":"Kolor purpury","original_language":"en","original_title":"The Color Purple","overview":"Dwie czarnoskóre siostry, 14-letnia Celie i młodsza Nettie (Akosua Busia), żyją w patologicznej relacji z ojcem, Alphonso Harrisem. Drogi ich rozchodzą się w momencie, kiedy Celie wyjeżdża z przyszłym mężem Albertem. Po 14 latach siostry się spotykają. Celie nie jest szczęśliwa w małżeństwie, ma dość cierpień oraz upokorzeń ze strony agresywnego męża, dlatego decyduje się od niego odejść.","popularity":4.4804,"poster_path":"/n3MkvpcTHEC42kaEklKZIbAubof.jpg","release_date":"1985-12-18","softcore":false,"video":false,"vote_average":7.726,"vote_count":1977,"credit_id":"52fe4285c3a36847f80257ad","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/39OxcFZjX4uc6vYzexUh5qXghxE.jpg","genre_ids":[12,14,35,10751],"id":879,"title":"Hook","original_language":"en","original_title":"Hook","overview":"40-letni Peter Banning bardzo kocha swoją żonę Moirę i dzieci, jednak jest tak zapracowany, że zaniedbuje obowiązki męża i ojca. Nagle, w tajemniczych okolicznościach zostają uprowadzone jego dzieci, Jack i Maggie. Zrozpaczonego Petera odwiedza... wróżka Dzwoneczek, która przekonuje go, że jako chłopiec był samym Piotrusiem Panem, a jego dzieci z zemsty porwał okrutny kapitan Hak.","popularity":7.5606,"poster_path":"/aaWAqK0oIALI9bWHeIdjSJy8hnt.jpg","release_date":"1991-04-10","softcore":false,"video":false,"vote_average":6.844,"vote_count":5735,"credit_id":"52fe4286c3a36847f8025c0d","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/4byUSbNrjqCSjqVYrJU6AxqyZYr.jpg","genre_ids":[14,35,10751],"id":888,"title":"Flintstonowie","original_language":"en","original_title":"The Flintstones","overview":"Flintstonowie i Rubble'owie to nowoczesne rodziny z epoki kamienia łupanego. Fred (John Goodman) i Barney (Rick Moranis) pracują w Slate and Company wysadzając skały. Fred pożycza Barney'owi pieniądze na adopcję dziecka. Gdy obaj przystępują do testu decydującego, kto powinien zostać nowym wiceprezesem firmy, Barney odwdzięcza się Fredowi odpowiedziami na pytania testowe. Fred dostaje się na wymarzone stanowisko, ale uświadamia sobie, że ulega manipulacjom Cliffa Vandercave'a (Kyle MacLachlan).","popularity":6.6108,"poster_path":"/o8XeT7IYpT9uG8CO8fNWN2P9mSR.jpg","release_date":"1994-05-27","softcore":false,"video":false,"vote_average":5.4,"vote_count":2620,"credit_id":"52fe4287c3a36847f80262f5","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/5UX6M0aEphiW6Xmy5rpYX75glbo.jpg","genre_ids":[14,27,35],"id":927,"title":"Gremliny rozrabiają","original_language":"en","original_title":"Gremlins","overview":"Trzymaj go z dala od wody. Chroń przed jasnym światłem. I najważniejsze! Żeby nie wiem jak płakał, żeby nie wiem jak błagał, nigdy, przenigdy nie karm go po północy. Tych oto instrukcji musi przestrzegać Billy Peltzer, gdy dostaje w prezencie urocze, kudłate stworzonko. Billy nie przypuszcza nawet, że już wkrótce czeka go nie lada niespodzianka.  \"Gremliny\" to horror w konwencji komedii z wytwórni Stevena Spielberga, który rozbawi cię do łez, a zaraz potem przestraszy nie na żarty.","popularity":7.7736,"poster_path":"/nYRCYOXIRQYQt9SZakLuI6d21SJ.jpg","release_date":"1984-06-08","softcore":false,"video":false,"vote_average":7.142,"vote_count":6983,"credit_id":"52fe428ec3a36847f8027f59","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/xt7boIC763DdceVQIGJdnmKlDVu.jpg","genre_ids":[18,36,10752],"id":10110,"title":"Imperium Słońca","original_language":"en","original_title":"Empire of the Sun","overview":"Trwa II Wojna Światowa. Lata 40-te ówczesnych Chin podczas napadu Japończyków na jedno z miast - Szanghaj. Jim Graham (Bale), syn arystokratycznej rodziny, wychowywany w domu pełnym luksusów, nieoczekiwanie zostaje rozdzielony z rodzicami. Rozpieszczony, przyzwyczajony do dobrobytu chłopak, musi zrobić wszystko, by przetrwać bez środków do życia. Zdany zupełnie na siebie, trafia do obozu dla internowanych. Wówczas spotyka na swojej drodze Basiego (Malkovich), który uczy go samodzielności. Dwunastolatek stara się przyzwyczaić do nowych, panujących tam warunków. Chociaż wojna zniszczyła dotychczasowe życie Jima, sprawiła również, że zaczął dorastać naprawdę.","popularity":3.6235,"poster_path":"/jAoeNTiIeWiOEtSzZjgeTIbThVA.jpg","release_date":"1987-12-09","softcore":false,"video":false,"vote_average":7.507,"vote_count":2128,"credit_id":"52fe43299251416c75005cb3","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/iR3tV8NXFls4UKzPA60D4zrI7Jh.jpg","genre_ids":[35,27,14],"id":928,"title":"Gremliny 2","original_language":"en","original_title":"Gremlins 2: The New Batch","overview":"Po przeprowadzce do Nowego Jorku Billy (Zach Galligan) i Kate (Phoebe Cates) podejmują pracę w należącym do milionera Daniela Clampa (John Glover) drapaczu chmur na Manhattanie. W jednym z pomieszczeń odkrywają tajne laboratorium doktora Cathetera (Christopher Lee), w którym przeprowadzane są badania nad nowym pokoleniem gremlinów. W wyniku doświadczeń stworki stają się jeszcze bardziej złośliwe od swoich poprzedników. Billy i Kate postanawiają je powstrzymać.","popularity":4.6343,"poster_path":"/hvPsOshW1d6cUVLvTm6NKs4QIj1.jpg","release_date":"1990-06-15","softcore":false,"video":false,"vote_average":6.526,"vote_count":2899,"credit_id":"52fe428ec3a36847f8028059","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/xt7boIC763DdceVQIGJdnmKlDVu.jpg","genre_ids":[18,36,10752],"id":10110,"title":"Imperium Słońca","original_language":"en","original_title":"Empire of the Sun","overview":"Trwa II Wojna Światowa. Lata 40-te ówczesnych Chin podczas napadu Japończyków na jedno z miast - Szanghaj. Jim Graham (Bale), syn arystokratycznej rodziny, wychowywany w domu pełnym luksusów, nieoczekiwanie zostaje rozdzielony z rodzicami. Rozpieszczony, przyzwyczajony do dobrobytu chłopak, musi zrobić wszystko, by przetrwać bez środków do życia. Zdany zupełnie na siebie, trafia do obozu dla internowanych. Wówczas spotyka na swojej drodze Basiego (Malkovich), który uczy go samodzielności. Dwunastolatek stara się przyzwyczaić do nowych, panujących tam warunków. Chociaż wojna zniszczyła dotychczasowe życie Jima, sprawiła również, że zaczął dorastać naprawdę.","popularity":3.6235,"poster_path":"/jAoeNTiIeWiOEtSzZjgeTIbThVA.jpg","release_date":"1987-12-09","softcore":false,"video":false,"vote_average":7.507,"vote_count":2128,"credit_id":"52fe43299251416c75005c95","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/2C2kUFxhs5u2G9xeg4KQ0FZvFFA.jpg","genre_ids":[35,10749],"id":10466,"title":"Skarbonka","original_language":"en","original_title":"The Money Pit","overview":"Sytuacja finansowa Waltera i Anny jest trudna. Na domiar złego - zostają bez dachu nad głową. Za pożyczone pieniądze kupują piękną willę na przedmieściach. Wkrótce odkrywają, że ich nowy dom to całkowita ruina. Silne uczucie i poczucie humoru pomogą parze pokonać mnożące się problemy, nie tylko te związane z remontem...","popularity":2.8059,"poster_path":"/lOoOo3jRmmi9pbT0FuthCbOPOVM.jpg","release_date":"1986-03-26","softcore":false,"video":false,"vote_average":6.511,"vote_count":1236,"credit_id":"52fe43759251416c7501128d","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":null,"genre_ids":[99,28,10752,36],"id":5707,"title":"Shooting War","original_language":"en","original_title":"Shooting War","overview":"","popularity":2.0289,"poster_path":"/81XtyZfL5WFPJXVLUUQP9PQP6Hl.jpg","release_date":"2000-12-07","softcore":false,"video":false,"vote_average":6.389,"vote_count":9,"credit_id":"52fe4419c3a36847f8082503","department":"Editing","job":"Editor"},{"adult":false,"backdrop_path":"/vscsDExaKK0oKqrYBze9Tm2oitf.jpg","genre_ids":[10752,18,36],"id":3683,"title":"Sztandar Chwały","original_language":"en","original_title":"Flags of Our Fathers","overview":"Jedno z najsłynniejszych wojennych zdjęć wykonanych przez fotografa Joego Rosenthala prezentuje sześciu marines, którzy po zwycięskiej bitwie o wyspę Iwo Jimę zatykają amerykańską flagę na górze Suribachi. Film przedstawia prawdziwą historię żołnierzy, konfrontując ich bohaterstwo i rzeczywiste wydarzenia jednej z najkrwawszych bitew drugiej wojny światowej z propagandą uprawianą przez amerykański rząd.","popularity":3.6723,"poster_path":"/z5SuCPbVgkXv3LATtFZFAcp70W6.jpg","release_date":"2006-10-19","softcore":false,"video":false,"vote_average":6.853,"vote_count":2020,"credit_id":"52fe43a2c3a36847f8063791","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/WRgAzhlujb9BRnSj97TZVMIvpz.jpg","genre_ids":[12,16,35,18,10751],"id":4978,"title":"Amerykańska opowieść","original_language":"en","original_title":"An American Tail","overview":"Fievel jest młodą rosyjską myszką. Oddzielił się od rodziców podczas podróży do Ameryki, czyli krainy, o której myszki z Europy bardzo marzą, gdyż krąży opinia, że nie ma tam kotów. Kiedy sam trafia do nowego, wielkiego świata ma nadzieję, że odnajdzie rodzinę. Zawiera nowe przyjaźnie, bawi się, a czasmi ucieka przed kotami, których się tu nie spodziewał.","popularity":3.9937,"poster_path":"/rHArmWv0j5X1X9E7Oou0D6d66Ap.jpg","release_date":"1986-11-21","softcore":false,"video":false,"vote_average":6.759,"vote_count":1456,"credit_id":"52fe43eac3a36847f8078227","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/cssKLoKClpgqaaGD2z3cjXgzPSM.jpg","genre_ids":[80,18,35],"id":5121,"title":"Sugarland Express","original_language":"en","original_title":"The Sugarland Express","overview":"Lou Jean Poplin i jej odsiadujący wyrok mąż zostali pozbawieni praw rodzicielskich. Ich synek mieszka z nową rodziną w miasteczku Sugarland. Rodzice, zatrzymując policjanta jako zakładnika, ruszają radiowozem w długą drogę po swoje dziecko, żądając jego wydania.","popularity":1.4345,"poster_path":"/xcdD3uzcq6JCnYtQ3Q28P7dLPmW.jpg","release_date":"1974-03-31","softcore":false,"video":false,"vote_average":6.606,"vote_count":458,"credit_id":"52fe43f4c3a36847f807a4b3","department":"Writing","job":"Story"},{"adult":false,"backdrop_path":"/cssKLoKClpgqaaGD2z3cjXgzPSM.jpg","genre_ids":[80,18,35],"id":5121,"title":"Sugarland Express","original_language":"en","original_title":"The Sugarland Express","overview":"Lou Jean Poplin i jej odsiadujący wyrok mąż zostali pozbawieni praw rodzicielskich. Ich synek mieszka z nową rodziną w miasteczku Sugarland. Rodzice, zatrzymując policjanta jako zakładnika, ruszają radiowozem w długą drogę po swoje dziecko, żądając jego wydania.","popularity":1.4345,"poster_path":"/xcdD3uzcq6JCnYtQ3Q28P7dLPmW.jpg","release_date":"1974-03-31","softcore":false,"video":false,"vote_average":6.606,"vote_count":458,"credit_id":"52fe43f4c3a36847f807a475","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/pIb1CLl08DxciZXJr7AK4qmkArA.jpg","genre_ids":[10749,14,18],"id":11352,"title":"Na zawsze","original_language":"en","original_title":"Always","overview":"Pete (Richard Dreyfuss) jest cywilnym pilotem uczestniczącym w akcjach gaszenia pożarów. Pewnego dnia, podczas jednej z takich akcji jego samolot ulega katastrofie. Pete ginie, ale powraca na ziemię jako duch, aby być w pobliżu swojej ukochanej Dorindy (Holly Hunter).","popularity":2.8902,"poster_path":"/wh0WItAFrw3m66mDMlCCuXQwfMW.jpg","release_date":"1989-12-22","softcore":false,"video":false,"vote_average":6.237,"vote_count":663,"credit_id":"52fe442c9251416c7502b56f","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/pIb1CLl08DxciZXJr7AK4qmkArA.jpg","genre_ids":[10749,14,18],"id":11352,"title":"Na zawsze","original_language":"en","original_title":"Always","overview":"Pete (Richard Dreyfuss) jest cywilnym pilotem uczestniczącym w akcjach gaszenia pożarów. Pewnego dnia, podczas jednej z takich akcji jego samolot ulega katastrofie. Pete ginie, ale powraca na ziemię jako duch, aby być w pobliżu swojej ukochanej Dorindy (Holly Hunter).","popularity":2.8902,"poster_path":"/wh0WItAFrw3m66mDMlCCuXQwfMW.jpg","release_date":"1989-12-22","softcore":false,"video":false,"vote_average":6.237,"vote_count":663,"credit_id":"52fe442c9251416c7502b551","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/wtJIV3BI3FbCJ2wKJCb9KngdEv2.jpg","genre_ids":[35,10752,28],"id":11519,"title":"1941","original_language":"en","original_title":"1941","overview":"Absolutnie zwariowana komedia wyreżyserowana przez Stevena Spielberga i nominowana do trzech nagród Akademii. Pełna niezapomnianych momentów komiczna farsa w gwiazdorskiej obsadzie, której akcja rozgrywa się w Los Angeles kilka dni po ataku na Pearl Harbor, kiedy to strach przed japońską inwazją wpędza miasto w stan permanentnej paranoi. Obraz szaleństwa panującego na hollywoodzkim bulwarze dopełnia cała menażeria zwariowanych postaci, takich jak obłąkani kombatanci, fanatyczni właściciele sklepów, grupa zapłakanych panien i skłóconych za sobą nazistów. Wszyscy oni staną się częścią tego intrygującego filmowego galimatiasu, w którym znajdzie się miejsce nawet dla autoparodii spielbergowskich \"Szczęk\".","popularity":3.1497,"poster_path":"/tXFj7PHkWD4vr6YA1jURwM0AhNq.jpg","release_date":"1979-12-14","softcore":false,"video":false,"vote_average":5.8,"vote_count":684,"credit_id":"52fe44509251416c750306d3","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/CTcfWsVAw524RZwIqb1DhokhRU.jpg","genre_ids":[35,27],"id":6488,"title":"Arachnofobia","original_language":"en","original_title":"Arachnophobia","overview":"Podczas wyprawy do wenezuelskiej dżungli jeden z jej uczestników zostaje ugryziony prze nieznany gatunek pająka i ginie. Jego ciało zostaje przewiezione do małego amerykańskiego miasteczka skąd pochodził. Niestety wraz z ciałem przybywa pająk, który go zabił. Kilka dni później dochodzi do jego krzyżówki z normalnymi domowymi pająkami, czego efektem jest plaga zabójczych pająków, których celem stają się mieszkańcy miasteczka.","popularity":3.497,"poster_path":"/lHjpwv1Yv2RcGcTQb4Lc1cKw1y9.jpg","release_date":"1990-07-20","softcore":false,"video":false,"vote_average":6.449,"vote_count":1523,"credit_id":"52fe4455c3a36847f808fe5f","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/AdSU7O4KhqqZuYadNAdWSEROSNg.jpg","genre_ids":[10751,35,14,878],"id":11548,"title":"Bez baterii nie działa","original_language":"en","original_title":"*batteries not included","overview":"Grupa lokatorów pewnego bloku dowiaduje się, że ma on zostać zburzony. Dlatego muszą się wyprowadzić. Ale wcale nie jest im to na rękę. Właściciel postanawia pozbyć się ich za wszelką cenę, wynajmuje więc lokalny gang, który ma przekonać nastolatków do opuszczenia mieszkania. I gdy sytuacja wydaje się beznadziejna pojawiają się w ich mieście kosmici, którzy zaprzyjaźniają się z bohaterami filmu. Postanawiają oni im pomóc wykorzystując do tego celu swoje niezwykłe umiejętności.","popularity":3.041,"poster_path":"/pndZqs5sG6WGq95IMLI8U1PCJeD.jpg","release_date":"1987-12-18","softcore":false,"video":false,"vote_average":6.708,"vote_count":797,"credit_id":"52fe44579251416c7503151d","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/AmTrqk910ot3aYLBGyIG78Xfa18.jpg","genre_ids":[18,36,9648],"id":11831,"title":"Amistad","original_language":"en","original_title":"Amistad","overview":"Film historyczny nawiązujący do wydarzeń autentycznych. Latem 1839 roku grupa czarnych niewolników transportowanych z Afryki do Ameryki urządza bunt pod pokładem statku. Próbują wrócić do swego macierzystego kraju, jednakże zostają przejęci przez Amerykańską straż przybrzeżną. Władze stawiają ich przed sądem.","popularity":1.0212,"poster_path":"/oGHjfTBDuMpNAKOMtqnEQxfYwu0.jpg","release_date":"1997-12-10","softcore":false,"video":false,"vote_average":7.013,"vote_count":1418,"credit_id":"52fe448e9251416c75038f15","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/AmTrqk910ot3aYLBGyIG78Xfa18.jpg","genre_ids":[18,36,9648],"id":11831,"title":"Amistad","original_language":"en","original_title":"Amistad","overview":"Film historyczny nawiązujący do wydarzeń autentycznych. Latem 1839 roku grupa czarnych niewolników transportowanych z Afryki do Ameryki urządza bunt pod pokładem statku. Próbują wrócić do swego macierzystego kraju, jednakże zostają przejęci przez Amerykańską straż przybrzeżną. Władze stawiają ich przed sądem.","popularity":1.0212,"poster_path":"/oGHjfTBDuMpNAKOMtqnEQxfYwu0.jpg","release_date":"1997-12-10","softcore":false,"video":false,"vote_average":7.013,"vote_count":1418,"credit_id":"52fe448e9251416c75038f27","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/depMebS7tRuR8ebxghxdkIlnX3s.jpg","genre_ids":[9648,12,53],"id":11904,"title":"Piramida strachu","original_language":"en","original_title":"Young Sherlock Holmes","overview":"Jak by to było, gdyby Sherlock Holmes i dr Watson spotkali się w wieku szkolnym? No cóż, odpowiedź jest prosta - to byłaby wspaniała przygoda! I właśnie to oferuje reżyser Barry Levinson (\"Diner\", \"Rain Man\", \"Włamanie na śniadanie\") w swej naładowanej efektami opowieści o pierwszej zagadce rozwiązanej przez super detektywa! Kiedy plaga zagadkowych morderstw spada na Londyn, młody Holmes i jego świeżo poznany przyjaciel Watson bezwiednie stają na progu mrocznej tajemnicy. I \"zaczyna się gra\"! A przyszły detektyw rozwiązuje najbardziej niesamowitą sprawę w swej niezwykłej karierze!","popularity":1.8052,"poster_path":"/5U7wlilPKXS7FsXa8baPPrTQE4u.jpg","release_date":"1985-12-04","softcore":false,"video":false,"vote_average":6.744,"vote_count":712,"credit_id":"52fe449e9251416c7503b1ff","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/bH1bhjn37uA1zOPvyHbzJSvza7v.jpg","genre_ids":[878,28,12],"id":8373,"title":"Transformers. Zemsta upadłych","original_language":"en","original_title":"Transformers: Revenge of the Fallen","overview":"Kolejna część wspaniałej, kultowej już opowieści o maszynach. Minęły dwa lata od czasu kiedy młody Sam Witwicky (Shia LaBeouf) dokonał ocalenia Ziemi przed decydującym starciem pomiędzy dwoma wojującymi ze sobą grupami robotów. Pomimo swoich precyzyjnie określonych planów, Sam po raz kolejny znajduje się w centrum śmiertelnej rozgrywki pomiędzy Autobotami i Deceptikonami, od której zależą już nie tylko losy Ziemi, ale również całego Wszechświata. Nieświadomy swojej roli w tym konflikcie, to właśnie Sam posiada klucz do rozwiązania potyczki pomiędzy siłami zła i dobra. Z pomocą przyjaciół, współpracowników z NEST-a, a nawet rodziców, Sam ostatecznie musi zmierzyć się ze swoim przeznaczeniem i prawem rządzącym losem rodziny Witwickich: Bez poświęcenia nie ma zwycięstwa!","popularity":3.5776,"poster_path":"/607jDyts27T8nLNbaLeuO5uxmn2.jpg","release_date":"2009-06-19","softcore":false,"video":false,"vote_average":6.217,"vote_count":9172,"credit_id":"52fe44a3c3a36847f80a19ef","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/pWmJBkdb0EMb3PSd2f9wjza0krb.jpg","genre_ids":[28,18,878],"id":8656,"title":"Dzień zagłady","original_language":"en","original_title":"Deep Impact","overview":"W kierunku Ziemi zbliża się ogromnych rozmiarów kometa. Wszystkie badania wykazały, że jej uderzenie zniszczy wszelkie formy życia. Podjęto ostatnie próby uniknięcia tragedii lub przynajmniej zmniejszenia jej skutków. W kierunku komety wyrusza statek z grupą astronautów. Kieruje nimi Spurgeon Tanner. Cały świat z uwagą śledzi każde ich posunięcie. Minuta po minucie nieubłaganie zbliża się dzień zagłady.","popularity":5.8573,"poster_path":"/dchqPy0TNVdZ5GKUr6ebkKEZi9L.jpg","release_date":"1998-05-08","softcore":false,"video":false,"vote_average":6.238,"vote_count":3321,"credit_id":"52fe44b2c3a36847f80a4e37","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/5abq386123nxHS8mVZLsFi7c75z.jpg","genre_ids":[14,18],"id":7980,"title":"Nostalgia Anioła","original_language":"en","original_title":"The Lovely Bones","overview":"Susie Salmon zostaje brutalnie zgwałcona i zamordowana przez swojego sąsiada. To, co się dzieje po jej śmierci, obserwuje z nieba. Spoglądając w dół, snuje głosem czternastolatki powieść koszmarną, ale też pełną nadziei. Przez długie tygodnie po swojej śmierci Susie obserwuje życie, które toczy się już bez niej – przysłuchuje się pogłoskom na temat swojego zniknięcia, współczuje rodzicom, którzy ciągle wierzą, że córka się odnajdzie, obserwuje, jak ten, który ją zamordował, zaciera ślady zbrodni, widzi jak małżeństwo jej rodziców rozpada się, ojciec obsesyjnie pragnie zemsty, a siostra staję się osobą zupełnie obcą.","popularity":7.8307,"poster_path":"/6fgwXqjjTI66jjN8ITXMPlnwSFm.jpg","release_date":"2009-12-26","softcore":false,"video":false,"vote_average":7.062,"vote_count":4952,"credit_id":"52fe448bc3a36847f809bee1","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/5qsyqA7FeYRymBmNbPBqBgqWPO4.jpg","genre_ids":[12,35,10751],"id":9340,"title":"Goonies","original_language":"en","original_title":"The Goonies","overview":"Nastolatek Mikey Walsh znajduje w teczce ojca starą mapę do skarbów. W nadziei ocalenia domu przed rozbiórką, Mikey i jego przyjaciele Data Wang, Chunk Cohen, i Mouth Deveraux uciekają ku wielkiej przygodzie by znaleźć ukryty skarb Jednookiego Willa.","popularity":9.5116,"poster_path":"/eBU7gCjTCj9n2LTxvCSIXXOvHkD.jpg","release_date":"1985-06-07","softcore":false,"video":false,"vote_average":7.515,"vote_count":6236,"credit_id":"52fe44eac3a36847f80b17d5","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/wn0e4o0FYd2cBouOviUeTOWzL89.jpg","genre_ids":[28,12],"id":9342,"title":"Maska Zorro","original_language":"en","original_title":"The Mask of Zorro","overview":"Zawadiacka opowieść o walce w Meksyku o niepodległość i wyzwolenie się spod rządów Hiszpanii. Po dwudziestu latach legendarny Zorro (Anthony Hopkins) ucieka z więzienia, by dokonać zemsty na mordercy swojej żony, Don Rafaelu Montero (Stuart Wilson) i wyrwać z rąk wroga, córkę Elenę (Catherine Zeta-Jones). Na wykonawcę swoich planów wybiera młodego, niesfornego złodziejaszka (Antonio Banderas), którego najpierw musi jednak przemienić w nieustraszonego bohatera, pełnego ogłady i dobrych manier - mistrza fechtunku.  [opis dystrybutora dvd]","popularity":5.6846,"poster_path":"/AjWyPdjKxZanUlV1fpoUuCfvx4X.jpg","release_date":"1998-07-16","softcore":false,"video":false,"vote_average":6.583,"vote_count":4334,"credit_id":"52fe44eac3a36847f80b1977","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/sXfQGa7juaTpZ5IF17Xa6hI53nx.jpg","genre_ids":[10751,16,12],"id":12144,"title":"Pradawny ląd","original_language":"en","original_title":"The Land Before Time","overview":"Zanim ruszył czas Ziemia była zamieszkana przez dinozaury. Z powodu suszy wszystkie stworzenia podążają do Wiecznie Zielonej Doliny, gdzie nie brakuje ani wody, ani zawsze pokrytych liśćmi drzew. Osierocony mały brontozaur Stopka wraz z zadziorną Sarą, mądrą Ducky, skrzydlatym Petrie i leniwym Spike'em muszą odnaleźć drogę do wymarzonej krainy i stawić czoła wielu niebezpieczeństowom, w tym krwiożerczemu Tyranozaurusowi. Długa podróż stanie się dla nich wszystkich nauką o przetrwaniu, przyjaźni i wzajemnej pomocy.","popularity":4.6258,"poster_path":"/xsPBgPDvCe1frfFAapa0kHc8oIV.jpg","release_date":"1988-11-18","softcore":false,"video":false,"vote_average":7.15,"vote_count":2750,"credit_id":"52fe44be9251416c7503f5f9","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/sQPckU0TfSeYIlUneHfIXwzQC2f.jpg","genre_ids":[14,35,10751],"id":8839,"title":"Kacper","original_language":"en","original_title":"Casper","overview":"Pośredniczka w handlu nieruchomościami Carrigan Crittenden odkrywa, że w starej ruderze, którą odziedziczyła po ojcu ukryty jest skarb. Nie mogąc sobie poradzić ze złośliwymi duchami, które bronią do niego dostępu, Carrigan wynajmuje dom doktorowi Harveyowi, pogromcy duchów. Harvey zamieszkuje w nim razem z córką Kat i zobowiązuje się oczyścić ruderę. Ulega on jednak namowom córki i próbom małego duszka Kacpra, który pomaga im wygnać chciwą właścicielkę.","popularity":6.1836,"poster_path":"/pqyEaiRSeadASsPCHLiQIiL5nCh.jpg","release_date":"1995-05-26","softcore":false,"video":false,"vote_average":6.341,"vote_count":4925,"credit_id":"52fe44bec3a36847f80a7937","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/5AhpUb8CAP0jZ4Wrn7AsRUYjZxB.jpg","genre_ids":[28,35,878],"id":41154,"title":"Faceci w czerni 3","original_language":"en","original_title":"Men in Black 3","overview":"Kolejna część kultowej serii o agentach specjalnej jednostki rządowej. Zadaniem jednostki jest zajmowanie się kontaktami z Obcymi i utrzymywaniem społeczeństwa w nieświadomości, jak częste są wizyty przybyszów z kosmosu... Pojawiają się bez zapowiedzi, znikają bez śladu. Ich znakiem rozpoznawczym są czarne garnitury i okulary... a także cały zestaw kosmicznych gadżetów. Tym razem dwaj najbardziej znani agenci MIB zmierzą się z kosmitami w niezwykłym śledztwie pokonującym bariery nie tylko przestrzeni, ale i czasu. Agenci w czerni bronią Ziemi przed kosmitami już po raz trzeci.","popularity":7.5374,"poster_path":"/4WhwRHhNsjVCwE5A7cozbXFwMpW.jpg","release_date":"2012-05-23","softcore":false,"video":false,"vote_average":6.544,"vote_count":10993,"credit_id":"52fe45b7c3a36847f80d68c7","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/ofRUyIddC3iE7hXGETqPAMUqy3P.jpg","genre_ids":[99,10770],"id":827007,"title":"Indiana Jones : à la recherche de l'âge d'or perdu","original_language":"fr","original_title":"Indiana Jones : à la recherche de l'âge d'or perdu","overview":"","popularity":1.4197,"poster_path":"/mcVm8tgWrPvLqJqcHwgVTq57GFR.jpg","release_date":"2021-05-07","softcore":false,"video":false,"vote_average":7.855,"vote_count":31,"credit_id":"6096ceb61130bd003d8cac1a","department":"Crew","job":"Thanks"},{"adult":false,"backdrop_path":"/h3js4rulxzKMOokM2oO5Kr0mBZU.jpg","genre_ids":[28,878,12],"id":38356,"title":"Transformers: Po ciemnej stronie Księżyca","original_language":"en","original_title":"Transformers: Dark of the Moon","overview":"rzeszłość kryję tajemnice, a wydarzenia sprzed lat mają wpływy na to, co się dzieje teraz. Być może wrak statku kosmicznego znaleziony na Księżycu przyczyni się do tego, że Ziemia stanie na krawędzi wojny. Wojny tak wielkiej, że siła Transformersów będzie zbyt mała, by nas ocalić. Autoboty kontra Decepticony, dobro przeciw złu. I wcale nie jest powiedziane, że dobro zwycięży.","popularity":2.3492,"poster_path":"/dJWfBROVkU216AK7xVAKUN5JCxZ.jpg","release_date":"2011-06-28","softcore":false,"video":false,"vote_average":6.231,"vote_count":8952,"credit_id":"52fe46b09251416c9105c61f","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/x6Dr9i6vhWICxs7hnX2BakcMtPd.jpg","genre_ids":[53,878,9648],"id":37686,"title":"Super 8","original_language":"en","original_title":"Super 8","overview":"Latem 1979 r. grupa nastolatków z małego miasteczka w Ohio kręci amatorski film na taśmie 8 mm. Są świadkami katastrofy kolejowej i podejrzewają, że nie była ona przypadkowa. Wkrótce potem w mieście mają miejsce niezwykłe zjawiska, a miejscowy szeryf próbuje odkryć prawdę - coś bardziej przerażającego, niż ktokolwiek mógł przypuszczać.","popularity":5.157,"poster_path":"/nbdhpfPFCTRZS4rTyjiykJrUIzV.jpg","release_date":"2011-06-09","softcore":false,"video":false,"vote_average":6.777,"vote_count":7081,"credit_id":"52fe46639251416c91052d21","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/pjlxrd646cBYznHoPBWTzz6FujX.jpg","genre_ids":[28,878,18],"id":39254,"title":"Giganci ze stali","original_language":"en","original_title":"Real Steel","overview":"Charlie Kenton jest weteranem walk wręcz. Jego kariera zakończyła się z chwilą, gdy panowanie na ringu przejęły roboty. Teraz zajmuje się organizacją nielegalnych walk i renowacją robotów. Jest na dnie, gdy w jego życiu pojawia się Max, który twierdzi, że jest jego synem. Chłopak motywuje go do wytrenowania robota, który mógłby stanąć do walki o mistrzostwo. Stawki w tym brutalnym sporcie są wysokie, a Charlie i Max mają tylko jedną szansę, by wrócić na szczyt.","popularity":89.4872,"poster_path":"/8qbwr8fhBO6iqXKIxmmNBf0tiEx.jpg","release_date":"2011-09-28","softcore":false,"video":false,"vote_average":7.1,"vote_count":9184,"credit_id":"52fe47079251416c91067e4d","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/5UX6M0aEphiW6Xmy5rpYX75glbo.jpg","genre_ids":[14,27,35],"id":927,"title":"Gremliny rozrabiają","original_language":"en","original_title":"Gremlins","overview":"Trzymaj go z dala od wody. Chroń przed jasnym światłem. I najważniejsze! Żeby nie wiem jak płakał, żeby nie wiem jak błagał, nigdy, przenigdy nie karm go po północy. Tych oto instrukcji musi przestrzegać Billy Peltzer, gdy dostaje w prezencie urocze, kudłate stworzonko. Billy nie przypuszcza nawet, że już wkrótce czeka go nie lada niespodzianka.  \"Gremliny\" to horror w konwencji komedii z wytwórni Stevena Spielberga, który rozbawi cię do łez, a zaraz potem przestraszy nie na żarty.","popularity":7.7736,"poster_path":"/nYRCYOXIRQYQt9SZakLuI6d21SJ.jpg","release_date":"1984-06-08","softcore":false,"video":false,"vote_average":7.142,"vote_count":6983,"credit_id":"609a5efdd6590b003d2133f0","department":"Crew","job":"Presenter"},{"adult":false,"backdrop_path":"/6mqgl2szMLRYj4lhlXOjju5Tpeo.jpg","genre_ids":[12,16,9648],"id":17578,"title":"Przygody Tintina","original_language":"en","original_title":"The Adventures of Tintin","overview":"Film zrealizowany na podstawie klasycznego komiksu frankońskiego wydrukowanego w ponad 200 milionów egzemplarzy, tłumaczonego na 50 języków. Nic nie jest w stanie powstrzymać śmiałego reportera śledczego TINTINA, młodego bohatera ponadczasowego komiksu, przed rozwiązaniem tajemnic świata. W pierwszym z trzech planowanych filmów ten nieustraszony reporter, jego niesforny, ale oddany pies Snowy oraz skłonny do bijatyk kapitan Haddock wyruszają, aby odnaleźć od dawna zaginiony statek, który kryje tajemnicę starożytnego skarbu... i klucz do odwiecznej klątwy.","popularity":6.9622,"poster_path":"/aZkEQFFPhsZqGjzoLZvmH22IyW8.jpg","release_date":"2011-10-24","softcore":false,"video":false,"vote_average":6.922,"vote_count":5815,"credit_id":"52fe47349251416c7509142d","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/6mqgl2szMLRYj4lhlXOjju5Tpeo.jpg","genre_ids":[12,16,9648],"id":17578,"title":"Przygody Tintina","original_language":"en","original_title":"The Adventures of Tintin","overview":"Film zrealizowany na podstawie klasycznego komiksu frankońskiego wydrukowanego w ponad 200 milionów egzemplarzy, tłumaczonego na 50 języków. Nic nie jest w stanie powstrzymać śmiałego reportera śledczego TINTINA, młodego bohatera ponadczasowego komiksu, przed rozwiązaniem tajemnic świata. W pierwszym z trzech planowanych filmów ten nieustraszony reporter, jego niesforny, ale oddany pies Snowy oraz skłonny do bijatyk kapitan Haddock wyruszają, aby odnaleźć od dawna zaginiony statek, który kryje tajemnicę starożytnego skarbu... i klucz do odwiecznej klątwy.","popularity":6.9622,"poster_path":"/aZkEQFFPhsZqGjzoLZvmH22IyW8.jpg","release_date":"2011-10-24","softcore":false,"video":false,"vote_average":6.922,"vote_count":5815,"credit_id":"52fe47349251416c75091461","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":192372,"title":"Don't Say No Until I Finish Talking: The Story of Richard D. Zanuck","original_language":"en","original_title":"Don't Say No Until I Finish Talking: The Story of Richard D. Zanuck","overview":"","popularity":0.6147,"poster_path":"/z4PICuZuYtg0c6Q7D9jH77gWpBY.jpg","release_date":"2013-04-28","softcore":false,"video":false,"vote_average":6.313,"vote_count":8,"credit_id":"60a5ca276ee3d70057f8018b","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/sGXCYMzr1sCnGNVuRpB2TOWPWDA.jpg","genre_ids":[28,878,53,37],"id":49849,"title":"Kowboje i Obcy","original_language":"en","original_title":"Cowboys & Aliens","overview":"Arizona, rok 1873. Rewolwerowiec Jake budzi się na pustyni z tajemniczą bransoletą na ręku, nie pamiętając wydarzeń z przeszłości. Nawiedzają go niepokojące wizje. Wędrując przez pustkowia, trafia do niewielkiego miasteczka o nazwie Absolution, rządzonego przez pułkownika Dolarhyde'a, hodowcę bydła i weterana wojennego. Między Jake'm a ranczerem rodzi się konflikt. Mimo to będą zmuszeni połączyć siły. Absolution staje się celem ataku dysponujących zaawansowaną technologią najeźdźców z kosmosu. Z pomocą napadniętym przychodzi tajemnicza Ella.","popularity":5.7575,"poster_path":"/pNb8t3YnYDvhjZZdJkC4UpkL7qO.jpg","release_date":"2011-07-29","softcore":false,"video":false,"vote_average":5.659,"vote_count":5419,"credit_id":"52fe47abc3a36847f8141eb3","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/6pbIOpnWFAO42JgZhuNUdMEUxi8.jpg","genre_ids":[16,878,10751],"id":18890,"title":"Były sobie dinozaury","original_language":"en","original_title":"We're Back! A Dinosaur's Story","overview":"Kapitan New Eyes podróżuje w czasie i dociera do ery dinozaurów. Karmi dinozaury swoimi magicznymi płatkami, które sprawiają, że stają się one inteligentne i nieagresywne. Następnie kapitan przenosi je do przyszłości, a dinozaury mają za zadanie spełnić życzenia dzieci mieszkających w Nowym Jorku","popularity":1.708,"poster_path":"/iyFmhYlioe3PDZjSKWtcIhu5R02.jpg","release_date":"1993-11-24","softcore":false,"video":false,"vote_average":6.095,"vote_count":446,"credit_id":"52fe47a79251416c750a0e31","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/rft7tLgv41w33b037512tlmxD4N.jpg","genre_ids":[35,16],"id":83200,"title":"Tummy Trouble","original_language":"en","original_title":"Tummy Trouble","overview":"","popularity":2.9457,"poster_path":"/mLOqZNasNOUKSNCpAIeHmJWPkvW.jpg","release_date":"1989-06-23","softcore":false,"video":false,"vote_average":6.7,"vote_count":76,"credit_id":"52fe48929251416c91091217","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/lJ55fed03axg2oMPIUkJLkydyxc.jpg","genre_ids":[10751,35,16],"id":83202,"title":"Roller Coaster Rabbit","original_language":"en","original_title":"Roller Coaster Rabbit","overview":"","popularity":0.6009,"poster_path":"/v9mNkB3htZEod4OZd3bXJd5VK7J.jpg","release_date":"1990-06-15","softcore":false,"video":false,"vote_average":6.663,"vote_count":80,"credit_id":"52fe48929251416c9109130d","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/o0okx4A8pBr6Fk0yd38oiYwL69j.jpg","genre_ids":[35,16],"id":83203,"title":"Trail Mix-Up","original_language":"en","original_title":"Trail Mix-Up","overview":"","popularity":0.7116,"poster_path":"/7FOzVF0CuBn3oOJOoHAg9JR0Ru2.jpg","release_date":"1993-03-12","softcore":false,"video":false,"vote_average":7.016,"vote_count":62,"credit_id":"52fe48939251416c910913ab","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/h9f8iOLtsh9QUJK69IYe5vnTPgC.jpg","genre_ids":[16,35,10751,10770],"id":52691,"title":"A Wish for Wings That Work","original_language":"en","original_title":"A Wish for Wings That Work","overview":"","popularity":0.2801,"poster_path":"/aKbEXHLlTlvSCe7SZ5T1WBaMsU6.jpg","release_date":"1991-12-18","softcore":false,"video":false,"vote_average":6.197,"vote_count":38,"credit_id":"52fe483ec3a36847f815dcff","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/hwOFrwHladQ8FktYn3aJNAt8KA1.jpg","genre_ids":[36,18],"id":72976,"title":"Lincoln","original_language":"en","original_title":"Lincoln","overview":"Styczeń 1865 roku. Od czterech lat w Ameryce trwa krwawa wojna domowa. Setki tysiące ludzi straciło już życie. Południe stoi na krawędzi klęski, zwycięstwo Północy wydaje się pewne. Prezydent Unii Abraham Lincoln chce wykorzystać pozostały do końca wojny czas na przegłosowanie w Izbie Reprezentantów projektu trzynastej poprawki do konstytucji, mającej całkowicie wyeliminować niewolnictwo. Do tego jednak niezbędne jest poparcie wszystkich Republikanów w Izbie, ale też głosy dwudziestu reprezentantów ze skrajnie wrogiej pomysłowi Partii Demokratycznej. Prezydent rozpoczyna polityczną grę, w której stawką jest przyszłość milionów ludzi.","popularity":4.3243,"poster_path":"/lOjNidVgcku72WeCZqFxyUbYZty.jpg","release_date":"2012-11-09","softcore":false,"video":false,"vote_average":6.848,"vote_count":4055,"credit_id":"52fe4886c3a368484e0fd421","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/hwOFrwHladQ8FktYn3aJNAt8KA1.jpg","genre_ids":[36,18],"id":72976,"title":"Lincoln","original_language":"en","original_title":"Lincoln","overview":"Styczeń 1865 roku. Od czterech lat w Ameryce trwa krwawa wojna domowa. Setki tysiące ludzi straciło już życie. Południe stoi na krawędzi klęski, zwycięstwo Północy wydaje się pewne. Prezydent Unii Abraham Lincoln chce wykorzystać pozostały do końca wojny czas na przegłosowanie w Izbie Reprezentantów projektu trzynastej poprawki do konstytucji, mającej całkowicie wyeliminować niewolnictwo. Do tego jednak niezbędne jest poparcie wszystkich Republikanów w Izbie, ale też głosy dwudziestu reprezentantów ze skrajnie wrogiej pomysłowi Partii Demokratycznej. Prezydent rozpoczyna polityczną grę, w której stawką jest przyszłość milionów ludzi.","popularity":4.3243,"poster_path":"/lOjNidVgcku72WeCZqFxyUbYZty.jpg","release_date":"2012-11-09","softcore":false,"video":false,"vote_average":6.848,"vote_count":4055,"credit_id":"52fe4887c3a368484e0fd56f","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/tcx15vswrQJCGET5lGxESQ4J5LG.jpg","genre_ids":[10752,36,12,18],"id":57212,"title":"Czas wojny","original_language":"en","original_title":"War Horse","overview":"Epicka opowieść, mówiąca o lojalności, nadziei i wytrwałości w pejzażu wiejskiej Anglii i Europy w czasie Pierwszej Wojny Światowej. Historia, która najpierw była książkowym bestsellerem, a potem spektakularnym sukcesem na deskach światowych teatrów, teraz zagości na srebrnym ekranie.  Rodzina Narracottów prowadzi farmę w Devon. Ojciec Ted kupuje pięknego konia Joeya, który nie nadaje się jednak do pracy w gospodarstwie. Bardzo się z nim zaprzyjaźnia syn Narracottów, Albert. Gdy rumak zostaje sprzedany armii, poznajemy jego dramatyczne, zmienne losy podczas wojennej zawieruchy. Tymczasem chłopak, choć nieletni, zaciąga się do wojska, mając nadzieję odnaleźć swego najwierniejszego przyjaciela.","popularity":5.4772,"poster_path":"/kTyFTf5ZnEqF29gRisC96zEk3yP.jpg","release_date":"2011-12-25","softcore":false,"video":false,"vote_average":7.305,"vote_count":3684,"credit_id":"52fe4928c3a36847f818c11d","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/2og6dqoazyVl30uofnQ62yTiJvj.jpg","genre_ids":[27,10770],"id":85483,"title":"Something Evil","original_language":"en","original_title":"Something Evil","overview":"","popularity":0.5642,"poster_path":"/ztVrElyzawZPKx0gLURx54s3IHK.jpg","release_date":"1972-01-21","softcore":false,"video":false,"vote_average":5.417,"vote_count":60,"credit_id":"52fe49459251416c910a7f33","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/zbgBfigzYTbgFugbhIWMRWgQM4L.jpg","genre_ids":[18,10749],"id":97105,"title":"Amblin'","original_language":"en","original_title":"Amblin'","overview":"","popularity":0.2129,"poster_path":"/1By3fBCDxIkkeLIY3Vn2p1i0agC.jpg","release_date":"1968-12-18","softcore":false,"video":false,"vote_average":6.1,"vote_count":48,"credit_id":"52fe49d29251416c750d4647","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":"/zbgBfigzYTbgFugbhIWMRWgQM4L.jpg","genre_ids":[18,10749],"id":97105,"title":"Amblin'","original_language":"en","original_title":"Amblin'","overview":"","popularity":0.2129,"poster_path":"/1By3fBCDxIkkeLIY3Vn2p1i0agC.jpg","release_date":"1968-12-18","softcore":false,"video":false,"vote_average":6.1,"vote_count":48,"credit_id":"52fe49d29251416c750d4641","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":451306,"title":"Looking Back to the Future","original_language":"en","original_title":"Looking Back to the Future","overview":"","popularity":0.4431,"poster_path":"/cyn7sa1eUYUU9GBFmVZ2FJJbsOs.jpg","release_date":"2009-02-10","softcore":false,"video":false,"vote_average":7.3,"vote_count":7,"credit_id":"627688ce9979d214834608c7","department":"Crew","job":"Thanks"},{"adult":false,"backdrop_path":"/yl73Eb3Hvu5zYAFGv0wN5agW6Mh.jpg","genre_ids":[18,9648,53,10770],"id":110747,"title":"Savage!","original_language":"en","original_title":"Savage!","overview":"","popularity":1.0497,"poster_path":"/d7dHb25MvLfV6zbkJeYzTtbPNDO.jpg","release_date":"1973-03-31","softcore":false,"video":true,"vote_average":5.5,"vote_count":14,"credit_id":"52fe4ae4c3a36847f81e7215","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/s5QfDFqRO6sjgPtKkjxD0WqXQef.jpg","genre_ids":[12,878,53],"id":135397,"title":"Jurassic World","original_language":"en","original_title":"Jurassic World","overview":"Przed 22 laty John Hammond zamarzył o parku rozrywki, którego goście staną oko w oko z żywymi dinozaurami. Teraz Jurassic World przyjmuje dziesiątki tysięcy gości dziennie, ale wśród atrakcji parku pojawia się niebezpieczeństwo: agresywny, genetycznie zmodyfikowany dinozaur wymykający się wszelkiej kontroli. Gdy na wyspie wybucha chaos, i Claire muszą pospiesznie przywrócić porządek, by pobyt w parku nie zamienił się w szkołę przetrwania.","popularity":13.0374,"poster_path":"/rhr4y79GpxQF9IsfJItRXVaoGs4.jpg","release_date":"2015-06-06","softcore":false,"video":false,"vote_average":6.701,"vote_count":21589,"credit_id":"52fe4bf7c3a368484e1a0683","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/gGTzXQsIeVTLoqihn7fcJk9GFnI.jpg","genre_ids":[27,53,18],"id":10383,"title":"Stracone dusze","original_language":"en","original_title":"Lost Souls","overview":"Zbliża się koniec XX wieku. Zgodnie z prastarą przepowiednią na ziemię ma zstąpić szatan, który wcieli się w postać człowieka. Członkini grupy egzorcystów, Maya, dowiaduje się, że wybrańcem władcy ciemności jest Peter Kelson, dziennikarz i autor książek o seryjnych mordercach. Kobieta musi go chronić.","popularity":2.6273,"poster_path":"/9DOq3KqGrNbqa3z5M8iDJ2wuaxJ.jpg","release_date":"2000-10-13","softcore":false,"video":false,"vote_average":5.047,"vote_count":201,"credit_id":"6293e58b7d5db510a529e634","department":"Crew","job":"Thanks"},{"adult":false,"backdrop_path":null,"genre_ids":[28,18,10770],"id":323111,"title":"Zawsze wierni","original_language":"en","original_title":"Semper Fi","overview":"Cliff Truckee rezygnuje z łatwego startu w życiu  który by miał dzięki rozpoczęciu nauki  na prestiżowej uczelni. W autobusie opuszczającym Chicago spotyka dziewczynę, która zmierza do Marines, zakochuje się i decyduje zrobić to samo. Paris Island staje się jego domem podobnie jak i innych rekrutów. To miejsce  gdzie każdy zmaga się nie tylko z trudami szkolenia, ale także z osobistymi problemami.","popularity":2.0989,"poster_path":"/8WzhW02Wd3X5HZs6OITRqUdFOaz.jpg","release_date":"2001-04-01","softcore":false,"video":false,"vote_average":6.2,"vote_count":5,"credit_id":"6500e1255545ca011ba67870","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/8uJ9saYjxsowclMt6sEuoz7UHRz.jpg","genre_ids":[99,18],"id":114053,"title":"Volevo solo vivere","original_language":"it","original_title":"Volevo solo vivere","overview":"","popularity":0.121,"poster_path":"/xOkDq5klQzGUtSwDSX1bjN3rQZz.jpg","release_date":"2006-01-26","softcore":false,"video":false,"vote_average":4.0,"vote_count":2,"credit_id":"629ee44785005d0052b87854","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":null,"genre_ids":[12,35,16,28,10751,878,10752],"id":139282,"title":"Lego Indiana Jones and the Raiders of the Lost Brick","original_language":"en","original_title":"Lego Indiana Jones and the Raiders of the Lost Brick","overview":"Indiana Jones chce odnaleźć trzy prastare artefakty: złotego idola, Arkę Przymierza i Kryształową Czaszkę. By tego dokonać, musi pokonać groźnych wrogów, lecz może liczyć na pomoc niezawodnych przyjaciół. Po wykonaniu zadania słynny poszukiwacz przygód znajduje dla skarbów niezwykłe zastosowanie.","popularity":0.3488,"poster_path":"/t1mZV6qw4fhJBu7ULK26n1dgexV.jpg","release_date":"2008-05-10","softcore":false,"video":false,"vote_average":6.4,"vote_count":22,"credit_id":"64fe207dffc9de0ee3c4bb5b","department":"Crew","job":"Thanks"},{"adult":false,"backdrop_path":"/xQc51OBY9UNF2fQKyAOXZE7az2w.jpg","genre_ids":[9648,53,28],"id":13027,"title":"Eagle Eye","original_language":"en","original_title":"Eagle Eye","overview":"Trzymający w napięciu od pierwszych chwil film sensacyjny. Dwoje nieznajomych Jerry i Rachel zostają wrobieni w polityczny zamach. Ktoś śledzi każdy ich ruch, a oni muszą działać tak, aby nie stać się celem.","popularity":5.7385,"poster_path":"/9KCOv0hL37IN3tWG3j86eZg3xDH.jpg","release_date":"2008-09-25","softcore":false,"video":false,"vote_average":6.495,"vote_count":3122,"credit_id":"530b2d1d92514168dc000cc5","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/tOTtJelsPKX0bvSdvDVL2ou3cGS.jpg","genre_ids":[12,10751,14],"id":267935,"title":"BFG: Bardzo Fajny Gigant","original_language":"en","original_title":"The BFG","overview":"Porywająca opowieść o małej dziewczynce z sierocińca i tajemniczym Olbrzymie, który odkrywa przed nią cuda i sekrety magicznej krainy. W środku nocy, gdy wszyscy ludzie śpią w najlepsze, mroczne istoty wychodzą z ukrycia i przejmują na kilka chwil cały świat. Takie historie od dziecka słyszała rezolutna dziesięciolatka o imieniu Sophie. Nic więc dziwnego, że kiedy dziewczynka pewnej nocy nie mogła zasnąć, wygramoliła się z łóżka, założyła okulary i wychyliła przez okno, by ujrzeć świat w poświacie księżycowego blasku. Znana jej dobrze ulica dziś wyglądała jakoś inaczej… Nagle z cienia wynurzyło się coś ogromnego i zaczęło zmierzać w jej kierunku.","popularity":7.1955,"poster_path":"/5210yKDadAaJKE5wY74m8eb8JdV.jpg","release_date":"2016-06-01","softcore":false,"video":false,"vote_average":6.292,"vote_count":3628,"credit_id":"536445f0c3a3681238000367","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/hKQtJhsUFTQagFQOpGA9LApoMro.jpg","genre_ids":[16,35,10751],"id":36257,"title":"Przygody Animków: Wakacyjne szaleństwo","original_language":"en","original_title":"Tiny Toon Adventures: How I Spent My Vacation","overview":"Na Bzikowersytecie rok szkolny dobiega końca i zaczynają się wakacje - dwumiesięczny czas odpoczynku. Jego uczniowie spędzają je w różny sposób: Pucuś jedzie wraz z rodziną i Tasiorem do lunaparku, Kinio i Kinia lądują na południu USA, pozostali zaś na Florydzie.","popularity":1.4725,"poster_path":"/iuPrC4w2hflbQWLtoQlihmk4xMo.jpg","release_date":"1992-03-11","softcore":false,"video":false,"vote_average":6.756,"vote_count":88,"credit_id":"53855ef20e0a261444000af1","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/tcx15vswrQJCGET5lGxESQ4J5LG.jpg","genre_ids":[10752,36,12,18],"id":57212,"title":"Czas wojny","original_language":"en","original_title":"War Horse","overview":"Epicka opowieść, mówiąca o lojalności, nadziei i wytrwałości w pejzażu wiejskiej Anglii i Europy w czasie Pierwszej Wojny Światowej. Historia, która najpierw była książkowym bestsellerem, a potem spektakularnym sukcesem na deskach światowych teatrów, teraz zagości na srebrnym ekranie.  Rodzina Narracottów prowadzi farmę w Devon. Ojciec Ted kupuje pięknego konia Joeya, który nie nadaje się jednak do pracy w gospodarstwie. Bardzo się z nim zaprzyjaźnia syn Narracottów, Albert. Gdy rumak zostaje sprzedany armii, poznajemy jego dramatyczne, zmienne losy podczas wojennej zawieruchy. Tymczasem chłopak, choć nieletni, zaciąga się do wojska, mając nadzieję odnaleźć swego najwierniejszego przyjaciela.","popularity":5.4772,"poster_path":"/kTyFTf5ZnEqF29gRisC96zEk3yP.jpg","release_date":"2011-12-25","softcore":false,"video":false,"vote_average":7.305,"vote_count":3684,"credit_id":"5385b2770e0a26144d00114e","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/9y19kOpdJE0PveOPdhn7yvvzyFW.jpg","genre_ids":[10749,18,12],"id":280129,"title":"Ace Eli and Rodger of the Skies","original_language":"en","original_title":"Ace Eli and Rodger of the Skies","overview":"","popularity":0.4263,"poster_path":"/fx1dQnFFTQN0rJcxtukCE9fkEm7.jpg","release_date":"1973-03-31","softcore":false,"video":false,"vote_average":5.143,"vote_count":7,"credit_id":"53b6ced90e0a2676bf0056e9","department":"Writing","job":"Story"},{"adult":false,"backdrop_path":null,"genre_ids":[18],"id":1187815,"title":"King: A Life","original_language":"en","original_title":"King: A Life","overview":"","popularity":0.4114,"poster_path":null,"release_date":"","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"651eff093d355700adb56955","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/zbgBfigzYTbgFugbhIWMRWgQM4L.jpg","genre_ids":[18,10749],"id":97105,"title":"Amblin'","original_language":"en","original_title":"Amblin'","overview":"","popularity":0.2129,"poster_path":"/1By3fBCDxIkkeLIY3Vn2p1i0agC.jpg","release_date":"1968-12-18","softcore":false,"video":false,"vote_average":6.1,"vote_count":48,"credit_id":"61423cda5e1200008da45f31","department":"Editing","job":"Editor"},{"adult":false,"backdrop_path":"/AtF7TESJEMmImBRUj9Z7HmW2ZH0.jpg","genre_ids":[12,35,878],"id":196,"title":"Powrót do przyszłości III","original_language":"en","original_title":"Back to the Future Part III","overview":"W tej porywającej widza produkcji, wieńczącej popularną serię filmów reżysera Roberta Zemeckisa i producenta Stevena Spielberga, możemy oglądać takich aktorów jak Michael J. Fox, Christopher Lloyd i Mary Steenburgen.  Uwięziony w 1985, po potężnym wybuchu, Marty musi przenieść się do roku 1885, aby uchronić dr. Browna przed przedwczesną śmiercią. Po ataku Indian i wrogo nastawionych mieszkańców miasta, Marty odnajduje dr. Browna jako... kowala. Marty musi podołać nie lada wyzwaniu, aby i powrócić do przyszłości i zabrać z Dzikiego Zachodu doktora, który jest pod urokiem czarującej Clary Clayton (Steenburgen). Ten wielki finał, zamykający serię brawurowych przygód w czasie, charakteryzuje się wartką akcją, humorystycznymi akcentami i niesamowitą fantazją.","popularity":6.0097,"poster_path":"/9cGV7KgXvjDJ4owybeiPgyL2UOw.jpg","release_date":"1990-05-25","softcore":false,"video":false,"vote_average":7.493,"vote_count":11534,"credit_id":"54007bdec3a368068c001628","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/5bzPWQ2dFUl2aZKkp7ILJVVkRed.jpg","genre_ids":[12,35,878],"id":105,"title":"Powrót do przyszłości","original_language":"en","original_title":"Back to the Future","overview":"Połowa lat 80, miasteczko Hill Valley... Młody, sympatyczny Marty (Michael J. Fox) przyjaźni się z pewnym osobliwym, starszym człowiekiem, doktorem Emmetem Brownem (Christopher Lloyd). Kiedy Marty przenosi się w czasie za pomocą wehikułu czasu skonstruowanego przez doktora, z przerażeniem odkrywa, że cofnął się o 30 lat wstecz... Na dodatek, zaraz po przybyciu zostaje przypadkowo potrącony przez swojego dziadka, a jego matka (oczywiście 30 lat młodsza) zakochuje się w nim... Marty musi w ciągu kilku dni znaleźć sposób na to, aby jego rodzice się w sobie zakochali, poradzić sobie z bandą opryszków, którzy prześladują jego ojca i przede wszystkim wrócić do swojego domu, do roku 1985...","popularity":19.6226,"poster_path":"/2fEoQxuMRzebtqwHICuyM6B0HTH.jpg","release_date":"1985-07-03","softcore":false,"video":false,"vote_average":8.326,"vote_count":21840,"credit_id":"540079350e0a2658f1002249","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/w6tPctxWAsHoQXeKxxNOT6lYKpx.jpg","genre_ids":[12,35,878],"id":165,"title":"Powrót do przyszłości II","original_language":"en","original_title":"Back to the Future Part II","overview":"Michael J. Fox i Christopher Lloyd ponownie wcielają się w postacie Marty'ego McFlya i dr. Browna w nowych przygodach zaprezentowanych widzowi przez reżysera Roberta Zemeckisa i producenta Stevena Spielberga.  Brawurowa podróż Marty'ego i dr. Browna do 2015 roku tylko z pozoru rozwiązuje kilka przyszłych problemów rodziny McFly'ów. Kiedy amatorzy przygód wracają do domu, wkrótce odkrywają, że ktoś majstrował przy zegarze, aby stworzyć koszmarne Hill Valley w 1985 roku. Ich jedyną nadzieją, by zmienić przyszłość, staje się ponowny powrót do roku 1955.","popularity":7.6663,"poster_path":"/9HIg6KgzwHzmCMeukzDcIPCdUiy.jpg","release_date":"1989-11-22","softcore":false,"video":false,"vote_average":7.781,"vote_count":13947,"credit_id":"54007a76c3a36806030014a9","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/2vFuG6bWGyQUzYS9d69E5l85nIz.jpg","genre_ids":[878,12,28],"id":667538,"title":"Transformers - Przebudzenie bestii","original_language":"en","original_title":"Transformers: Rise of the Beasts","overview":"OPTIMUS PRIME i AUTOBOTY w nowej, pełnej adrenaliny przygodzie. W obliczu grożącego planecie niebezpieczeństwa Transformersi muszą połączyć siły z potężną frakcją Maximali, aby wziąć udział w ostatecznej bitwie o ocalenie Ziemi. Gdy los ludzkości będzie zagrożony, Noah  i Elena  zrobią co tylko w ich mocy, by pomóc w ostatecznej walce o ocalenie Ziemi w nowym, ekscytującym rozdziale sagi z cyklu TRANSFORMERS.","popularity":12.2869,"poster_path":"/aAoRVlCqV35rVqBDT3NgMfEC6bZ.jpg","release_date":"2023-06-06","softcore":false,"video":false,"vote_average":7.171,"vote_count":5279,"credit_id":"6154561967dcc90043e3757a","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/12M3SvYO4WMdlXCajWklz1zUAly.jpg","genre_ids":[53,18],"id":296098,"title":"Most szpiegów","original_language":"en","original_title":"Bridge of Spies","overview":"Most szpiegów to pełen dramatyzmu thriller rozgrywający się na tle historycznych wydarzeń. James Donovan, prawnik z Brooklynu, trafia w sam środek zimnej wojny, gdy CIA wysyła go ze, zdawać by się mogło, niemożliwą do wykonania misją wynegocjowania uwolnienia więzionego przez Sowietów amerykańskiego pilota wojskowego. W tym inspirowanym prawdziwymi wydarzeniami mocnym, trzymającym w nieustannym napięciu filmie twórcy udało się uchwycić istotę człowieczeństwa, gdy James Donovan gotów jest zaryzykować wszystko w imię swoiście pojętej sprawiedliwości i wierności ojczyźnie.","popularity":4.3355,"poster_path":"/uiUhE1MfZ69ESKcNEGPboodQOli.jpg","release_date":"2015-10-15","softcore":false,"video":false,"vote_average":7.24,"vote_count":7275,"credit_id":"543050e4c3a36831b50010a0","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/12M3SvYO4WMdlXCajWklz1zUAly.jpg","genre_ids":[53,18],"id":296098,"title":"Most szpiegów","original_language":"en","original_title":"Bridge of Spies","overview":"Most szpiegów to pełen dramatyzmu thriller rozgrywający się na tle historycznych wydarzeń. James Donovan, prawnik z Brooklynu, trafia w sam środek zimnej wojny, gdy CIA wysyła go ze, zdawać by się mogło, niemożliwą do wykonania misją wynegocjowania uwolnienia więzionego przez Sowietów amerykańskiego pilota wojskowego. W tym inspirowanym prawdziwymi wydarzeniami mocnym, trzymającym w nieustannym napięciu filmie twórcy udało się uchwycić istotę człowieczeństwa, gdy James Donovan gotów jest zaryzykować wszystko w imię swoiście pojętej sprawiedliwości i wierności ojczyźnie.","popularity":4.3355,"poster_path":"/uiUhE1MfZ69ESKcNEGPboodQOli.jpg","release_date":"2015-10-15","softcore":false,"video":false,"vote_average":7.24,"vote_count":7275,"credit_id":"5430507dc3a36831ac001073","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":null,"genre_ids":[99,10752],"id":1198548,"title":"A Timeless Call","original_language":"en","original_title":"A Timeless Call","overview":"","popularity":0.4719,"poster_path":"/eSIJDlKvMt1OllOCBqfZ0bmRqqQ.jpg","release_date":"2008-08-27","softcore":false,"video":false,"vote_average":5.0,"vote_count":3,"credit_id":"653ff3b8c8a5ac011d6e3d93","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/xQyGkQ8ICa4lgifGr3oZjkm3AJ2.jpg","genre_ids":[18],"id":804095,"title":"Fabelmanowie","original_language":"en","original_title":"The Fabelmans","overview":"Steven Spielberg wraca do czasów swojego dzieciństwa, by opowiedzieć o dorastaniu Sammy’ego Fabelmana, wrażliwego nastolatka, wielkiego miłośnika kina i poczatkującego filmowca. Sammy przypadkiem poznaje dramatyczną rodzinną tajemnicę i odkrywa przy okazji, że kino w niezwykły sposób pomaga nam odkrywać prawdę o naszych bliskich i o nas samych.","popularity":4.7227,"poster_path":"/l6kO7x34XjFtN2RDmuHWqd5QDBc.jpg","release_date":"2022-11-11","softcore":false,"video":false,"vote_average":7.57,"vote_count":2769,"credit_id":"6303ab60b39e35007a86067f","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":null,"genre_ids":[12,28,18,10770],"id":101125,"title":"Class of '61","original_language":"en","original_title":"Class of '61","overview":"","popularity":0.6263,"poster_path":"/r6Rb65B1GcmPtsFmnY5ZZWYTmED.jpg","release_date":"1993-04-12","softcore":false,"video":false,"vote_average":4.353,"vote_count":17,"credit_id":"54e84d50c3a36836ea001867","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/xQyGkQ8ICa4lgifGr3oZjkm3AJ2.jpg","genre_ids":[18],"id":804095,"title":"Fabelmanowie","original_language":"en","original_title":"The Fabelmans","overview":"Steven Spielberg wraca do czasów swojego dzieciństwa, by opowiedzieć o dorastaniu Sammy’ego Fabelmana, wrażliwego nastolatka, wielkiego miłośnika kina i poczatkującego filmowca. Sammy przypadkiem poznaje dramatyczną rodzinną tajemnicę i odkrywa przy okazji, że kino w niezwykły sposób pomaga nam odkrywać prawdę o naszych bliskich i o nas samych.","popularity":4.7227,"poster_path":"/l6kO7x34XjFtN2RDmuHWqd5QDBc.jpg","release_date":"2022-11-11","softcore":false,"video":false,"vote_average":7.57,"vote_count":2769,"credit_id":"6312d7fc0231f20091bf2ac0","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/uTLfl7VZA27a9e6vg33Tp9dn6ae.jpg","genre_ids":[99],"id":1201609,"title":"The Fabelmans: A Family in Film","original_language":"en","original_title":"The Fabelmans: A Family in Film","overview":"","popularity":0.5908,"poster_path":"/9vj7Of4a8LgvGu21l3rPWs5Xt6D.jpg","release_date":"2023-02-14","softcore":false,"video":false,"vote_average":7.1,"vote_count":13,"credit_id":"654960bb43494f0101c9319d","department":"Crew","job":"Thanks"},{"adult":false,"backdrop_path":"/6zMevCRj7ybKCAqxAsZkiFreCQ9.jpg","genre_ids":[35],"id":14475,"title":"Używane samochody","original_language":"en","original_title":"Used Cars","overview":"Luke i Roy, bracia bliźniacy, są właścicielami konkurujących ze sobą, położonych naprzeciwko komisów samochodowych. Chciwość jednego z nich prowadzi do tragedii. Teraz o interesy zmarłego szefa, a przede wszystkim własne, walczą pracownicy komisu. Starają się ukryć śmierć Luke'a, by nie dopuścić do przejęcia firmy przez konkurencję, i mówią, że szef wyjechał. Niespodziewanie pojawia się córka Luke'a, Barbara, która odeszła z domu przed dziesięcioma laty.","popularity":2.5852,"poster_path":"/h9hqesyEBaag8ZkgrBSaUGgGNFF.jpg","release_date":"1980-07-11","softcore":false,"video":false,"vote_average":6.421,"vote_count":291,"credit_id":"5507dee8c3a3682b49000c84","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/5a7lMDn3nAj2ByO0X1fg6BhUphR.jpg","genre_ids":[12,28,878],"id":333339,"title":"Player One","original_language":"en","original_title":"Ready Player One","overview":"Akcja rozgrywa się w roku 2045, kiedy to świat znajduje się na skraju upadku i pogrążenia się w chaosie. Ludzie znajdują ratunek w OAZIE, ekspansywnym uniwersum rzeczywistości wirtualnej stworzonym przez błyskotliwego ekscentryka Jamesa Hallidaya (Mark Rylance). Przed śmiercią Halliday postanawia przekazać swoją niewyobrażalną fortunę pierwszej osobie, która odnajdzie cyfrowe „wielkanocne jajko” ukryte gdzieś w OAZIE. Rozpoczyna się rywalizacja, która wkrótce ogarnia cały świat. Młody Wade Watts (Tye Sheridan), kiepski kandydat na bohatera, postanawia dołączyć do karkołomnego, zakrzywiającego rzeczywistość wyścigu po skarb w fantastycznym uniwersum pełnym tajemnic, odkryć i niebezpieczeństw.","popularity":12.2961,"poster_path":"/okKPf7AhVAL1zgBdm2g2SVabKlB.jpg","release_date":"2018-03-28","softcore":false,"video":false,"vote_average":7.588,"vote_count":16942,"credit_id":"551975f0925141731c003965","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/bvkPno6U02lLyvPWCnmibq4eIaN.jpg","genre_ids":[27],"id":609,"title":"Duch","original_language":"en","original_title":"Poltergeist","overview":"Szczęśliwa rodzina przeprowadza się do wymarzonego domu. Po pewnym czasie zaczynają dziać się niezwykłe rzeczy. Upiorne drzewo stojące za oknem próbuje zjeść chłopca, a mała dziewczynka oglądając telewizję zostaje porwana przez tytułowego ducha. Rodzice dziewczynki postanawiają wezwać na pomoc parapsychologów, którzy odkrywają, że ich dom stoi na starym indiańskim cmentarzu.","popularity":6.0631,"poster_path":"/9XPfrH8kbMs947bAtjXgjsIEg8C.jpg","release_date":"1982-06-04","softcore":false,"video":false,"vote_average":7.2,"vote_count":3324,"credit_id":"55378046c3a36878fd0021ea","department":"Writing","job":"Story"},{"adult":false,"backdrop_path":"/3otAGduCHdqdEIVC1HOOLb5Qnp2.jpg","genre_ids":[16,35,10751,14],"id":9297,"title":"Straszny dom","original_language":"en","original_title":"Monster House","overview":"12-letni DJ Walters od dzieciństwa obserwował dom Nebbercrackerów i od dawna podejrzewał, że z tym domem jest coś nie tak. Zauważył, że coraz więcej rzeczy z otoczenia domu zaczyna znikać, nawet pani Nebbercracker gdzieś przepadła. Gdy nadejdzie święto Halloween DJ wraz z dwójką przyjaciół uda się na rekonesans i odkryje przerażającą prawdę: dom jest żywym pożerającym wszystko i wszystkich potworem. Dzieciaki próbują o tym fakcie powiedzieć rodzicom i policji, ale dorośli biorą ich rewelacje jako wymysły wybujałej dziecięcej wyobraźni. Nikt chłopakom nie wierzy, a dom robi się coraz groźniejszy i coraz bardziej głodny...","popularity":6.2564,"poster_path":"/zCRPr4bkO3ae0U1134vJ39xZnAG.jpg","release_date":"2006-06-30","softcore":false,"video":false,"vote_average":6.71,"vote_count":4327,"credit_id":"55469f38c3a3680cd90074c7","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/g3v4J60R5LjKmMwyv85RrjY8kFD.jpg","genre_ids":[28,12,16],"id":1036956,"title":"Park Jurajski: Obóz Kredowy – Ukryta przygoda","original_language":"en","original_title":"Jurassic World Camp Cretaceous: Hidden Adventure","overview":"Po burzy brakuje pożywienia i wszędzie roi się od wygłodniałych dinozaurów. Ekscytujący program interaktywny, w którym to Ty decydujesz, jak pomóc Obozowej Rodzinie.","popularity":1.6025,"poster_path":"/7ZeqXAT3EXu9uhFXwhyKlH4NAlM.jpg","release_date":"2022-11-15","softcore":false,"video":false,"vote_average":6.65,"vote_count":40,"credit_id":"63742e2546e75f007ba74562","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/tOTtJelsPKX0bvSdvDVL2ou3cGS.jpg","genre_ids":[12,10751,14],"id":267935,"title":"BFG: Bardzo Fajny Gigant","original_language":"en","original_title":"The BFG","overview":"Porywająca opowieść o małej dziewczynce z sierocińca i tajemniczym Olbrzymie, który odkrywa przed nią cuda i sekrety magicznej krainy. W środku nocy, gdy wszyscy ludzie śpią w najlepsze, mroczne istoty wychodzą z ukrycia i przejmują na kilka chwil cały świat. Takie historie od dziecka słyszała rezolutna dziesięciolatka o imieniu Sophie. Nic więc dziwnego, że kiedy dziewczynka pewnej nocy nie mogła zasnąć, wygramoliła się z łóżka, założyła okulary i wychyliła przez okno, by ujrzeć świat w poświacie księżycowego blasku. Znana jej dobrze ulica dziś wyglądała jakoś inaczej… Nagle z cienia wynurzyło się coś ogromnego i zaczęło zmierzać w jej kierunku.","popularity":7.1955,"poster_path":"/5210yKDadAaJKE5wY74m8eb8JdV.jpg","release_date":"2016-06-01","softcore":false,"video":false,"vote_average":6.292,"vote_count":3628,"credit_id":"56a0b1b992514137d6005a05","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":null,"genre_ids":[27,53],"id":1227431,"title":"Long Lost","original_language":"en","original_title":"Long Lost","overview":"","popularity":0.3482,"poster_path":null,"release_date":"","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"6599d34ec995ee0095cede0a","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":null,"genre_ids":[35,16,10402],"id":385920,"title":"I'm Mad","original_language":"en","original_title":"I'm Mad","overview":"","popularity":0.1689,"poster_path":null,"release_date":"1994-03-30","softcore":false,"video":false,"vote_average":6.8,"vote_count":20,"credit_id":"56daea26c3a3684cac00242c","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/ik66StCvdrPcptl1SioAIh2kOEc.jpg","genre_ids":[27,53,10770],"id":391069,"title":"Night Gallery","original_language":"en","original_title":"Night Gallery","overview":"","popularity":1.703,"poster_path":"/rAFY2356u8IYmnyLD4cYJZ7hocL.jpg","release_date":"1969-11-08","softcore":false,"video":false,"vote_average":6.5,"vote_count":23,"credit_id":"5700afc4c3a3686e980049f1","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/z0aeJcWsSI1cVpZ0U1hQ2QaZEp9.jpg","genre_ids":[99],"id":346679,"title":"Auschwitz","original_language":"en","original_title":"Auschwitz","overview":"","popularity":0.4517,"poster_path":"/aAf4Pg4BuN0r4FHQ0N8eXorn3AY.jpg","release_date":"2015-01-27","softcore":false,"video":false,"vote_average":7.4,"vote_count":10,"credit_id":"5714aac8c3a3686521000d89","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/zNriRTr0kWwyaXPzdg1EIxf0BWk.jpg","genre_ids":[878,12,28],"id":1234821,"title":"Jurassic World. Odrodzenie","original_language":"en","original_title":"Jurassic World Rebirth","overview":"Pięć lat po wydarzeniach z Jurassic World Dominion, ekologia planety okazała się w dużej mierze niegościnna dla dinozaurów. Te, które pozostały, żyją w odizolowanych środowiskach równikowych o klimacie przypominającym ten, w którym kiedyś się rozwijały. W międzyczasie tajny zespół dowodzony przez wykwalifikowaną specjalistkę Zorę Bennett (Scarlett Johansson) musi pozyskać materiał genetyczny od trzech najbardziej masywnych dinozaurów na świecie. Dzięki temu wejdą w posiadanie klucza do leku, który przyniesie ludzkości cudowne korzyści ratujące życie. Kiedy spotykają pewną cywilną rodzinę, która uległa wypadkowi podczas żeglarskiej wyprawy, misja się komplikuje i w wyniku niefortunnych zdarzeń wszyscy zostają uwięzieni na wyspie. Wkrótce staną twarzą w twarz ze złowieszczym, szokującym odkryciem, które było ukrywane przed światem przez dziesięciolecia.","popularity":33.9176,"poster_path":"/zsuKNoe7HfDaGf9Nn3FG1SPkG33.jpg","release_date":"2025-06-23","softcore":false,"video":false,"vote_average":6.27,"vote_count":3393,"credit_id":"65aec54d67b61300aff01037","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/my7xPXXv3WkJ3ZynbpsOY28mv9j.jpg","genre_ids":[35,10749],"id":26560,"title":"Przez kontynent","original_language":"en","original_title":"Continental Divide","overview":"Ernie Souchak jest dziennikarzem jednej z gazet w Chicago. Do tego stopnia naraża się mafii, że pewnego dnia jego mieszkanie wybucha. Żeby ochłonął i trochę odpoczął redaktor naczelny jego gazety każe przygotować mu materiał na temat kobiety, która obserwuje obyczaje orłów. W tym celu Ernie wyjeżdża do Colorado, gdzie poznaje bohaterkę swojego artykułu - Nell Porter. Chociaż oboje sprzeczają się na początku, ostatecznie się w sobie zakochują. Niestety Ernie musi wracać do Chicago z powodu tajemniczego morderstwa.","popularity":0.6568,"poster_path":"/jwLFNA10RJBcQ4Fe0SoySkSFr0V.jpg","release_date":"1981-09-18","softcore":false,"video":false,"vote_average":6.091,"vote_count":126,"credit_id":"573afd4f925141150a000292","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/6cKRCRPuOTuoVjsPTyqCX4P1CZW.jpg","genre_ids":[27,878,35],"id":166214,"title":"Plaga zombie: zona mutante: revolución tóxica","original_language":"es","original_title":"Plaga zombie: zona mutante: revolución tóxica","overview":"","popularity":0.8594,"poster_path":"/dKReb8xd1WR2EinjboW87zBmCyD.jpg","release_date":"2012-03-12","softcore":false,"video":false,"vote_average":5.7,"vote_count":14,"credit_id":"65ba9b0290fca3017b092a27","department":"Crew","job":"Thanks"},{"adult":false,"backdrop_path":"/wxr4Z6E83h14CogsZOzDm1vuDX3.jpg","genre_ids":[878,28,12],"id":91314,"title":"Transformers. Wiek zagłady","original_language":"en","original_title":"Transformers: Age of Extinction","overview":"Ludzkość próbuje dojść do siebie po wydarzeniach, które miały miejsce w ostatnim czasie. Zarówno Autoboty, jak i Decepticony praktycznie zniknęły z naszej planety. Mimo to nie wszyscy zapomnieli o ich istnieniu. Grupa naukowców i biznesmenów stara się, jak najwięcej dowiedzieć o technologii Transformerów, co często popycha ich do przekraczania granic, których nigdy nie powinni naruszać. Tymczasem na Ziemię powracają Decepticony i ponownie rozpoczyna się walka dobra ze złem.","popularity":12.0688,"poster_path":"/ihe41FZzQOF36dr7UBBu4uOtI82.jpg","release_date":"2014-06-25","softcore":false,"video":false,"vote_average":5.964,"vote_count":8756,"credit_id":"574f4ed2c3a36879f400028d","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/8nYMPifaBNFbE9RO2173wsFNbdG.jpg","genre_ids":[27,878,35],"id":299540,"title":"DeGenerazione","original_language":"it","original_title":"DeGenerazione","overview":"","popularity":0.5333,"poster_path":"/7pWbHNwY7gkoZzjwLyzPuDFLrmQ.jpg","release_date":"1994-07-15","softcore":false,"video":false,"vote_average":5.875,"vote_count":8,"credit_id":"65c9126b9451e701847c65a0","department":"Crew","job":"Thanks"},{"adult":false,"backdrop_path":null,"genre_ids":[],"id":1061685,"title":"Ultra","original_language":"en","original_title":"Ultra","overview":"","popularity":0.2586,"poster_path":null,"release_date":"","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"639b494dcb9f4b00c6e12274","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/5a7lMDn3nAj2ByO0X1fg6BhUphR.jpg","genre_ids":[12,28,878],"id":333339,"title":"Player One","original_language":"en","original_title":"Ready Player One","overview":"Akcja rozgrywa się w roku 2045, kiedy to świat znajduje się na skraju upadku i pogrążenia się w chaosie. Ludzie znajdują ratunek w OAZIE, ekspansywnym uniwersum rzeczywistości wirtualnej stworzonym przez błyskotliwego ekscentryka Jamesa Hallidaya (Mark Rylance). Przed śmiercią Halliday postanawia przekazać swoją niewyobrażalną fortunę pierwszej osobie, która odnajdzie cyfrowe „wielkanocne jajko” ukryte gdzieś w OAZIE. Rozpoczyna się rywalizacja, która wkrótce ogarnia cały świat. Młody Wade Watts (Tye Sheridan), kiepski kandydat na bohatera, postanawia dołączyć do karkołomnego, zakrzywiającego rzeczywistość wyścigu po skarb w fantastycznym uniwersum pełnym tajemnic, odkryć i niebezpieczeństw.","popularity":12.2961,"poster_path":"/okKPf7AhVAL1zgBdm2g2SVabKlB.jpg","release_date":"2018-03-28","softcore":false,"video":false,"vote_average":7.588,"vote_count":16942,"credit_id":"57948a3e92514179a5000c7d","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/V4ei73IZFuKjz9316gAKI4GAV.jpg","genre_ids":[18,36,10770],"id":347123,"title":"Do końca","original_language":"en","original_title":"All the Way","overview":"Rok 1963. Stanami Zjednoczonymi wstrząsa wiadomość o śmierci uwielbianego prezydenta Johna Kennedy’ego. Zgodnie z konstytucją jego obowiązki przejmuje wiceprezydent Lyndon B. Johnson (Bryan Cranston). Pierwszy rok prezydentury Johnsona jest niezwykle trudny – polityk musi scalić społeczeństwo po dramatycznej śmierci poprzednika, poradzić sobie z trudną sytuacją międzynarodową (wojna w Wietnamie) i utrzymać pokój w kraju targanym niepokojami wewnętrznymi, związanymi z walką Afroamerykanów o prawa obywatelskie.","popularity":1.1516,"poster_path":"/j4AEurmnYoRsA1nHhRK9AE4j2CL.jpg","release_date":"2016-05-23","softcore":false,"video":false,"vote_average":6.654,"vote_count":311,"credit_id":"584ea63e92514118e400e73b","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/kXnTDs4xdEHw2alRsPQgfrtOjek.jpg","genre_ids":[35,878],"id":345115,"title":"Абдуллажон, ёки Стевен Спиелбергга багʻишланади","original_language":"uz","original_title":"Абдуллажон, ёки Стевен Спиелбергга багʻишланади","overview":"","popularity":0.2984,"poster_path":"/m5YEIykxkwER7AgXUrij6We1RQ6.jpg","release_date":"1992-07-13","softcore":false,"video":false,"vote_average":6.1,"vote_count":10,"credit_id":"65df5fb84d23dd0163a073a2","department":"Crew","job":"In Memory Of"},{"adult":false,"backdrop_path":"/4m8yq8vEVGVcmOxO39j1Yz8ry1s.jpg","genre_ids":[10752,99,36],"id":1251636,"title":"Krwawa załoga","original_language":"en","original_title":"The Bloody Hundredth","overview":"Poznaj lotników, którzy byli inspiracją dla twórców „Władców przestworzy”. W tym materiale podniebni weterani 100. Grupy Bombowej snują wciągające historie o przerażających wydarzeniach, które zmieniły ich na zawsze.","popularity":3.8248,"poster_path":"/ijBp0j1rVb804Au5gPFJIIswOWK.jpg","release_date":"2024-03-14","softcore":false,"video":false,"vote_average":7.083,"vote_count":48,"credit_id":"65df63d8b39e3501632fc7c9","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":1079535,"title":"Remembering Stanley Kubrick","original_language":"en","original_title":"Remembering Stanley Kubrick","overview":"","popularity":0.2919,"poster_path":"/3MGGb8w86h5hR1gZrh8LQHIavOy.jpg","release_date":"1999-01-01","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"63d4a0163dc31300c7f8d283","department":"Crew","job":"Thanks"},{"adult":false,"backdrop_path":"/57JocxmicOoAMhkUSmdKBlpZWMT.jpg","genre_ids":[12,28],"id":335977,"title":"Indiana Jones i artefakt przeznaczenia","original_language":"en","original_title":"Indiana Jones and the Dial of Destiny","overview":"1969. Apogeum wyścigu kosmicznego między Stanami Zjednoczonymi a Związkiem Radzieckim. Jones jest zdeterminowany, aby wyjawić nikczemną działalność nazistowskich naukowców licznie stojących za programami kosmicznymi.","popularity":10.3648,"poster_path":"/omZTGZm5wgBFEg6M66koqhm7PDL.jpg","release_date":"2023-06-25","softcore":false,"video":false,"vote_average":6.513,"vote_count":4159,"credit_id":"585e94c392514115c700f680","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/2ormFaKdyP2m8qGcB3cNlk5VjGD.jpg","genre_ids":[18,27,9648,53],"id":2655,"title":"Co Kryje Prawda","original_language":"en","original_title":"What Lies Beneath","overview":"Szczęśliwe małżeństwo, Claire (Michelle Pfeiffer) i Norman (Harrison Ford) Spencerowie, zamieszkuje w nowym domu nad jeziorem. Wyjazd na studia ich córki Caitlin (Katharine Towne) przygnębia Claire, która zaczyna dopatrywać się podejrzanych rzeczy w zachowaniach sąsiadów. Słyszy głosy, widzi odbicie obcej kobiety w wodzie. Im bardziej zagłębia się w rozwiązanie zagadek nawiedzonego domu i tajemniczego zniknięcia sąsiadki, tym bardziej jej szczęście małżeńskie okazuje się pozorne...","popularity":3.7652,"poster_path":"/uj2WqQSg6EXLUY3seJY7iNBPvvr.jpg","release_date":"2000-07-21","softcore":false,"video":false,"vote_average":6.434,"vote_count":2025,"credit_id":"588927f89251416300014725","department":"Writing","job":"Idea"},{"adult":false,"backdrop_path":"/8sb4aBST28vN3rBz704XJczS0Ld.jpg","genre_ids":[18,36],"id":446354,"title":"Czwarta władza","original_language":"en","original_title":"The Post","overview":"Dwoje wydawców dziennika „The Washington Post” Katherine Graham (Meryl Streep) i Ben Bradlee (Tom Hanks) staje na czele bezprecedensowego starcia amerykańskiej prasy z najwyższymi władzami, walcząc o prawo do ujawnienia szokujących tajemnic, przez cztery dekady ukrywanych przez najwyższe władze USA.","popularity":5.9854,"poster_path":"/uEpU98NPVTkJmxXB6tbapOj6TxP.jpg","release_date":"2017-12-22","softcore":false,"video":false,"vote_average":7.0,"vote_count":4915,"credit_id":"58c4316cc3a36853b20000f2","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/8sb4aBST28vN3rBz704XJczS0Ld.jpg","genre_ids":[18,36],"id":446354,"title":"Czwarta władza","original_language":"en","original_title":"The Post","overview":"Dwoje wydawców dziennika „The Washington Post” Katherine Graham (Meryl Streep) i Ben Bradlee (Tom Hanks) staje na czele bezprecedensowego starcia amerykańskiej prasy z najwyższymi władzami, walcząc o prawo do ujawnienia szokujących tajemnic, przez cztery dekady ukrywanych przez najwyższe władze USA.","popularity":5.9854,"poster_path":"/uEpU98NPVTkJmxXB6tbapOj6TxP.jpg","release_date":"2017-12-22","softcore":false,"video":false,"vote_average":7.0,"vote_count":4915,"credit_id":"58c4313ac3a36853360000ff","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/jJ7kAlZN2p9jK5qn6SdIG6iYvxb.jpg","genre_ids":[99,10752],"id":449758,"title":"Five Came Back","original_language":"en","original_title":"Five Came Back","overview":"","popularity":0.9221,"poster_path":"/2XlOc0kQGK9q7Xjq77FLBllppm8.jpg","release_date":"2017-03-31","softcore":false,"video":false,"vote_average":7.9,"vote_count":45,"credit_id":"58e16b68c3a36872ee0041c5","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":null,"genre_ids":[99,28,10752,36],"id":5707,"title":"Shooting War","original_language":"en","original_title":"Shooting War","overview":"","popularity":2.0289,"poster_path":"/81XtyZfL5WFPJXVLUUQP9PQP6Hl.jpg","release_date":"2000-12-07","softcore":false,"video":false,"vote_average":6.389,"vote_count":9,"credit_id":"593f2575c3a3680369002417","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/hljMglukfpnfaNmUgMuORmL4OVW.jpg","genre_ids":[12,16,18,10751],"id":21032,"title":"Balto","original_language":"en","original_title":"Balto","overview":"Film opowiada historię Balto, bezpańskiego psa rasy husky, który w połowie jest wilkiem i jako takiego mieszańca odtrącają go zarówno ludzie, jak i przedstawiciele swojego gatunku. Balto nawiązuje kilka przyjaźni, z gęsią Borisem i dwoma niedźwiedziami polarnymi Mukiem i Lukiem, ale jest szczególnie zwalczany przez przywódcę psiej sfory Steela, z którym rywalizuje o względy pięknej suczki Jenny. Pewnego dnia nawałnica śnieżna odcina od świata wioskę Nome na Alasce, gdzie potrzebne są lekarstwa na zwalczenie epidemii dyfterytu. Kiedy psi zaprzęg, dostarczający antytoksynę grzęźnie w śniegu, Balto staje się jedyną deską ratunku dla mieszkańców wioski.","popularity":3.022,"poster_path":"/dCVcdb5oxDizqFLz0F7TE60NoC9.jpg","release_date":"1995-12-22","softcore":false,"video":false,"vote_average":7.311,"vote_count":2185,"credit_id":"593f24b9c3a3680369002371","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/jUaZAbdpNl33VHprUl4qEohXn8q.jpg","genre_ids":[18,35],"id":228194,"title":"Podróż na sto stóp","original_language":"en","original_title":"The Hundred-Foot Journey","overview":"Dystyngowana Madame Mallory (Helen Mirren) od lat kieruje cenioną restauracją w niewielkiej miejscowości na południu Francji. Sława jej potraw wykracza daleko poza lokalną społeczność. A przyznana lokalowi prestiżowa gwiazdka w słynnym Przewodniku Michelina napawa dumą wszystkich mieszkańców. Pewnego dnia w miasteczku osiada rodzina emigrantów z Bombaju. Gdy przybysze otwierają skromny lokal vis a vis renomowanej restauracji, Madame Malory nie kryje oburzenia wobec ich kulinarnego nieokrzesania. Unoszące się w powietrzu zmysłowe nuty curry, kardamonu i kminu sprawiają jednak, że nowa knajpka zaczyna cieszyć się coraz większym zainteresowaniem. Czy uwodzicielskie smaki Orientu przekonają do życzliwych Hindusów również kuchenną arystokratkę?","popularity":1.783,"poster_path":"/hLPQQI0St3OTR2HolI4Xalwi2l5.jpg","release_date":"2014-08-06","softcore":false,"video":false,"vote_average":7.273,"vote_count":1550,"credit_id":"593fe99f92514105f7000e0a","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/5Kj7EjjbFmpnW4dagWeYs2tmmOL.jpg","genre_ids":[99,10752,36],"id":41327,"title":"Price for Peace","original_language":"en","original_title":"Price for Peace","overview":"","popularity":0.2798,"poster_path":"/kL23b7Wdf30uqpbpi5TTBMVC8sQ.jpg","release_date":"2002-05-27","softcore":false,"video":false,"vote_average":6.75,"vote_count":6,"credit_id":"593fe7a49251414af200f59a","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":null,"genre_ids":[99,18],"id":412258,"title":"Spell Your Name","original_language":"en","original_title":"Spell Your Name","overview":"","popularity":0.1222,"poster_path":"/yEMyoDztQ1Wr4FJQQmuMkZQXmHe.jpg","release_date":"2006-09-01","softcore":false,"video":false,"vote_average":7.6,"vote_count":5,"credit_id":"59414eb59251417a8301891c","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":null,"genre_ids":[878,28,12],"id":1273526,"title":"Untitled Transformers/G.I. Joe Crossover Movie","original_language":"en","original_title":"Untitled Transformers/G.I. Joe Crossover Movie","overview":"","popularity":0.7216,"poster_path":null,"release_date":"","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"661aa9764e4dff017ed1cc6d","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/3pdeJZh0aMYuIhTz0qP5W8oZ1Dq.jpg","genre_ids":[35,10402],"id":55457,"title":"Chcę trzymać cię za rękę","original_language":"en","original_title":"I Wanna Hold Your Hand","overview":"Gdyby przegapiły pierwszy występ Beatlesów w Stanach Zjednoczonych, na pewno byłyby na siebie wściekłe do końca życia. Dlatego czwórka dziewcząt z New Jersey wyrusza na imprezę. Nie obchodzi ich to, że nie mają biletów. One muszą tam być...","popularity":0.7315,"poster_path":"/42FrsGqERVyIUNtjGFTBji2L2Lp.jpg","release_date":"1978-04-01","softcore":false,"video":false,"vote_average":6.3,"vote_count":118,"credit_id":"5935a5b7c3a3685bf9000c36","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/s6ly8laenkHWlIBRkLSfIuEMLC6.jpg","genre_ids":[9648,878,53],"id":1275779,"title":"Dzień objawienia","original_language":"en","original_title":"Disclosure Day","overview":"Gdybyś dowiedział się, że nie jesteśmy sami, gdyby ktoś ci to pokazał i udowodnił, bałbyś się?\r Prezenterka pogody wywołuje panikę i uruchamia falę spekulacji po tym, jak w czasie transmisji na żywo nagle zaczyna mówić w tajemniczym obcym języku. Zaczynają się spekulacje o kontakcie z istotami pozaziemskimi...","popularity":63.8211,"poster_path":"/AsTNDKxTltcNuNjn9COdl9dz4OG.jpg","release_date":"2026-06-10","softcore":false,"video":false,"vote_average":8.1,"vote_count":6,"credit_id":"661ff087ecaef50163f9a434","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":null,"genre_ids":[],"id":1288243,"title":"The Heaven & Earth Grocery Store","original_language":"en","original_title":"The Heaven & Earth Grocery Store","overview":"","popularity":0.193,"poster_path":null,"release_date":"","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"663e1059ab0d3c9f9c512414","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/exnFsbb9c3fDutTsgtJSWcDmZm0.jpg","genre_ids":[18,10749,80],"id":511809,"title":"West Side Story","original_language":"en","original_title":"West Side Story","overview":"USA, lata 50. XX w. Obszar zachodniego wybrzeża Manhattanu staje się polem walki między dwoma gangami. Bernardo to przywódca portorykańskich Sharksów. Ich przeciwnikami są biali Amerykanie zwani Jetsami, na których czele stoi Riff. Tony jest jego przyjacielem i zarazem byłym liderem grupy. Chłopak zakochuje się w Marii, siostrze Bernarda. Zakochani spotykają się potajemne i planują razem uciec. Tymczasem oba gangi szykują się do ostatecznego starcia. Zwycięzca pojedynku przejmie kontrolę nad dzielnicą. Tony i Maria usiłują zapobiec tragedii.","popularity":4.139,"poster_path":"/yfz3IUoYYSY32tkb97HlUBGFsnh.jpg","release_date":"2021-12-08","softcore":false,"video":false,"vote_average":6.915,"vote_count":1781,"credit_id":"664a74b25de992b39095fa1a","department":"Art","job":"Title Designer"},{"adult":false,"backdrop_path":"/cMfokHWle5lfCreoV08cbmkKv6G.jpg","genre_ids":[16,878,12,10751],"id":698687,"title":"Transformers: Początek","original_language":"en","original_title":"Transformers One","overview":"Poznaj historię Optimusa Prime'a i Megatrona, lepiej znanych jako zaprzysięgli wrogowie. Kiedyś byli jednak przyjaciółmi związanymi jak bracia, którzy na zawsze zmienili los Cybertronu.","popularity":10.318,"poster_path":"/9SreQFuTBKRlMOlcfk9c8IkIS12.jpg","release_date":"2024-09-11","softcore":false,"video":false,"vote_average":8.0,"vote_count":1629,"credit_id":"644b03da336e0104c372ff98","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/cuih9Rn2y72KhGkJYSmmkw1Y597.jpg","genre_ids":[27],"id":243688,"title":"Poltergeist","original_language":"en","original_title":"Poltergeist","overview":"Rodzina Bowenów postanawia przeprowadzić się na spokojne przedmieścia. W nowym, pozornie wymarzonym domu zaczynają się dziać dziwne rzeczy. Okazuje się, że niepokojące znaki wiążą się z duchem poltergeist, który wykorzystuje przeciwko domownikom ich największe lęki i zabiera do równoległego świata najmłodszą córkę Bowenów.","popularity":4.1926,"poster_path":"/2WwA746HwYH8tYQp1ftauNjVfX5.jpg","release_date":"2015-05-20","softcore":false,"video":false,"vote_average":5.228,"vote_count":2391,"credit_id":"645e1495d6c30001246b8dcd","department":"Writing","job":"Original Film Writer"},{"adult":false,"backdrop_path":"/rSle4ix2IZ6UMgCDY8L3ngdOmSZ.jpg","genre_ids":[18],"id":558915,"title":"Kolor purpury","original_language":"en","original_title":"The Color Purple","overview":"Opowieść obejmująca dziesięciolecia, opisująca miłość, wytrwałość oraz podróż kobiety ku samodzielności. Mimo licznych trudności, Celie odnajduje niezwykłą siłę i nadzieję w niepodważalnych więzach siostrzanej solidarności.","popularity":2.8007,"poster_path":"/h5bqIxM8GO4TewJ0u6Rzkg58ssJ.jpg","release_date":"2023-12-25","softcore":false,"video":false,"vote_average":6.988,"vote_count":360,"credit_id":"646be891d1857201802e0436","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/1n00NlOGRFZVs8coBxyZLm5l4EC.jpg","genre_ids":[28,12,878],"id":335988,"title":"Transformers. Ostatni rycerz","original_language":"en","original_title":"Transformers: The Last Knight","overview":"Optiums Prime odszedł, a między ludźmi i Transformerami toczy się walka o przetrwanie. Cade Yeager tworzy sojusz z Bumblebee oraz brytyjskim lordem i oksfordzką profesorką, aby dowiedzieć się dlaczego Transformery wciąż wracają na Ziemię.","popularity":9.0708,"poster_path":"/wQ0fXIxOrM9e0BIy7rUbWZmSGwi.jpg","release_date":"2017-06-16","softcore":false,"video":false,"vote_average":6.058,"vote_count":6721,"credit_id":"646c06bb2bcf670172b2af89","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/exnFsbb9c3fDutTsgtJSWcDmZm0.jpg","genre_ids":[18,10749,80],"id":511809,"title":"West Side Story","original_language":"en","original_title":"West Side Story","overview":"USA, lata 50. XX w. Obszar zachodniego wybrzeża Manhattanu staje się polem walki między dwoma gangami. Bernardo to przywódca portorykańskich Sharksów. Ich przeciwnikami są biali Amerykanie zwani Jetsami, na których czele stoi Riff. Tony jest jego przyjacielem i zarazem byłym liderem grupy. Chłopak zakochuje się w Marii, siostrze Bernarda. Zakochani spotykają się potajemne i planują razem uciec. Tymczasem oba gangi szykują się do ostatecznego starcia. Zwycięzca pojedynku przejmie kontrolę nad dzielnicą. Tony i Maria usiłują zapobiec tragedii.","popularity":4.139,"poster_path":"/yfz3IUoYYSY32tkb97HlUBGFsnh.jpg","release_date":"2021-12-08","softcore":false,"video":false,"vote_average":6.915,"vote_count":1781,"credit_id":"5aa9a77a9251410564000612","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/7sPSK3EFpCiCy5klJ7ahqeRfM25.jpg","genre_ids":[16,10770,35,10751],"id":203848,"title":"Tiny Toon Spring Break","original_language":"en","original_title":"Tiny Toon Spring Break","overview":"","popularity":1.3514,"poster_path":"/gAn2iQ8CtTC9uCdzczfMS2dFBmd.jpg","release_date":"1994-03-27","softcore":false,"video":false,"vote_average":6.516,"vote_count":32,"credit_id":"5ab81e6c925141395e02237f","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/hp5QR9qSzvu9SGgx8gXE0TOLEVS.jpg","genre_ids":[16,10751,35,10770,27],"id":203847,"title":"Tiny Toon Night Ghoulery","original_language":"en","original_title":"Tiny Toon Night Ghoulery","overview":"","popularity":1.0797,"poster_path":"/js7O06FmO3y1e0MUifdA6yuSNLY.jpg","release_date":"1995-05-28","softcore":false,"video":false,"vote_average":6.338,"vote_count":40,"credit_id":"5ab8240a925141395b022920","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/6WA9stUMbIkEPxn3D5SWlA8FIi7.jpg","genre_ids":[12,878,53],"id":351286,"title":"Jurassic World: Upadłe Królestwo","original_language":"en","original_title":"Jurassic World: Fallen Kingdom","overview":"Mijają już cztery lata od chwili, gdy park rozrywki i luksusowy kurort Jurassic World został zniszczony przez dinozaury, które wymknęły się spod kontroli. \"Isla Nublar\" jest miejscem opuszczonym przez ludzi, ze swobodnie żyjącymi dinozaurami. Kiedy jednak uśpiony wulkan na wyspie budzi się do życia, Owen i Claire rozpoczynają kampanię na rzecz ocalenia dinozaurów z wyspy przed zagładą.","popularity":10.6417,"poster_path":"/zk03qvmvgu25q1SJiXqxfKbFFSl.jpg","release_date":"2018-06-06","softcore":false,"video":false,"vote_average":6.531,"vote_count":12766,"credit_id":"5abb63b3c3a368435f00e60c","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/5qsyqA7FeYRymBmNbPBqBgqWPO4.jpg","genre_ids":[12,35,10751],"id":9340,"title":"Goonies","original_language":"en","original_title":"The Goonies","overview":"Nastolatek Mikey Walsh znajduje w teczce ojca starą mapę do skarbów. W nadziei ocalenia domu przed rozbiórką, Mikey i jego przyjaciele Data Wang, Chunk Cohen, i Mouth Deveraux uciekają ku wielkiej przygodzie by znaleźć ukryty skarb Jednookiego Willa.","popularity":9.5116,"poster_path":"/eBU7gCjTCj9n2LTxvCSIXXOvHkD.jpg","release_date":"1985-06-07","softcore":false,"video":false,"vote_average":7.515,"vote_count":6236,"credit_id":"5ac10129c3a3682d6600813f","department":"Writing","job":"Story"},{"adult":false,"backdrop_path":null,"genre_ids":[18],"id":1307214,"title":"James","original_language":"en","original_title":"James","overview":"","popularity":0.2571,"poster_path":null,"release_date":"","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"6674bd83f578921f4c28d750","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/hMANgfPHR1tRObNp2oPiOi9mMlz.jpg","genre_ids":[28,12,878],"id":424783,"title":"Bumblebee","original_language":"en","original_title":"Bumblebee","overview":"Rok 1987. Na jednej z kalifornijskich plaż Bumblebee znajduje azyl na złomowisku. Tymczasem Charlie, dziewczyna u progu dorosłości, próbuje zrozumieć świat, wciąż szukając w nim dla siebie miejsca i roli. Na wspomnianym złomowisku znajduje zdezelowanego, rdzewiejącego Bumblebee. Kiedy udaje jej się go odrestaurować, szybko orientuje się, że Bumblebee nie jest zwykłym żółtym \"garbusem\".","popularity":7.5182,"poster_path":"/fw02ONlDhrYjTSZV8XO6hhU3ds3.jpg","release_date":"2018-11-22","softcore":false,"video":false,"vote_average":6.72,"vote_count":6631,"credit_id":"5ac489b6c3a3682d9a04794a","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/58D6ZAvOKxlHjyX9S8qNKSBE9Y.jpg","genre_ids":[28,53],"id":718821,"title":"Twisters","original_language":"en","original_title":"Twisters","overview":"Była łowczyni burz, dręczona wspomnieniami związanymi z tornadami, powraca do Oklahomy. Tam ponownie musi stawić czoła nadchodzącej katastrofie.","popularity":8.7308,"poster_path":"/q0q1MwuQqFFdXgXHfVGcn4gs1Zv.jpg","release_date":"2024-07-10","softcore":false,"video":false,"vote_average":6.8,"vote_count":2989,"credit_id":"6685fd283135969e6ff049b6","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":null,"genre_ids":[10770],"id":1126932,"title":"Vanessa in the Garden","original_language":"en","original_title":"Vanessa in the Garden","overview":"","popularity":0.5748,"poster_path":"/sVgi4d0p3oFd1nhnE4dM1mkxrIK.jpg","release_date":"1985-12-29","softcore":false,"video":false,"vote_average":6.0,"vote_count":1,"credit_id":"648be9e5c3c89100cad93c95","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":null,"genre_ids":[10770],"id":1126932,"title":"Vanessa in the Garden","original_language":"en","original_title":"Vanessa in the Garden","overview":"","popularity":0.5748,"poster_path":"/sVgi4d0p3oFd1nhnE4dM1mkxrIK.jpg","release_date":"1985-12-29","softcore":false,"video":false,"vote_average":6.0,"vote_count":1,"credit_id":"648bea2f42bf01011e721311","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/et0G74BxoBgNQEZBkUcVhsgeRFF.jpg","genre_ids":[18,10749,10402],"id":523607,"title":"Maestro","original_language":"en","original_title":"Maestro","overview":"Ta opowieść miłosna stanowi kronikę trwającej całe życie skomplikowanej relacji legendy muzyki Leonarda Bernsteina i Felicii Montealegre Cohn Bernstein.","popularity":1.9585,"poster_path":"/qC2AOV4HMzxNeoq4UJHdE1ySAAj.jpg","release_date":"2023-11-22","softcore":false,"video":false,"vote_average":6.266,"vote_count":839,"credit_id":"5b0b499a9251411d8900f43d","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/exnFsbb9c3fDutTsgtJSWcDmZm0.jpg","genre_ids":[18,10749,80],"id":511809,"title":"West Side Story","original_language":"en","original_title":"West Side Story","overview":"USA, lata 50. XX w. Obszar zachodniego wybrzeża Manhattanu staje się polem walki między dwoma gangami. Bernardo to przywódca portorykańskich Sharksów. Ich przeciwnikami są biali Amerykanie zwani Jetsami, na których czele stoi Riff. Tony jest jego przyjacielem i zarazem byłym liderem grupy. Chłopak zakochuje się w Marii, siostrze Bernarda. Zakochani spotykają się potajemne i planują razem uciec. Tymczasem oba gangi szykują się do ostatecznego starcia. Zwycięzca pojedynku przejmie kontrolę nad dzielnicą. Tony i Maria usiłują zapobiec tragedii.","popularity":4.139,"poster_path":"/yfz3IUoYYSY32tkb97HlUBGFsnh.jpg","release_date":"2021-12-08","softcore":false,"video":false,"vote_average":6.915,"vote_count":1781,"credit_id":"5bce374c925141057400522f","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/tFRjxakgJqErlmWz6FfipiF4VIF.jpg","genre_ids":[9648,99,80,36],"id":442236,"title":"Finding Oscar","original_language":"en","original_title":"Finding Oscar","overview":"","popularity":0.1598,"poster_path":"/btoiZliAR7NTtxzRBOpReKaOCcC.jpg","release_date":"2016-09-03","softcore":false,"video":false,"vote_average":7.7,"vote_count":12,"credit_id":"5bce3b7d9251410574005639","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/meUCKOMgrkNzZhojAnUDpfV9XS7.jpg","genre_ids":[99,18,10752],"id":167966,"title":"Voices from the List","original_language":"en","original_title":"Voices from the List","overview":"","popularity":0.2559,"poster_path":"/vDaZo3DHytTcawVVKUPP34MrbsX.jpg","release_date":"2004-03-09","softcore":false,"video":false,"vote_average":6.864,"vote_count":11,"credit_id":"5bce3c189251410587005a3d","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/66jPR8KMmdGzo8wa4VsSDevLTAf.jpg","genre_ids":[18],"id":21291,"title":"Tato","original_language":"en","original_title":"Dad","overview":"Po tym, jak matka Johna niespodziewanie trafia do szpitala, mężczyzna musi zaopiekować się zniedołężniałym ojcem, próbując nauczyć go samodzielności i rozbudzić w nim chęć życia.","popularity":1.4151,"poster_path":"/l43BVUdXxbsSt3stBgiW53Dql1n.jpg","release_date":"1989-10-27","softcore":false,"video":false,"vote_average":6.387,"vote_count":111,"credit_id":"5bce32b20e0a265d31005541","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/5dwlH8Krm2bsuc2Pubw2cBb03g5.jpg","genre_ids":[18,12,37],"id":44264,"title":"Prawdziwe Męstwo","original_language":"en","original_title":"True Grit","overview":"Czternastoletnia Mattie Ross nie może pozbierać się po śmierci ojca i zrobi wszystko, żeby dopaść jego mordercę, którym jest tchórzliwy Tom Chaney. Dziewczyna zgłasza się po pomoc do najtwardszego szeryfa w Stanach Zjednoczonych, \"Roostera\". Mattie wyrusza z nim na poszukiwanie zbrodniarza. Przyłącza się do nich teksański strażnik LaBoeuf. Trop wiedzie ich na terytorium Indian, gdzie będą musieli się zmierzyć z problemami.","popularity":5.2172,"poster_path":"/qtPJTMSp4agnjBGPKck0gBGRpAK.jpg","release_date":"2010-12-22","softcore":false,"video":false,"vote_average":7.306,"vote_count":5757,"credit_id":"5bce3647925141056f005256","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":409933,"title":"A Holocaust szemei","original_language":"hu","original_title":"A Holocaust szemei","overview":"","popularity":0.2447,"poster_path":null,"release_date":"2000-01-01","softcore":false,"video":false,"vote_average":6.0,"vote_count":4,"credit_id":"5bce3ba2925141056f005870","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":null,"genre_ids":[99,10770],"id":360879,"title":"Survivors of the Holocaust","original_language":"en","original_title":"Survivors of the Holocaust","overview":"","popularity":0.0841,"poster_path":null,"release_date":"1996-01-08","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"5bce38f80e0a265d440058ce","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/f2z00VIPyrrfFabw0RnoY5M8uYt.jpg","genre_ids":[18,14],"id":44603,"title":"Medium","original_language":"en","original_title":"Hereafter","overview":"Drogi życiowe trzech osób boleśnie doświadczonych przez śmierć, przecinają się w poszukiwaniu prawdy. Obdarzony wyjątkowymi zdolnościami George (Matt Damon), francuska reporterka (Cécile De France) oraz uczeń londyńskiej szkoły - przechodzą metamorfozę przekonani, że musi istnieć \"coś\" po śmierci.","popularity":2.483,"poster_path":"/3dCF8LPKjASZTopgFpTegqazZmE.jpg","release_date":"2010-10-22","softcore":false,"video":false,"vote_average":6.143,"vote_count":1814,"credit_id":"5bce35480e0a265d40005947","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/zT0gHcGOXEtVd0K4MIiByIq9jf0.jpg","genre_ids":[10770,53,18],"id":348536,"title":"Locke & Key","original_language":"en","original_title":"Locke & Key","overview":"","popularity":0.723,"poster_path":"/55gcNVeDdgFrV9RYk8Z2Ex58rfe.jpg","release_date":"2011-01-01","softcore":false,"video":false,"vote_average":6.9,"vote_count":38,"credit_id":"5bce3982c3a3683d63005ff8","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/bSvegZGcIA2ipKgPfKu2YQp0EtK.jpg","genre_ids":[99,36],"id":20595,"title":"The Last Days","original_language":"en","original_title":"The Last Days","overview":"","popularity":0.6022,"poster_path":"/kWr6QDDcO2HHKqvJvgsJ1hQz4Gs.jpg","release_date":"1998-10-23","softcore":false,"video":false,"vote_average":7.406,"vote_count":101,"credit_id":"5bce3bc1c3a3683d6f005801","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/mC6cE2M2UtGPTE0WdmOV12dgPgP.jpg","genre_ids":[99],"id":1358,"title":"A Brief History of Time","original_language":"en","original_title":"A Brief History of Time","overview":"","popularity":0.652,"poster_path":"/A3sVrDThz8Xthfq2EglWoypKEfU.jpg","release_date":"1991-10-01","softcore":false,"video":false,"vote_average":7.2,"vote_count":126,"credit_id":"5bce3becc3a3683d66005bbc","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/jrudoaXcoLyHRPdolyOGemXgPEs.jpg","genre_ids":[36,18],"id":369972,"title":"Pierwszy człowiek","original_language":"en","original_title":"First Man","overview":"Damien Chazelle i Ryan Gosling łączą siły w historycznej opowieści o misji NASA, dzięki której na Księżycu wylądował człowiek. Film skupia się na życiu Neila Armstronga w latach 1961-1969. „Pierwszy Człowiek” to wstrząsająca, opowiedziana w pierwszej osobie historia na podstawie książki Jamesa R. Hansena. Zapis trudu, wyrzeczeń i poświęcenia, które wiązały się z jedną z najbardziej niebezpiecznych misji w historii ludzkości.  [opis dystrybutora Blu-ray]","popularity":5.3899,"poster_path":"/mH6GfuyV3thTglqcrt4OAjENqTx.jpg","release_date":"2018-10-10","softcore":false,"video":false,"vote_average":7.042,"vote_count":5660,"credit_id":"5bce36f9c3a3683d5a005826","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/lMLyfSiaumaKniwynwAxu69CLTz.jpg","genre_ids":[18,10749,36],"id":858024,"title":"Hamnet","original_language":"en","original_title":"Hamnet","overview":"Poruszająca historia miłości Williama, ambitnego dramaturga i jego żony Agnes. Ich idylliczne życie zostaje zburzone, gdy wybucha epidemia dżumy, która dotyka ich dzieci, Hamneta i Judith. Po latach William pisze nową sztukę zatytułowaną Hamlet, aby poradzić sobie z żałobą.","popularity":16.4823,"poster_path":"/zIcd6yuBucRNof5t9KVuGBHIhXU.jpg","release_date":"2025-11-26","softcore":false,"video":false,"vote_average":7.744,"vote_count":1368,"credit_id":"66c4ce49818bd63d7b712587","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/7jzCLnt5IDGDHhNAKTfbq1In4dM.jpg","genre_ids":[99,10402],"id":1076708,"title":"Muzyka filmowa: John Williams","original_language":"en","original_title":"Music by John Williams","overview":"Jego niezapomniana muzyka stanowi nieodłączny element najsłynniejszych filmów z kilku dekad. Zobacz i usłysz historię mistrza Johna Williamsa wzbogaconą o rozmowy z twórcami, muzykami i osobami, które zainspirował, a także zajrzyj za kulisy historii kinematografii.","popularity":1.185,"poster_path":"/fFNnqLiMfG1CG2c2Pu16SxotD7E.jpg","release_date":"2024-11-01","softcore":false,"video":false,"vote_average":8.012,"vote_count":84,"credit_id":"66c795911ca86e197229a232","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/cl2PJfdyV1PlmNvzsSEsajUCbHQ.jpg","genre_ids":[10770,14,27],"id":576510,"title":"Amazing Stories","original_language":"en","original_title":"Amazing Stories","overview":"","popularity":1.5952,"poster_path":"/8XJb9oEnpLtMoOx4Za6JVMA8vqy.jpg","release_date":"1986-07-10","softcore":false,"video":false,"vote_average":6.3,"vote_count":30,"credit_id":"5c445f3cc3a3681a06246edf","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/uK9uFbAwQ1s2JHKkJ5l0obPTcXI.jpg","genre_ids":[35,878,28,12],"id":479455,"title":"Men in Black: International","original_language":"en","original_title":"Men in Black: International","overview":"Jednostki Men in Black są już na całym świecie. Ale podobnie rozprzestrzeniły się na nim szumowiny z kosmosu. Dlatego, abyśmy byli bezpieczni, doświadczony agent H i zdeterminowana początkująca agentka M zostają połączeni w parę. Jego doświadczenie i jej upór mogą być naprawdę skuteczne. Ale na Ziemi pojawił się nowy obcy, który może przybrać dowolną formę, nawet wcielić się w agenta MIB. Dlatego, by ocalić świat i agencję, współpraca agentów H i M musi być naprawdę skuteczna. \"Men in Black: International\" to zupełnie nowi agenci, nowe przygody, miejsca i obcy, wreszcie nowa skuteczniejsza broń.","popularity":5.9999,"poster_path":"/hmS4NWaLitfABKqiG0XB5Rvwb5E.jpg","release_date":"2019-06-12","softcore":false,"video":false,"vote_average":5.9,"vote_count":5356,"credit_id":"5c7276820e0a262c1f7d5519","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/5qsyqA7FeYRymBmNbPBqBgqWPO4.jpg","genre_ids":[12,35,10751],"id":9340,"title":"Goonies","original_language":"en","original_title":"The Goonies","overview":"Nastolatek Mikey Walsh znajduje w teczce ojca starą mapę do skarbów. W nadziei ocalenia domu przed rozbiórką, Mikey i jego przyjaciele Data Wang, Chunk Cohen, i Mouth Deveraux uciekają ku wielkiej przygodzie by znaleźć ukryty skarb Jednookiego Willa.","popularity":9.5116,"poster_path":"/eBU7gCjTCj9n2LTxvCSIXXOvHkD.jpg","release_date":"1985-06-07","softcore":false,"video":false,"vote_average":7.515,"vote_count":6236,"credit_id":"5cef0d7c0e0a264146ca1d0f","department":"Crew","job":"Presenter"},{"adult":false,"backdrop_path":"/cl2PJfdyV1PlmNvzsSEsajUCbHQ.jpg","genre_ids":[10770,14,27],"id":576510,"title":"Amazing Stories","original_language":"en","original_title":"Amazing Stories","overview":"","popularity":1.5952,"poster_path":"/8XJb9oEnpLtMoOx4Za6JVMA8vqy.jpg","release_date":"1986-07-10","softcore":false,"video":false,"vote_average":6.3,"vote_count":30,"credit_id":"5d2879d7caab6d7ddb9556c6","department":"Writing","job":"Story"},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":705267,"title":"The Music of E.T.: A Discussion with John Williams","original_language":"en","original_title":"The Music of E.T.: A Discussion with John Williams","overview":"","popularity":0.187,"poster_path":"/AsQBnPagtzaN3xUmMQCT7ESB2bM.jpg","release_date":"2002-01-01","softcore":false,"video":false,"vote_average":5.0,"vote_count":1,"credit_id":"5ec1300a3d3557001ee58e4c","department":"Crew","job":"Thanks"},{"adult":false,"backdrop_path":"/698FjyzLdpgXmUSr63LaRwblTmx.jpg","genre_ids":[12,878,53],"id":507086,"title":"Jurassic World: Dominion","original_language":"en","original_title":"Jurassic World Dominion","overview":"Dinozaury żyjące wśród ludzi czeka nieuchronna katastrofa, aby je ocalić, bohaterowie — zarówno starzy, jak i nowi — po raz kolejny przeżywają ekscytującą przygodę.","popularity":12.5883,"poster_path":"/3i5rHe44lA2wwkC4Bmpxcc575H7.jpg","release_date":"2022-06-01","softcore":false,"video":false,"vote_average":6.598,"vote_count":7058,"credit_id":"5ef319762b210800359055ef","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/ozIhpAb69vQahq5obDlRGP87Y0m.jpg","genre_ids":[99],"id":503210,"title":"Return to Jurassic Park","original_language":"en","original_title":"Return to Jurassic Park","overview":"","popularity":0.9651,"poster_path":"/mPyu59cDdmMDDW9IOtfjVlM0THd.jpg","release_date":"2011-02-05","softcore":false,"video":false,"vote_average":6.586,"vote_count":846,"credit_id":"5f89bb501443f40037c73311","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/ozIhpAb69vQahq5obDlRGP87Y0m.jpg","genre_ids":[99],"id":503210,"title":"Return to Jurassic Park","original_language":"en","original_title":"Return to Jurassic Park","overview":"","popularity":0.9651,"poster_path":"/mPyu59cDdmMDDW9IOtfjVlM0THd.jpg","release_date":"2011-02-05","softcore":false,"video":false,"vote_average":6.586,"vote_count":846,"credit_id":"5f89bb6323851300353cc385","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/ozIhpAb69vQahq5obDlRGP87Y0m.jpg","genre_ids":[99],"id":503210,"title":"Return to Jurassic Park","original_language":"en","original_title":"Return to Jurassic Park","overview":"","popularity":0.9651,"poster_path":"/mPyu59cDdmMDDW9IOtfjVlM0THd.jpg","release_date":"2011-02-05","softcore":false,"video":false,"vote_average":6.586,"vote_count":846,"credit_id":"5f89bb751443f40037c7334c","department":"Crew","job":"Presenter"},{"adult":false,"backdrop_path":"/fsop0LLsBaU1HfnlIn22PKFIpDw.jpg","genre_ids":[10770,18,36],"id":553087,"title":"Oslo","original_language":"en","original_title":"Oslo","overview":"Film nakręcony na podstawie sztuki o tym samym tytule autorstwa J.T. Rogersa, przedstawia opartą na prawdziwych wydarzeniach opowieść o tajnych negocjacjach między nieprzejednanymi wrogami. Obraz podąża za tajnymi zakulisowymi rozmowami, nieprawdopodobnymi przyjaźniami i sojuszami, jakie zawiązały się w małej, ale zaangażowanej grupie składającej się z Izraelczyków, Palestyńczyków oraz jednej norweskiej pary, które ostatecznie doprowadziły do podpisania Porozumień z Oslo w 1993 roku.","popularity":1.53,"poster_path":"/tULZeNNlwLvXPdQpERfrfYyZfTC.jpg","release_date":"2021-05-29","softcore":false,"video":false,"vote_average":6.536,"vote_count":111,"credit_id":"5faa5f631d019100427b629f","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/pM4tWr37Y2cOB0mVGmvbshKpvmP.jpg","genre_ids":[28,35,878],"id":2614,"title":"Interkosmos","original_language":"en","original_title":"Innerspace","overview":"Porucznik sił powietrznych armii USA, Tuck Pendelton (Dennis Quaid), zostaje wyrzucony z wojska za pijaństwo. Zrozpaczony wyraża zgodę na wzięcie udziału w eksperymencie miniaturyzacji w laboratorium doktora Wexlera (John Hora). Na rewelacyjny wynalazek polują szpiedzy przemysłowi. Ich nieoczekiwany atak powoduje, że miniaturowa łódź podwodna z umieszczonym w środku Pendeltonem zostaje wstrzyknięta do ludzkiego ciała przypadkowego przechodnia Jacka Puttera (Martin Short). Rozpoczyna się pełna przygód i niebezpieczeństw wędrówka po zakamarkach ludzkiego ciała (i nie tylko).","popularity":4.1063,"poster_path":"/cBoy4TpjECnUyF5zYwE0tav4eIn.jpg","release_date":"1987-07-01","softcore":false,"video":false,"vote_average":6.819,"vote_count":1399,"credit_id":"5fcdb3876af8f8003c0846e8","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":null,"genre_ids":[99,36],"id":793912,"title":"The Unfinished Journey","original_language":"en","original_title":"The Unfinished Journey","overview":"","popularity":0.72,"poster_path":"/iwOxkJJAFZhRHb97drDzaRtm6WW.jpg","release_date":"1999-12-31","softcore":false,"video":false,"vote_average":6.5,"vote_count":4,"credit_id":"601db575202e1100415a99bf","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/xQyGkQ8ICa4lgifGr3oZjkm3AJ2.jpg","genre_ids":[18],"id":804095,"title":"Fabelmanowie","original_language":"en","original_title":"The Fabelmans","overview":"Steven Spielberg wraca do czasów swojego dzieciństwa, by opowiedzieć o dorastaniu Sammy’ego Fabelmana, wrażliwego nastolatka, wielkiego miłośnika kina i poczatkującego filmowca. Sammy przypadkiem poznaje dramatyczną rodzinną tajemnicę i odkrywa przy okazji, że kino w niezwykły sposób pomaga nam odkrywać prawdę o naszych bliskich i o nas samych.","popularity":4.7227,"poster_path":"/l6kO7x34XjFtN2RDmuHWqd5QDBc.jpg","release_date":"2022-11-11","softcore":false,"video":false,"vote_average":7.57,"vote_count":2769,"credit_id":"6047b8ab54508d0077575f79","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":null,"genre_ids":[18],"id":1250073,"title":"Cola Wars","original_language":"en","original_title":"Cola Wars","overview":"","popularity":0.449,"poster_path":null,"release_date":"","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"66e1ee26c45fb90c6f20f266","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/s6ly8laenkHWlIBRkLSfIuEMLC6.jpg","genre_ids":[9648,878,53],"id":1275779,"title":"Dzień objawienia","original_language":"en","original_title":"Disclosure Day","overview":"Gdybyś dowiedział się, że nie jesteśmy sami, gdyby ktoś ci to pokazał i udowodnił, bałbyś się?\r Prezenterka pogody wywołuje panikę i uruchamia falę spekulacji po tym, jak w czasie transmisji na żywo nagle zaczyna mówić w tajemniczym obcym języku. Zaczynają się spekulacje o kontakcie z istotami pozaziemskimi...","popularity":63.8211,"poster_path":"/AsTNDKxTltcNuNjn9COdl9dz4OG.jpg","release_date":"2026-06-10","softcore":false,"video":false,"vote_average":8.1,"vote_count":6,"credit_id":"66ebbe2582ff873f7d1fb249","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/hfRllpqjLJfD2s78OVj0KCaGPQN.jpg","genre_ids":[99,10752,10770],"id":235199,"title":"We Stand Alone Together: The Men of Easy Company","original_language":"en","original_title":"We Stand Alone Together: The Men of Easy Company","overview":"","popularity":1.1303,"poster_path":"/sB1gxrDCLp9ikxDzMEzraVKrTnj.jpg","release_date":"2001-11-10","softcore":false,"video":false,"vote_average":7.366,"vote_count":41,"credit_id":"66f2ac2c7300a5ba213bf223","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/8z8uPdpCBxGMQQGr8IfxRSbXNFs.jpg","genre_ids":[27,14,878],"id":15301,"title":"Strefa mroku","original_language":"en","original_title":"Twilight Zone: The Movie","overview":"Film nakręcony w hołdzie dla ulubionego przez S. Spielberga serialu telewizyjnego z lat 60' \"The Twilight Zone\", złożony z czterech nowel. Nowele mają charakter grozy, a łączy je wspólny temat powrotu do czasów młodości przez mieszkańców domu opieki. [opis dystrybutora dvd]","popularity":2.5969,"poster_path":"/sDWARc5aYTUKE8Y2FIGVgWXuI4K.jpg","release_date":"1983-06-24","softcore":false,"video":false,"vote_average":6.485,"vote_count":807,"credit_id":"66fa5ecf07821b65365b10d8","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/8z8uPdpCBxGMQQGr8IfxRSbXNFs.jpg","genre_ids":[27,14,878],"id":15301,"title":"Strefa mroku","original_language":"en","original_title":"Twilight Zone: The Movie","overview":"Film nakręcony w hołdzie dla ulubionego przez S. Spielberga serialu telewizyjnego z lat 60' \"The Twilight Zone\", złożony z czterech nowel. Nowele mają charakter grozy, a łączy je wspólny temat powrotu do czasów młodości przez mieszkańców domu opieki. [opis dystrybutora dvd]","popularity":2.5969,"poster_path":"/sDWARc5aYTUKE8Y2FIGVgWXuI4K.jpg","release_date":"1983-06-24","softcore":false,"video":false,"vote_average":6.485,"vote_count":807,"credit_id":"66fa608d606b595d9fcfffe1","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/s6ly8laenkHWlIBRkLSfIuEMLC6.jpg","genre_ids":[9648,878,53],"id":1275779,"title":"Dzień objawienia","original_language":"en","original_title":"Disclosure Day","overview":"Gdybyś dowiedział się, że nie jesteśmy sami, gdyby ktoś ci to pokazał i udowodnił, bałbyś się?\r Prezenterka pogody wywołuje panikę i uruchamia falę spekulacji po tym, jak w czasie transmisji na żywo nagle zaczyna mówić w tajemniczym obcym języku. Zaczynają się spekulacje o kontakcie z istotami pozaziemskimi...","popularity":63.8211,"poster_path":"/AsTNDKxTltcNuNjn9COdl9dz4OG.jpg","release_date":"2026-06-10","softcore":false,"video":false,"vote_average":8.1,"vote_count":6,"credit_id":"673ba7b22f1ca2baf347941d","department":"Writing","job":"Story"},{"adult":false,"backdrop_path":"/wG3r7SxR8TMhyXKk2jincWByBXY.jpg","genre_ids":[16,10402,35,12,18,10751,14],"id":73901,"title":"Animaniacy: Życzenie Wakko","original_language":"en","original_title":"Animaniacs: Wakko's Wish","overview":"Rodzeństwo Yakko, Wakko i Dot mieszka w Acme Falls - miasteczku w królestwie Warnerstock. Po śmierci władcy Williama kraj ogarnia wojna domowa. Z sytuacji korzysta sąsiednie królestwo Ticktockii, przejmując kontrolę w Warnerstock i radykalnie podwyższając podatki. Z nieba spada na teren okolicznych gór czarodziejska gwiazdka. Kto dotknie jej pierwszy, ten może wypowiedzieć życzenie. Wakko, Yakko i Dot wyruszają na magiczną wyprawę, aby zdobyć gwiazdkę. Muszą się spieszyć, ponieważ władca Ticktockii wysyła po gwiazdkę całą armię.","popularity":1.0309,"poster_path":"/lNVhFOzd939TlI9r1uKVZKrmKFn.jpg","release_date":"1999-12-20","softcore":false,"video":false,"vote_average":7.496,"vote_count":116,"credit_id":"67b9c479a23929ac28beabc6","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/pM4tWr37Y2cOB0mVGmvbshKpvmP.jpg","genre_ids":[28,35,878],"id":2614,"title":"Interkosmos","original_language":"en","original_title":"Innerspace","overview":"Porucznik sił powietrznych armii USA, Tuck Pendelton (Dennis Quaid), zostaje wyrzucony z wojska za pijaństwo. Zrozpaczony wyraża zgodę na wzięcie udziału w eksperymencie miniaturyzacji w laboratorium doktora Wexlera (John Hora). Na rewelacyjny wynalazek polują szpiedzy przemysłowi. Ich nieoczekiwany atak powoduje, że miniaturowa łódź podwodna z umieszczonym w środku Pendeltonem zostaje wstrzyknięta do ludzkiego ciała przypadkowego przechodnia Jacka Puttera (Martin Short). Rozpoczyna się pełna przygód i niebezpieczeństw wędrówka po zakamarkach ludzkiego ciała (i nie tylko).","popularity":4.1063,"poster_path":"/cBoy4TpjECnUyF5zYwE0tav4eIn.jpg","release_date":"1987-07-01","softcore":false,"video":false,"vote_average":6.819,"vote_count":1399,"credit_id":"67fd72d99d1f778ab8993cc6","department":"Crew","job":"Presenter"},{"adult":false,"backdrop_path":"/sXfQGa7juaTpZ5IF17Xa6hI53nx.jpg","genre_ids":[10751,16,12],"id":12144,"title":"Pradawny ląd","original_language":"en","original_title":"The Land Before Time","overview":"Zanim ruszył czas Ziemia była zamieszkana przez dinozaury. Z powodu suszy wszystkie stworzenia podążają do Wiecznie Zielonej Doliny, gdzie nie brakuje ani wody, ani zawsze pokrytych liśćmi drzew. Osierocony mały brontozaur Stopka wraz z zadziorną Sarą, mądrą Ducky, skrzydlatym Petrie i leniwym Spike'em muszą odnaleźć drogę do wymarzonej krainy i stawić czoła wielu niebezpieczeństowom, w tym krwiożerczemu Tyranozaurusowi. Długa podróż stanie się dla nich wszystkich nauką o przetrwaniu, przyjaźni i wzajemnej pomocy.","popularity":4.6258,"poster_path":"/xsPBgPDvCe1frfFAapa0kHc8oIV.jpg","release_date":"1988-11-18","softcore":false,"video":false,"vote_average":7.15,"vote_count":2750,"credit_id":"67fd73ac437f0b80eead0f4b","department":"Crew","job":"Presenter"},{"adult":false,"backdrop_path":null,"genre_ids":[14,27],"id":1309288,"title":"Amazing Stories: The Movie II","original_language":"en","original_title":"Amazing Stories: The Movie II","overview":"","popularity":0.5546,"poster_path":"/hbUxPympZYzP4oJISUOYHZD3oRf.jpg","release_date":"1990-11-25","softcore":false,"video":true,"vote_average":0.0,"vote_count":0,"credit_id":"687e6465cf7126cd5af76af6","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/qZ8t05qidOjhSSsaByxxpu6CKOH.jpg","genre_ids":[35,10749],"id":2565,"title":"Joe kontra wulkan","original_language":"en","original_title":"Joe Versus the Volcano","overview":"Milioner Graynamore (Lloyd Bridges) chce zdobyć rzadki minerał z wyspy Waponi. Mieszkańcy wyspy żądają za niego żywej ofiary dla swojego bóstwa drzemiącego na dnie wulkanu. Joe (Tom Hanks), hipochondryk i pechowiec przekonany, że jest śmiertelnie chory, za pełną wrażeń i luksusową podróż, zgadza się dokonać swego żywota w wulkanie.[filmweb.pl]","popularity":1.9417,"poster_path":"/fwjMUuDZUxedfsUpVQKQN8cYfzB.jpg","release_date":"1990-03-09","softcore":false,"video":false,"vote_average":5.804,"vote_count":581,"credit_id":"68e3d3a071e86f77e5961b32","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":685277,"title":"Drew Struzan: An Appreciation of An Artist","original_language":"en","original_title":"Drew Struzan: An Appreciation of An Artist","overview":"","popularity":0.4324,"poster_path":"/5pyo6SIvWAdOvWOYoYryAAe3x7r.jpg","release_date":"2008-03-25","softcore":false,"video":false,"vote_average":4.8,"vote_count":2,"credit_id":"68efc54a533cc4cdf2aee06f","department":"Crew","job":"Thanks"},{"adult":false,"backdrop_path":null,"genre_ids":[35,27,14],"id":1423577,"title":"Gremlins 3","original_language":"en","original_title":"Gremlins 3","overview":"","popularity":2.5201,"poster_path":null,"release_date":"2027-11-18","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"690ca6e55151b1b998614107","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/hpXBJxLD2SEf8l2CspmSeiHrBKX.jpg","genre_ids":[18,14,27],"id":1062722,"title":"Frankenstein","original_language":"en","original_title":"Frankenstein","overview":"Genialny, ale egoistyczny naukowiec Wiktor Frankenstein usiłuje rozwikłać zagadkę śmierci. Odkrywa możliwość stworzenia życia w martwym ciele, lecz zamiast ideału powstaje inteligentne, wykazujące ludzkie odruchy monstrum. Efekt tego potwornego eksperymentu ostatecznie prowadzi do zguby zarówno twórcy, jak i jego tragicznego dzieła.","popularity":17.7562,"poster_path":"/oiw5wMwYH3GzHXhvim5kPRWBDw6.jpg","release_date":"2025-10-17","softcore":false,"video":false,"vote_average":7.638,"vote_count":3479,"credit_id":"691282f56f33467683c06496","department":"Crew","job":"Thanks"},{"adult":false,"backdrop_path":"/wVpZAFqzcXKlHw3Dx85EpnG9vvW.jpg","genre_ids":[18],"id":753,"title":"Twarze","original_language":"en","original_title":"Faces","overview":"Znudzony i wypalony Richard Frost, producent filmowy, próbuje zmienić swoje życie, rzucając się w objęcia luksusowej call girl. W tym czasie jego żona Maria po raz pierwszy dopuszcza do siebie prawdę o ich związku. Dla obojga jest ona przygniatająca.","popularity":1.1925,"poster_path":"/qTkhxFQ0o6DEtTtPXkv4IA5M90J.jpg","release_date":"1968-11-24","softcore":false,"video":false,"vote_average":7.1,"vote_count":220,"credit_id":"696d57596fd884581bf12149","department":"Production","job":"Production Assistant"},{"adult":false,"backdrop_path":"/g2Y4A9qgkHhecPBnYMaAIzTlmcN.jpg","genre_ids":[14,18],"id":12516,"title":"Sny","original_language":"ja","original_title":"夢","overview":"Film składa się z ośmiu krótkich opowieści opartych na snach samego Kurosawy. Każdy z nich przedstawia inną prawdę o człowieku i świecie w którym żyjemy. Niezależnie od tego czy będzie to wizja nuklearnej zagłady wiszącej nad Japonią czy sielankowy obraz wsi odciętej z dala od cywilizacji, to mamy do czynienia z obrazem pełnym symboliki i wizjonerstwa.","popularity":3.5563,"poster_path":"/deukbAigTrh4aQo6LrU0HgH5Zke.jpg","release_date":"1990-05-11","softcore":false,"video":false,"vote_average":7.746,"vote_count":556,"credit_id":"698ace3c487194b9561e622d","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/6bVzP9lyoSTevfblZuIUOOye895.jpg","genre_ids":[878,27],"id":1066313,"title":"Setan Alas!","original_language":"id","original_title":"Setan Alas!","overview":"","popularity":3.2578,"poster_path":"/iqr2HSY0NC3U0x5t9M5RRAnmr3i.jpg","release_date":"2023-11-27","softcore":false,"video":false,"vote_average":5.3,"vote_count":11,"credit_id":"69ad19d3ad29bd1503c1ddd4","department":"Crew","job":"Thanks"},{"adult":false,"backdrop_path":"/n3xZcicwYbcgyxvRbwOgBdLbvzC.jpg","genre_ids":[16],"id":1654995,"title":"Red Princess Blues Animated: The Book of Violence","original_language":"en","original_title":"Red Princess Blues Animated: The Book of Violence","overview":"","popularity":0.1219,"poster_path":"/7G3dOMh81YPh1tZq8nFcP363VDt.jpg","release_date":"2007-11-30","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"69bd5a89e843e4d46506e575","department":"Crew","job":"Thanks"},{"adult":false,"backdrop_path":"/cQmuMloZvHGXbwiOv2GNsC1OpJK.jpg","genre_ids":[28,12,878,10751],"id":1664699,"title":"SeaQuest DSV","original_language":"en","original_title":"SeaQuest DSV","overview":"","popularity":0.391,"poster_path":"/fPUtiCsIAyc3YqiCohxnzAo9xTO.jpg","release_date":"1993-09-12","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"69d3a5c24