xF48cR5V.jpg","release_date":"2013-11-21","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"character":"Self","credit_id":"6951187ec5278cb1b588db12","order":4},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":1608572,"title":"Wajda","original_language":"pl","original_title":"Wajda","overview":"Film dokumentalny o Andrzeju Wajdzie.","popularity":0.1059,"poster_path":null,"release_date":"","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"character":"Self (archive footage)","credit_id":"6957fda4e73b0ed169cbef95","order":0},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":375739,"title":"Aktorka","original_language":"pl","original_title":"Aktorka","overview":"Pełnometrażowy, biograficzny film dokumentalny o zmarłej w 2010 roku Elżbiecie Czyżewskiej, jednej z największych polskich aktorek, ikonie urody lat 60. Odniosła wielką karierę w Polsce, ale autorzy filmu bardziej skupiają uwagę na jej próbach zaistnienia jako aktorka w Ameryce, po nagłej emigracji do Stanów Zjednoczonych wraz z mężem, amerykańskim dziennikarzem Davidem Halberstamem.  Przyjaciele i znajomi Elżbiety Czyżewskiej mówią bez upiększeń o jej nieudanym małżeństwie, o wygranej po latach walce z alkoholizmem, o próbach powrotu do Polski. To opowieść o losach aktorki na różnych etapach kariery: na szczycie, na dnie i pomiędzy.","popularity":0.8682,"poster_path":"/8O0pjj6lx75Wj0kt8r5wjiPdujl.jpg","release_date":"2015-12-04","softcore":false,"video":false,"vote_average":10.0,"vote_count":1,"character":"Self","credit_id":"695e2e864214aafa86cfd348","order":1},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":937822,"title":"„Biesy” po latach","original_language":"pl","original_title":"„Biesy” po latach","overview":"\"Biesy\" wystawione w 1971 roku w Starym Teatrze w Krakowie to jeden z najważniejszych spektakli zrealizowanych przez Andrzeja Wajdę. Przyjęte entuzjastycznie przez publiczność, przez dziesięć lat nieprzerwanie pozostawały w repertuarze teatru. W zrealizowanym w 2013 roku dokumencie wybitny reżyser, a także twórcy i obsada spektaklu, opowiadają o procesie jego powstania.","popularity":0.0714,"poster_path":"/2aqFrkYryEKKppEV8zfrcRuCrom.jpg","release_date":"2013-01-01","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"character":"Self","credit_id":"696e72c3d73d81deceaaafad","order":0},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":270740,"title":"Lekcja polskiego kina","original_language":"pl","original_title":"Lekcja polskiego kina","overview":"","popularity":0.1671,"poster_path":null,"release_date":"2002-04-01","softcore":false,"video":false,"vote_average":7.0,"vote_count":2,"character":"Self","credit_id":"69714beaaa7b7274adde5236","order":0},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":1686961,"title":"Pan... Dziad z lirą?","original_language":"pl","original_title":"Pan... Dziad z lirą?","overview":"","popularity":0.0709,"poster_path":null,"release_date":"","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"character":"Self","credit_id":"69f663bac9cb61d24738d42d","order":0}],"crew":[{"adult":false,"backdrop_path":"/row4sMw5mVzKCWRbyrAQ39zvyLX.jpg","genre_ids":[18,36],"id":225,"title":"Człowiek z żelaza","original_language":"pl","original_title":"Człowiek z żelaza","overview":"Gdańsk, rok 1980. W stoczni trwa strajk. Winkel otrzymuje polecenie zrealizowania radiowego reportażu kompromitującego Macieja Tomczyka, działacza komitetu strajkowego. Badecki, przedstawiciel władz, uświadamia mu wagę zadania. W tłumie przed bramą zakładu Winkel spotyka znajomego, Dzidka. Ten opowiada mu o Tomczyku. Aby uzyskać przepustkę na teren stoczni, Winkel odwiedza rodzinę Wiesławy Hulewicz. Dowiaduje się, że Tomczyk jest mężem Agnieszki, która w roku 1976 robiła film o Mateuszu Birkucie, ojcu Maćka.","popularity":0.5602,"poster_path":"/2FlIwfhRyiJXVgZwjfUSIEeWCmD.jpg","release_date":"1981-07-27","softcore":false,"video":false,"vote_average":7.0,"vote_count":94,"credit_id":"52fe4229c3a36847f80089db","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/36zif7dloaMlMUzrIW5xf1ymqV2.jpg","genre_ids":[18],"id":224,"title":"Człowiek z marmuru","original_language":"pl","original_title":"Człowiek z marmuru","overview":"Rok 1976. Agnieszka, dyplomantka szkoły filmowej, realizuje film o przodowniku pracy z lat 50-tych. Rozpoczyna prywatne śledztwo, mające ustalić przyczyny sukcesu i nagłego upadku.","popularity":0.8395,"poster_path":"/iCAc0Eyxa1Gd3DqsoxfD3Pvl0re.jpg","release_date":"1977-02-25","softcore":false,"video":false,"vote_average":7.0,"vote_count":93,"credit_id":"52fe4228c3a36847f8008953","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/xQa198uEb8DLwQntDwO9jlilXcC.jpg","genre_ids":[18,36],"id":511,"title":"Ziemia obiecana","original_language":"pl","original_title":"Ziemia obiecana","overview":"Adaptacja powieści Władysława Reymonta. Epicki obraz konfliktów kapitalistycznej Łodzi końca XIX w. ukazany poprzez dzieje kariery trzech zaprzyjaźnionych przemysłowców Polaka, Żyda i Niemca, którzy za cenę rezygnacji z młodzieńczych ideałów i przejęcia bezwzględnych reguł walki o pieniądz zdobywają fortunę.","popularity":0.8217,"poster_path":"/uwMs9axSBS0opiO7Ih2J3AjUvMv.jpg","release_date":"1975-02-21","softcore":false,"video":false,"vote_average":7.324,"vote_count":85,"credit_id":"52fe424cc3a36847f8013589","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":"/xQa198uEb8DLwQntDwO9jlilXcC.jpg","genre_ids":[18,36],"id":511,"title":"Ziemia obiecana","original_language":"pl","original_title":"Ziemia obiecana","overview":"Adaptacja powieści Władysława Reymonta. Epicki obraz konfliktów kapitalistycznej Łodzi końca XIX w. ukazany poprzez dzieje kariery trzech zaprzyjaźnionych przemysłowców Polaka, Żyda i Niemca, którzy za cenę rezygnacji z młodzieńczych ideałów i przejęcia bezwzględnych reguł walki o pieniądz zdobywają fortunę.","popularity":0.8217,"poster_path":"/uwMs9axSBS0opiO7Ih2J3AjUvMv.jpg","release_date":"1975-02-21","softcore":false,"video":false,"vote_average":7.324,"vote_count":85,"credit_id":"52fe424cc3a36847f801357d","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/azsdBXsRuGPZNgAEYrpnfaPVDWg.jpg","genre_ids":[18,36],"id":4202,"title":"Danton","original_language":"fr","original_title":"Danton","overview":"W rewolucyjnej Francji szaleje terror. Na posiedzeniu Komitetu Ocalenia Publicznego Billaud Varenne oskarża Dantona i jego przyjaciół o działalność kontrrewolucyjną. Robespierre nie zgadza się wprawdzie na sądzenie Dantona, ale inni członkowie Komitetu przytaczają wciąż nowe argumenty przeciwko niemu. Jednocześnie dochodzi do konfiskaty redagowanej przez Desmoulinsa gazety dantonistów \"Vieux Cordelier\". Wkrótce Danton otrzymuje poufne ostrzeżenie, że rząd nosi się z zamiarem aresztowania go. [filmweb.pl]","popularity":1.1752,"poster_path":"/o6pJk815sEJxZW2S5FkCCvUkBGz.jpg","release_date":"1983-01-12","softcore":false,"video":false,"vote_average":6.8,"vote_count":175,"credit_id":"52fe43b2c3a36847f80686dd","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/sCZDOHktwAHpCayhDiYBd9wTaH4.jpg","genre_ids":[18],"id":2285,"title":"Eine Liebe in Deutschland","original_language":"de","original_title":"Eine Liebe in Deutschland","overview":"","popularity":0.3543,"poster_path":"/yKdRE7dHa6bVXhHnSEw2L1usFIj.jpg","release_date":"1983-10-26","softcore":false,"video":false,"vote_average":5.5,"vote_count":8,"credit_id":"52fe4349c3a36847f8048d67","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":"/sCZDOHktwAHpCayhDiYBd9wTaH4.jpg","genre_ids":[18],"id":2285,"title":"Eine Liebe in Deutschland","original_language":"de","original_title":"Eine Liebe in Deutschland","overview":"","popularity":0.3543,"poster_path":"/yKdRE7dHa6bVXhHnSEw2L1usFIj.jpg","release_date":"1983-10-26","softcore":false,"video":false,"vote_average":5.5,"vote_count":8,"credit_id":"52fe4349c3a36847f8048d5b","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/df5iAHuH2brY9zXMeeRuL2AAE6O.jpg","genre_ids":[18,10749,36],"id":4966,"title":"Pan Tadeusz","original_language":"pl","original_title":"Pan Tadeusz","overview":"Jest rok 1811. Tadeusz Soplica wraca po ukończeniu nauk do rodzinnego dworku w Soplicowe, na Litwie. Gospodarzem posiadłości jest stryj i opiekun młodzieńca, Sędzia. Wydaje się, że dom jest zupełnie pusty, jego mieszkańcy wybrali się do pobliskiego lasu. Zwiedzając stare zakamarki, Tadeusz trafia do dawnego pokoju dziecinnego, w którym spotyka Zosię. Świeżość i uroda dziewczyny podbijają serce młodzieńca.","popularity":0.5512,"poster_path":"/3oSRt8qV2oxrr14Igo8och6nkN8.jpg","release_date":"1999-10-22","softcore":false,"video":false,"vote_average":5.492,"vote_count":63,"credit_id":"52fe43e9c3a36847f8077b91","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/df5iAHuH2brY9zXMeeRuL2AAE6O.jpg","genre_ids":[18,10749,36],"id":4966,"title":"Pan Tadeusz","original_language":"pl","original_title":"Pan Tadeusz","overview":"Jest rok 1811. Tadeusz Soplica wraca po ukończeniu nauk do rodzinnego dworku w Soplicowe, na Litwie. Gospodarzem posiadłości jest stryj i opiekun młodzieńca, Sędzia. Wydaje się, że dom jest zupełnie pusty, jego mieszkańcy wybrali się do pobliskiego lasu. Zwiedzając stare zakamarki, Tadeusz trafia do dawnego pokoju dziecinnego, w którym spotyka Zosię. Świeżość i uroda dziewczyny podbijają serce młodzieńca.","popularity":0.5512,"poster_path":"/3oSRt8qV2oxrr14Igo8och6nkN8.jpg","release_date":"1999-10-22","softcore":false,"video":false,"vote_average":5.492,"vote_count":63,"credit_id":"52fe43e9c3a36847f8077b9d","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":"/1QlZ3Kge4bCH01V3VibxckeVIiu.jpg","genre_ids":[18,10752,10749],"id":5055,"title":"Popiół i diament","original_language":"pl","original_title":"Popiół i diament","overview":"Młody akowiec, Maciek Chełmicki, otrzymuje rozkaz zastrzelenia sekretarza KW PPR. Zbieg okoliczności powoduje, że zabija kogoś innego. Spotykając się twarzą w twarz ze swoją ofiarą doznaje szoku. Staje przed koniecznością powtórzenia zamachu. Poznaje Krystynę, dziewczynę pracującą jako barmanka w restauracji hotelu \"Monopol\". Uczucie do niej uświadamia mu jeszcze bardziej bezsens zabijania w chwili zakończenia wojny. Wierność złożonej przysiędze, a tym samym obowiązek podporządkowania się rozkazowi, przeważa szalę.","popularity":1.0011,"poster_path":"/66yNLyK66WgySI7sZLXUfa7NRHp.jpg","release_date":"1958-10-03","softcore":false,"video":false,"vote_average":7.4,"vote_count":280,"credit_id":"52fe43f1c3a36847f8079731","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/uJlc4aNPF3Y8yAqahJTKBwgwPVW.jpg","genre_ids":[18,10749],"id":8773,"title":"Miłość dwudziestolatków","original_language":"fr","original_title":"L'Amour à vingt ans","overview":"Film nowelowy. Poza nowelą polską zawiera także nowele: francuską w reżyserii Françoisa Truffauta; włoską w reżyserii Renzo Rosselliniego; niemiecką w reżyserii Marcela Ophülsa i japońską w reżyserii Shintarô Ishihary.","popularity":0.5265,"poster_path":"/gNzLjEuxtV8yzyjeZ572QKFC7SN.jpg","release_date":"1962-06-22","softcore":false,"video":false,"vote_average":6.75,"vote_count":52,"credit_id":"52fe44b8c3a36847f80a663d","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/Pbr2ImzoDbE8CdGyencQpdEOdw.jpg","genre_ids":[18,36,10752],"id":13614,"title":"Katyń","original_language":"pl","original_title":"Katyń","overview":"Gdy 17 września 1939 roku armia radziecka wkroczyła do Polski, nieprzygotowana do walki na dwóch frontach armia II Rzeczpospolitej musiała ponieść klęskę. Wśród jeńców wojennych znalazło się kilkanaście tysięcy oficerów. Ich rodziny z utęsknieniem czekały na ich powrót. Nigdy on jednak nie nastąpił. Dzieło Andrzeja Wajdy ukazuje historie kobiet, które mimo upływu lat, ciągle czekały na powrót swych mężów, synów, braci i ojców, uwięzionych przez NKWD.","popularity":1.1268,"poster_path":"/jTjmCW1ymW3G29TQBVGthRMUKSG.jpg","release_date":"2007-09-21","softcore":false,"video":false,"vote_average":6.7,"vote_count":282,"credit_id":"52fe45829251416c75058e3f","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/5eAMGOn8qsJ9QSqVHQexbX4mYfN.jpg","genre_ids":[18,36,53],"id":169247,"title":"Biesy","original_language":"fr","original_title":"Les Possédés","overview":"Rosja, 1870 r. Grupa młodych anarchistycznych rewolucjonistów wyrusza, by obalić carski reżim przemocą. Ich ataki tworzą atmosferę psychozy i wzajemnej nieufności wśród ludności, ale w rzeczywistości zarówno rewolucjoniści, jak i represjonowani są manipulowani przez diabolicznego osobnika.","popularity":1.8607,"poster_path":"/rtq2zzutphyNSwPxQ9eyYbs4vIv.jpg","release_date":"1988-02-24","softcore":false,"video":false,"vote_average":5.4,"vote_count":25,"credit_id":"623308b78e8d300047abc9ee","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":"/3d7Zh7ZGk1TbiUA3ZGKyS3qCpBi.jpg","genre_ids":[18],"id":42199,"title":"Bez znieczulenia","original_language":"pl","original_title":"Bez znieczulenia","overview":"Po powrocie z zagranicy znany dziennikarz dowiaduje się, że żona bierze z nim rozwód. Ponieważ nie zna przyczyn decyzji małżonki, nie może się z tym pogodzić. Dodatkowo zaczyna popadać w coraz większe kłopoty zawodowe. Jego wystąpienie telewizyjne i publikacje prasowe nie zyskują uznania. Na uniwersytecie zawieszono wykłady, które prowadził. Planowany od dłuższego czasu wyjazd za granicę zostaje niespodziewanie odwołany. Podczas rozprawy rozwodowej żona zaczyna obciążać męża, składając fałszywe zeznania.","popularity":0.3599,"poster_path":"/bxS0z1Ji4VVWZthMZpooi0Fcviu.jpg","release_date":"1978-11-27","softcore":false,"video":false,"vote_average":6.8,"vote_count":16,"credit_id":"52fe45f4c3a36847f80e3fbd","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/kfuJtNiY3aevZHzSMA007pbVWqH.jpg","genre_ids":[10752,18],"id":29933,"title":"Kanał","original_language":"pl","original_title":"Kanał","overview":"Powstanie Warszawskie. Tragiczne losy żołnierzy oddziału AK, którzy z pozycji na Mokotowie usiłują przedostać się kanałami do walczącego jeszcze Śródmieścia. Wszystkich czeka śmierć. Dowódca \"Zadra\" wraca do kanału, bo oszukany przez tchórzliwego \"Kulę\" zostawił za sobą swój oddział. \"Mądry\" załamuje się, wychodzi przez właz i zostaje rozstrzelany przez Niemców. Halinka popełnia samobójstwo, \"Smukły\" ginie rozbrajając granaty. Ciężko ranny \"Korab\" i \"Stokrotka\" docierają resztkami sił do Wisły, ale drogę zagradza im zamykająca kanał żelazna krata.","popularity":0.979,"poster_path":"/xQ8yk1V4Z2EwEtoAUdwOExCp02B.jpg","release_date":"1957-04-20","softcore":false,"video":false,"vote_average":7.679,"vote_count":159,"credit_id":"52fe4604c3a368484e07c3b5","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/mVQthfjH5QrkDyiY6RxAgl60LqG.jpg","genre_ids":[10752,18],"id":43322,"title":"Pokolenie","original_language":"pl","original_title":"Pokolenie","overview":"Film opowiada o zwycięstwach, poświęceniach, goryczy i ofiarach grupy młodych idealistów, którzy na progu dorosłości muszą sprostać najtrudniejszym wyzwaniom. Akcja toczy się w czasie okupacji, a tematem są dramatyczne wybory oraz rozterki moralne ludzi postawionych w ekstremalnej sytuacji wojny, z jej okrucieństwem i etycznymi pułapkami. Stach pragnie walczyć z Niemcami. Początkowo zamierza wstąpić do AK, ostatecznie związuje się jednak z osobami z komunistycznego podziemia i zaciąga się do oddziału Gwardii Ludowej.","popularity":0.6105,"poster_path":"/scQZlYRRxyU8CjExJ3MI5ISA1wx.jpg","release_date":"1955-01-26","softcore":false,"video":false,"vote_average":6.968,"vote_count":62,"credit_id":"52fe463dc3a36847f80f4109","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/4lV7RWF2XnoWlExYQM0ibfVS4or.jpg","genre_ids":[18,36,10752],"id":47430,"title":"Korczak","original_language":"pl","original_title":"Korczak","overview":"Janusz Korczak przed wojną znany był głównie dzięki swym audycjom radiowym. Gdy w 1936 roku jego program został zdjęty z anteny, doktor poświęcił się całkowicie opiece nad sierotami. Gdy wybuchła wojna Korczak znalazł się w warszawskim getcie, gdzie w tragicznych warunkach kontynuował swą pracę na rzecz dzieci. Starając się uchronić je przed koszmarem wojny, gotów był poświęcić wszystko dla ich dobra. Gdy Niemcy rozpoczęli likwidację getta, Korczak stanął przed dramatyczną decyzją.","popularity":1.326,"poster_path":"/oCrjLiap6UXaqqD18s7ZziwJlwV.jpg","release_date":"1990-05-06","softcore":false,"video":false,"vote_average":7.1,"vote_count":32,"credit_id":"52fe4733c3a36847f8128937","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/hTkBjpiUjzhrJEBE6b25hMfA9CW.jpg","genre_ids":[18,53,80],"id":18614,"title":"Przesłuchanie","original_language":"pl","original_title":"Przesłuchanie","overview":"Artystka kabaretowa zostaje upita w restauracji przez dwóch mężczyzn, a następnie przewieziona do więzienia. SB żąda od niej zeznań obciążających kolegę z zespołu. W ciągu długich miesięcy okrutnego śledztwa trwa zmaganie oprawców z ofiarą, walczącą o swoje człowieczeństwo. Film-legenda, określony przez władze jako \"najbardziej antykomunistyczny film w historii PRL\", stał się bezpośrednią przyczyną rozwiązania zespołu \"X\" Andrzeja Wajdy.","popularity":0.39,"poster_path":"/diRFffvdByzXJySKniYeFPKuwbs.jpg","release_date":"1989-12-13","softcore":false,"video":false,"vote_average":7.113,"vote_count":75,"credit_id":"52fe478a9251416c7509d2b7","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":null,"genre_ids":[36,35,18],"id":831722,"title":"Solidarność, Solidarność...","original_language":"pl","original_title":"Solidarność, Solidarność...","overview":"Film nowelowy z 2005 roku powstały z okazji 25 rocznicy powstania „Solidarności”. Składa się z 13 etiud 10-minutowych. Są tu różne formy: minifabuła, teledysk, dokument, animacja, wywiad.","popularity":0.2419,"poster_path":null,"release_date":"2005-08-31","softcore":false,"video":false,"vote_average":7.333,"vote_count":3,"credit_id":"60a6a9a4cb5c8e0029b4e174","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":831770,"title":"Kręć! Jak kochasz to kręć!","original_language":"pl","original_title":"Kręć! Jak kochasz to kręć!","overview":"Andrzej Wajda przedstawia w tym dokumencie biografię słynnego filmowca i swojego wieloletniego współpracownika - Edwarda Kłosińskiego. Był on wybitnym operatorem filmowym. O jego niezwykłej twórczości opowiada miedzy innymi żona Krystyna Janda oraz najbliżsi przyjaciele, jak i sam reżyser. W filmie wykorzystano również fragmenty wielu ważniejszych produkcji, przy których tworzeniu brał udział Kłosiński.","popularity":0.0923,"poster_path":null,"release_date":"2010-01-01","softcore":false,"video":false,"vote_average":8.0,"vote_count":1,"credit_id":"60a6b7e568b1ea005744d612","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":null,"genre_ids":[36,35,18],"id":831722,"title":"Solidarność, Solidarność...","original_language":"pl","original_title":"Solidarność, Solidarność...","overview":"Film nowelowy z 2005 roku powstały z okazji 25 rocznicy powstania „Solidarności”. Składa się z 13 etiud 10-minutowych. Są tu różne formy: minifabuła, teledysk, dokument, animacja, wywiad.","popularity":0.2419,"poster_path":null,"release_date":"2005-08-31","softcore":false,"video":false,"vote_average":7.333,"vote_count":3,"credit_id":"60a6acca28723c0029d9316f","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":831770,"title":"Kręć! Jak kochasz to kręć!","original_language":"pl","original_title":"Kręć! Jak kochasz to kręć!","overview":"Andrzej Wajda przedstawia w tym dokumencie biografię słynnego filmowca i swojego wieloletniego współpracownika - Edwarda Kłosińskiego. Był on wybitnym operatorem filmowym. O jego niezwykłej twórczości opowiada miedzy innymi żona Krystyna Janda oraz najbliżsi przyjaciele, jak i sam reżyser. W filmie wykorzystano również fragmenty wielu ważniejszych produkcji, przy których tworzeniu brał udział Kłosiński.","popularity":0.0923,"poster_path":null,"release_date":"2010-01-01","softcore":false,"video":false,"vote_average":8.0,"vote_count":1,"credit_id":"60a6b7ee9a64c1006e240ae4","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":831766,"title":"Pogoda domu niechaj będzie z Tobą...","original_language":"pl","original_title":"Pogoda domu niechaj będzie z Tobą...","overview":"Jarosław Iwaszkiewicz odwiedza dom, który przywołuje wspomnienia z wczesnej młodości pisarza. Opowiada o kobietach, wśród których się wychowywał. One właśnie są pierwowzorami bohaterek opowiadania „Panny z Wilka”.","popularity":0.1312,"poster_path":null,"release_date":"1979-01-01","softcore":false,"video":false,"vote_average":7.0,"vote_count":1,"credit_id":"60a6b5bf9a64c10058c2711f","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/7bZdGn0ACPpHjuvCI2rR7xtWK1H.jpg","genre_ids":[99],"id":831755,"title":"Andrzej Wajda: Moje inspiracje","original_language":"pl","original_title":"Andrzej Wajda: Moje inspiracje","overview":"Andrzej Wajda odsłania tajniki swego warsztatu reżyserskiego. Poznajemy powody, dla których reżyser porzucił studia malarskie na krakowskiej Akademii Sztuk Pięknych i trafił do szkoły filmowej w Łodzi. Dowiadujemy się, czym stała się dla niego sztuka filmowa, co chciał przez nią wyrazić i jak polskie malarstwo inspirowało go przy tworzeniu wybranych scen w najbardziej znanych filmach. Wskazując na konkretne obrazy wybitnych polskich artystów, takich jak Jan Matejko, Stanisław Wyspiański, Kazimierz Michałowski, Jacek Malczewski, Leopold Löffler, Józef Chełmoński czy Andrzej Wróblewski, i zestawiając je z kadrami z \"Wesela\", \"Ziemi obiecanej\", \"Brzeziny\", \"Krajobrazu po bitwie\", \"Katynia\", Andrzej Wajda - największy malarz polskiego kina, pozwala nam zrozumieć siłę oddziaływania malarstwa i jego wpływ na wybór estetyki kreowanych obrazów filmowych. W krótkim słowie wstępnym Martin Scorsese komentuje ten aspekt twórczości Andrzeja Wajdy.","popularity":0.0707,"poster_path":"/fItnAQQionSzlFwYscC77yQkiCk.jpg","release_date":"2017-03-06","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"60a6af779a64c10029645739","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/yVywZerF7Blnq4lZcGTl9OtRvEr.jpg","genre_ids":[10749,35],"id":80324,"title":"Niewinni czarodzieje","original_language":"pl","original_title":"Niewinni czarodzieje","overview":"Historia przypadkowego spotkania młodego lekarza i dziewczyny, którzy poznają się w piwnicy jazzowej i spędzają ze sobą noc. Akcja rozgrywa się głównie w czterech ścianach mieszkania, a tło społeczne zostaje ledwo zarysowane. Niewiele też dowiadujemy się o samych bohaterach, poza tym, że noszą imiona Pelagia i Bazyli. Młodzi ludzie przybierają wobec siebie maski obojętności, ukrywając pod nimi rodzące się uczucie. Prowadzą grę pozorów i zwodniczych gestów, ulegając przy tym coraz silniejszej wzajemnej fascynacji, której jednak w ramach konwencji gry - starają się oprzeć. A wszystko to zatopione w nostalgiczno - egzystencjalnym klimacie.","popularity":0.3782,"poster_path":"/hQRD3Gh69SR5izkp8V1W3wHZV8B.jpg","release_date":"1960-12-17","softcore":false,"video":false,"vote_average":7.0,"vote_count":43,"credit_id":"52fe47b89251416c91073849","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/cGcEoUx2Cdcn1b21VF8nMKk5bqf.jpg","genre_ids":[18],"id":80652,"title":"Panna Nikt","original_language":"pl","original_title":"Panna Nikt","overview":"Piętnastoletnia Marysia trafia do nowej szkoły. Pod wpływem koleżanek nastolatka zaczyna się zmieniać.","popularity":0.2143,"poster_path":"/yiWjXIc7iMHAKxgmKh5GJ3FHtM1.jpg","release_date":"1996-10-25","softcore":false,"video":false,"vote_average":5.4,"vote_count":20,"credit_id":"52fe47d29251416c91076c6b","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/g5q2wZBTMD4i2PnhD2yzjyZ0xEM.jpg","genre_ids":[18],"id":51010,"title":"Tatarak","original_language":"pl","original_title":"Tatarak","overview":"Historia starzejącej się, doświadczonej życiem i schorowanej doktorowej Marty borykającej się z nudą i wspomnieniami. Żyje ze swym mężem w małym miasteczku. Przypadek sprawi, że przypomni sobie, czym jest miłość, a nawet fizyczna fascynacja. Spotkanie z młodym mężczyzną i jego tragiczna śmierć w trakcie wspólnej kąpieli wywołują w niej uczucia i reakcje, jakich sama się nie spodziewała.","popularity":1.5891,"poster_path":"/zZug56IxAkk0hTk4RgnQpVimFFn.jpg","release_date":"2009-04-23","softcore":false,"video":false,"vote_average":6.3,"vote_count":34,"credit_id":"52fe47dec3a36847f814ca37","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":"/g5q2wZBTMD4i2PnhD2yzjyZ0xEM.jpg","genre_ids":[18],"id":51010,"title":"Tatarak","original_language":"pl","original_title":"Tatarak","overview":"Historia starzejącej się, doświadczonej życiem i schorowanej doktorowej Marty borykającej się z nudą i wspomnieniami. Żyje ze swym mężem w małym miasteczku. Przypadek sprawi, że przypomni sobie, czym jest miłość, a nawet fizyczna fascynacja. Spotkanie z młodym mężczyzną i jego tragiczna śmierć w trakcie wspólnej kąpieli wywołują w niej uczucia i reakcje, jakich sama się nie spodziewała.","popularity":1.5891,"poster_path":"/zZug56IxAkk0hTk4RgnQpVimFFn.jpg","release_date":"2009-04-23","softcore":false,"video":false,"vote_average":6.3,"vote_count":34,"credit_id":"52fe47dec3a36847f814ca31","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/4A8P55DQK3kLRuMJMRn2HjwW7ax.jpg","genre_ids":[18,10402],"id":95269,"title":"Dyrygent","original_language":"pl","original_title":"Dyrygent","overview":"Młoda skrzypaczka Marta będąc na stypendium w Nowym Jorku poznaje słynnego dyrygenta Johna Lasockiego, którego łączyła przed laty wielka miłość z jej matką. Pod wpływem tego spotkania w Lasockim odżywają wspomnienia dawnego uczucia. Postanawia przyjechać do Polski, by w rodzinnym mieście Marty poprowadzić wykonanie V symfonii Beethovena. Mąż Marty - Adam będący dyrygentem owej orkiestry początkowo widzi w wizycie wielkiego mistrza szansę dla siebie, ale dostrzegając fascynację, jaką Lasocki budzi w Marcie, zaczyna być zazdrosny.","popularity":0.4497,"poster_path":"/pjWuMZg54MBnbZTjKHFVvdfVemb.jpg","release_date":"1980-02-27","softcore":false,"video":false,"vote_average":6.222,"vote_count":18,"credit_id":"52fe497c9251416c750c99bb","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/kw4V10wOKPWO3mIBOjkWF1kbPL0.jpg","genre_ids":[18,36,14],"id":840248,"title":"Makbet","original_language":"pl","original_title":"Makbet","overview":"","popularity":0.2542,"poster_path":"/hMPfSaxARJUzBRHBdBIBKkFfhft.jpg","release_date":"2010-05-25","softcore":false,"video":true,"vote_average":0.0,"vote_count":0,"credit_id":"60c715428e8702006d397ce9","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/kw4V10wOKPWO3mIBOjkWF1kbPL0.jpg","genre_ids":[18,36,14],"id":840248,"title":"Makbet","original_language":"pl","original_title":"Makbet","overview":"","popularity":0.2542,"poster_path":"/hMPfSaxARJUzBRHBdBIBKkFfhft.jpg","release_date":"2010-05-25","softcore":false,"video":true,"vote_average":0.0,"vote_count":0,"credit_id":"60c7154ce039f1006df04739","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":"/bBIMJJTkqKvQzBbyUpW8iIcbi79.jpg","genre_ids":[18],"id":1166923,"title":"Bigda idzie!","original_language":"pl","original_title":"Bigda idzie!","overview":"Żądny władzy działacz chłopski, Bigda, knuje intrygi zmierzające do obalenia rządu i zastąpienia go nowym, na którego czele chce stanąć. Grożąc i zastraszając, polityk realizuje swój plan.","popularity":0.2226,"poster_path":"/lTyHt1POIwzXx3wepjiSRK59eSN.jpg","release_date":"1999-11-29","softcore":false,"video":true,"vote_average":5.0,"vote_count":1,"credit_id":"64e0687de19de900adfccb85","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/3uT2LA3EkfgzErJlRo335ZJ5ue3.jpg","genre_ids":[18,14,36],"id":153917,"title":"Wesele","original_language":"pl","original_title":"Wesele","overview":"Mistrzowska adaptacja dramatu Stanisława Wyspiańskiego, dokonana przez Andrzeja Wajdę. Odpowiedni klimat epoki został stworzony poprzez kolorystykę, scenografię, kostiumy ale również, a może przede wszystkim przez muzykę. Mistrz Wajda w doskonały sposób obsadził w rolach aktorów, którzy stworzyli niezapomniane, wręcz życiowe kreacje. Obraz jest przesiąknięty charakterystyczną dla Wyspiańskiego symboliką, tajemniczością i niejednoznacznymi postaciami. \"Wesele\" to lektura obowiązkowa dla każdego Polaka.","popularity":0.439,"poster_path":"/8lF6C6i4z411K051D8GYHGaIVcs.jpg","release_date":"1973-01-09","softcore":false,"video":false,"vote_average":7.296,"vote_count":27,"credit_id":"52fe4b4f9251416c910d6699","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/d6P2YYCEYbzc1xr5LW9FhalctTd.jpg","genre_ids":[18,10749],"id":117483,"title":"Panny z Wilka","original_language":"pl","original_title":"Panny z Wilka","overview":"Niespełna czterdziestoletni Wiktor Ruben po stracie przyjaciela przyjeżdża do wujostwa na wieś, gdzie w pobliskim dworku, w gronie kilku panien, spędził młodzieńcze lata. Julia doczekała się bliźniaczek, wyemancypowana Jola wyszła za mąż, Fela przedwcześnie zmarła, zmieniły się też Zosia i Kazia, mała Tunia wyrosła na piękną pannę. Pojawienie się Rubena, jego wspomnienia i chęć ożywienia przeszłości burzą spokój mieszkanek dworu, ujawniają ich powikłane losy, dramaty, życiowe klęski.","popularity":0.2983,"poster_path":"/kYVZkCMgfnxzAUPVPBJvPQ935lZ.jpg","release_date":"1979-09-04","softcore":false,"video":false,"vote_average":6.633,"vote_count":30,"credit_id":"52fe4bb6c3a36847f8210ccd","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/fxXkKpMVPSJSdciQStPEEdC0nnj.jpg","genre_ids":[18],"id":149136,"title":"Krajobraz po bitwie","original_language":"pl","original_title":"Krajobraz po bitwie","overview":"Akcja toczy się w byłym obozie koncentracyjnym na terenie Niemiec. Mimo że został wyzwolony przez Amerykanów, wciąż istnieje, ale na innych zasadach. Wśród niedawnych więźniów jest Tadeusz, młody Polak, piszący wiersze miłośnik książek. Stroni od rodaków, którzy, ledwie odzyskawszy wolność, ujawniają najgorsze narodowe przywary. Pewnego dnia kobiety przyjeżdżają do obozu. Tadeusz poznaje Żydówkę Ninę. Namawia ona młodego poetę, by z nią uciekł. Tadeusz waha się. Lata obozowego życia sprawiły, że czuje strach przed normalnym życiem.","popularity":0.2423,"poster_path":"/wwGdrHFJTIefv5RjyDbrrVz9Meo.jpg","release_date":"1970-08-09","softcore":false,"video":false,"vote_average":5.886,"vote_count":22,"credit_id":"52fe4be09251416c75110d0d","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/uP3nXeSH6ZD9L76ycGHH9JmUhIf.jpg","genre_ids":[10752,18,36],"id":149511,"title":"Popioły","original_language":"pl","original_title":"Popioły","overview":"Ekranizacja powieści Stefana Żeromskiego. Akcja filmu rozpoczyna się latem 1798 roku, w chwili, gdy podróżujący po Włoszech książę Gintułt wraca do Polski. Los styka go tu z młodym szlachcicem Rafałem Olbromskim, który zostaje jego sekretarzem. Podróżując wraz z Gintułtem po kraju, Rafał wchodzi w kręgi masonerii. Nawiązuje tragiczny romans z żoną dostojnika loży, by wreszcie wspólnie z poznanym Krzysztofem Cedrą wstąpić do armii Napoleona.","popularity":0.3179,"poster_path":"/t0ytkejwNei7UbArOj8nPs4wC8r.jpg","release_date":"1965-09-25","softcore":false,"video":false,"vote_average":6.667,"vote_count":18,"credit_id":"52fe4bea9251416c75111e47","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/nOzNHS4yBRAAHWFdZ3VorAEhBoC.jpg","genre_ids":[35,878,10770],"id":189214,"title":"Przekładaniec","original_language":"pl","original_title":"Przekładaniec","overview":"Odnoszący sukcesy kierowca rajdowy Richard Fox ciągle ulega groźnym wypadkom. Może jednak dalej uprawiać sport dzięki genialnemu doktorowi Burtonowi, który przeszczepia Foksowi na miejsce uszkodzonych części ciała narządy od ofiar jego własnych karamboli. Sprawę komplikuje fakt, że Fox zdaje się przejmować cząstki osobowości od dawców, wśród których jest zarówno kobieta, jak i pies. Prawnie rzecz wikła się jeszcze bardziej, gdy wskutek pecha, rajdowca nie stać na zapłatę rachunków medycznych oraz gdy po jednym z wypadków dawcą zostaje jego własny brat, który był jego pilotem. Pojawia się także kwestia wypłaty ubezpieczenia. Wdowa po bracie mówi jeśli to Richard to niech odda pieniądze z ubezpieczenia, a jeśli to mój mąż niech wraca do domu. Wdowa ginie w kolejnym wypadku. Akcja toczy się wokół pytania, ile jeszcze jest Richarda Foxa w Richardzie Foxie oraz jaka jest jego właściwa osobowość prawna.","popularity":0.2352,"poster_path":"/n4oecK4rVnnXxCgfuqLMTcNLWDy.jpg","release_date":"1968-03-17","softcore":false,"video":false,"vote_average":7.056,"vote_count":18,"credit_id":"52fe4d539251416c75137691","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/7ji6L5oQEJZZ4dCzAc6frpI0ZN7.jpg","genre_ids":[10749,18,9648],"id":191407,"title":"Sibirska Ledi Magbet","original_language":"sh","original_title":"Sibirska Ledi Magbet","overview":"","popularity":0.3332,"poster_path":"/qmdVUPcuFZZHON6dlsEONnrdAL1.jpg","release_date":"1962-07-27","softcore":false,"video":false,"vote_average":5.733,"vote_count":16,"credit_id":"52fe4c829251416c910f730f","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/k1gbnFXnyAwyNVoPaX5N0ArYrEF.jpg","genre_ids":[18,36],"id":209385,"title":"Wałęsa. Człowiek z nadziei","original_language":"pl","original_title":"Wałęsa. Człowiek z nadziei","overview":"Zdobywca Oscara Andrzej Wajda przedstawia historię wielkich przemian, która przetoczyła się nie tylko przez zebrania partyjne, wiece i Okrągły Stół, ale także przez jedno z mieszkań na gdańskim osiedlu z wielkiej płyty. Reżyser wdzierając się w prywatność, nawet intymność związkowego przywódcy próbuje uchwycić fenomen przemiany prostego, skupionego na codzienności człowieka w charyzmatycznego przywódcę. To opowieść o mężu, ojcu, prostym robotniku, który wyzwolił ukryte w sercach milionów ludzi marzenie o wolności.","popularity":0.3951,"poster_path":"/rmDqg20hm8sS43ToN8hdOKflEiC.jpg","release_date":"2013-09-23","softcore":false,"video":false,"vote_average":5.7,"vote_count":85,"credit_id":"52fe4d64c3a368484e1e6b17","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/oTDF4Vtnlavbqpx4BR9jpBDKpF0.jpg","genre_ids":[10770,18],"id":440178,"title":"Piłat i inni","original_language":"de","original_title":"Pilatus und andere - Ein Film für Karfreitag","overview":"Kolejna wersja \"Mistrza i Małgorzaty\". Tym razem Wajda dość luźno koncentruje się na jednym wątku - Piłata i Jezusa. Przy czym wszystko zostaje osadzone w współczesnych realiach. Widać tu np autostradę czy wysypisko śmieci. Są sceny takie jak np. wywiad z baranem prowadzonym na rzeź. Ale na największą uwagę zasługuje scena w której Judasz wydaje Jezusa, przez telefon, a następnie z aparatu (budka w mieście) wypada mu 30 srebrników...","popularity":0.4071,"poster_path":"/wf2tQOVx7UuRo8ZEDkfgLtctQW0.jpg","release_date":"1972-03-29","softcore":false,"video":false,"vote_average":6.4,"vote_count":5,"credit_id":"64ecd6b71feac10138dbf43a","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":"/oTDF4Vtnlavbqpx4BR9jpBDKpF0.jpg","genre_ids":[10770,18],"id":440178,"title":"Piłat i inni","original_language":"de","original_title":"Pilatus und andere - Ein Film für Karfreitag","overview":"Kolejna wersja \"Mistrza i Małgorzaty\". Tym razem Wajda dość luźno koncentruje się na jednym wątku - Piłata i Jezusa. Przy czym wszystko zostaje osadzone w współczesnych realiach. Widać tu np autostradę czy wysypisko śmieci. Są sceny takie jak np. wywiad z baranem prowadzonym na rzeź. Ale na największą uwagę zasługuje scena w której Judasz wydaje Jezusa, przez telefon, a następnie z aparatu (budka w mieście) wypada mu 30 srebrników...","popularity":0.4071,"poster_path":"/wf2tQOVx7UuRo8ZEDkfgLtctQW0.jpg","release_date":"1972-03-29","softcore":false,"video":false,"vote_average":6.4,"vote_count":5,"credit_id":"64ecd6e4594c9400c554dedf","department":"Art","job":"Production Design"},{"adult":false,"backdrop_path":"/bGreAeXgzRSqNnbclynL6spZorB.jpg","genre_ids":[10749,35],"id":198669,"title":"Polowanie na muchy","original_language":"pl","original_title":"Polowanie na muchy","overview":"Bohaterem filmu jest Włodek, pracownik księgarni, niedoszły rusycysta. Pewnego dnia poznaje młodą dziewczynę, Irenę. Choć jest żonaty, nawiązuje z nią romans. Irena jest przekonana, że jej ukochany jest zdolny do lepszego życia niż to, które wiedzie u boku Hanki. Pokłada w nim wielkie nadzieje, chce wylansować go jako tłumacza, a nawet pisarza. Jej wysiłki okazują się daremne. Kariera jej wybrańca nie udaje się, on z kolei wpada w sidła ambitnych planów żony.","popularity":0.1474,"poster_path":"/3PHJj56FnuMvhTg0L1dAMUFqwCC.jpg","release_date":"1969-08-19","softcore":false,"video":false,"vote_average":5.556,"vote_count":18,"credit_id":"52fe4d859251416c91119161","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/oTDF4Vtnlavbqpx4BR9jpBDKpF0.jpg","genre_ids":[10770,18],"id":440178,"title":"Piłat i inni","original_language":"de","original_title":"Pilatus und andere - Ein Film für Karfreitag","overview":"Kolejna wersja \"Mistrza i Małgorzaty\". Tym razem Wajda dość luźno koncentruje się na jednym wątku - Piłata i Jezusa. Przy czym wszystko zostaje osadzone w współczesnych realiach. Widać tu np autostradę czy wysypisko śmieci. Są sceny takie jak np. wywiad z baranem prowadzonym na rzeź. Ale na największą uwagę zasługuje scena w której Judasz wydaje Jezusa, przez telefon, a następnie z aparatu (budka w mieście) wypada mu 30 srebrników...","popularity":0.4071,"poster_path":"/wf2tQOVx7UuRo8ZEDkfgLtctQW0.jpg","release_date":"1972-03-29","softcore":false,"video":false,"vote_average":6.4,"vote_count":5,"credit_id":"64ecd700c3c89100c6842748","department":"Costume & Make-Up","job":"Costume Design"},{"adult":false,"backdrop_path":"/iDr0wAPyydrTXq8JcjdEpe6hIy8.jpg","genre_ids":[36,18],"id":185050,"title":"Gates to Paradise","original_language":"en","original_title":"Gates to Paradise","overview":"","popularity":0.4155,"poster_path":"/76DsUCxO2QigpOFJ17rqkIN3LZg.jpg","release_date":"1968-05-31","softcore":false,"video":false,"vote_average":6.071,"vote_count":14,"credit_id":"52fe4cd49251416c75126e09","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/xi7frd8JRME37yCsSEf6orYiQ0K.jpg","genre_ids":[99],"id":43618,"title":"Olimpiada w Tokio","original_language":"ja","original_title":"東京オリンピック","overview":"","popularity":0.6058,"poster_path":"/hhdbYn3Yp8JbbXLOpJ8z4qDl6TK.jpg","release_date":"1965-03-20","softcore":false,"video":false,"vote_average":7.735,"vote_count":51,"credit_id":"60f61ae8ad87f70047891dc3","department":"Crew","job":"Thanks"},{"adult":false,"backdrop_path":"/2Jy6r0QANILYfbSzQTnpe4oD6Nt.jpg","genre_ids":[18,10752,36],"id":173510,"title":"Wielki tydzień","original_language":"pl","original_title":"Wielki tydzień","overview":"Historua Ireny Lilien, która w trakcie powstania w getcie ukrywa się u przyjaciela rodziny. Gdy znajduje ją tam gestapo, dziewczynie udaje się przekupić funkcjonariuszy i zostaje wypuszczona na wolność. Błąkając się samotnie po Warszawie spotyka swojego byłego narzeczonego Jana Maleckiego, który proponuje jej schronienie w swoim domu. Żona Maleckiego bez wahania otacza Irenę opieką. Jednak nie wszystkim odpowiada obecność młodej Żydówki za ścianą...","popularity":0.1484,"poster_path":"/r0BjtAihZscUPlYnBNd5crTNqlw.jpg","release_date":"1995-01-01","softcore":false,"video":false,"vote_average":5.636,"vote_count":11,"credit_id":"52fe4d35c3a36847f82548c7","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/5eAMGOn8qsJ9QSqVHQexbX4mYfN.jpg","genre_ids":[18,36,53],"id":169247,"title":"Biesy","original_language":"fr","original_title":"Les Possédés","overview":"Rosja, 1870 r. Grupa młodych anarchistycznych rewolucjonistów wyrusza, by obalić carski reżim przemocą. Ich ataki tworzą atmosferę psychozy i wzajemnej nieufności wśród ludności, ale w rzeczywistości zarówno rewolucjoniści, jak i represjonowani są manipulowani przez diabolicznego osobnika.","popularity":1.8607,"poster_path":"/rtq2zzutphyNSwPxQ9eyYbs4vIv.jpg","release_date":"1988-02-24","softcore":false,"video":false,"vote_average":5.4,"vote_count":25,"credit_id":"52fe4cdec3a36847f8242513","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":null,"genre_ids":[12],"id":204196,"title":"Samson","original_language":"pl","original_title":"Samson","overview":"","popularity":0.2776,"poster_path":"/xF4QU8J4UNFrUyeRi19t9KbkCVX.jpg","release_date":"1961-09-11","softcore":false,"video":false,"vote_average":4.833,"vote_count":12,"credit_id":"52fe4ceec3a368484e1cd8ff","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/lZnrt1oKNnICQjJi8rsH56R5UDI.jpg","genre_ids":[10752,18],"id":270737,"title":"Pierścionek z orłem w koronie","original_language":"pl","original_title":"Pierścionek z orłem w koronie","overview":"Powstanie w Warszawie dobiega końca. Dwudziestoletni Marcin przejmuje dowództwo oddziału z rąk majora Steinerta. Rozkazuje swoim ocalałym żołnierzom zdjąć mundury i opuścić miasto z cywilami. Jest ranny. Jego dziewczynę Wisię zabierają ronowcy. Na chwilę przed tym, ukochana daje mu pierścionek z orłem w koronie, cenną pamiątkę ich miłości. Rannego Marcina wywozi w bezpieczne miejsce łączniczka Janina. Po dojściu do zdrowia Marcin odmawia Steinertowi przystąpienia do podziemnej organizacji \"NIE\". Sam chce poznać cele i zamiary nowych władz. Film nawiązuje do stylu i problematyki polskiej szkoły filmowej oraz jej najwybitniejszego osiągnięcia, Popiołu i diamentu. Jest ostatecznym rozrachunkiem reżysera z etosem Armii Krajowej.","popularity":0.1887,"poster_path":"/4Pf04SZJkhUPX3RyrCsBTzMDnkd.jpg","release_date":"1992-04-01","softcore":false,"video":false,"vote_average":4.7,"vote_count":12,"credit_id":"537b14ecc3a3685e410014f0","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/3LrUc3J5pie1NnRjXCzMv56Lwwd.jpg","genre_ids":[18],"id":270735,"title":"Kronika wypadków miłosnych","original_language":"pl","original_title":"Kronika wypadków miłosnych","overview":"Wiosna 1939 roku. Witek zakochuje się w córce polskiego oficera, Alinie. Dziewczyna z trudem akceptuje miłość chłopca, ale w końcu zgadza się na randkę. Razem planują ucieczkę po maturze. Umawiają się po ogłoszeniu wyników egzaminów. Niestety, Witek nie zdał matury. Wkrótce dowiaduje się, że Alina wyjeżdża za granicę. Dziewczyna jednak przychodzi na ostatnie spotkanie w białej, \"ślubnej\" sukience. Nasyceni sobą zasypiają nad brzegiem rzeki. Budzi ich wycie syren alarmowych zwiastujących wybuch wojny.","popularity":0.2907,"poster_path":"/kuF4e5ttk1YHyzbvpSlZETeHkFu.jpg","release_date":"1986-11-24","softcore":false,"video":false,"vote_average":5.9,"vote_count":15,"credit_id":"537b10930e0a26012d0012ca","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/gzwodA1QtTwjsdyStfgnK3Rmx7S.jpg","genre_ids":[18,10752],"id":270728,"title":"Lotna","original_language":"pl","original_title":"Lotna","overview":"","popularity":0.1907,"poster_path":"/mIWAqoIOlIFmRW6uQJ9RkNE2r3v.jpg","release_date":"1959-09-27","softcore":false,"video":false,"vote_average":5.846,"vote_count":13,"credit_id":"537b08440e0a267fea0010c6","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":"/wDsvG01uEaWi90DLda9UGJ4fPYk.jpg","genre_ids":[18],"id":270731,"title":"Smuga cienia","original_language":"pl","original_title":"Smuga cienia","overview":"Młody i niedoświadczony oficer marynarki handlowej Conrad - Polak z pochodzenia, obejmuje po raz pierwszy dowództwo statku handlowego. Ma przyprowadzić z Bangkoku do Singapuru statek, którego kapitan niespodziewanie umarł. Okazuje się, że statek jest zaniedbany, załoga niezdyscyplinowana. Jedynym doświadczonym marynarzem na pokładzie jest niechętny nowemu kapitanowi I oficer Burns, lecz jeszcze przed wyruszeniem w rejs zapada na cholerę.","popularity":0.4542,"poster_path":"/yXuYwp9PNnXrERmk7Wlm1oilNcY.jpg","release_date":"1976-09-06","softcore":false,"video":false,"vote_average":6.417,"vote_count":6,"credit_id":"537b0e52c3a3685e1a0011cb","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/gzwodA1QtTwjsdyStfgnK3Rmx7S.jpg","genre_ids":[18,10752],"id":270728,"title":"Lotna","original_language":"pl","original_title":"Lotna","overview":"","popularity":0.1907,"poster_path":"/mIWAqoIOlIFmRW6uQJ9RkNE2r3v.jpg","release_date":"1959-09-27","softcore":false,"video":false,"vote_average":5.846,"vote_count":13,"credit_id":"537b08270e0a267ff400125f","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":270740,"title":"Lekcja polskiego kina","original_language":"pl","original_title":"Lekcja polskiego kina","overview":"","popularity":0.1671,"poster_path":null,"release_date":"2002-04-01","softcore":false,"video":false,"vote_average":7.0,"vote_count":2,"credit_id":"537b1a920e0a26012d0013db","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/c9B2ZkMPrI7TVjHLeTyg8czs6yR.jpg","genre_ids":[18],"id":94527,"title":"Wszystko na sprzedaż","original_language":"pl","original_title":"Wszystko na sprzedaż","overview":"Film, zainspirowany tragiczną śmiercią Zbigniewa Cybulskiego, skonstruowany został wokół motywu poszukiwań zaginionego aktora, który nie zjawił się na planie. Reżyser musi wykonać za niego karkołomny skok do pociągu. Ela, żona aktora, oraz Beata, żona reżysera i dawna miłość aktora, starają się go odnaleźć. Wkrótce dociera do nich wiadomość, że poszukiwany mężczyzna zginął, wyskakując z pociągu. Reżyser nie wie, co zrobić z nieskończonym filmem.","popularity":0.2643,"poster_path":"/hhRWKFrjeOK8MZ4IX2itZLvJPJC.jpg","release_date":"1969-01-28","softcore":false,"video":false,"vote_average":6.1,"vote_count":30,"credit_id":"537b0b6a0e0a267fea0010fd","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/3LrUc3J5pie1NnRjXCzMv56Lwwd.jpg","genre_ids":[18],"id":270735,"title":"Kronika wypadków miłosnych","original_language":"pl","original_title":"Kronika wypadków miłosnych","overview":"Wiosna 1939 roku. Witek zakochuje się w córce polskiego oficera, Alinie. Dziewczyna z trudem akceptuje miłość chłopca, ale w końcu zgadza się na randkę. Razem planują ucieczkę po maturze. Umawiają się po ogłoszeniu wyników egzaminów. Niestety, Witek nie zdał matury. Wkrótce dowiaduje się, że Alina wyjeżdża za granicę. Dziewczyna jednak przychodzi na ostatnie spotkanie w białej, \"ślubnej\" sukience. Nasyceni sobą zasypiają nad brzegiem rzeki. Budzi ich wycie syren alarmowych zwiastujących wybuch wojny.","popularity":0.2907,"poster_path":"/kuF4e5ttk1YHyzbvpSlZETeHkFu.jpg","release_date":"1986-11-24","softcore":false,"video":false,"vote_average":5.9,"vote_count":15,"credit_id":"537b10b70e0a267ffb001341","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":null,"genre_ids":[18],"id":270738,"title":"Nastazja","original_language":"ja","original_title":"Nastazja","overview":"","popularity":0.3237,"poster_path":"/jQfSNfU9coB8LWjegr93oj5tP7P.jpg","release_date":"1994-04-01","softcore":false,"video":false,"vote_average":6.4,"vote_count":5,"credit_id":"537b164fc3a3685e1a001254","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/m1IsEhhaG3mPPi2RHoLQ6avw90x.jpg","genre_ids":[18],"id":42539,"title":"Brzezina","original_language":"pl","original_title":"Brzezina","overview":"Akcja tego kameralnego dramatu rozgrywa się w leśniczówce otoczonej przepiękną brzeziną na przełomie zimy i wiosny. Do Bolesława przyjeżdża ciężko chory na gruźlicę brat Stanisław, by u niego spędzić ostatnie miesiące życia. Bolesław, mieszkający po śmierci żony z córką Olą i gosposią Maliną, nie potrafi przyzwyczaić się do ekstrawaganckiego stylu życia Stanisława, który chce czerpać z niego do ostatniej chwili. Rozpoczyna się podświadoma i uczuciowa rywalizacja obu braci.","popularity":0.3373,"poster_path":"/nZWaiNDaY6fWUh8KE9nCKFQXQ00.jpg","release_date":"1970-11-10","softcore":false,"video":false,"vote_average":6.563,"vote_count":24,"credit_id":"537b0bff0e0a267ff40012ac","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":271909,"title":"Ceramika iłżecka","original_language":"pl","original_title":"Ceramika iłżecka","overview":"","popularity":0.0712,"poster_path":"/b6Dka54SgeVkQ89WreURBsuIiwa.jpg","release_date":"1951-01-01","softcore":false,"video":false,"vote_average":5.385,"vote_count":13,"credit_id":"53820d66c3a36805a8006dc2","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":271909,"title":"Ceramika iłżecka","original_language":"pl","original_title":"Ceramika iłżecka","overview":"","popularity":0.0712,"poster_path":"/b6Dka54SgeVkQ89WreURBsuIiwa.jpg","release_date":"1951-01-01","softcore":false,"video":false,"vote_average":5.385,"vote_count":13,"credit_id":"53820d78c3a36805a1006fb4","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":null,"genre_ids":[18],"id":299539,"title":"Zły chłopiec","original_language":"pl","original_title":"Zły chłopiec","overview":"","popularity":0.3255,"poster_path":"/xFSGOdDJzGvCrfMSVr9BFBTLuR2.jpg","release_date":"1951-01-01","softcore":false,"video":false,"vote_average":4.667,"vote_count":6,"credit_id":"544fedba0e0a263a07002738","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":329698,"title":"Idę do słońca","original_language":"pl","original_title":"Idę do słońca","overview":"","popularity":0.0617,"poster_path":"/k3za4fxf2OClaKpphVBQLv7pkrJ.jpg","release_date":"1955-01-01","softcore":false,"video":false,"vote_average":5.667,"vote_count":6,"credit_id":"54fde4d5c3a36878c000010e","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":329698,"title":"Idę do słońca","original_language":"pl","original_title":"Idę do słońca","overview":"","popularity":0.0617,"poster_path":"/k3za4fxf2OClaKpphVBQLv7pkrJ.jpg","release_date":"1955-01-01","softcore":false,"video":false,"vote_average":5.667,"vote_count":6,"credit_id":"54fde4cf92514112c400012f","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":null,"genre_ids":[10770,18],"id":425260,"title":"Wyrok na Franciszka Kłosa","original_language":"pl","original_title":"Wyrok na Franciszka Kłosa","overview":"Franciszek Kłos jest funkcjonariuszem Granatowej Policji w małym miasteczku. Za współpracę z hitlerowskim okupantem otrzymuje wyrok śmierci.","popularity":0.1279,"poster_path":"/dXSxcwnrMBaSnL9uFodQqXtEJrR.jpg","release_date":"2000-09-23","softcore":false,"video":false,"vote_average":6.429,"vote_count":7,"credit_id":"619f4e1d63536a00619eb2ae","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":null,"genre_ids":[10752,99,18],"id":341961,"title":"Les Français vus par","original_language":"fr","original_title":"Les Français vus par","overview":"","popularity":1.541,"poster_path":"/n9XvRGI9OH5FDFWmCOFjxxnGTlL.jpg","release_date":"1988-10-26","softcore":false,"video":false,"vote_average":6.947,"vote_count":19,"credit_id":"5564bb6692514116cb004380","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/hTkBjpiUjzhrJEBE6b25hMfA9CW.jpg","genre_ids":[18,53,80],"id":18614,"title":"Przesłuchanie","original_language":"pl","original_title":"Przesłuchanie","overview":"Artystka kabaretowa zostaje upita w restauracji przez dwóch mężczyzn, a następnie przewieziona do więzienia. SB żąda od niej zeznań obciążających kolegę z zespołu. W ciągu długich miesięcy okrutnego śledztwa trwa zmaganie oprawców z ofiarą, walczącą o swoje człowieczeństwo. Film-legenda, określony przez władze jako \"najbardziej antykomunistyczny film w historii PRL\", stał się bezpośrednią przyczyną rozwiązania zespołu \"X\" Andrzeja Wajdy.","popularity":0.39,"poster_path":"/diRFffvdByzXJySKniYeFPKuwbs.jpg","release_date":"1989-12-13","softcore":false,"video":false,"vote_average":7.113,"vote_count":75,"credit_id":"564ad7f29251414dc80025bb","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":null,"genre_ids":[18],"id":1219828,"title":"Proust Contre La Déchéance","original_language":"en","original_title":"Proust Contre La Déchéance","overview":"","popularity":0.0418,"poster_path":null,"release_date":"1988-01-01","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"6580e48cac617c08ce14e09d","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/8ROKf5LV3tcQEb9JjlOC0OmbRq9.jpg","genre_ids":[18],"id":199453,"title":"Piątka z ulicy Barskiej","original_language":"pl","original_title":"Piątka z ulicy Barskiej","overview":"Historia trudnej reedukacji zdeprawowanych przez wojnę chłopców, których reakcyjne podziemie usiłuje wykorzystać do swoich celów. Pięciu młodych chłopców, którzy przywykli do wojennego stylu życia, nie potrafili dostosować się do nowych warunków i wchodzi na drogę przestępczą.","popularity":0.2756,"poster_path":"/5SwdAC0RnuWZyMFuEWDfWVmNn1z.jpg","release_date":"1954-02-27","softcore":false,"video":false,"vote_average":5.9,"vote_count":5,"credit_id":"65980c3b60c51d36369787e0","department":"Directing","job":"Assistant Director"},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":420257,"title":"Wróblewski według Wajdy","original_language":"pl","original_title":"Wróblewski według Wajdy","overview":"","popularity":0.0828,"poster_path":"/8a46rZe0A21A7nJW8MR9xK38Ose.jpg","release_date":"2016-02-12","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"6207c7581d78f23c5a0f8b92","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":937822,"title":"„Biesy” po latach","original_language":"pl","original_title":"„Biesy” po latach","overview":"\"Biesy\" wystawione w 1971 roku w Starym Teatrze w Krakowie to jeden z najważniejszych spektakli zrealizowanych przez Andrzeja Wajdę. Przyjęte entuzjastycznie przez publiczność, przez dziesięć lat nieprzerwanie pozostawały w repertuarze teatru. W zrealizowanym w 2013 roku dokumencie wybitny reżyser, a także twórcy i obsada spektaklu, opowiadają o procesie jego powstania.","popularity":0.0714,"poster_path":"/2aqFrkYryEKKppEV8zfrcRuCrom.jpg","release_date":"2013-01-01","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"6207d888efd3c200e5171612","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/1QlZ3Kge4bCH01V3VibxckeVIiu.jpg","genre_ids":[18,10752,10749],"id":5055,"title":"Popiół i diament","original_language":"pl","original_title":"Popiół i diament","overview":"Młody akowiec, Maciek Chełmicki, otrzymuje rozkaz zastrzelenia sekretarza KW PPR. Zbieg okoliczności powoduje, że zabija kogoś innego. Spotykając się twarzą w twarz ze swoją ofiarą doznaje szoku. Staje przed koniecznością powtórzenia zamachu. Poznaje Krystynę, dziewczynę pracującą jako barmanka w restauracji hotelu \"Monopol\". Uczucie do niej uświadamia mu jeszcze bardziej bezsens zabijania w chwili zakończenia wojny. Wierność złożonej przysiędze, a tym samym obowiązek podporządkowania się rozkazowi, przeważa szalę.","popularity":1.0011,"poster_path":"/66yNLyK66WgySI7sZLXUfa7NRHp.jpg","release_date":"1958-10-03","softcore":false,"video":false,"vote_average":7.4,"vote_count":280,"credit_id":"5708108dc3a3681d360000a7","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":"/vqI9awXaqs64a9wW8DwjgIWa5Gj.jpg","genre_ids":[18,36],"id":411678,"title":"Powidoki","original_language":"pl","original_title":"Powidoki","overview":"Intymny zapis ostatniego okresu życia pioniera awangardy w Polsce lat 20. i 30. XX w. Głównym bohaterem jest artysta, który nie poddał się obowiązującemu socrealizmowi i doświadczył dramatycznych skutków swoich wyborów. Opowieść o tym, jak komunistyczna władza zniszczyła obdarzonego charyzmą, niepokornego człowieka. Wajda jak nikt, potrafi w uniwersalny, a jednocześnie subtelny sposób wydobyć z niemalarskiego świata niedostrzegalne obrazy i sycić nimi widza.","popularity":0.6034,"poster_path":"/wQLCoJN7Ua3Q0GGi2nlf8Bcu74D.jpg","release_date":"2016-10-22","softcore":false,"video":false,"vote_average":6.53,"vote_count":84,"credit_id":"57b3ca76c3a368184a0005fa","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/gxit7oTVFNMe0KS61Xqyz14XSAX.jpg","genre_ids":[35],"id":19721,"title":"Zemsta","original_language":"pl","original_title":"Zemsta","overview":"Farsa o dwóch podupadłych rodzinach szlacheckich, które zostały zmuszone do roztrząsania wzajemnych urazów w jednym zrujnowanym dworze.","popularity":0.4069,"poster_path":"/n8Xrdyf1kSt3WfxMGycHhINNuuY.jpg","release_date":"2002-10-04","softcore":false,"video":false,"vote_average":5.618,"vote_count":38,"credit_id":"57e3fd989251411237005e51","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/gxit7oTVFNMe0KS61Xqyz14XSAX.jpg","genre_ids":[35],"id":19721,"title":"Zemsta","original_language":"pl","original_title":"Zemsta","overview":"Farsa o dwóch podupadłych rodzinach szlacheckich, które zostały zmuszone do roztrząsania wzajemnych urazów w jednym zrujnowanym dworze.","popularity":0.4069,"poster_path":"/n8Xrdyf1kSt3WfxMGycHhINNuuY.jpg","release_date":"2002-10-04","softcore":false,"video":false,"vote_average":5.618,"vote_count":38,"credit_id":"57e3fda3c3a3687590005b74","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":420257,"title":"Wróblewski według Wajdy","original_language":"pl","original_title":"Wróblewski według Wajdy","overview":"","popularity":0.0828,"poster_path":"/8a46rZe0A21A7nJW8MR9xK38Ose.jpg","release_date":"2016-02-12","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"57fa0bd992514101620061bd","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":null,"genre_ids":[12],"id":204196,"title":"Samson","original_language":"pl","original_title":"Samson","overview":"","popularity":0.2776,"poster_path":"/xF4QU8J4UNFrUyeRi19t9KbkCVX.jpg","release_date":"1961-09-11","softcore":false,"video":false,"vote_average":4.833,"vote_count":12,"credit_id":"65de0929c433ea01863d5cae","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":"/wDsvG01uEaWi90DLda9UGJ4fPYk.jpg","genre_ids":[18],"id":270731,"title":"Smuga cienia","original_language":"pl","original_title":"Smuga cienia","overview":"Młody i niedoświadczony oficer marynarki handlowej Conrad - Polak z pochodzenia, obejmuje po raz pierwszy dowództwo statku handlowego. Ma przyprowadzić z Bangkoku do Singapuru statek, którego kapitan niespodziewanie umarł. Okazuje się, że statek jest zaniedbany, załoga niezdyscyplinowana. Jedynym doświadczonym marynarzem na pokładzie jest niechętny nowemu kapitanowi I oficer Burns, lecz jeszcze przed wyruszeniem w rejs zapada na cholerę.","popularity":0.4542,"poster_path":"/yXuYwp9PNnXrERmk7Wlm1oilNcY.jpg","release_date":"1976-09-06","softcore":false,"video":false,"vote_average":6.417,"vote_count":6,"credit_id":"5825ffebc3a368360800ad02","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":"/lZnrt1oKNnICQjJi8rsH56R5UDI.jpg","genre_ids":[10752,18],"id":270737,"title":"Pierścionek z orłem w koronie","original_language":"pl","original_title":"Pierścionek z orłem w koronie","overview":"Powstanie w Warszawie dobiega końca. Dwudziestoletni Marcin przejmuje dowództwo oddziału z rąk majora Steinerta. Rozkazuje swoim ocalałym żołnierzom zdjąć mundury i opuścić miasto z cywilami. Jest ranny. Jego dziewczynę Wisię zabierają ronowcy. Na chwilę przed tym, ukochana daje mu pierścionek z orłem w koronie, cenną pamiątkę ich miłości. Rannego Marcina wywozi w bezpieczne miejsce łączniczka Janina. Po dojściu do zdrowia Marcin odmawia Steinertowi przystąpienia do podziemnej organizacji \"NIE\". Sam chce poznać cele i zamiary nowych władz. Film nawiązuje do stylu i problematyki polskiej szkoły filmowej oraz jej najwybitniejszego osiągnięcia, Popiołu i diamentu. Jest ostatecznym rozrachunkiem reżysera z etosem Armii Krajowej.","popularity":0.1887,"poster_path":"/4Pf04SZJkhUPX3RyrCsBTzMDnkd.jpg","release_date":"1992-04-01","softcore":false,"video":false,"vote_average":4.7,"vote_count":12,"credit_id":"5825fe5a9251417b2900b7cc","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":null,"genre_ids":[18],"id":299539,"title":"Zły chłopiec","original_language":"pl","original_title":"Zły chłopiec","overview":"","popularity":0.3255,"poster_path":"/xFSGOdDJzGvCrfMSVr9BFBTLuR2.jpg","release_date":"1951-01-01","softcore":false,"video":false,"vote_average":4.667,"vote_count":6,"credit_id":"65e03ff1391b9c0186827b0e","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":"/oTDF4Vtnlavbqpx4BR9jpBDKpF0.jpg","genre_ids":[10770,18],"id":440178,"title":"Piłat i inni","original_language":"de","original_title":"Pilatus und andere - Ein Film für Karfreitag","overview":"Kolejna wersja \"Mistrza i Małgorzaty\". Tym razem Wajda dość luźno koncentruje się na jednym wątku - Piłata i Jezusa. Przy czym wszystko zostaje osadzone w współczesnych realiach. Widać tu np autostradę czy wysypisko śmieci. Są sceny takie jak np. wywiad z baranem prowadzonym na rzeź. Ale na największą uwagę zasługuje scena w której Judasz wydaje Jezusa, przez telefon, a następnie z aparatu (budka w mieście) wypada mu 30 srebrników...","popularity":0.4071,"poster_path":"/wf2tQOVx7UuRo8ZEDkfgLtctQW0.jpg","release_date":"1972-03-29","softcore":false,"video":false,"vote_average":6.4,"vote_count":5,"credit_id":"589980f8c3a368425e001aa4","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/5MQakXbRXsSnPgvcekyYzZSsb4c.jpg","genre_ids":[18],"id":1265691,"title":"Makbet","original_language":"pl","original_title":"Makbet","overview":"","popularity":1.3096,"poster_path":"/wXqMDtMHs0IcyKfLvrzXAm2eCLJ.jpg","release_date":"1969-06-30","softcore":false,"video":true,"vote_average":0.0,"vote_count":0,"credit_id":"6604b4c12811a10186da3f51","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":null,"genre_ids":[28,18],"id":465041,"title":"Trzy opowieści","original_language":"pl","original_title":"Trzy opowieści","overview":"Nowele ukazujące konflikty, z jakimi stykała się młodzież z brygad organizacji \"Służba Polsce\".","popularity":0.1719,"poster_path":"/jDPPjXCWsi4WQjlvb3q5i9fpOrY.jpg","release_date":"1953-04-24","softcore":false,"video":false,"vote_average":5.0,"vote_count":2,"credit_id":"595f940b925141790400990f","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":"/dvtkXHjQPFmeXKbjckkCbMY7Ct6.jpg","genre_ids":[18,99],"id":420934,"title":"Umarła klasa","original_language":"pl","original_title":"Umarła klasa","overview":"Sfilmowana w 1976 roku przez Andrzeja Wajdę inscenizacja najsłynniejszego spektaklu Teatru Cricot 2 Tadeusza Kantora \"Umarła klasa\". Przedstawienie miało formę collage'u obrazów o wyrazistej plastyce i precyzyjnej orkiestracji ruchu aktorów i dźwięku (leitmotivem spektaklu był \"Walc Francois\"). Inspirowane tekstami Witkacego, Gombrowicza i Schulza było bardzo osobistą wypowiedzią Kantora.","popularity":0.1628,"poster_path":"/nR8zUOtpU9i02hNgaKFPzZuKauX.jpg","release_date":"1977-01-01","softcore":false,"video":false,"vote_average":6.167,"vote_count":6,"credit_id":"59c68f639251415b8704473c","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/c9B2ZkMPrI7TVjHLeTyg8czs6yR.jpg","genre_ids":[18],"id":94527,"title":"Wszystko na sprzedaż","original_language":"pl","original_title":"Wszystko na sprzedaż","overview":"Film, zainspirowany tragiczną śmiercią Zbigniewa Cybulskiego, skonstruowany został wokół motywu poszukiwań zaginionego aktora, który nie zjawił się na planie. Reżyser musi wykonać za niego karkołomny skok do pociągu. Ela, żona aktora, oraz Beata, żona reżysera i dawna miłość aktora, starają się go odnaleźć. Wkrótce dociera do nich wiadomość, że poszukiwany mężczyzna zginął, wyskakując z pociągu. Reżyser nie wie, co zrobić z nieskończonym filmem.","popularity":0.2643,"poster_path":"/hhRWKFrjeOK8MZ4IX2itZLvJPJC.jpg","release_date":"1969-01-28","softcore":false,"video":false,"vote_average":6.1,"vote_count":30,"credit_id":"664cf9485d189ce4f1ca8017","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":"/dvtkXHjQPFmeXKbjckkCbMY7Ct6.jpg","genre_ids":[18,99],"id":420934,"title":"Umarła klasa","original_language":"pl","original_title":"Umarła klasa","overview":"Sfilmowana w 1976 roku przez Andrzeja Wajdę inscenizacja najsłynniejszego spektaklu Teatru Cricot 2 Tadeusza Kantora \"Umarła klasa\". Przedstawienie miało formę collage'u obrazów o wyrazistej plastyce i precyzyjnej orkiestracji ruchu aktorów i dźwięku (leitmotivem spektaklu był \"Walc Francois\"). Inspirowane tekstami Witkacego, Gombrowicza i Schulza było bardzo osobistą wypowiedzią Kantora.","popularity":0.1628,"poster_path":"/nR8zUOtpU9i02hNgaKFPzZuKauX.jpg","release_date":"1977-01-01","softcore":false,"video":false,"vote_average":6.167,"vote_count":6,"credit_id":"5a7debd99251416ac8002a2d","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":null,"genre_ids":[18],"id":504394,"title":"Schuld und Sühne","original_language":"de","original_title":"Schuld und Sühne","overview":"","popularity":0.0984,"poster_path":null,"release_date":"1992-09-02","softcore":false,"video":false,"vote_average":7.0,"vote_count":1,"credit_id":"5a7f827092514140fb012fdf","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":null,"genre_ids":[18],"id":577836,"title":"Znaki na drodze","original_language":"pl","original_title":"Znaki na drodze","overview":"Rozgrywający się w środowisku kierowców budowlanej bazy transportowej dramat psychologiczny; obciążony więzienną przeszłością mężczyzna podejmuje walkę z panującymi w bazie nadużyciami, bałaganem i rozprężeniem. Michał po odbyciu kary więzienia podejmuje pracę w bazie transportowej, gdzie przeciwstawia się kradzieżom i nadużyciom. Po jego stronie stoi jedynie dyspozytorka Jadwiga. W dramatycznych okolicznościach uniemożliwia swemu byłemu koledze więziennemu Jaksonkowi kradzież cementu. Michał mianowany zostaje kierownikiem bazy, a Jadwiga będzie mu towarzyszyła nie tylko w pracy, także w życiu.","popularity":0.1281,"poster_path":"/bO2cJJWrwGZHdIbhml5Vlwy95zL.jpg","release_date":"1970-06-02","softcore":false,"video":false,"vote_average":10.0,"vote_count":1,"credit_id":"665f0cbf8a025ba08ff3e1e0","department":"Art","job":"Supervising Art Director"},{"adult":false,"backdrop_path":"/zb6fM1CX41D9rF9hdgclu0peUmy.jpg","genre_ids":[18,36,10752],"id":424,"title":"Lista Schindlera","original_language":"en","original_title":"Schindler's List","overview":"Oskar Schindler jest poważanym niemieckim przemysłowcem, który podczas II wojny światowej jest właścicielem dużej fabryki, w której w nieludzkich warunkach pracują Żydzi. Widząc cierpienie tych ludzi zaczyna ratować ich przed śmiercią w obozach koncentracyjnych. Film oparty jest na prawdziwej historii Oskara Schindlera, który podczas wojny ocalił przed śmiercią około 1100 ludzkich istnień.","popularity":23.5327,"poster_path":"/7mYojklW12jrWzvjxipWFeUnO9M.jpg","release_date":"1993-12-15","softcore":false,"video":false,"vote_average":8.569,"vote_count":17494,"credit_id":"665f630db60dbe6ae4004b38","department":"Crew","job":"Thanks"},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":805525,"title":"À l'ombre d'Hollywood","original_language":"fr","original_title":"À l'ombre d'Hollywood","overview":"","popularity":0.1365,"poster_path":null,"release_date":"2000-01-01","softcore":false,"video":false,"vote_average":8.0,"vote_count":1,"credit_id":"665f62e8d0599a12e47d5ae6","department":"Crew","job":"Thanks"},{"adult":false,"backdrop_path":"/m1IsEhhaG3mPPi2RHoLQ6avw90x.jpg","genre_ids":[18],"id":42539,"title":"Brzezina","original_language":"pl","original_title":"Brzezina","overview":"Akcja tego kameralnego dramatu rozgrywa się w leśniczówce otoczonej przepiękną brzeziną na przełomie zimy i wiosny. Do Bolesława przyjeżdża ciężko chory na gruźlicę brat Stanisław, by u niego spędzić ostatnie miesiące życia. Bolesław, mieszkający po śmierci żony z córką Olą i gosposią Maliną, nie potrafi przyzwyczaić się do ekstrawaganckiego stylu życia Stanisława, który chce czerpać z niego do ostatniej chwili. Rozpoczyna się podświadoma i uczuciowa rywalizacja obu braci.","popularity":0.3373,"poster_path":"/nZWaiNDaY6fWUh8KE9nCKFQXQ00.jpg","release_date":"1970-11-10","softcore":false,"video":false,"vote_average":6.563,"vote_count":24,"credit_id":"6675b58b5a4c16e9fa6c7278","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":"/fxXkKpMVPSJSdciQStPEEdC0nnj.jpg","genre_ids":[18],"id":149136,"title":"Krajobraz po bitwie","original_language":"pl","original_title":"Krajobraz po bitwie","overview":"Akcja toczy się w byłym obozie koncentracyjnym na terenie Niemiec. Mimo że został wyzwolony przez Amerykanów, wciąż istnieje, ale na innych zasadach. Wśród niedawnych więźniów jest Tadeusz, młody Polak, piszący wiersze miłośnik książek. Stroni od rodaków, którzy, ledwie odzyskawszy wolność, ujawniają najgorsze narodowe przywary. Pewnego dnia kobiety przyjeżdżają do obozu. Tadeusz poznaje Żydówkę Ninę. Namawia ona młodego poetę, by z nią uciekł. Tadeusz waha się. Lata obozowego życia sprawiły, że czuje strach przed normalnym życiem.","popularity":0.2423,"poster_path":"/wwGdrHFJTIefv5RjyDbrrVz9Meo.jpg","release_date":"1970-08-09","softcore":false,"video":false,"vote_average":5.886,"vote_count":22,"credit_id":"6675c17cd018bc2802b05db3","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":"/azsdBXsRuGPZNgAEYrpnfaPVDWg.jpg","genre_ids":[18,36],"id":4202,"title":"Danton","original_language":"fr","original_title":"Danton","overview":"W rewolucyjnej Francji szaleje terror. Na posiedzeniu Komitetu Ocalenia Publicznego Billaud Varenne oskarża Dantona i jego przyjaciół o działalność kontrrewolucyjną. Robespierre nie zgadza się wprawdzie na sądzenie Dantona, ale inni członkowie Komitetu przytaczają wciąż nowe argumenty przeciwko niemu. Jednocześnie dochodzi do konfiskaty redagowanej przez Desmoulinsa gazety dantonistów \"Vieux Cordelier\". Wkrótce Danton otrzymuje poufne ostrzeżenie, że rząd nosi się z zamiarem aresztowania go. [filmweb.pl]","popularity":1.1752,"poster_path":"/o6pJk815sEJxZW2S5FkCCvUkBGz.jpg","release_date":"1983-01-12","softcore":false,"video":false,"vote_average":6.8,"vote_count":175,"credit_id":"5aed5cefc3a368345e007f47","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":null,"genre_ids":[10770,18],"id":425260,"title":"Wyrok na Franciszka Kłosa","original_language":"pl","original_title":"Wyrok na Franciszka Kłosa","overview":"Franciszek Kłos jest funkcjonariuszem Granatowej Policji w małym miasteczku. Za współpracę z hitlerowskim okupantem otrzymuje wyrok śmierci.","popularity":0.1279,"poster_path":"/dXSxcwnrMBaSnL9uFodQqXtEJrR.jpg","release_date":"2000-09-23","softcore":false,"video":false,"vote_average":6.429,"vote_count":7,"credit_id":"6696497d0acccd3c2da391dd","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":874483,"title":"Kredyt i debet. Andrzej Wajda o sobie","original_language":"pl","original_title":"Kredyt i debet. Andrzej Wajda o sobie","overview":"Filmowy autoportret Andrzeja Wajdy.","popularity":0.0577,"poster_path":null,"release_date":"1999-12-31","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"6696492e7c2c9fca477b8c23","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/y9NXfEz8p1IiR8Ug4vpa3MiI8lJ.jpg","genre_ids":[10752,18,27],"id":46799,"title":"Trzecia część nocy","original_language":"pl","original_title":"Trzecia część nocy","overview":"II wojna światowa. Żona, matka i syn Michała zostali zamordowani przez Niemców. Mężczyzna wstępuje do organizacji podziemnej. Jedna z akcji bojowych z udziałem Michała kończy się niepowodzeniem. Z ukrycia jest świadkiem aresztowania podobnego do siebie mężczyzny. Ciężarna żona aresztowanego, Marta, przypomina zabitą Helenę. Kobieta zaczyna rodzić, Michał pomaga przyjść dziecku na świat, a potem traci przytomność. Po jej odzyskaniu okazuje się, że matka i noworodek zniknęli. Michał za wszelką cenę chce odnaleźć Martę.","popularity":0.5019,"poster_path":"/cRHc7JFmWjCtXz3rOfk07zuCyW9.jpg","release_date":"1972-01-04","softcore":false,"video":false,"vote_average":6.984,"vote_count":94,"credit_id":"64bc143b58efd3013953367e","department":"Art","job":"Supervising Art Director"},{"adult":false,"backdrop_path":"/hCO8QAuPWmIWgoSjEczLnvvC9SO.jpg","genre_ids":[35,10770],"id":656129,"title":"Dekameron 40 czyli cudowne przytrafienie pewnego nieboszczyka","original_language":"pl","original_title":"Dekameron 40 czyli cudowne przytrafienie pewnego nieboszczyka","overview":"Ekranizacja czterdziestego opowiadania z \"Dekamerona\". Przy suto zastawionym stole sześć młodych roznegliżowanych kobiet słucha opowiadania siódmej uczestniczki spotkania-Angeli-o \"cudownym przytrafieniu pewnego nieboszczyka\".","popularity":0.2172,"poster_path":"/yVYgCajIWUfnt393SSq1s4Xdyer.jpg","release_date":"1971-12-26","softcore":false,"video":false,"vote_average":3.8,"vote_count":5,"credit_id":"66b102f778d49f94fb481ef5","department":"Art","job":"Supervising Art Director"},{"adult":false,"backdrop_path":null,"genre_ids":[10770,18],"id":657827,"title":"Mateo Falcone","original_language":"pl","original_title":"Mateo Falcone","overview":"Rodzice małego Fortunato Falcone - wieśniacy korsykańscy, wyruszyli w góry zostawiając w domu syna, który za cenę srebrnej monety ukrywa przybyłego bandytę. Kiedy jednak przychodzą żandarmi - Fortunato, tym razem za cenę pięknego zegarka, wydaje bandytę w ich ręce. Po ich odejściu, mimo rozpaczy matki próbującej bronić małego Fortunata, ojciec chłopca, Mateo Falcone, wyprowadza syna wysoko w góry, by tam wykonać na nim okrutny wyrok.","popularity":0.249,"poster_path":"/qMwTSsTg3SrqmwzL8E2tzUqRIRt.jpg","release_date":"1971-12-21","softcore":false,"video":false,"vote_average":10.0,"vote_count":1,"credit_id":"66c4eb84a4b5bbdacfd18e57","department":"Art","job":"Supervising Art Director"},{"adult":false,"backdrop_path":null,"genre_ids":[18,10749,10770],"id":838588,"title":"Pierwsza miłość","original_language":"pl","original_title":"Pierwsza miłość","overview":"","popularity":0.1726,"poster_path":null,"release_date":"1971-09-17","softcore":false,"video":false,"vote_average":10.0,"vote_count":1,"credit_id":"66ca3f24d6c9c439b31d473b","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":575992,"title":"Jan Nowak Jeziorański. Kurier z Warszawy. 60 lat później 1944-2004","original_language":"pl","original_title":"Jan Nowak Jeziorański. Kurier z Warszawy. 60 lat później 1944-2004","overview":"","popularity":0.0909,"poster_path":null,"release_date":"2004-12-31","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"5c4125409251416e2db181c5","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":576063,"title":"Kiedy ty śpisz","original_language":"pl","original_title":"Kiedy ty śpisz","overview":"","popularity":0.0801,"poster_path":"/ijfiaXAt2VixvZUnjP0qbQMqdh4.jpg","release_date":"1953-01-01","softcore":false,"video":false,"vote_average":6.2,"vote_count":10,"credit_id":"5c41e092c3a36852d33cedea","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":576063,"title":"Kiedy ty śpisz","original_language":"pl","original_title":"Kiedy ty śpisz","overview":"","popularity":0.0801,"poster_path":"/ijfiaXAt2VixvZUnjP0qbQMqdh4.jpg","release_date":"1953-01-01","softcore":false,"video":false,"vote_average":6.2,"vote_count":10,"credit_id":"5c41e09ac3a36852d33cedfc","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":"/cI8cAeTLbYlH2GcSqHUw2141Z5X.jpg","genre_ids":[99,36,18],"id":589915,"title":"Marek Edelman… i była miłość w getcie","original_language":"pl","original_title":"Marek Edelman… i była miłość w getcie","overview":"","popularity":0.0829,"poster_path":"/9Rki7Uf5648ce0E1hBlEuWFgvrz.jpg","release_date":"2019-04-29","softcore":false,"video":false,"vote_average":6.0,"vote_count":1,"credit_id":"5c9452aec3a3682e66f24c3e","department":"Directing","job":"Co-Director"},{"adult":false,"backdrop_path":"/Pbr2ImzoDbE8CdGyencQpdEOdw.jpg","genre_ids":[18,36,10752],"id":13614,"title":"Katyń","original_language":"pl","original_title":"Katyń","overview":"Gdy 17 września 1939 roku armia radziecka wkroczyła do Polski, nieprzygotowana do walki na dwóch frontach armia II Rzeczpospolitej musiała ponieść klęskę. Wśród jeńców wojennych znalazło się kilkanaście tysięcy oficerów. Ich rodziny z utęsknieniem czekały na ich powrót. Nigdy on jednak nie nastąpił. Dzieło Andrzeja Wajdy ukazuje historie kobiet, które mimo upływu lat, ciągle czekały na powrót swych mężów, synów, braci i ojców, uwięzionych przez NKWD.","popularity":1.1268,"poster_path":"/jTjmCW1ymW3G29TQBVGthRMUKSG.jpg","release_date":"2007-09-21","softcore":false,"video":false,"vote_average":6.7,"vote_count":282,"credit_id":"5ea1f85fdb72c00026ba65c1","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":"/3d7Zh7ZGk1TbiUA3ZGKyS3qCpBi.jpg","genre_ids":[18],"id":42199,"title":"Bez znieczulenia","original_language":"pl","original_title":"Bez znieczulenia","overview":"Po powrocie z zagranicy znany dziennikarz dowiaduje się, że żona bierze z nim rozwód. Ponieważ nie zna przyczyn decyzji małżonki, nie może się z tym pogodzić. Dodatkowo zaczyna popadać w coraz większe kłopoty zawodowe. Jego wystąpienie telewizyjne i publikacje prasowe nie zyskują uznania. Na uniwersytecie zawieszono wykłady, które prowadził. Planowany od dłuższego czasu wyjazd za granicę zostaje niespodziewanie odwołany. Podczas rozprawy rozwodowej żona zaczyna obciążać męża, składając fałszywe zeznania.","popularity":0.3599,"poster_path":"/bxS0z1Ji4VVWZthMZpooi0Fcviu.jpg","release_date":"1978-11-27","softcore":false,"video":false,"vote_average":6.8,"vote_count":16,"credit_id":"5fe5dfe21ac2920040bac93e","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":"/4NadZy5DWh7KGrmnf5Ye95VnlnA.jpg","genre_ids":[18],"id":1367512,"title":"Noc listopadowa","original_language":"pl","original_title":"Noc listopadowa","overview":"Staging of Stanisław Wyspański’s play","popularity":0.4125,"poster_path":null,"release_date":"1974-01-13","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"6703d6c2cc904f12d91397bf","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/cWUaArHGceAvZR7QEqOt8JM9E5f.jpg","genre_ids":[18],"id":1433418,"title":"Zbrodnia i kara","original_language":"pl","original_title":"Zbrodnia i kara","overview":"","popularity":0.1382,"poster_path":"/jiENMfJA1lIKEatxRoUjxqIgP4i.jpg","release_date":"1987-04-13","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"67ad20ceb9b17924e2d0b2dd","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/cWUaArHGceAvZR7QEqOt8JM9E5f.jpg","genre_ids":[18],"id":1433418,"title":"Zbrodnia i kara","original_language":"pl","original_title":"Zbrodnia i kara","overview":"","popularit