:[18],"id":1166923,"title":"Bigda idzie!","original_language":"pl","original_title":"Bigda idzie!","overview":"Żądny władzy działacz chłopski, Bigda, knuje intrygi zmierzające do obalenia rządu i zastąpienia go nowym, na którego czele chce stanąć. Grożąc i zastraszając, polityk realizuje swój plan.","popularity":0.2226,"poster_path":"/lTyHt1POIwzXx3wepjiSRK59eSN.jpg","release_date":"1999-11-29","softcore":false,"video":true,"vote_average":5.0,"vote_count":1,"credit_id":"697cafa7ba5cfb4f3959a27a","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":"/vqI9awXaqs64a9wW8DwjgIWa5Gj.jpg","genre_ids":[18,36],"id":411678,"title":"Powidoki","original_language":"pl","original_title":"Powidoki","overview":"Intymny zapis ostatniego okresu życia pioniera awangardy w Polsce lat 20. i 30. XX w. Głównym bohaterem jest artysta, który nie poddał się obowiązującemu socrealizmowi i doświadczył dramatycznych skutków swoich wyborów. Opowieść o tym, jak komunistyczna władza zniszczyła obdarzonego charyzmą, niepokornego człowieka. Wajda jak nikt, potrafi w uniwersalny, a jednocześnie subtelny sposób wydobyć z niemalarskiego świata niedostrzegalne obrazy i sycić nimi widza.","popularity":0.6034,"poster_path":"/wQLCoJN7Ua3Q0GGi2nlf8Bcu74D.jpg","release_date":"2016-10-22","softcore":false,"video":false,"vote_average":6.53,"vote_count":84,"credit_id":"6988a8b257a4b625272ceacb","department":"Writing","job":"Screenplay"}],"id":2801}