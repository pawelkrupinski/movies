3567,"poster_path":"/y23N8PDx5jJnPBwZhrnl1hhFCyn.jpg","release_date":"2015-01-06","softcore":false,"video":false,"vote_average":6.0,"vote_count":1,"character":"Self","credit_id":"5faf07ac9b6e47003ca31875","order":2},{"adult":false,"backdrop_path":"/gLr8DBGveOCJAS469GnWTRSXsP9.jpg","genre_ids":[35,80,18],"id":92591,"title":"Bernie","original_language":"en","original_title":"Bernie","overview":"W małym teksańskim miasteczku mieszka Bernie (Jack Black). Wszyscy go uwielbiają, jest wzorowym chrześcijaninem, dobrym sąsiadem i porządnym obywatelem. Pracuje jako grabarz i gdy zaprzyjaźnia się z wyjątkowo nieuprzejmą i dopiero co owdowiałą Marjorie (Shirley MacLaine), nikogo to nie dziwi. Spędzają razem każdą wolną chwilę, do czasu kiedy Marjorie znika w tajemniczych okolicznościach...","popularity":1.1456,"poster_path":"/rW5CetooG545jpkPNpD4FjFAXfe.jpg","release_date":"2012-04-27","softcore":false,"video":false,"vote_average":6.573,"vote_count":1036,"character":"Deadbeat Dad (uncredited)","credit_id":"60348430d7f465003c70e5e8","order":119},{"adult":false,"backdrop_path":"/pQ1DEjnekaOy7EoUsKwThMeEMKN.jpg","genre_ids":[99],"id":486888,"title":"Linklater: On Cinema and Time","original_language":"en","original_title":"Linklater: On Cinema and Time","overview":"","popularity":0.251,"poster_path":"/6qsyj1LiV0FRWPj3oyc1FVuoBuw.jpg","release_date":"2013-12-04","softcore":false,"video":false,"vote_average":7.1,"vote_count":8,"character":"Self (voice)","credit_id":"6101ef65f0647c0047d902f0","order":0},{"adult":false,"backdrop_path":"/nAoDRZ7ESMhfVmQW3VTtISWnmFX.jpg","genre_ids":[10402,18,10749],"id":18586,"title":"The Hottest State","original_language":"en","original_title":"The Hottest State","overview":"Akcja filmu rozgrywa się w świecie nowojorskiej awangardy artystycznej. Jest to opowieść o dwójce ambitnych osób (aktor i piosenkarka), którzy muszą odnaleźć własne \"ja\" w konsumpcyjnej rzeczywistości jednocześnie dbając o łączące ich uczucie.","popularity":0.8902,"poster_path":"