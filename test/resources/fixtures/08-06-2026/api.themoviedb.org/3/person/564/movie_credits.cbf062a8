ł dziewczynę. Przyparty do muru, potwierdza swoją winę. Vince nagrywa wyznanie na taśmę, by zaprezentować ją Amy, która niebawem zjawi się w hotelu.","popularity":0.8373,"poster_path":"/4Flz17KOjGdGqJ2dFRhKnB7eg5.jpg","release_date":"2001-11-02","softcore":false,"video":false,"vote_average":6.9,"vote_count":245,"credit_id":"5c1d023fc3a368510aec3e7c","department":"Camera","job":"Camera Operator"},{"adult":false,"backdrop_path":null,"genre_ids":[10402,35],"id":627012,"title":"Merrily We Roll Along","original_language":"en","original_title":"Merrily We Roll Along","overview":"","popularity":0.3475,"poster_path":"/l9xGuTAKuBmbuj7OVL2yJgpE0yE.jpg","release_date":"","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"5d68744cb7fbbd001212a197","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":null,"genre_ids":[10402,35],"id":627012,"title":"Merrily We Roll Along","original_language":"en","original_title":"Merrily We Roll Along","overview":"","popularity":0.3475,"poster_path":"/l9xGuTAKuBmbuj7OVL2yJgpE0yE.jpg","release_date":"","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"5d6820cca27502000faf7b0f","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":null,"genre_ids":[35],"id":655865,"title":"Une journée au bureau","original_language":"en","original_title":"Une journée au bureau","overview":"","popularity":1.138,"poster_path":"/vZ3ZH2L1G5l8WqRNOgpwmkbu6CH.jpg","release_date":"2019-11-25","softcore":false,"video":false,"vote_average":5.0,"vote_count":1,"credit_id":"5df61bcc65686e0018845a23","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":null,"genre_ids":[35],"id":655865,"title":"Une journée au bureau","original_language":"en","original_title":"Une journée au bureau","overview":"","popularity":1.138,"poster_path":"/vZ3ZH2L1G5l8WqRNOgpwmkbu6CH.jpg","release_date":"2019-11-25","softcore":false,"video":false,"vote_average":5.0,"vote_count":1,"credit_