{"cast":[{"adult":false,"backdrop_path":null,"genre_ids":[18,10402],"id":1000001,"title":"Narodziny rozgwiazdy","original_language":"pl","original_title":"Narodziny rozgwiazdy","overview":"Przypadkowe spotkanie sprzątaczki z Ukrainy i byłego gwiazdora polskiej sceny muzycznej prowadzi do nagrania przez nich wspólnej piosenki o miłości.","popularity":0.0569,"poster_path":"/hhobxAk36PlxSHU8KIeugkNBJBs.jpg","release_date":"2022-09-17","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"character":"","credit_id":"62d125a835811d0051dd817b","order":4},{"adult":false,"backdrop_path":"/fYN5LVxnLHc890ABfD8QVBvGUkc.jpg","genre_ids":[18],"id":1359369,"title":"Serwis","original_language":"pl","original_title":"Serwis","overview":"Piotruś jest wiecznie spłukany i ma tego dość. W nocy jest gwiazdą undergroundowego zespołu, w dzień pracuje jako kelner w hotelowej restauracji. Kiedy nadarza się okazja, postanawia sprzedać narkotyki jednej z wyjątkowo bogatych gościń, Joannie.","popularity":0.0596,"poster_path":"/9pwKhRFS9teDeVC6bybBhA9PWpG.jpg","release_date":"2024-10-16","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"character":"","credit_id":"66edef836c3b7a8d648cf985","order":4}],"crew":[{"adult":false,"backdrop_path":"/2z97plJlbn0pG9Aws04Ka0GJlUP.jpg","genre_ids":[18,35,10749],"id":999597,"title":"Martwe małżeństwo","original_language":"pl","original_title":"Martwe małżeństwo","overview":"Filip jest mężczyzną w średnim wieku. Pracuje jako zawodowy statysta filmowy, a jego specjalnością są role martwych ciał. Na planie filmu historycznego poznaje Łucję, która wciela się w rolę martwej kobiety.","popularity":0.2267,"poster_path":"/cGiFGJaa4YmkrSWRidgQhxVwYZP.jpg","release_date":"2022-09-17","softcore":false,"video":false,"vote_average":7.688,"vote_count":8,"credit_id":"62cf3b720b5fd60053874ca1","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/2z97plJlbn0pG9Aws04Ka0GJlUP.jpg","genre_ids":[18,35,10749],"id":999597,"title":"