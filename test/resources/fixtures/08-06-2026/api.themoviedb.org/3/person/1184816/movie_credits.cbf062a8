{"cast":[{"adult":false,"backdrop_path":"/m0tv3CSX7GFhyaVSja6eKD6Yt67.jpg","genre_ids":[99],"id":191510,"title":"Shooting Bigfoot","original_language":"en","original_title":"Shooting Bigfoot","overview":"","popularity":0.4491,"poster_path":"/5lis2dKN9d7PAQvm7ElgkMah27Y.jpg","release_date":"2013-06-21","softcore":false,"video":false,"vote_average":6.8,"vote_count":4,"character":"Himself","credit_id":"52fe4c889251416c910f7e03","order":4},{"adult":false,"backdrop_path":"/r5ktLr4tBNGJ8GLs28IgTMQrjS6.jpg","genre_ids":[99],"id":273456,"title":"When Harry Left Hogwarts","original_language":"en","original_title":"When Harry Left Hogwarts","overview":"","popularity":0.7,"poster_path":"/teaxwoDYzx63hzq39ytfavHMEbI.jpg","release_date":"2011-11-11","softcore":false,"video":false,"vote_average":7.2,"vote_count":10,"character":"Self","credit_id":"65c965ab54a098018403b180","order":12}],"crew":[{"adult":false,"backdrop_path":"/poL87RE9mtvfiAKas8DHtdqA6nG.jpg","genre_ids":[99,80],"id":946327,"title":"Nie ufaj nikomu: Polowanie na króla kryptowalut","original_language":"en","original_title":"Trust No One: The Hunt for the Crypto King","overview":"Kiedy młody założyciel upadającej giełdy kryptowalutowej niespodziewanie umiera, zdenerwowani inwestorzy podejrzewają, że za jego śmiercią kryje się coś więcej.","popularity":1.025,"poster_path":"/2ZzllPVrYmBn28Kc7PZaQ0PrQat.jpg","release_date":"2022-03-30","softcore":false,"video":false,"vote_average":6.083,"vote_count":120,"credit_id":"6228c5d055c1f40047a4e32f","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/A2WRSXXo5c8ojPhARzN5aczv86H.jpg","genre_ids":[18,10751,12],"id":826680,"title":"Wielka ucieczka","original_language":"en","original_title":"The Railway Children Return","overview":"Jest rok 1944. Trójka rodzeństwa zostaje wysłana do oddalonej od zagrożeń małej miejscowości na prowincji Anglii. Na peronie stacji kolejowej czeka już na nich zaprzyjaźniona rodzina. Z pomocą życzliwych ludzi, dzieci już wkrótce przyzwyczajają się do życia z dala od zgiełku niebezpiecznego miasta. Pewnego dnia, podczas zabawy w chowanego, dzieci spotykają ukrywającego się na stacji kolejowej młodego żołnierza, który mówi im, że ma do wykonania ściśle tajną misję. Na tropie nieznajomego jest Żandarmeria Wojskowa, która próbuje go schwytać za wszelką cenę. Tak oto rozpoczyna się niezwykła i ekscytująca przygoda. Jednak trójka rodzeństwa to za mało, więc do akcji ratowania żołnierza przyłączają się również dzieci z całej okolicy. Młodzi bohaterowie muszą zrobić wszystko co w ich mocy, aby pomóc mu wsiąść do pociągu, który odwiezie go w bezpieczne miejsce.","popularity":1.2171,"poster_path":"/drajSOlftyfzJKIk1f0TgSGYhmP.jpg","release_date":"2022-07-15","softcore":false,"video":false,"vote_average":6.5,"vote_count":264,"credit_id":"60942483a6d93100790be10a","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/4ctZVxjWSujhyPg3s9JU8Gdnvc8.jpg","genre_ids":[99],"id":836020,"title":"Killer in Our Classroom: Never Again","original_language":"en","original_title":"Killer in Our Classroom: Never Again","overview":"","popularity":0.0437,"poster_path":"/tPyeSpzx84UOGAV8N1yFO2U2VyG.jpg","release_date":"2018-09-04","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"60b6ff89dfaae9004069bccf","department":"Production","job":"Executive Producer"},{"adult":false,"backdrop_path":"/m0tv3CSX7GFhyaVSja6eKD6Yt67.jpg","genre_ids":[99],"id":191510,"title":"Shooting Bigfoot","original_language":"en","original_title":"Shooting Bigfoot","overview":"","popularity":0.4491,"poster_path":"/5lis2dKN9d7PAQvm7ElgkMah27Y.jpg","release_date":"2013-06-21","softcore":false,"video":false,"vote_average":6.8,"vote_count":4,"credit_id":"52fe4c889251416c910f7def","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":207137,"title":"Britain in a Day","original_language":"en","original_title":"Britain in a Day","overview":"","popul