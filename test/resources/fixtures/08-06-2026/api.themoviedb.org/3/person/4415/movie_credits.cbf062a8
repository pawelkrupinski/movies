original_language":"it","original_title":"L'ultima carrozzella","overview":"Toto (Aldo Fabrizi), rzymski woźnica ze staromodnym powozem konnym, który sprzeciwia się konkurencji ze strony zmotoryzowanych taksówek, nie chce, aby jego córka Nannarella spotykała się z Roberto, młodym taksówkarzem. Jednak to Roberto pomaga mu, gdy wpada w kłopoty z byłą klientką, arogancką piosenkarką Mary Dunchetti (Anna Magnani).","popularity":0.146,"poster_path":"/X0b2fJHWzVYxyrEBsjEGaABV1Q.jpg","release_date":"1943-12-01","softcore":false,"video":false,"vote_average":6.75,"vote_count":10,"credit_id":"61c0f371d55c3d0041a65fb4","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":"/ff8fudPikvrwJgIOoDJMDX2l3eD.jpg","genre_ids":[18,12],"id":210511,"title":"Il passatore","original_language":"it","original_title":"Il passatore","overview":"","popularity":0.1894,"poster_path":"/3XACouU6nfHF25dPPDK1TH91XnK.jpg","release_date":"1947-10-22","softcore":false,"video":false,"vote_average":6.0,"vote_count":4,"credit_id":"61c0fb062da8460092967f13","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":"/6xAhBxYtGys6vAwalOHmZAaVbKL.jpg","genre_ids":[10749,35],"id":257438,"title":"Avanti c'è posto!","original_language":"it","original_title":"Avanti c'è posto!","overview":"","popularity":0.1953,"poster_path":"/jZ9hb2a6mEZh4aKamFylWGXEPSE.jpg","release_date":"1942-08-30","softcore":false,"video":false,"vote_average":8.0,"vote_count":3,"credit_id":"61c0f04ba84ff70068f9a763","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":"/sc59wMnnTPgbYynDhOeEdTWd6JJ.jpg","genre_ids":[35],"id":57060,"title":"Cameriera bella presenza offresi...","original_language":"it","original_title":"Cameriera bella presenza offresi...","overview":"","popularity":0.318,"poster_path":"/9UFzJdGWREngKo6N5wKUfBvdIyG.jpg","release_date":"1951-11-03","softcore":false,"video":false,"vote_average":8.3,"vote_count":5,"credit_id":"61c245ec63a6950019d2eea2","department":"Writing"