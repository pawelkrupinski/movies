</script>


        <script id="repo-template" type="text/x-handlebars-template">
        <div class="modal  fade in dialog" id="RepoModal" style="display: block">

            <button id="trap-top-focus" href="#" title="Przycisk funkcyjny programu" style="opacity:0;cursor:pointer;" tabindex="0">
                Początek treści
            </button>
            <div class="dialog-backdrop active fade in" style="bottom: 0">
                <div class="modal-dialog" id="modalDialog" role="dialog" aria-modal="true">
                    <div class="modal-content">
                        <div class="modal-header">
                            <button type="button" class="close modal-Focus first-element-in-modal" data-dismiss="modal" aria-label="Close" title="Zamknij " id="closeModalBtn">
                                <span class="sr-only">Zamknij </span>
                                <span aria-hidden="true">&times;</span>
                            </button>
                            <h3 class="modal-title dialog-title " tabindex="0">
                                <span class="glyphicon glyphicon-tag"></span>
                                {{Name}}
                            </h3>
                        </div>
                        <div class="modal-body" style=" word-wrap:break-word;">
                            <div class="media">
                                {{#ifCond PosterId '>' 0}}
                                <div class="media-left hidden-xs" tabindex="0">
                                    <a href="#" class="modal-Focus">
                                        <img src="/MSI/ImageData.ashx?id={{PosterId}}&amp;mode=thumb" alt="{{Name}}" class="" />
                                    </a>
                                </div>
                                {{/ifCond}}
                                <div class="media-body" style=" word-wrap:break-word;" tabindex="0">
                                    Data: <strong class="dialog-strong">{{Date}}</strong>
                                    {{#if Hour}}
                                    <div>Godzina: <strong class="dialog-strong">{{Hour}}</strong></div>
                                    {{/if}}
                                    {{#if Description}}
                                    <br />
                                    <div class="hidden-xs">{{{Description}}}</div>
                                    {{/if}}
                                </div>
                                <div class="modal-footer">
                                    <div class="row">
                                        <div class="col-sm-3">
                                            <button type="button" class="btn btn-anuluj btn-block modal-Focus" data-dismiss="modal" aria-label="Close" title="Zamknij">
                                                <span class="sr-only">Zamknij  </span>
                                                <span class="glyphicon glyphicon-remove"></span>ANULUJ
                                            </button>
                                        </div>

                                        {{#if ShowFreeEventButton}}
                                        <div class="col-sm-4">
                                            <a href="{{ UrlBuy }}" class="btn btn-kup btn-block modal-Focus">
                                                <span class="glyphicon glyphicon-star"></span>WYBIERAM
                                            </a>
                                        </div>
                                        {{/if}}
                                        {{#if ShowBuyButton}}
                                        <div class="col-sm-4">
                                            <a href="{{ UrlBuy }}" class="btn btn-kup btn-block  modal-Focus">
                                                <span class="glyphicon glyphicon-credit-card"></span>KUP BILET
                                            </a>
                                        </div>
                                        {{/if}}
                                        {{#if ShowReservationButton}}
                                        <div class="col-sm-5">
                                            <a href="{{ UrlRez }}" class="btn btn-rezerwuj btn-block modal-Focus">
                                                <span class="glyphicon glyphicon-star"></span>REZERWUJ MIEJSCE
                                            </a>
                                        </div>
                                        {{/if}}

                                    </div>
                                    <div class="row" tabindex="0" id="modalLastItem">
                                        <div class="col-12" style="margin-top: 15px; text-align: justify">
                                            <div class="alert alert-warning last-element-on-modal" style="margin-bottom: 0">
                                                Uwaga! W następnym kroku nie ma już możliwości wyboru pomiędzy Kupnem bilet&#243;w a Rezerwacją miejsc.

                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            </div>

            <button id="trap-down-focus" href="#" title="Przycisk funkcyjny programu" style="opacity:0;cursor:pointer;position:absolute;left:-100px;">
                Koniec treści
            </button>
        </div>
    </script>
    <script type="text/javascript">
        var RepertoireEvents = [{ 'Id': 16944, 'Name': 'Drugie życie', 'Date': '19.06.2026', 'Hour': '19:00', 'PosterId': '1572', 'Description': 'María Ángeles od czterdziestu lat mieszka w słonecznym apartamencie w sercu marokańskiego Tangeru. To miejsce, które pamięta jej miłość, codzienne rytuały i całe życie zapisane w ścianach, meblach i drobnych gestach. Gdy zostaje zmuszona do opuszczenia swojego domu, nie potrafi się z tym pogodzić – bo dom to nie tylko adres,...', 'ShowBuyButton': true, 'ShowReservationButton': true, 'ShowFreeEventButton': false},{ 'Id': 16945, 'Name': 'Drugie życie', 'Date': '20.06.2026', 'Hour': '19:00', 'PosterId': '1572', 'Description': 'María Ángeles od czterdziestu lat mieszka w słonecznym apartamencie w sercu marokańskiego Tangeru. To miejsce, które pamięta jej miłość, codzienne rytuały i całe życie zapisane w ścianach, meblach i drobnych gestach. Gdy zostaje zmuszona do opuszczenia swojego domu, nie potrafi się z tym pogodzić – bo dom to nie tylko adres,...', 'ShowBuyButton': true, 'ShowReservationButton': true, 'ShowFreeEventButton': false},{ 'Id': 16946, 'Name': 'Drugie życie', 'Date': '21.06.2026', 'Hour': '19:00', 'PosterId': '1572', 'Description': 'María Ángeles od czterdziestu lat mieszka w słonecznym apartamencie w sercu marokańskiego Tangeru. To miejsce, które pamięta jej miłość, codzienne rytuały i całe życie zapisane w ścianach, meblach i drobnych gestach. Gdy zostaje zmuszona do opuszczenia swojego domu, nie potrafi się z tym pogodzić – bo dom to nie tylko adres,...', 'ShowBuyButton': true, 'ShowReservationButton': true, 'ShowFreeEventButton': false},{ 'Id': 16947, 'Name': 'Drugie życie', 'Date': '24.06.2026', 'Hour': '19:00', 'PosterId': '1572', 'Description': 'María Ángeles od czterdziestu lat mieszka w słonecznym apartamencie w sercu marokańskiego Tangeru. To miejsce, które pamięta jej miłość, codzienne rytuały i całe życie zapisane w ścianach, meblach i drobnych gestach. Gdy zostaje zmuszona do opuszczenia swojego domu, nie potrafi się z tym pogodzić – bo dom to nie tylko adres,...', 'ShowBuyButton': true, 'ShowReservationButton': true, 'ShowFreeEventButton': false},{ 'Id': 16949, 'Name': 'Dzień objawienia', 'Date': '26.06.2026', 'Hour': '18:30', 'PosterId': '1573', 'Description': 'Gdybyś dowiedział się, że nie jesteśmy sami, gdyby ktoś ci to pokazał i udowodnił, bałbyś się?', 'ShowBuyButton': true, 'ShowReservationButton': true, 'ShowFreeEventButton': false},{ 'Id': 16950, 'Name': 'Dzień objawienia', 'Date': '27.06.2026', 'Hour': '18:30', 'PosterId': '1573', 'Description': 'Gdybyś dowiedział się, że nie jesteśmy sami, gdyby ktoś ci to pokazał i udowodnił, bałbyś się?', 'ShowBuyButton': true, 'ShowReservationButton': true, 'ShowFreeEventButton': false},{ 'Id': 16951, 'Name': 'Dzień objawienia', 'Date': '28.06.2026', 'Hour': '18:30', 'PosterId': '1573', 'Description': 'Gdybyś dowiedział się, że nie jesteśmy sami, gdyby ktoś ci to pokazał i udowodnił, bałbyś się?', 'ShowBuyButton': true, 'ShowReservationButton': true, 'ShowFreeEventButton': false},{ 'Id': 16952, 'Name': 'Dzień objawienia', 'Date': '30.06.2026', 'Hour': '18:30', 'PosterId': '1573', 'Description': 'Gdybyś dowiedział się, że nie jesteśmy sami, gdyby ktoś ci to pokazał i udowodnił, bałbyś się?', 'ShowBuyButton': true, 'ShowReservationButton': true, 'ShowFreeEventButton': false},{ 'Id': 16962, 'Name': 'K-popowe łowczynie demonów', 'Date': '14.06.2026', 'Hour': '15:00', 'PosterId': '1577', 'Description': 'Gwiazdy K-popu Rumi, Mira i Zoey w przerwach między koncertami na pełnych stadionach bronią fanów przed nadnaturalnymi zagrożeniami, korzystając ze swoich tajemnych mocy.', 'ShowBuyButton': true, 'ShowReservationButton': true, 'ShowFreeEventButton': false},{ 'Id': 16963, 'Name': 'K-popowe łowczynie demonów', 'Date': '16.06.2026', 'Hour': '15:00', 'PosterId': '1577', 'Description': 'Gwiazdy K-popu Rumi, Mira i Zoey w przerwach między koncertami na pełnych stadionach bronią fanów przed nadnaturalnymi zagrożeniami, korzystając ze swoich tajemnych mocy.', 'ShowBuyButton': true, 'ShowReservationButton': true, 'ShowFreeEventButton': false},{ 'Id': 16964, 'Name': 'K-popowe łowczynie demonów', 'Date': '17.06.2026', 'Hour': '15:00', 'PosterId': '1577', 'Description': 'Gwiazdy K-popu Rumi, Mira i Zoey w przerwach między koncertami na pełnych stadionach bronią fanów przed nadnaturalnymi zagrożeniami, korzystając ze swoich tajemnych mocy.', 'ShowBuyButton': true, 'ShowReservationButton': true, 'ShowFreeEventButton': false},{ 'Id': 16955, 'Name': 'Łobuz', 'Date': '25.06.2026', 'Hour': '18:00', 'PosterId': '1575', 'Description': 'Młody bezdomny zmaga się z przeszłością i marginalizacją, próbując odmienić swoje życie. Wśród trudności pojawiają się nieoczekiwane szanse na nowy początek i samopoznanie.', 'ShowBuyButton': true, 'ShowReservationButton': true, 'ShowFreeEventButton': false},{ 'Id': 16960, 'Name': 'Mandalorian i Grogu - dubbing', 'Date': '10.06.2026', 'Hour': '14:30', 'PosterId': '1565', 'Description': 'Imperium upadło, a Nowa Republika, która stara się chronić wszystko, o co walczyła Rebelia, zwraca się o pomoc do legendarnego mandaloriańskiego łowcy nagród, Dina Djarina, i jego młodego ucznia, Grogu.', 'ShowBuyButton': true, 'ShowReservationButton': true, 'ShowFreeEventButton': false},{ 'Id': 16905, 'Name': 'Mandalorian i Grogu - napisy', 'Date': '10.06.2026', 'Hour': '17:00', 'PosterId': '0', 'Description': 'Imperium upadło, a Nowa Republika, która stara się chronić wszystko, o co walczyła Rebelia, zwraca się o pomoc do legendarnego mandaloriańskiego łowcy nagród, Dina Djarina, i jego młodego ucznia, Grogu.', 'ShowBuyButton': true, 'ShowReservationButton': true, 'ShowFreeEventButton': false},{ 'Id': 16954, 'Name': 'Niesamowita historia Mumbo Jumbo', 'Date': '21.06.2026', 'Hour': '10:00', 'PosterId': '1574', 'Description': 'Mumbo Jumbo w magiczny sposób wyrasta do gigantycznych rozmiarów. Teraz, wraz z trójką przyjaciół, musi wyruszyć w niebezpieczną podróż, by odnaleźć straszną czarownicę, która przywróci go do normalnego rozmiaru.', 'ShowBuyButton': true, 'ShowReservationButton': true, 'ShowFreeEventButton': false},{ 'Id': 16919, 'Name': 'Ostatnia sesja w Paryżu', 'Date': '12.06.2026', 'Hour': '19:00', 'PosterId': '1569', 'Description': 'Kiedy znana psychiatrka Lilian Steiner dowiaduje się o śmierci jednej ze swoich pacjentek, jest głęboko zaniepokojona. Przekonana, że było to morderstwo, postanawia podjąć śledztwo.', 'ShowBuyButton': true, 'ShowReservationButton': true, 'ShowFreeEventButton': false},{ 'Id': 16948, 'Name': 'Rambo. Pierwsza krew', 'Date': '23.06.2026', 'Hour': '19:00', 'PosterId': '1576', 'Description': 'John Rambo, były komandos, weteran wojny w Wietnamie, naraża się policjantom z pewnego miasteczka. Ci nie wiedzą, jak groźnym przeciwnikiem jest ten włóczęga.', 'ShowBuyButton': true, 'ShowReservationButton': true, 'ShowFreeEventButton': false},{ 'Id': 16911, 'Name': 'Straszny film - dubbing', 'Date': '12.06.2026', 'Hour': '17:00', 'PosterId': '0', 'Description': 'Dwóch przyjaciół po raz kolejny wpada w sam środek chaosu z udziałem zabójców, potworów i nadprzyrodzonych istot.', 'ShowBuyButton': true, 'ShowReservationButton': true, 'ShowFreeEventButton': false},{ 'Id': 16912, 'Name': 'Straszny film - dubbing', 'Date': '13.06.2026', 'Hour': '17:00', 'PosterId': '0', 'Description': 'Dwóch przyjaciół po raz kolejny wpada w sam środek chaosu z udziałem zabójców, potworów i nadprzyrodzonych istot.', 'ShowBuyButton': true, 'ShowReservationButton': true, 'ShowFreeEventButton': false},{ 'Id': 16914, 'Name': 'Straszny film - dubbing', 'Date': '16.06.2026', 'Hour': '17:00', 'PosterId': '0', 'Description': 'Dwóch przyjaciół po raz kolejny wpada w sam środek chaosu z udziałem zabójców, potworów i nadprzyrodzonych istot.', 'ShowBuyButton': true, 'ShowReservationButton': true, 'ShowFreeEventButton': false},{ 'Id': 16915, 'Name': 'Straszny film - dubbing', 'Date': '17.06.2026', 'Hour': '17:00', 'PosterId': '0', 'Description': 'Dwóch przyjaci