        <script id="repo-template" type="text/x-handlebars-template">
        <div class="modal  fade in dialog" id="RepoModal" style="display: block">

            <button id="trap-top-focus" href="#" title="Przycisk funkcyjny programu" style="opacity:0;cursor:pointer;" tabindex="0">
                Początek treści
            </button>
            <div class="dialog-backdrop active fade in" style="bottom: 0">
                <div class="modal-dialog" id="modalDialog" role="dialog" aria-modal="true">
                    <div class="modal-content">
                        <div class="modal-header">
                            <button type="button" class="close modal-Focus first-element-in-modal" data-dismiss="modal" aria-label="Close" title="Zamknij " id="closeModalBtn">
                                <span class="sr-only">Zamknij </span>
                                <span aria-hidden="true">&times;</span>
                            </button>
                            <h3 class="modal-title dialog-title " tabindex="0">
                                <span class="glyphicon glyphicon-tag"></span>
                                {{Name}}
                            </h3>
                        </div>
                        <div class="modal-body" style=" word-wrap:break-word;">
                            <div class="media">
                                {{#ifCond PosterId '>' 0}}
                                <div class="media-left hidden-xs" tabindex="0">
                                    <a href="#" class="modal-Focus">
                                        <img src="/MSI/ImageData.ashx?id={{PosterId}}&amp;mode=thumb" alt="{{Name}}" class="" />
                                    </a>
                                </div>
                                {{/ifCond}}
                                <div class="media-body" style=" word-wrap:break-word;" tabindex="0">
                                    Data: <strong class="dialog-strong">{{Date}}</strong>
                                    {{#if Hour}}
                                    <div>Godzina: <strong class="dialog-strong">{{Hour}}</strong></div>
                                    {{/if}}
                                    {{#if Description}}
                                    <br />
                                    <div class="hidden-xs">{{{Description}}}</div>
                                    {{/if}}
                                </div>
                                <div class="modal-footer">
                                    <div class="row">
                                        <div class="col-sm-3">
                                            <button type="button" class="btn btn-anuluj btn-block modal-Focus" data-dismiss="modal" aria-label="Close" title="Zamknij">
                                                <span class="sr-only">Zamknij  </span>
                                                <span class="glyphicon glyphicon-remove"></span>ANULUJ
                                            </button>
                                        </div>

                                        {{#if ShowFreeEventButton}}
                                        <div class="col-sm-4">
                                            <a href="{{ UrlBuy }}" class="btn btn-kup btn-block modal-Focus">
                                                <span class="glyphicon glyphicon-star"></span>WYBIERAM
                                            </a>
                                        </div>
                                        {{/if}}
                                        {{#if ShowBuyButton}}
                                        <div class="col-sm-4">
                                            <a href="{{ UrlBuy }}" class="btn btn-kup btn-block  modal-Focus">
                                                <span class="glyphicon glyphicon-credit-card"></span>KUP BILET
                                            </a>
                                        </div>
                                        {{/if}}
                                        {{#if ShowReservationButton}}
                                        <div class="col-sm-5">
                                            <a href="{{ UrlRez }}" class="btn btn-rezerwuj btn-block modal-Focus">
                                                <span class="glyphicon glyphicon-star"></span>REZERWUJ MIEJSCE
                                            </a>
                                        </div>
                                        {{/if}}

                                    </div>
                                    <div class="row" tabindex="0" id="modalLastItem">
                                        <div class="col-12" style="margin-top: 15px; text-align: justify">
                                            <div class="alert alert-warning last-element-on-modal" style="margin-bottom: 0">
                                                Uwaga! W następnym kroku nie ma już możliwości wyboru pomiędzy Kupnem bilet&#243;w a Rezerwacją miejsc.

                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            </div>

            <button id="trap-down-focus" href="#" title="Przycisk funkcyjny programu" style="opacity:0;cursor:pointer;position:absolute;left:-100px;">
                Koniec treści
            </button>
        </div>
    </script>
    <script type="text/javascript">
        var RepertoireEvents = [{ 'Id': 35091, 'Name': '90. URODZINY PAVAROTTIEGO (Luciano Pavarotti – The man who moved the world)', 'Date': '14.06.2026', 'Hour': '14:30', 'PosterId': '1723', 'Description': 'REŻYSERIA: Luigi Antonini<br><br> WYSTĘPUJĄ: Andrea Bocelli, José Carreras, Plácido Domingo, Il Volo, Jonathan Tetelman, Hauser <br><br><br>Jesienią 2025 roku w słynnej Arena di Verona zebrały się największe gwiazdy opery i popu, w tym Andrea Bocelli, Jonathan Tetelman, Angela Gheorghiu i Il Volo, by dać niebywały koncert,...', 'ShowBuyButton': true, 'ShowReservationButton': true, 'ShowFreeEventButton': false},{ 'Id': 35092, 'Name': '90. URODZINY PAVAROTTIEGO (Luciano Pavarotti – The man who moved the world)', 'Date': '28.06.2026', 'Hour': '13:00', 'PosterId': '1723', 'Description': 'REŻYSERIA: Luigi Antonini<br><br> WYSTĘPUJĄ: Andrea Bocelli, José Carreras, Plácido Domingo, Il Volo, Jonathan Tetelman, Hauser <br><br><br>Jesienią 2025 roku w słynnej Arena di Verona zebrały się największe gwiazdy opery i popu, w tym Andrea Bocelli, Jonathan Tetelman, Angela Gheorghiu i Il Volo, by dać niebywały koncert,...', 'ShowBuyButton': true, 'ShowReservationButton': true, 'ShowFreeEventButton': false},{ 'Id': 35116, 'Name': 'ALICJA W KRAINIE TALENTÓW', 'Date': '27.06.2026', 'Hour': '12:00', 'PosterId': '1757', 'Description': 'Witajcie moi drodzy! Nazywam się Alicja i muszę się Wam poskarżyć... Bo ja nie<br>mam żadnego talentu! Naprawdę! Każdy robi coś wyjątkowego. Jedni śpiewają,<br>inni tańczą, a jeszcze inni potrafią malować obrazy, które wyglądają jak żywe...<br>A ja? Ja wyglądam jak... jak ktoś, kto zgubił swój talent po drodze. Albo go nigdy<br>nie...', 'ShowBuyButton': true, 'ShowReservationButton': true, 'ShowFreeEventButton': false},{ 'Id': 35093, 'Name': 'ANIOŁ MORSKI', 'Date': '10.06.2026', 'Hour': '17:00', 'PosterId': '1724', 'Description': 'REŻYSERIA: Rafał Reyman Głombiowski<br>. <br>OBSADA: Sylwia Gola, Sebastian Pawlak, Luiza Budejko, Tomasz Bieliński<br><br><br>Mateusz (Sebastian Pawlak) i Agata (Sylwia Gola) są w pozornie udanym związku. Jednak wszystko zmienia się, kiedy mężczyzna odkrywa, że jego partnerka z kimś się spotyka. Kolejne miesiące to prawdziwa...', 'ShowBuyButton': true, 'ShowReservationButton': true, 'ShowFreeEventButton': false},{ 'Id': 35094, 'Name': 'ANIOŁ MORSKI', 'Date': '18.06.2026', 'Hour': '16:00', 'PosterId': '1724', 'Description': 'REŻYSERIA: Rafał Reyman Głombiowski<br>. <br>OBSADA: Sylwia Gola, Sebastian Pawlak, Luiza Budejko, Tomasz Bieliński<br><br><br>Mateusz (Sebastian Pawlak) i Agata (Sylwia Gola) są w pozornie udanym związku. Jednak wszystko zmienia się, kiedy mężczyzna odkrywa, że jego partnerka z kimś się spotyka. Kolejne miesiące to prawdziwa...', 'ShowBuyButton': true, 'ShowReservationButton': true, 'ShowFreeEventButton': false},{ 'Id': 35095, 'Name': 'ANIOŁ MORSKI', 'Date': '23.06.2026', 'Hour': '17:00', 'PosterId': '1724', 'Description': 'REŻYSERIA: Rafał Reyman Głombiowski<br>. <br>OBSADA: Sylwia Gola, Sebastian Pawlak, Luiza Budejko, Tomasz Bieliński<br><br><br>Mateusz (Sebastian Pawlak) i Agata (Sylwia Gola) są w pozornie udanym związku. Jednak wszystko zmienia się, kiedy mężczyzna odkrywa, że jego partnerka z kimś się spotyka. Kolejne miesiące to prawdziwa...', 'ShowBuyButton': true, 'ShowReservationButton': true, 'ShowFreeEventButton': false},{ 'Id': 35111, 'Name': 'BOTTICELLI, FLORENCJA I MEDYCEUSZE', 'Date': '27.06.2026', 'Hour': '14:00', 'PosterId': '1040', 'Description': 'dokumentalny, Włochy 2021 (94 min) <br><br>Reżysera  Marco Pianigiani<br><br><br>Salvador Dali i Andy Warhol, Terry Gilliam i David LaChapelle, Jeff Koons i Lady Gaga. Co łączy tych artystów? Fascynacja Botticellim. Film opowiada o jego życiu i dziełach oraz o – całkiem niedawnym – ponownym odkryciu fenomenu jego twórczości....', 'ShowBuyButton': true, 'ShowReservationButton': true, 'ShowFreeEventButton': false},{ 'Id': 35082, 'Name': 'CARAVAGGIO. ARCYDZIEŁA NIEPOKORNEGO GENIUSZA', 'Date': '16.06.2026', 'Hour': '17:00', 'PosterId': '1672', 'Description': '(Caravaggio, Wielka Brytania 2025, 100’) – FILM O SZTUCE<br>REŻYSERIA: David Bickerstaff, Phil Grabsky<br><br>Malował świętych z brudem pod paznokciami, ponieważ uważał, że prawdziwa boskość znajduje się w tym, co surowe, realne i najzwyczajniej ludzkie. Takie podejście wymagało od niego odwagi, wymagało też stuprocentowego...', 'ShowBuyButton': true, 'ShowReservationButton': true, 'ShowFreeEventButton': false},{ 'Id': 35059, 'Name': 'CASABLANCA – AMERYKAŃSKA KLASYKA', 'Date': '21.06.2026', 'Hour': '19:00', 'PosterId': '1706', 'Description': '(Casablanca, USA 1942, 102’) <br><br><br>REŻYSERIA Michael Curtiz. <br>OBSADA: Humphrey Bogart, Ingrid Bergman <br><br><br>„Zawsze będziemy mieli Paryż…” – powiada Rick do Ilsy – a my zawsze już będziemy mieli Casablancę. Humphrey Bogart w swojej najbardziej ikonicznej roli przewodzi genialnej obsadzie w filmie, który mógłby...', 'ShowBuyButton': true, 'ShowReservationButton': true, 'ShowFreeEventButton': false},{ 'Id': 35058, 'Name': 'CO SIĘ ZDARZYŁO BABY JANE? – AMERYKAŃSKA KLASYKA', 'Date': '20.06.2026', 'Hour': '19:00', 'PosterId': '1705', 'Description': '(What Ever Happened to Baby Jane?, USA 1962, 134’) <br><br><br>REŻYSERIA Robert Aldrich. <br>OBSADA: Bette Davis, Joan Crawford, Victor Buono <br><br><br>Dwie legendarne gwiazdy złotej ery Hollywood, Bette Davis i Joan Crawford, przenoszą autentyczny prywatny i zawodowy konflikt na ekran w słynnym, kontrowersyjnym thrillerze...', 'ShowBuyButton': true, 'ShowReservationButton': true, 'ShowFreeEventButton': false},{ 'Id': 35050, 'Name': 'CZŁOWIEK Z MARMURU – WAJDA: re- wizje', 'Date': '11.06.2026', 'Hour': '19:00', 'PosterId': '1698', 'Description': '(Polska 1976, 153’) <br><br><br>REŻYSERIA Andrzej Wajda. <br>OBSADA: Krystyna Janda, Jerzy Radziwiłowicz, Tadeusz Łomnicki <br><br><br>Demaskatorska podróż przez archiwa i pamięć stalinowskiej Polski, obraz propagandy niszczącej jednostkę i jeden z najważniejszych filmowych portretów systemowego zniewolenia. <br><br><br>Agnieszka...', 'ShowBuyButton': true, 'ShowReservationButton': true, 'ShowFreeEventButton': false},{ 'Id': 35108, 'Name': 'CZYTAJĄC LOLITĘ W TEHERANIE (Reading Lolita in Tehran)', 'Date': '25.06.2026', 'Hour': '17:00', 'PosterId': '1727', 'Description': ' Izrael/Włochy 2024, 108’<br><br>REŻYSERIA: Eran Riklis.<br>OBSADA: Golshifteh Farahani, Zar Amir Ebrahimi, Mina Kavani<br><br><br>Oparty na bestsellerowej autobiografii Azar Nafisi film to przejmująca i wciąż aktualna opowieść o kobiecej solidarności, odwadze i sile literatury. W głównych rolach wystąpiły czołowe irańskie...', 'ShowBuyButton': true, 'ShowReservationButton': true, 'ShowFreeEventButton': false},{ 'Id': 35109, 'Name': 'CZYTAJĄC LOLITĘ W TEHERANIE (Reading Lolita in Tehran)', 'Date': '27.06.2026', 'Hour': '16:30', 'PosterId': '1727', 'Description': ' Izrael/Włochy 2024, 108’<br><br>REŻYSERIA: Eran Riklis.<br>OBSADA: Golshifteh Farahani, Zar Amir Ebrahimi, Mina Kavani<br><br><br>Oparty na bestsellerowej autobiografii Azar Nafisi film to przejmująca i wciąż aktualna opowieść o kobiecej solidarności, odwadze i sile literatury. W głównych rolach wystąpiły czołowe irańskie...', 'ShowBuyButton': true, 'ShowReservationButton': true, 'ShowFreeEventButton': false},{ 'Id': 35110, 'Name': 'CZYTAJĄC LOLITĘ W TEHERANIE (Reading Lolita in Tehran)', 'Date': '28.06.2026', 'Hour': '15:00', 'PosterId': '1727', 'Description': ' Izrael/Włochy 2024, 108’<br><br>REŻYSERIA: Eran Riklis.<br>OBSADA: Golshifteh Farahani, Zar Amir Ebrahimi, Mina Kavani<br><br><br>Oparty na bestsellerowej autobiografii Azar Nafisi film to przejmująca i wciąż aktualna opowieść o kobiecej solidarności, odwadze i sile literatury. W głównych rolach wystąpiły czołowe irańskie...', 'ShowBuyButton': true, 'ShowReservationButton': true, 'ShowFreeEventButton': false},{ 'Id': 35048, 'Name': 'DO UTRATY TCHU – JEAN-LUC GODARD', 'Date': '09.06.2026', 'Hour': '19:00', 'PosterId': '1696', 'Description': '(À bout de