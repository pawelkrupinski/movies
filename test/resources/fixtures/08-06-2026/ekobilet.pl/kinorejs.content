    <script>
    $.fn.datepicker.dates.pl = {
      clear: "Wyczyść",
      days: ["Niedziela", "Poniedziałek", "Wtorek", "Środa", "Czwartek", "Piątek", "Sobota"],
      daysShort: ["Nie", "Pn", "Wt", "Śr", "Czw", "Pt", "So"],
      daysMin: ["Nd", "Pn", "Wt", "Śr", "Cz", "Pt", "So"],
      months: ["Styczeń", "Luty", "Marzec", "Kwiecień", "Maj", "Czerwiec", "Lipiec", "Sierpień", "Wrzesień", "Październik", "Listopad", "Grudzień"],
      monthsShort: ["Sty", "Lu", "Mar", "Kw", "Maj", "Cze", "Lip", "Sie", "Wrz", "Pa", "Lis", "Gru"],
      today: "Dzisiaj",
      titleFormat: "MM yyyy"
    };

    var eventDatesArray = [
        '10.06.2026',
        '11.06.2026',
        '12.06.2026',
        '13.06.2026',
        '14.06.2026',
        '16.06.2026',
        '17.06.2026',
        '18.06.2026',
        '19.06.2026',
        '20.06.2026',
        '21.06.2026',
        '23.06.2026',
        '24.06.2026',
        '25.06.2026',
        '26.06.2026',
        '27.06.2026',
        '28.06.2026',
        '30.06.2026',
        '01.07.2026',
        '02.07.2026',
    ];

    $('.datepicker').datepicker({
      language:'pl',
      format: 'dd.mm.yyyy',
      startDate: '10.06.2026',
      endDate: '02.07.2026',
      beforeShowDay: function(date) {
        var dateStr = ('0' + date.getDate()).slice(-2) + '.' +
                      ('0' + (date.getMonth() + 1)).slice(-2) + '.' +
                      date.getFullYear();
        if (eventDatesArray.indexOf(dateStr) !== -1) {
          return {
            enabled: true,
            classes: 'available-date'
          };
        }
        return {
          enabled: false
        };
      }
    }).on('changeDate', function(e) {
      console.log(e.date)
      var selectedDate = formatDate(e.date)
      var url = [null, URL_NAME].join('/') + `?date=${selectedDate}`;
      window.location.replace(url);
    });

    $('.card-date').on('click', function(e){
      var date = $(this).data('date').split('.').reverse().join('-');
      var url = [null, URL_NAME].join('/') + `?date=${date}`;
      window.location.replace(url);
    });
  </script>

