document.addEventListener('DOMContentLoaded', function() {
    const slides = document.querySelectorAll(".slide");
    const btnPrev = document.getElementById("btn-prev");
    const btnNext = document.getElementById("btn-next");
    if (slides.length === 0) return;

    let slideIndex = 0;
    let autoPlayInterval;
    function showSlide(index) {
        slides.forEach(slide => slide.classList.remove("active"));
        if (index >= slides.length) slideIndex = 0;
        else if (index < 0) slideIndex = slides.length - 1;
        else slideIndex = index;
        slides[slideIndex].classList.add("active");
    }

    function moveSlide(step) {
        showSlide(slideIndex + step);
        resetTimer();
    }

    if(btnPrev) {
        btnPrev.addEventListener('click', function(e) {
            e.preventDefault();
            moveSlide(-1);
        });
    }

    if(btnNext) {
        btnNext.addEventListener('click', function(e) {
            e.preventDefault();
            moveSlide(1);
        });
    }

    function startTimer() {
        autoPlayInterval = setInterval(() => {
            showSlide(slideIndex + 1);
        }, 5000); // 5 sekund
    }

    function resetTimer() {
        clearInterval(autoPlayInterval);
        startTimer();
    }
    startTimer();

});
</script>
    <script>
        // MENU
        function toggleMenu() {
            document.getElementById('navMenu').classList.toggle('active');
            document.querySelector('.hamburger').classList.toggle('toggle');
        }
        function toggleSubmenu(el) { if(window.innerWidth<=768) el.classList.toggle('open'); }
        function toggleFooter(el) { if(window.innerWidth<=768) el.classList.toggle('open'); }
        function togglePartners() {
            const grid = document.getElementById('partnersGrid');
            const btn = document.getElementById('togglePartnersBtn');
            if(grid.classList.contains('show')) { grid.classList.remove('show'); btn.innerText="+ Pokaż partnerów"; }
            else { grid.classList.add('show'); btn.innerText="- Ukryj partnerów"; }
        }

        // MODAL
        document.addEventListener('DOMContentLoaded', () => {
            const wrap = document.getElementById('ticket-panel-wrapper');
            const pan = document.getElementById('ticket-panel');
            const back = document.getElementById('ticket-panel-backdrop');
            const uiT = document.getElementById('panel-movie-title');
            const uiS = document.getElementById('panel-seats-counter');
            const btnCta = document.getElementById('main-cta-btn');
            const uiP = document.getElementById('total-price');
            const limitMsg = document.getElementById('limit-msg');
            const MAX_PER_ORDER = 10;
            let maxS = 0;

            function open() {
                wrap.classList.remove('pointer-events-none');
                back.classList.remove('opacity-0'); back.classList.add('opacity-100');
                pan.classList.remove('translate-y-full', 'md:translate-x-full');
                pan.classList.add('translate-y-0', 'md:translate-x-0');
            }
            function close() {
                pan.classList.remove('translate-y-0', 'md:translate-x-0');
                pan.classList.add('translate-y-full', 'md:translate-x-full');
                setTimeout(() => { back.classList.remove('opacity-100'); back.classList.add('opacity-0'); }, 300);
                setTimeout(() => wrap.classList.add('pointer-events-none'), 500);
            }
            
            document.getElementById('close-panel-btn').addEventListener('click', close);
            back.addEventListener('click', close);

            document.querySelectorAll('.buy-ticket-btn').forEach(btn => {
                btn.addEventListener('click', () => {
                    open();
                    uiT.innerText = "Ładowanie...";
                    maxS = parseInt(btn.dataset.mockSeats);
                    setTimeout(() => {
                        uiT.innerText = btn.dataset.id === "101" ? "La Grazia" : "Flow";
                        uiS.innerText = `Dostępne: ${maxS}`;
                        btnCta.disabled = true;
                        document.querySelectorAll('.ticket-input').forEach(i => i.value=0);
                        update();
                    }, 500);
                });
            });

            function update() {
                let qty = 0; let price = 0;
                document.querySelectorAll('.ticket-row').forEach(row => {
                    qty += parseInt(row.querySelector('.ticket-input').value);
                });

                document.querySelectorAll('.ticket-row').forEach(row => {
                    const q = parseInt(row.querySelector('.ticket-input').value);
                    const p = parseFloat(row.querySelector('.price-display').dataset.price);
                    price += q * p;
                    row.querySelector('.btn-minus').disabled = q <= 0;
                    // Disable + if no seats OR if global limit (10) reached
                    row.querySelector('.btn-plus').disabled = (qty >= maxS) || (qty >= MAX_PER_ORDER);
                });

                uiP.innerText = price.toFixed(2) + " zł";
                
                if(qty >= MAX_PER_ORDER) limitMsg.classList.remove('hidden');
                else limitMsg.classList.add('hidden');

                if(qty > 0) { btnCta.disabled = false; btnCta.innerText = `KUPUJĘ (${price.toFixed(2)} zł)`; btnCta.classList.add('bg-[#c5a059]', 'text-black'); btnCta.classList.remove('bg-neutral-800'); }
                else { btnCta.disabled = true; btnCta.innerText = "WYBIERZ BILETY"; btnCta.classList.add('bg-neutral-800'); btnCta.classList.remove('bg-[#c5a059]', 'text-black'); }
            }

            document.querySelectorAll('.ticket-row').forEach(row => {
                const inp = row.querySelector('.ticket-input');
                row.querySelector('.btn-plus').addEventListener('click', () => { 
                    // Calculate current total BEFORE incrementing to prevent overflow
                    let currentTotal = 0;
                    document.querySelectorAll('.ticket-input').forEach(i => currentTotal += parseInt(i.value));
                    
                    if(currentTotal < MAX_PER_ORDER && currentTotal < maxS) {
                        inp.value++; 
                        update();
                    }
                });
                row.querySelector('.btn-minus').addEventListener('click', () => { if(inp.value>0) inp.value--; update(); });
            });
        });
    </script>
