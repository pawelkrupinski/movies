	<div class="content_news_1 hand" onclick="document.location.href='wydarzenia,11,20570,1,Wieczory-z-Kinem-Polskim-Nic-smiesznego.html'">
											<div class="content_news_1_1a f_8">Wieczory z Kinem Polskim: Nic śmiesznego</div>
