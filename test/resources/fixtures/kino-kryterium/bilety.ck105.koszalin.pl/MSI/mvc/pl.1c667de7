                            <div class="col-xs-12 event-gallery-background" id="modalEventImageGallery">
                                <h2 class=""><span class="fa fa-camera"></span> Galeria</h2>
                                <div id="modalEventImageGalleryItems" style="display: flex; flex-wrap: wrap;"></div>
                            </div>
                        </div>
                    </div>
