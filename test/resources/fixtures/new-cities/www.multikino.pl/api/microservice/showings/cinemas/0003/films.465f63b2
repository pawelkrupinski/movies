":127,"startTime":"2026-06-11T20:55:00","endTime":"2026-06-11T23:28:00","showTimeWithTimeZone":"2026-06-11T20:55:00+02:00","isSoldOut":false,"color":null,"isMidnightSession":false,"isBookingAvailable":true,"attributes":[{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 1","sessionPricingDisplayStatus":1,"wheelchairSeatAvailability":1}]}],"filmId":"HO00002504","certificate":{"name":null,"description":null,"src":null},"secondaryCertificates":[],"filmUrl":"https://www.multikino.pl/filmy/michael","filmAttributes":[],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/images/film-and-events/2026/michael/michael-plakat-net-fin-cut.jpg?rev=50ffa68228ab41d0a9633db28bbd2b6e","cast":"Jaafar Jackson","releaseDate":"2026-04-24T00:00:00","runningTime":127,"isDurationUnknown":false,"synopsisShort":"Film pokazuje historię Michaela Jacksona nie tylko przez pryzmat jego muzyki - od momentu, gdy został odkryty jako wokalista Jackson Five, aż po czasy, gdy stał się wizjonerem i dążył do tego, by zostać największym artystą rozrywkowym na świecie.  Oprócz życia prywatnego, film przywołuje też jego najsłynniejsze występy z początków solowej kariery, dając widzom wyjątkową okazję, by zobaczyć Michaela Jacksona jak nigdy dotąd. To tutaj zaczyna się jego historia.","filmTitle":"Michael","hasSessions":true,"hasTrailer":true,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/images/film-and-events/2026/michael/michael-kadr1.jpg?rev=1d4a19aacb7646d2a53a9592cae5797d","filmStatus":1,"trailers":[],"director":"Antoine Fuqua","distributor":"UIP","movieXchangeCode":"a73eea3f-dfe0-495e-9bca-648f96c61201","crossCountryMovieXchangeId":"","originalTitle":"","showingInCinemas":["0003","0004","0005","0006","0007","0010","0011","0013","0014","0023","0024","0025","0028","0034","0035","0036","0039","0040","0052","0053"],"genres":[],"sessionAttributes":[{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}]},{"showingGroups":[{"date":"2026-08-21T00:00:00","datePrefix":"","pricingTypes":[],"sessions":[{"sessionId":"110041","bookingUrl":"/rezerwacja-biletow/podsumowanie/0003/HO00000881/110041","formattedPrice":"32,90 zł","isPriceVisible":true,"duration":720,"startTime":"2026-08-21T22:00:00","endTime":"2026-08-22T01:34:00","showTimeWithTimeZone":"2026-08-21T22:00:00+02:00","isSoldOut":false,"color":null,"isMidnightSession":false,"isBookingAvailable":true,"attributes":[{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 13","sessionPricingDisplayStatus":1,"wheelchairSeatAvailability":1}]}],"filmId":"HO00000881","certificate":{"name":null,"description":null,"src":null},"secondaryCertificates":[],"filmUrl":"https://www.multikino.pl/filmy/nmf-noc-wladcy-pierscieni-wersje-rozszerzone","filmAttributes":[],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/images/maraton/lotr/lotr_2026_plakat.jpg?rev=c5ca96212d114e9eb256e066a10b0b28","cast":"","releaseDate":"2026-08-21T00:00:00","runningTime":720,"isDurationUnknown":false,"synopsisShort":"Niektóre historie potrzebują skali, by w pełni wybrzmieć. W tym roku świętujemy 25-lecie premiery „Drużyny Pierścienia” – momentu, który na zawsze zmienił oblicze kina fantasy.  21 sierpnia „Władca Pierścieni” powraca na wielki ekran w pełnej, rozszerzonej formie, pozwalającej przeżyć tę trylogię dokładnie tak, jak zaplanował to Peter Jackson. Multikino zaprasza na Maraton Władcy Pierścieni – wydarzenie, które gwarantuje całkowite odcięcie od rzeczywistości i powrót do Śródziemia w jego najbardziej epickiej odsłonie.  Maraton to coś więcej niż zwykły seans – to fizyczne doświadczenie kinowej potęgi. Dopiero na wielkim ekranie bitwa o Helmowy Jar czy szarża pod Minas Tirith nabierają właściwego ciężaru, a potężny dźwięk sprawia, że ryk armii Uruk-hai staje się niemal namacalny. Możesz przeżyć tę podróż z grupą znajomych, wspólnie dzieląc emocje lub solo, w pełnym skupieniu chłonąc monumentalne krajobrazy i każdy detal tej opowieści.  Wersje rozszerzone prezentowane w kinie zapewniają intensywność, której nie da się odtworzyć w domowych warunkach. Brak rozpraszaczy i całkowita immersja sprawiają, że każda scena zyskuje nową głębię, a Ty stajesz się częścią Drużyny Pierścienia na te kilka godzin wspólnej, nocnej wyprawy.","filmTitle":"NMF: Noc Władcy Pierścieni (wersje rozszerzone)","hasSessions":true,"hasTrailer":false,"embargoMessage":null,"embargoEndDate":null,"embarg