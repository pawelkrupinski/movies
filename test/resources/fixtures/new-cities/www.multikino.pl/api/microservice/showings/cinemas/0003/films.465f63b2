":null,"src":null},"secondaryCertificates":[],"filmUrl":"https://www.multikino.pl/filmy/nt-live-audiencja","filmAttributes":[{"name":"TEATR","shortName":"TEATR - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/images/wydarzenia/teatr/audiencja/audience_plakat.jpg?rev=aff6a9407f624513b3a44c7871e97f7d","cast":"","releaseDate":"2026-08-19T00:00:00","runningTime":180,"isDurationUnknown":false,"synopsisShort":"Retransmisja sztuki wraca do kin po ponad dekadzie. Helen Mirren wciela się w rolę królowej Elżbiety II w uhonorowanej nagrodami Olivier i Tony Award® przebojowej produkcji w reżyserii Stephena Daldry'ego. Przez 60 lat królowa Elżbieta II odbywała cotygodniowe, poufne spotkania z każdym z 12 premierów Wielkiej Brytanii. Takie spotkanie jest znane jako audiencja. Królowa doradzała premierom, począwszy od Winstona Churchilla, przez Margaret Thatcher, po Davida Camerona, w sprawach publicznych i osobistych. Podczas prywatnych audiencji możemy przyjrzeć się bliżej kobiecie kryjącej się za koroną i być świadkami chwil, które ukształtowały monarchinię. Fenomen Netflixa, serial The Crown, za którego sukcesem stoi Peter Morgan, powstał na podstawie tej przebojowej sztuki, którą transmitowano na żywo z londyńskiego West Endu w 2013 roku, a która stała się jedną z najchętniej oglądanych produkcji NT Live.","filmTitle":"NT Live: Audiencja","hasSessions":true,"hasTrailer":true,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/images/wydarzenia/teatr/audiencja/audiencja-kadr.jpg?rev=d9064d15b34743ee9aa40dc60f05efde","filmStatus":2,"trailers":[],"director":"","distributor":"","movieXchangeCode":"ed1b1fa8-ac72-4665-a263-34482c67332e","crossCountryMovieXchangeId":"","originalTitle":"","showingInCinemas":["0003","0004","0005","0006","0007","0010","0011","0013","0023","0028","0029","0034","0035","0036","0040","0053"],"genres":[],"sessionAttributes":[{"name":"TEATR","shortName":"TEATR - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}]},{"showingGroups":[{"date":"2026-07-15T00:00:00","datePrefix":"","pricingTypes":[],"sessions":[{"sessionId":"106743","bookingUrl":"/rezerwacja-biletow/podsumowanie/0003/HO00002722/106743","formattedPrice":"43,90 zł","isPriceVisible":true,"duration":150,"startTime":"2026-07-15T19:00:00","endTime":"2026-07-15T21:45:00","showTimeWithTimeZone":"2026-07-15T19:00:00+02:00","isSoldOut":false,"color":null,"isMidnightSession":false,"isBookingAvailable":true,"attributes":[{"name":"TEATR","shortName":"TEATR - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 6","sessionPricingDisplayStatus":1,"wheelchairSeatAvailability":1}]}],"filmId":"HO00002722","certificate":{"name":null,"description":null,"src":null},"secondaryCertificates":[],"filmUrl":"https://www.multikino.pl/filmy/nt-live-niebezpieczne-zwiazki","filmAttributes":[{"name":"TEATR","shortName":"TEATR - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/images/wydarzenia/teatr/niebezpieczne-zwiazki/niebezpiecznezwiazki_plakat.jpg?rev=eaa00fa62980438295bc9c57b914a338","cast":"","releaseDate":"2026-07-15T00:00:00","runningTime":150,"isDurationUnknown":false,"synopsisShort":"Laureatka nagrody BAFTA, Lesley Manville (Nić widmo) oraz Aidan Turner (Rywale) w nowej, poruszającej inscenizacji klasycznej powieści według słynnej adaptacji Christophera Hamptona. Tu w olśniewających salonach zamożnej elity jeden fałszywy krok może oznaczać ruinę. Markiza de Merteuil jest mistrzynią sztuki przetrwania. Wraz z magnetycznym wicehrabią de Valmont uwodzenie zamieniają w strategię, a pożądanie w broń. Jednak gdy sojusz zamienia się w rywalizację, walka grozi zagładą wszystkiego, co stanie im na drodze. Reżyserką tej trzymającej w napięciu sztuki o miłości, kłamstwach i wojnie klas, nakręconej na żywo w National Theatre, jest Marianne Elliott (Anioły w Ameryce).","filmTitle":"NT Live: Niebezpieczne związki","hasSessions":true,"hasTrailer":true,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/global/img/film-panel-default-image.png?rev=-1","filmStatus":2,"trailers":[],"director":"","distributor":"","movieXchangeCode":"604