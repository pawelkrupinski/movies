r Costa-Jackson, Russell Thomas, Adriana Gonzales, Alexander Vinogradov","releaseDate":"2026-11-15T00:00:00","runningTime":215,"isDurationUnknown":false,"synopsisShort":"W upalnym słońcu Hiszpanii niezwykle niezależna Carmen przyciąga uwagę Don José. Ostrzega go, by się w niej nie zakochiwał, ale jego obsesja sięga zenitu. To powrót poruszającej inscenizacji Damiano Michieletto, rzucającej ostre światło na żądzę, przemoc i destrukcyjne pragnienia w tej niezmiennie popularnej operze Bizeta.  Gwiazdorska obsada ożywia ten gorący dramat, z Ginger Costa-Jackson w ognistej roli tytułowej oraz Russellem Thomasem jako zazdrosnym i zrozpaczonym Don José. Po debiucie w Royal Opera w 2023 roku Sesto Quatrini powraca, by dyrygować elektryzującą i zmysłową partyturą Bizeta.","filmTitle":"Royal Ballet and Opera Sezon Kinowy 2026-27: Carmen","hasSessions":true,"hasTrailer":false,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/global/img/film-panel-default-image.png?rev=-1","filmStatus":2,"trailers":[],"director":"Damiano Michieletto (reżyser)","distributor":"","movieXchangeCode":"","crossCountryMovieXchangeId":"","originalTitle":"","showingInCinemas":["0003","0004","0005","0006","0007","0008","0010","0011","0013","0023","0028","0029","0034","0035","0036","0040"],"genres":[],"sessionAttributes":[{"name":"OPERA","shortName":"OPERA - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"SUPERHIT","shortName":"SUPERHIT","value":"SUPERHIT","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}]},{"showingGroups":[{"date":"2026-11-01T00:00:00","datePrefix":"","pricingTypes":[],"sessions":[{"sessionId":"111152","bookingUrl":"/rezerwacja-biletow/podsumowanie/0003/HO00002783/111152","formattedPrice":"42,90 zł","isPriceVisible":true,"duration":190,"startTime":"2026-11-01T15:00:00","endTime":"2026-11-01T18:25:00","showTimeWithTimeZone":"2026-11-01T15:00:00+01:00","isSoldOut":false,"color":null,"isMidnightSession":false,"isBookingAvailable":true,"attributes":[{"name":"BALET","shortName":"BALET - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"SUPERHIT","shortName":"SUPERHIT","value":"SUPERHIT","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 3","sessionPricingDisplayStatus":1,"wheelchairSeatAvailability":1}]}],"filmId":"HO00002783","certificate":{"name":null,"description":null,"src":null},"secondaryCertificates":[],"filmUrl":"https://www.multikino.pl/filmy/rbo-sezon-kinowy-2026-27-manon","filmAttributes":[{"name":"BALET","shortName":"BALET - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/images/film-and-events/wkrotce_1_plakat.jpg?rev=4671625446e74c9aa1a2bfee37296ea3","cast":"","releaseDate":"2026-11-01T00:00:00","runningTime":190,"isDurationUnknown":false,"synopsisShort":"W mrocznej dzielnicy XVIII-wiecznego Paryża władzę sprawuje pieniądz. Nie ma świętości – nawet miłość można kupić za odpowiednią cenę. Pochodząca z tego hedonistycznego półświatka Manon tkwi rozdarta między odmiennymi pragnieniami, gdy zakochuje się w studencie Des Grieux. Niezłomny i oddany chłopak oferuje jej możliwość godnego życia. Jednak bogactwa obiecywane przez paryską socjetę pozostają kuszące... Wewnętrzne rozterki Manon i jej walka o przetrwanie stanowią rdzeń druzgocącej adaptacji powieści Abbé Prévosta autorstwa Kennetha MacMillana z 1974 roku. W tym charakterystycznym dla The Royal Ballet dziele zrozumienie subtelnych niuansów ludzkiej psychiki przez MacMillana pozwala na bezkompromisowe spojrzenie na moralną degrengoladę Paryża w czasach Manon, a cała jego dekadencja i upadek ożywają dzięki muzyce Julesa Masseneta i scenografii Nicholasa Georgiadisa.","filmTitle":"Royal Ballet and Opera Sezon Kinowy 2026-27: Manon","hasSessions":true,"hasTrailer":false,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/global/img/film-panel-default-image.png?rev=-1","filmStatus":2,"trailers":[],"director":"Koen Kessels (dyrygent)","distributor":"","movieXchangeCode":"","crossCountryMovieXchangeId":"","originalTitle":"","showingInCinemas":["0003","0004","0005","0006","0007","0008","0010","0011","0013","0023","0028","0029","0034","0035","0036","0040"],"genres":[],"sessionAttributes":[{"name":"BALET","shortName":"BALET - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundIma