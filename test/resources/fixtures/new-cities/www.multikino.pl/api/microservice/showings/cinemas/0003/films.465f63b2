w, gdzie poznaje Julię (Claire Danes). Jej ojciec chciałby wydać ją za wpływowego Davida Parysa (Paul Rudd). Ślub córki pozwoliłby mu zwiększyć swoje wpływy w mafijnym światku. Julia jednak zakochuje się bez pamięci w Romeo.","filmTitle":"Romeo i Julia – wersja oryginalna","hasSessions":true,"hasTrailer":false,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/images/kultowe-kino/romeojulia_kadr.jpg?rev=b4f6c56ccef641df9453d07aa7f9f5e1","filmStatus":1,"trailers":[],"director":"Baz Luhrmann","distributor":"Park Circus","movieXchangeCode":"","crossCountryMovieXchangeId":"","originalTitle":"","showingInCinemas":["0003","0004","0005","0006","0007","0008","0010","0011","0013","0014","0015","0023","0024","0025","0026","0027","0028","0029","0030","0031","0033","0034","0035","0036","0037","0038","0039","0040","0041","0042","0043","0044","0047","0048","0050","0051","0052","0053"],"genres":[],"sessionAttributes":[{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"KULTOWE KINO","shortName":"KULTOWE KINO","value":"","description":"<span style=\"color: #474747; background-color: #ffffff;\">Największe polskie i światowe hity ponownie na wielkim ekranie!</span>","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}]},{"showingGroups":[{"date":"2026-06-07T00:00:00","datePrefix":"Dzisiaj","pricingTypes":[],"sessions":[{"sessionId":"111792","bookingUrl":"/rezerwacja-biletow/podsumowanie/0003/HO00002711/111792","formattedPrice":"14,90 zł","isPriceVisib