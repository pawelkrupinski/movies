c":null},"secondaryCertificates":[],"filmUrl":"https://www.multikino.pl/filmy/bts-world-tour-arirang-in-busan-live-viewing","filmAttributes":[{"name":"KONCERT","shortName":"KONCERT - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/images/wydarzenia/koncerty/kpop/bts_busan_plakat.jpg?rev=3ebe23c67eda474c8d47f23309b69661","cast":"","releaseDate":"2026-06-13T00:00:00","runningTime":180,"isDurationUnknown":false,"synopsisShort":"Historyczna trasa trwa dalej! Po rekordowym otwarciu światowej trasy ARIRANG, BTS powraca do legendarnego Busan Asiad Main Stadium na wyjątkowy koncert transmitowany na żywo do kin na całym świecie — także do Multikina. To niezwykle emocjonalny moment zarówno dla zespołu, jak i fanów. Po raz pierwszy od 3 lat i 8 miesięcy BTS wystąpi ponownie w miejscu, gdzie odbył się ich ostatni koncert w pełnym składzie przed rozpoczęciem służby wojskowej członków grupy. Trasa obejmująca 34 miasta i 85 koncertów już teraz zapisała się w historii jako największe tournée koreańskiego artysty. Występ w Busanie odbędzie się dodatkowo 13 czerwca — w rocznicę debiutu BTS — co nadaje wydarzeniu wyjątkowy i symboliczny charakter. Nazwa trasy ARIRANG nawiązuje do piątego albumu studyjnego BTS i opowiada o tożsamości, tęsknocie, szczerości oraz głębokiej miłości. Widowiskowa scena 360° zapewni w pełni immersyjne doświadczenie, dzięki któremu widzowie poczują się częścią tego niezwykłego wydarzenia. Nie przegap jednego z najważniejszych muzycznych wydarzeń roku i przeżyj energię koncertu BTS na wielkim kinowym ekranie — już 13 czerwca, prosto z Busanu.","filmTitle":"BTS WORLD TOUR 'ARIRANG' IN BUSAN: LIVE VIEWING","hasSessions":true,"hasTrailer":false,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"descript