awych zmaganiach, żeby obalić mroczne rządy Shao Kahna, zagrażające istnieniu Ziemi i jej obrońców.","filmTitle":"Mortal Kombat 2","hasSessions":true,"hasTrailer":true,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/images/film-and-events/2025/mortal-kombat-2/mortal-kombat-2-kadr.jpg?rev=aa88f8214d5b4430bdb4544d6a5587b7","filmStatus":1,"trailers":[],"director":"Simon McQuoid","distributor":"Warner","movieXchangeCode":"a973ae1f-b4cb-428d-92b9-7233566ef72f","crossCountryMovieXchangeId":"","originalTitle":"","showingInCinemas":["0003","0005","0024","0026","0042"],"genres":[],"sessionAttributes":[{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}]},{"showingGroups":[{"date":"2026-06-27T00:00:00","datePrefix":"","pricingTypes":[],"sessions":[{"sessionId":"109144","bookingUrl":"/rezerwacja-biletow/podsumowanie/0003/HO00002635/109144","formattedPrice":"14,90 zł","isPriceVisible":true,"duration":94,"startTime":"2026-06-27T15:00:00","endTime":"2026-06-27T16:49:00","showTimeWithTimeZone":"2026-06-27T15:00:00+02:00","isSoldOut":false,"color":null,"isMidnightSession":false,"isBookingAvailable":true,"attributes":[{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"KULTOWE KINO","shortName":"KULTOWE KINO","value":"","description":"<span style=\"color: #474747; background-color: #ffffff;\">Największe polskie i światowe hity ponownie na wielkim ekranie!</span>","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 4","sessionPricingDisplayStatus":1,"wheelchairSeatAvailability":1}]}],"filmId":"HO00002635","certificate":{"name":null,"description":null,"src":null},"secondaryCertificates":[],"filmUrl":"https://www.multikino.pl/filmy/zywot-briana-grupy-monty-pythona-wersja-zremasterowana","filmAttributes":[],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/images/kultowe-kino/ywot_briana_plakat.jpg?rev=9ec79149ee78480185000b354a311e71","cast":"Graham Chapman, John Cleese, Terry Gilliam, Eric Idle","releaseDate":"2026-04-06T00:00:00","runningTime":94,"isDurationUnknown":false,"synopsisShort":"Kinowy seans „Żywota Briana” po latach to wyjątkowa okazja, by na wielkim ekranie zobaczyć legendarne już spory między Frontem Wyzwolenia Judei a Judejskim Frontem Ludowym (pamiętajcie, to dwie zupełnie różne frakcje!). Odwiedzimy też pałac Poncjusza Piłata, który ma drobną wadę wymowy i być może zechce: „uwolnić Błajana”, jeśli go ładnie o to poprosicie. Warto też zadać sobie fundamentalne pytanie: „Co takiego zrobili dla nas Rzymianie?”. Bohaterem filmu jest rówieśnik Jezusa, który urodził się tej samej nocy w Betlejem, ale w sąsiedniej stajence. Losy chłopca o imieniu Brian są przewrotną paralelą losów Chrystusa. Także zostaje uznany za Mesjasza i także kończy na krzyżu. Pierwotny tytuł filmu brzmiał „Jezus Chrystus. Żądza chwały”. Postać Briana pojawiła się później, a dzieło miało nosić nazwę „Ewangelia według Świętego Briana” lub „Brian z Nazaretu”. Choć premiera w 1979 roku wywołała skandal, dziś „Żywot Briana” jest niekwestionowanym klasykiem. To inteligentna satyra, która nie wyśmiewa szczerej wiary, lecz ludzką głupotę, dogmatyzm, fanatyzm i ślepe podążanie za tłumem. Kpi także z hollywoodzkich produkcji o tematyce biblijnej. Warto dodać, że w filmie pojawia się postać samego Jezusa. Jest on przedstawiony tradycyjnie i z szacunkiem, a komizm w scenach z nim nie wynika z jego zachowania, lecz z reakcji tłumu.","filmTitle":"Żywot Briana Grupy Monty Pythona. Wersja zremasterowana","hasSessions":true,"hasTrailer":false,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/images/kultowe-kino/ywot_briana_tlo.jpg?rev=0dfca7425666435aacd793486fea345a","filmStatus":2,"trailers":[],"director":"Terry Jones","distributor":"Ferment","movieXchangeCode":"","crossCountryMovieXchangeId":"","originalTitle":"","showingInCinemas":["0003","0004","0005","0006","0007","0008","0010","0011","0013","0014","0015","0023","0024","0025","0026","0028","0029","0030","0031","0033","0034","0035","0036","0037","0038","0039","0040","0041","0042","0043","0044","0047","0048","0050","0051","0053"],"genres":[],"sessionAttributes":[{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"KUL