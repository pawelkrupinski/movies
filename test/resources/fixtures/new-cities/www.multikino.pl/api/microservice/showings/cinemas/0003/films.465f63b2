onName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}]},{"showingGroups":[{"date":"2026-06-26T00:00:00","datePrefix":"","pricingTypes":[],"sessions":[{"sessionId":"112206","bookingUrl":"/rezerwacja-biletow/podsumowanie/0003/HO00002773/112206","formattedPrice":"24,90 zł","isPriceVisible":true,"duration":248,"startTime":"2026-06-26T19:15:00","endTime":"2026-06-26T21:29:00","showTimeWithTimeZone":"2026-06-26T19:15:00+02:00","isSoldOut":false,"color":null,"isMidnightSession":false,"isBookingAvailable":true,"attributes":[{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 8","sessionPricingDisplayStatus":1,"wheelchairSeatAvailability":1}]}],"filmId":"HO00002773","certificate":{"name":null,"description":null,"src":null},"secondaryCertificates":[],"filmUrl":"https://www.multikino.pl/filmy/minimaraton-superman-i-supergirl","filmAttributes":[],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/images/maraton/superduo/maratonsuperduo_plakat.jpg?rev=ec5a2979870645fead22bab34742a2c8","cast":"","releaseDate":"2026-06-26T00:00:00","runningTime":248,"isDurationUnknown":false,"synopsisShort":"Zapraszamy fanów losów superbohaterów na wyjątkowy Minimaraton „Superman i Supergirl”, który odbędzie się 26 czerwca 2026 roku w wybranych kinach sieci Multikino w całej Polsce. Tego wieczoru widzowie zobaczą dwa widowiskowe filmy z uniwersum DC, pełne spektakularnej akcji, emocji i międzygalaktycznych przygód. W ramach Minimaratonu premierowo na wielkim ekranie zostanie zaprezentowana „Supergirl”, której premiera przypada właśnie na 26 czerwca. Kara Zor-El, znana jako Supergirl, wyruszy w pełną niebezpieczeństw podróż w poszukiwaniu zemsty i sprawiedliwości. W roli głównej zobaczymy Milly Alcock, a na ekranie pojawią się także Jason Momoa oraz Matthias Schoenaerts. Pokaz premierowy poprzedzi „Superman” w reżyserii Jamesa Gunna, ostatnia odsłona historii jednego z najbardziej ikonicznych superbohaterów wszech czasów. Film przedstawia Supermana jako bohatera kierującego się współczuciem oraz głęboko zakorzenioną wiarą w dobro ludzkości. Produkcja łączy widowiskową akcję, humor i emocje, otwierając nowy rozdział filmowego uniwersum DC Studios.","filmTitle":"Minimaraton Superman i Supergirl","hasSessions":true,"hasTrailer":false,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/images/maraton/superduo/maratonsuperduo_tlo.jpg?rev=824584f8beb34b00a514bd4c9b6f3d4f","filmStatus":2,"trailers":[],"director":"","distributor":"","movieXchangeCode":"","crossCountryMovieXchangeId":"","originalTitle":"","showingInCinemas":["0003","0004","0005","0006","0007","0008","0010","0011","0014","0015","0023","0024","0025","0026","0028","0029","0030","0033","0034","0035","0036","0037","0038","0039","0040","0042","0043","0044","0047","0048","0050","0051","0052","0053"],"genres":[],"sessionAttributes":[{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","short