 jednego dzielnego mugolskiego piekarza. W niebezpiecznej misji natkną się oni na znane już i nowe zwierzęta oraz staną do walki z coraz liczniejszymi zastępami zwolenników Grindelwalda. Ale jak długo Dumbledore będzie trzymał się z boku, skoro stawka jest tak wielka?","filmTitle":"Fantastyczne zwierzęta: Tajemnice Dumbledorea","hasSessions":true,"hasTrailer":false,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/multikino_imported/imported_from_external_source/panelimage/fantastyczne-tlo_1a37565df3.jpeg?rev=adb62192411f42c29c1badc09f238366","filmStatus":2,"trailers":[],"director":"David Yates","distributor":"Warner","movieXchangeCode":"","crossCountryMovieXchangeId":"","originalTitle":"","showingInCinemas":["0003","0004","0005","0006","0007","0008","0010","0011","0013","0014","0015","0023","0024","0025","0026","0028","0029","0030","0031","0033","0034","0035","0036","0037","0038","0039","0040","0041","0042","0043","0044","0047","0048","0050","0051","0052","0053"],"genres":[],"sessionAttributes":[{"name":"DUBBING","shortName":"DUBBING","value":"DUBBING","description":"DUBBING","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"KULTOWE KINO","shortName":"KULTOWE KINO","value":"","description":"<span style=\"color: #474747; background-color: #ffffff;\">Największe polskie i światowe hity ponownie na wielkim ekranie!</span>","attributeType":"Session","color":"","borderGradient":[],"