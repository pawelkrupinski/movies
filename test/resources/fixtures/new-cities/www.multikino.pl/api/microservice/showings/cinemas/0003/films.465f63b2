false,"isBookingAvailable":true,"attributes":[{"name":"DUBBING","shortName":"DUBBING","value":"DUBBING","description":"DUBBING","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 12","sessionPricingDisplayStatus":1,"wheelchairSeatAvailability":1},{"sessionId":"112071","bookingUrl":"/rezerwacja-biletow/podsumowanie/0003/HO00002605/112071","formattedPrice":"14,90 zł","isPriceVisible":true,"duration":104,"startTime":"2026-06-11T18:00:00","endTime":"2026-06-11T20:06:00","showTimeWithTimeZone":"2026-06-11T18:00:00+02:00","isSoldOut":false,"color":null,"isMidnightSession":false,"isBookingAvailable":true,"attributes":[{"name":"DUBBING","shortName":"DUBBING","value":"DUBBING","description":"DUBBING","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 12","sessionPricingDisplayStatus":1,"wheelchairSeatAvailability":1}]}],"filmId":"HO00002605","certificate":{"name":null,"description":null,"src":null},"secondaryCertificates":[],"filmUrl":"https://www.multikino.pl/filmy/tom-i-jerry-przygoda-w-muzeum","filmAttributes":[],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/images/film-and-events/2026/tom-i-jerry-przygoda-w-muzeum/tomjerry_finalcut.jpg?rev=e9732d1e047445efa30ec640743b950b","cast":"","releaseDate":"2026-05-29T00:00:00","runningTime":104,"isDurationUnknown":false,"synopsisShort":"Podczas pościgu w nowojorskim Metropolitan Museum Tom i Jerry przypadkowo uruchamiają mityczny Astralny Kompas, który przenosi ich do olśniewającego Złotego Miasta rodem ze starożytnych legend. Tom zostaje uznany za bóstwo i staje się ulubieńcem władcy oraz jego poddanych. Tymczasem niedoceniony i zazdrosny Jerry wpada w sidła charyzmatycznego, lecz niebezpiecznego szczurzego bossa. Wkrótce okaże, że władca miasta i szczurzy boss toczą między sobą odwieczną walkę o władanie nad Złotym Miastem, a Tom i Jerry mają być tylko pionkami w ich grze. Aby przetrwać i ocalić poddanych będą musieli zawiesić swoją odwieczną rywalizację i łapa w łapę staną w obronie dobra.","filmTitle":"Tom i Jerry: Przygoda w muzeum","hasSessions":true,"hasTrailer":true,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/images/film-and-events/2026/tom-i-jerry-przygoda-w-muzeum/tomjerry_muzeum_kadr.jpg?rev=6be15d7130f3402e9fb3024e87ea384e","filmStatus":1,"trailers":[],"director":"Gang Zhang","distributor":"Monolith","movieXchangeCode":"f6e6f47e-84b1-4607-878c-6e34b1de7be9","crossCountryMovieXchangeId":"","originalTitle":"","showingInCinemas":["0003","0004","0005","0006","0007","0008","0010","0011","0013","0014","0015","0023","0024","0025","0026","0027","0028","0029","0030","0031","0033","0034","0035","0036","0037","0038","0039","0040","0041","0042","0043","0044","0047","0048","0050","0051","0052","0053"],"genres":[],"sessionAttributes":[{"name":"DUBBING","shortName":"DUBBING","value":"DUBBING","description":"DUBBING","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","descript