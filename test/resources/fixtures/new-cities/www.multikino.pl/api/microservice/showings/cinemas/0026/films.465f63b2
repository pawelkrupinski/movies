żetów oraz odkryć uroki świata na świeżym powietrzu. Podczas eksploracji okolicznych lasów trafiają na niezwykłe drzewo, zamieszkane przez barwne, ekscentryczne istoty. Jeśli odważą się wspiąć na jego szczyt, czekają na nie fantastyczne krainy, pełne zapierających dech przygód. Dzięki magicznym doświadczeniom rodzina na nowo uczy się bycia razem i odkrywa, jak ważne jest wzajemne wsparcie i bliskość.","filmTitle":"Drzewo magii","hasSessions":true,"hasTrailer":true,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/images/film-and-events/2026/drzewo-magii/drzewomagii_kadr.jpg?rev=d00b279ff0fe4aad9fcc6625b9f43a9d","filmStatus":1,"trailers":[],"director":"","distributor":"Kino Świat","movieXchangeCode":"64763037-407b-40fb-a672-4cf029d77392","crossCountryMovieXchangeId":"","originalTitle":"","showingInCinemas":["0003","0004","0005","0006","0007","0008","0010","0011","0013","0014","0015","0023","0024","0025","0026","0027","0028","0029","0030","0031","0033","0034","0035","0036","0037","0038","0039","0040","0041","0042","0043","0044","0047","0048","0050","0051","0052","0053"],"genres":[],"sessionAttributes":[{"name":"DUBBING","shortName":"DUBBING","value":"DUBBING","description":"DUBBING","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}]},{"showingGroups":[{"date":"2026-06-07T00:00:00","datePrefix":"Dzisiaj","pricingTypes":[],"sessions":[{"sessionId":"58784","bookingUrl":"/rezerwacja-biletow/p