tikino.pl/-/media/multikino/images/film-and-events/2026/kicia-kocia-w-podrozy/kiciakociawpodrozy_plakat_cut.jpg?rev=9580dbf224274f4db873abeb84a9840a","cast":"","releaseDate":"2026-02-20T00:00:00","runningTime":43,"isDurationUnknown":false,"synopsisShort":"Kicia Kocia powraca do kin! Bystra kotka i jej przyjaciele zapraszają widzów na wyjątkową podróż pełną przygód — spotkają wiele zwierząt, odwiedzą teatr, a nawet polecą samolotem!  Rezolutną Kicię Kocię czeka dużo nowych przeżyć! Ukochana bohaterka książek dla dzieci zabierze widzów na afrykańską sawannę, lotnisko i budowę placu zabaw! Nie będzie jednak sama! Będą jej towarzyszyć wierni przyjaciele – Pacek, Adelka i Julianek! Wybiorą się razem na ciekawą wycieczkę do lasu, gdzie będą poznawać jego mieszkańców. Nauczą się także segregacji śmieci oraz w świetnych humorach pójdą na swój pierwszy spektakl do teatru! Czeka ich sporo dobrej zabawy! Przyłączycie się?","filmTitle":"Kicia Kocia  w podróży","hasSessions":true,"hasTrailer":true,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/images/film-and-events/2026/kicia-kocia-w-podrozy/kiciakociawpodrozy_kadr.jpg?rev=989f3ef0320944ed8f7a3c49529f6a4b","filmStatus":1,"trailers":[],"director":"Marta Stróżycka","distributor":"NH","movieXchangeCode":"4c13a7e2-e30b-4336-a15f-38ce68636fb6","crossCountryMovieXchangeId":"","originalTitle":"","showingInCinemas":["0026"],"genres":[],"sessionAttributes":[{"name":"DUBBING","shortName":"DUBBING","value":"DUBBING","description":"DUBBING","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"SZKOŁY","shortName":"SZKOŁY","value":"SZKOŁY","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}]},{"showingGroups":[{"date":"2026-08-21T00:00:00","datePrefix":"","pricingTypes":[],"sessions":[{"sessionId":"57738","bookingUrl":"/rezerwacja-biletow/podsumowanie/0026/HO00000881/57738","formattedPrice":"36,90 zł","isPriceVisible":true,"duration":720,"startTime":"2026-08-21T22:00:00","endTime":"2026-08-22T01:34:00","showTimeWithTimeZone":"2026-08-21T22:00:00+02:00","isSoldOut":false,"color":null,"isMidnightSession":false,"isBookingAvailable":true,"attributes":[{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 6","sessionPricingDisplayStatus":1,"wheelchairSeatAvailability":1}]}],"filmId":"HO00000881","certificate":{"name":null,"description":null,"src":null},"secondaryCertificates":[],"filmUrl":"https://www.multikino.pl/filmy/nmf-noc-wladcy-pierscieni-wersje-rozszerzone","filmAttributes":[],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/images/maraton/lotr/lotr_2026_plakat.jpg?rev=c5ca96212d114e9eb256e066a10b0b28","cast":"","releaseDate":"2026-08-21T00:00:00","runningTime":720,"isDurationUnknown":false,"synopsisShort":"Niektóre historie potrzebują skali, by w pełni wybrzmieć. W tym roku świętujemy 25-lecie premiery „Drużyny Pierścienia” – momentu, który na zawsze zmienił oblicze kina fantasy.  21 sierpnia „Władca Pierścieni” powraca na wielki ekran w pełnej, rozszerzonej formie, pozwalającej przeżyć tę trylogię dokładnie tak, jak zaplanował to Peter Jackson. Multikino zaprasza na Maraton Władcy Pierścieni – wydarzenie, które gwarantuje całkowite odcięcie od rzeczywistości i powrót do Śródziemia w jego najbardziej epickiej odsłonie.  Maraton to coś więcej niż zwykły seans – to fizyczne doświadczenie kinowej potęgi. Dopiero na wielkim ekranie bitwa o Helmowy Jar czy szarża pod Minas Tirith nabierają właściwego ciężaru, a potężny dźwięk sprawia, że ryk armii Uruk-hai staje się niemal namacalny. Możesz przeżyć tę podróż z grupą znajomych, wspólnie dzieląc emocje lub solo, w pełnym skupieniu chłonąc monumentalne krajobrazy i każdy detal tej opowieści.  Wersje rozszerzone prezentowane w kinie zapewniają intensywność, której nie da się odtworzyć w domowych warunkach. Brak rozpraszaczy i całkowita immersja sprawiają, że każda scena zyskuje nową głębię, a Ty stajesz się częścią Drużyny Pierścienia na te kilka godzin wspólnej, nocnej wyprawy.","filmTitle":"NMF: Noc Władcy Pierścieni (wersje rozszerzone)","hasSessions":true,"hasTrailer":false,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/images/maraton/lotr/lotr_2026_tlo.jpg?rev=2cd2c7f7e6f7419e9f11b2da63f1668c","filmStatus":2,"trailers":[],"director":"","distributor":"","movieXchangeCode":"","crossCountryMovieXchangeId":"","originalTitle":"","showingInCinemas":["0003","0004","0005","0006","0007","0008","0010","0011","0013","0014","0015","0023","0024","0025","0026","0028","0029","0030","0031","0033","0034","0035","0036","0038","0039","0040","0043","0044","0047","0048","0050","0051","0052","0053"],"genres":[],"sessionAttributes":[{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","descripti