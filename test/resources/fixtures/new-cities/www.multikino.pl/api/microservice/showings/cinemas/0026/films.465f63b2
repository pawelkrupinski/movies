"color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 4","sessionPricingDisplayStatus":1,"wheelchairSeatAvailability":1}]}],"filmId":"HO00002669","certificate":{"name":null,"description":null,"src":null},"secondaryCertificates":[],"filmUrl":"https://www.multikino.pl/filmy/zawodowcy","filmAttributes":[],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/images/film-and-events/2026/zawodowcy/zawodowcy_plakat_cut.jpg?rev=307b6e79745349b48c3f2df3088133fb","cast":"Jake Gyllenhaal, Henry Cavill, Eiza Gonzalez, Rosamund Pike","releaseDate":"2026-05-29T00:00:00","runningTime":98,"isDurationUnknown":false,"synopsisShort":"Eve, działająca w szarej strefie specjalistka od załatwiania ekstremalnie trudnych spraw dla wyjątkowo bogatych klientów otrzymuje zlecenie od grupy nowojorskich inwestorów. Ma odzyskać dług od mieszkającego na prywatnej wyspie, dysponującego własną armią miliardera o szemranej reputacji. Gdy zawodzą cywilizowane metody negocjacji i staje się jasne, że dłużnik nie ma najmniejszego zamiaru regulować należności, do gry wchodzi ekipa do zadań specjalnych. To grupa byłych żołnierzy, z którymi Eve pracuje do lat. Wspólnie opracowują i wcielają w życie misterny plan wtargnięcia na wyspę, „załatwienia sprawy” i ucieczki. Brzmi prosto, ale ludzie miliardera są przygotowani na takie ewentualności, a okazywanie litości nie należy do zakresu ich obowiązków.","filmTitle":"Zawodowcy","hasSessions":true,"hasTrailer":true,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/images/film-and-events/2026/zawodowcy/zawodowcy-kadr.jpg?rev=1e497157a33741e590f