ltikino.pl/-/media/multikino/images/kultowe-kino/milczenie-owiec-cut.jpg?rev=e42068650341416bb3c39e499ad5bc5b","cast":"Anthony Hopkins, Jodie Foster, Ted Levine, Kasi Lemmons","releaseDate":"2026-05-25T00:00:00","runningTime":0,"isDurationUnknown":true,"synopsisShort":"35 lat od premiery. Owce wciąż krzyczą…  Młoda kadetka FBI, Clarice Starling (w tej roli rewelacyjna Jodie Foster) otrzymuje zadanie schwytania seryjnego mordercy zwanego Buffalo Billem. W tym celu zostaje wysłana do doktora Hannibala Lectera (ikoniczna rola Anthony’ego Hopkinsa) – uwięzionego w celi psychopaty i kanibala, który może pomóc w ustaleniu tożsamości zabójcy. Relacja między Starling i Lecterem odbiega od rutynowej znajomości i oparta jest na niebezpiecznej psychologicznej grze. Lecter analizuje traumy Clarice, za które oferuje wskazówki prowadzące do schwytania Buffalo Billa.","filmTitle":"Milczenie owiec","hasSessions":true,"hasTrailer":false,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/images/kultowe-kino/milczenie-owiec-kadr.jpg?rev=26d993049e4449719cf5d798eafcc254","filmStatus":2,"trailers":[],"director":"Jonathan Demme","distributor":"Resetowanie","movieXchangeCode":"","crossCountryMovieXchangeId":"","originalTitle":"","showingInCinemas":["0003","0004","0005","0006","0007","0008","0010","0011","0013","0014","0015","0023","0024","0025","0026","0028","0029","0030","0031","0033","0034","0035","0036","0037","0038","0039","0040","0041","0042","0043","0044","0047","0048","0050","0051","0052","0053"],"genres":[],"sessionAttributes":[{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","co