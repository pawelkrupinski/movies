mageUrl":null,"iconName":null}],"screenName":"Sala 5","sessionPricingDisplayStatus":1,"wheelchairSeatAvailability":1}]}],"filmId":"HO00002494","certificate":{"name":null,"description":null,"src":null},"secondaryCertificates":[],"filmUrl":"https://www.multikino.pl/filmy/pucio","filmAttributes":[],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/images/film-and-events/2026/pucio/pucio-plakat.jpg?rev=5c59e10082a64578b39f13a3bf9616bd","cast":"","releaseDate":"2026-04-17T00:00:00","runningTime":45,"isDurationUnknown":false,"synopsisShort":"Pucio razem ze swoją rodziną odkrywa świat! Każdy dzień to nowe przygody – wspólne gotowanie konfitury, malowanie rodzinnego portretu, a nawet… spływ kajakowy i biwak we własnym salonie! Gdy przychodzi pora kąpieli, Puciowi i Bobo towarzystwa dotrzymuje wesoły zabawkowy krokodyl, który również pilnie potrzebuje się wykąpać! Pucio uczy się dzielić z innymi, nawiązywać nowe przyjaźnie i radzić sobie z nudą w deszczowy dzień. W każdym odcinku Pucio udowadnia, że wyobraźnia i kreatywność potrafią zamienić najzwyklejsze chwile w coś naprawdę wyjątkowego!","filmTitle":"Pucio","hasSessions":true,"hasTrailer":true,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/images/film-and-events/2026/pucio/pucio-kadr.jpg?rev=6887f91632584976a659640efa377246","filmStatus":1,"trailers":[],"director":"Marta Stróżycka","distributor":"Młode Horyzonty","movieXchangeCode":"a62f983e-4b69-42ed-ac37-cc720d64e615","crossCountryMovieXchangeId":"","originalTitle":"","showingInCinemas":["0003","0004","0005","0006","0007","0008","0010","0011","0013","0014","0015","0023","0024","0025","0026","0027","0028","0029","0030","0031","0033","0034","0035","0036","0037","0038","0039","0040","0041","0042","0043","0044","0047","0048","0050","0051","0052","0053"],"genres":[],"sessionAttributes":[{"name":"DUBBING","shortName":"DUBBING","value":"DUBBING","description":"DUBBING","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}]},{"showingGroups":[{"date":"2026-06-19T00:00:00","datePrefix":"","pricingTypes":[],"sessions":[{"sessionId":"58487","bookingUrl":"/rezerwacja-biletow/podsumowanie/0026/HO00002770/58487","formattedPrice":"36,90 zł","isPriceVisible":true,"duration":444,"startTime":"2026-06-19T22:00:00","endTime":"2026-06-19T23:56:00","showTimeWithTimeZone":"2026-06-19T22:00:00+02:00","isSoldOut":false,"color":null,"isMidnightSession":false,"isBookingAvailable":true,"attributes":[{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 6","sessionPricingDisplayStatus":1,"wheelchairSeatAvailability":1}]}],"filmId":"HO00002770","certificate":{"name":"15+","description":"Film rekomendowany dla osób powyżej 15 roku życia. ","src":"https://www.multikino.pl/-/media/multikino/certificates/15_48x48.png?rev=c3426b8d8a2041b2af8fc83086cbe1ff"},"secondaryCertificates":[],"filmUrl":"https://www.multikino.pl/filmy/nmf-maraton-horrorow-19-czerwca-2026","filmAttributes":[],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/images/maraton/horrory/czerwiec-2026/maratonhorrorow_190626_plakat.jpg?rev=82219b20b0c64fdf968d69b63add0c46","cast":"","releaseDate":"2026-06-19T00:00:00","runningTime":444,"isDurationUnknown":false,"synopsisShort":"Dobry maraton to taki, który nie daje poczucia powtarzalności. W Multikinie udowadniamy, że groza to najbardziej elastyczny gatunek na świecie. Przygotowaliśmy selekcję dla koneserów, którzy szukają różnorodności: od internetowych legend w Backrooms. Bez wyjścia, przez religijny thriller z Sydney Sweeney, aż po bezkompromisowe kino klasy B i artystyczny mix w wykonaniu Michaela Shanksa (Together). Każdy z tych filmów gra na innych strunach – od obrzydzenia, przez śmiech, aż po czystą fascynację. Nie szukaj jednego filmu, szukaj pełnego doświadczenia.","filmTitle":"NMF: Maraton Horrorów 19 czerwca 2026","hasSessions":true,"hasTrailer":false,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/images/maraton/horrory/czerwiec-2026/maratonhorrorow_190626_tlo.jpg?rev=f7c97f99550a4913a98ac31b87b8ba10","filmStatus":2,"trailers":[],"director":"","distributor":"","movieXchangeCode":"","crossCountryMovieXchangeId":"","originalTitle":"","showingInCinemas":["0003","0004","0005","0006","0007","0008","0010","0011","0013","0014","0015","0023","0024","0026","0028","0029","0030","0034","0035","0036","0038","0039","0040","0044","0050","0053"],"genres":[],"sessionAttributes":[{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortNa