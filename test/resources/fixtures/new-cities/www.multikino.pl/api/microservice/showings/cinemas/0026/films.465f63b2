on":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 4","sessionPricingDisplayStatus":1,"wheelchairSeatAvailability":1}]}],"filmId":"HO00002605","certificate":{"name":null,"description":null,"src":null},"secondaryCertificates":[],"filmUrl":"https://www.multikino.pl/filmy/tom-i-jerry-przygoda-w-muzeum","filmAttributes":[],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/images/film-and-events/2026/tom-i-jerry-przygoda-w-muzeum/tomjerry_finalcut.jpg?rev=e9732d1e047445efa30ec640743b950b","cast":"","releaseDate":"2026-05-29T00:00:00","runningTime":104,"isDurationUnknown":false,"synopsisShort":"Podczas pościgu w nowojorskim Metropolitan Museum Tom i Jerry przypadkowo uruchamiają mityczny Astralny Kompas, który przenosi ich do olśniewającego Złotego Miasta rodem ze starożytnych legend. Tom zostaje uznany za bóstwo i staje się ulubieńcem władcy oraz jego poddanych. Tymczasem niedoceniony i zazdrosny Jerry wpada w sidła charyzmatycznego, lecz niebezpiecznego szczurzego bossa. Wkrótce okaże, że władca miasta i szczurzy boss toczą między sobą odwieczną walkę o władanie nad Złotym Miastem, a Tom i Jerry mają być tylko pionkami w ich grze. Aby przetrwać i ocalić poddanych będą musieli zawiesić swoją odwieczną rywalizację i łapa w łapę staną w obronie dobra.","filmTitle":"Tom i Jerry: Przygoda w muzeum","hasSessions":true,"hasTrailer":true,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/images/film-and-events/2026/tom-i-jerry-przygoda-w-muzeum/tomjerry_muzeum_kadr.jpg?rev=6be15d7130f3402e9fb3024e87ea384e","filmStatus":1