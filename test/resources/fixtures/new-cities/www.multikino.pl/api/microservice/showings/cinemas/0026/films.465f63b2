ype":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 3","sessionPricingDisplayStatus":1,"wheelchairSeatAvailability":1}]}],"filmId":"HO00002630","certificate":{"name":null,"description":null,"src":null},"secondaryCertificates":[],"filmUrl":"https://www.multikino.pl/filmy/kolekcja-mamoru-hosody-o-dziewczynie-skaczacej-przez-czas","filmAttributes":[],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/images/wydarzenia/anime/o-dziewczynie-skaczacej-przez-czas-plakat2.jpg?rev=125e66df557f4228bf3605103ca217f9","cast":"Riisa Naka, Mitsutaka Itakura, Takuya Ishida, Ayami Kakiuchi","releaseDate":"2026-06-12T00:00:00","runningTime":98,"isDurationUnknown":false,"synopsisShort":"Makoto jest zwyczajną nastolatką, spędzającą większość czasu z przyjaciółmi. Kiedy pewnego dnia, spiesząc się z wizytą do ciotki, cudem unika potrącenia przez pociąg – przeskakuje w czasie do momentu sprzed wypadku. Korzystając z nowo poznanych zdolności, naprawia swoje codzienne błędy – od słabych ocen na sprawdzianach po nieudane wyznania miłości. Kiedy jednak dosięgają ją konsekwencje manipulowania czasem, Makoto musi zrobić wszystko, żeby uniknąć straszliwej przyszłości, której nie da się cofnąć. ","filmTitle":"Kolekcja Mamoru Hosody: O dziewczynie skaczącej przez czas","hasSessions":true,"hasTrailer":false,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/global/img/film-panel-default-image.png?rev=-1","filmStatus":1,"trailers":[],"director":"Mamoru Hosoda","distributor":"","movieXchangeCode":"","crossCountryMovieXchangeId":"","originalTitle":"","showingInCinemas":["0003","0004","0005","0006","0007","0008","0010","0011","0013","0014","0015","0023","0024","0025","0026","0028","0029","0030","0031","0033","0034","0035","0036","0037","0038","0039","0040","