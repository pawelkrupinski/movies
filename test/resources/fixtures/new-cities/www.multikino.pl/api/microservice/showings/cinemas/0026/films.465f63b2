2026/niesamowite-przygody-skarpetek-3/niesamowite-przygody-skarpetek-3-plakat-cut.png?rev=f5940b2f416e4b19a59c25edac82e020","cast":"","releaseDate":"2026-05-29T00:00:00","runningTime":55,"isDurationUnknown":false,"synopsisShort":"Najbardziej odlotowi bohaterowie książek dla dzieci powracają do kin z nowymi przygodami. Zagadka detektywistyczna, pojedynki na Dzikim Zachodzie i podróże w kosmos to dopiero początek!  Czy skarpetka może zostać przebiegłym szeryfem, genialnym detektywem lub… międzygalaktycznym podróżnikiem? Oczywiście! W najnowszej odsłonie kinowych przygód ulubione urwisy z szuflady wyruszają na podbój nieznanych światów. Od pojedynków w samo południe, przez wybiegi mody, aż po rakiety startujące w stronę gwiazd – każda opowieść to zastrzyk pozytywnej energii i abstrakcyjnego humoru, który rozbawi do łez zarówno dzieci, jak i dorosłych.","filmTitle":"Niesamowite przygody skarpetek 3. Ale kosmos!","hasSessions":true,"hasTrailer":true,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/images/film-and-events/2026/niesamowite-przygody-skarpetek-3/niesamowite-przygody-skarpetek-3-kadr.png?rev=3af6b0043d174bbfa4a6641f34ebfec7","filmStatus":1,"trailers":[],"director":"Elżbieta Wąsik, Paweł Wendorff\t","distributor":"NH","movieXchangeCode":"1e7e1a9c-94bc-482c-b156-d2d5c1640b4c","crossCountryMovieXchangeId":"","originalTitle":"","showingInCinemas":["0003","0004","0005","0006","0007","0008","0010","0011","0013","0014","0015","0023","0024","0025","0026","0027","0028","0029","0030","0031","0033","0034","0035","0036","0037","0038","0039","0040","0041","0042","0043","0044","0047","0048","0050","0051","0052","0053"],"genres":[],"sessionAttributes":[{"name":"DUBBING","shortName":"DUBBING","value":"DUBBING","description":"DUBBING","attributeType":"Language","color":"","borderGradie