O00002732/56938","formattedPrice":"21,90 zł","isPriceVisible":true,"duration":93,"startTime":"2026-06-07T14:30:00","endTime":"2026-06-07T16:29:00","showTimeWithTimeZone":"2026-06-07T14:30:00+02:00","isSoldOut":false,"color":null,"isMidnightSession":false,"isBookingAvailable":true,"attributes":[{"name":"DUBBING","shortName":"DUBBING","value":"DUBBING","description":"DUBBING","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 6","sessionPricingDisplayStatus":1,"wheelchairSeatAvailability":1}]}],"filmId":"HO00002732","certificate":{"name":null,"description":null,"src":null},"secondaryCertificates":[],"filmUrl":"https://www.multikino.pl/filmy/the-amazing-digital-circus-ostatni-akt","filmAttributes":[],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/images/film-and-events/2026/tadc/tadc_plakat1.jpg?rev=6804403f06ff476592b3fb32300bcdf8","cast":"Lizzie Freeman, Michael Kovach, Marissa Lenti, Ashley Nichols","releaseDate":"2026-06-04T00:00:00","runningTime":93,"isDurationUnknown":false,"synopsisShort":"Internetowy fenomen „The Amazing Digital Circus” doczeka się długo wyczekiwanego  finału w formie pełnometrażowego seansu kinowego! „Ostatni akt” łączy odcinek 8 z  zupełnie nowym, godzinnym odcinkiem 9, który fani zobaczą jako pierwsi.  Gdy Caine znika, a cyrk pogrąża się w mroku, bohaterom pozostają jedynie błędy i traumy z  przeszłości. W obliczu nieuchronnej wieczności odkrywają prawdę o Cyfrowym Cyrku i jego  historii.  Czy zaakceptują to, co odkryją… czy zdecydują się na inne wyjście? Na pewno ktoś  rzuci coś zabawnego… bo to zakończenie nie może by