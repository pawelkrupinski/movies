idnightSession":false,"isBookingAvailable":true,"attributes":[{"name":"WYSTAWY","shortName":"WYSTAWY - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 3","sessionPricingDisplayStatus":1,"wheelchairSeatAvailability":1}]},{"date":"2026-08-05T00:00:00","datePrefix":"","pricingTypes":[],"sessions":[{"sessionId":"58377","bookingUrl":"/rezerwacja-biletow/podsumowanie/0026/HO00002588/58377","formattedPrice":"27,90 zł","isPriceVisible":true,"duration":100,"startTime":"2026-08-05T13:00:00","endTime":"2026-08-05T14:55:00","showTimeWithTimeZone":"2026-08-05T13:00:00+02:00","isSoldOut":false,"color":null,"isMidnightSession":false,"isBookingAvailable":true,"attributes":[{"name":"WYSTAWY","shortName":"WYSTAWY - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 3","sessionPricingDisplayStatus":1,"wheelchairSeatAvailability":1}]}],"filmId":"HO00002588","certificate":{"name":null,"description":null,"src":null},"secondaryCertificates":[],"filmUrl":"https://www.multikino.pl/filmy/caravaggio-arcydziela-niepokornego-geniusza","filmAttributes":[{"name":"WYSTAWY","shortName":"WYSTAWY - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/images/wydarzenia/wystawy/caravaggio_plakat.jpg?rev=743d8bdf88b64f9ea981dbbf1ef55121","cast":"","releaseDate":"2026-05-25T00:00:00","runningTime":100,"isDurationUnknown":false,"synopsisShort":"Malował świętych z brudem pod paznokciami, ponieważ uważał, że prawdziwa boskość znajduje się w tym, co surowe, realne i najzwyczajniej ludzkie. Takie podejście wymagało od niego odwagi, wymagało też stuprocentowego przekonania. I empatii, którą niewielu artystom przedtem i potem udało się wyrazić tak dobitnie. Realizacja tego bezprecedensowego filmu zajęła twórcom aż 5 lat. Kamery zabiorą widzów w podróż śladami malarza i jego arcydzieł: od Mediolanu i Rzymu, przez Neapol, aż po Maltę. W filmie zobaczymy niemal wszystkie dzieła mistrza w jakości pozwalającej dostrzec każde pociągnięcie pędzla, a fabularyzowane sceny pomogą zrozumieć osobiste zmagania tego kontrowersyjnego artysty. „Caravaggio. Arcydzieła niepokornego geniusza” to pozycja obowiązkowa dla wszystkich miłośników sztuki i... dobrego thrillera. Caravaggio był reformatorem malarstwa europejskiego przełomu XVI i XVII wieku. W swoich obrazach wyrzekł się piękna ludzkiego ciała, idealizowanego przez malarzy renesansowych. W celu ukazania realizmu wprowadził do swych dzieł ostry światłocień. Malowidła Caravaggia cechuje połączenie fizycznej formy i psychologicznej treści. Jego styl stał się wzorem dla malarzy epoki baroku. Arcydzieła Caravaggia należą do najbardziej rozpoznawalnych na świecie dzięki mistrzowskiemu operowaniu światłem i niezwykłemu realizmowi. Ten film to jednak nie tylko opowieść o sztuce, ale też śledztwo w sprawie awanturniczego życia i tajemniczej śmierci artysty. Eksperci analizują wskazówki ukryte w jego płótnach, by odkryć prawdę o człowieku, którego talent dorównywał sile jego zmagań z własnymi demonami.","filmTitle":"Caravaggio. Arcydzieła niepokornego geniusza","hasSessions":true,"hasTrailer":true,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/images/wydarzenia/wystawy/caravaggio_tlo.jpg?rev=ae2988d5ba094c0790489a046b9d7a44","filmStatus":2,"trailers":[],"director":"David Bickerstaff, Phil Grabsky","distributor":"kinomaestro","movieXchangeCode":"11164a17-df22-4f2f-a58b-76e5d5bd251c","crossCountryMovieXchangeId":"","originalTitle":"","showingInCinemas":["0003","0004","0005","0006","0007","0008","0010","0011","0013","0014","0015","0023","0024","0025","0026","0028","0029","0030","0031","0033","0034","0035","0036","0037","0038","0039","0040","0041","0042","0043","0044","0047","0048","0050","0051","0052","0053"],"genres":[],"sessionAttributes":[{"name":"WYSTAWY","shortName":"WYSTAWY - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}]},{"showingGroups":[{"date":"2026-07-16T00:00:00","datePrefix":"","pricingTypes":[],"sessions":[{"sessionId":"53706","bookingUrl":"/rezerwacja-biletow/podsumowanie/0026/HO00002648/53706","formattedPrice":"42,90 zł","isPriceVisible":true,"duration":90,"startTime":"2026-07-16T18:00:00","endTime":"2026-07-16T19:45:00","showTimeWithTimeZone":"2026-07-16T18:00:00+02:00","isSoldOut":false,"color":null,"isMidnightSession":false,"isBookingAvailable":true,"attributes":[{"name":"WIDOWISKO","shortName":"WIDOWISKO - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 3","sessionPricingDisplayStatus":1,"wheelchairSeatAvailability":1}]}],"filmId":"HO00002648","certificate":{"name":null,"description":null,"src":null},"secondaryCertificates":[],"filmUrl":"https://www.multikino.pl/filmy/cirque-du-soleil-kooza","filmAttributes":[{"name":"WIDOWISKO","shortName":"WIDOWISKO - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/img/import/4e7d682d-c594-4525-a0d9-6a0b2fd97021_cirque-du-soleil-kooza_posters_koo_full_2000x3000px_712px.png?rev=ecb26b3f261f45559f7c9bd2c71b1b22","cast":"Cirque du Soleil","releaseDate":"2026-07-16T00:00:00","runningTime":90,"isDurationUnknown":false,"synopsisShort":"Pomiędzy siłą a kruchością, śmiechem a uśmiechem, zamętem a harmonią, KOOZA zgłębia tematy tożsamości, uznania i władzy. Spektakl rozgrywa się w elektryzującym i egzotycznym świecie pełnym niespodzianek, emocji, dreszczyku emocji, śmiałości i całkowitego zaangażowania. Składa się z dziesięciu aktów: balansowanie na krzesłach, charivari, kontorsjonizm, chodzenie po linie, obręcze, obręcz powietrzna, huśtawka, duet na monocyklu, koło śmierci i diabolo: akt w rotacji.","filmTitle":"Cirque du Soleil: Kooza","hasSessions":true,"hasTrailer":true,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/images/film-and-events/2026/cirque-de-soleil/kooza_tlo.jpg?rev=7843f98f5a1b417e89a23a1574cf7539","filmStatus":2,"trailers":[],"director":"Mario Janelle, David Shiner","distributor":"Qrios Interactive (Pannonia Entertainment)","movieXchangeCode":"d74aae68-943c-4fff-8e76-dc0a66155639","crossCountryMovieXchangeId":"63836845-9240-4061-86b7-30047219dc29","originalTitle":"Cirque du Soleil: Kooza","showingInCinemas":["0003","0004","0005","0006","0007","0008","0010","0011","0013","0014","0015","0023","0024","0025","0026","0028","0029","0030","0031","0033","0034","0035","0036","0037","0038","0039","0040","0041","0042","0043","0044","0047","0048","0050","0051","0052","0053"],"genres":[],"sessionAttributes":[{"name":"WIDOWISKO","shortName":"WIDOWISKO - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}]},{"showingGroups":[{"date":"2026-10-15T00:00:00","datePrefix":"","pricingTypes":[],"sessions":[{"sessionId":