rtificate":{"name":null,"description":null,"src":null},"secondaryCertificates":[],"filmUrl":"https://www.multikino.pl/filmy/nt-live-niebezpieczne-zwiazki","filmAttributes":[{"name":"TEATR","shortName":"TEATR - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/images/wydarzenia/teatr/niebezpieczne-zwiazki/niebezpiecznezwiazki_plakat.jpg?rev=eaa00fa62980438295bc9c57b914a338","cast":"","releaseDate":"2026-07-15T00:00:00","runningTime":150,"isDurationUnknown":false,"synopsisShort":"Laureatka nagrody BAFTA, Lesley Manville (Nić widmo) oraz Aidan Turner (Rywale) w nowej, poruszającej inscenizacji klasycznej powieści według słynnej adaptacji Christophera Hamptona. Tu w olśniewających salonach zamożnej elity jeden fałszywy krok może oznaczać ruinę. Markiza de Merteuil jest mistrzynią sztuki przetrwania. Wraz z magnetycznym wicehrabią de Valmont uwodzenie zamieniają w strategię, a pożądanie w broń. Jednak gdy sojusz zamienia się w rywalizację, walka grozi zagładą wszystkiego, co stanie im na drodze. Reżyserką tej trzymającej w napięciu sztuki o miłości, kłamstwach i wojnie klas, nakręconej na żywo w National Theatre, jest Marianne Elliott (Anioły w Ameryce).","filmTitle":"NT Live: Niebezpieczne związki","hasSessions":true,"hasTrailer":true,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/global/img/film-panel-default-image.png?rev=-1","filmStatus":2,"trailers":[],"director":"","distributor":"","movieXchangeCode":"604fa129-c5ef-40ca-ae57-5aa9a68861e6","crossCountryMovieXchangeId":"","originalTitle":"","showingInCinemas":["0003","0004","0005","0006","0007","0010","0011","0013","0023","0028","0029","0034","0035","0036","0040","0053"],"genr