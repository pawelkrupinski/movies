eat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"SUPERHIT","shortName":"SUPERHIT","value":"SUPERHIT","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 1","sessionPricingDisplayStatus":0,"wheelchairSeatAvailability":1}]}],"filmId":"HO00002785","certificate":{"name":null,"description":null,"src":null},"secondaryCertificates":[],"filmUrl":"https://www.multikino.pl/filmy/rbo-sezon-kinowy-2026-27-carmen","filmAttributes":[{"name":"OPERA","shortName":"OPERA - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/images/film-and-events/wkrotce_1_plakat.jpg?rev=4671625446e74c9aa1a2bfee37296ea3","cast":"Ginger Costa-Jackson, Russell Thomas, Adriana Gonzales, Alexander Vinogradov","releaseDate":"2026-11-15T00:00:00","runningTime":215,"isDurationUnknown":false,"synopsisShort":"W upalnym słońcu Hiszpanii niezwykle niezależna Carmen przyciąga uwagę Don José. Ostrzega go, by się w niej nie zakochiwał, ale jego obsesja sięga zenitu. To powrót poruszającej inscenizacji Damiano Michieletto, rzucającej ostre światło na żądzę, przemoc i destrukcyjne pragnienia w tej niezmiennie popularnej operze Bizeta.  Gwiazdorska obsada ożywia ten gorący dramat, z Ginger Costa-Jackson w ognistej roli tytułowej oraz Russellem Thomasem jako zazdrosnym i zrozpaczonym Don José. Po debiucie w Royal Opera w 2023 roku Sesto Quatrini powraca, by dyrygować elektryzującą i zmysłową partyturą Bizeta.","filmTitle":"Royal Ballet and Opera Sezon Kinowy 2026-27: Carmen","hasSessions":true,"hasTrailer":false,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"n