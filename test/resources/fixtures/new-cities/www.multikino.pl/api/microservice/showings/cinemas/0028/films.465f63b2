splayStatus":0,"wheelchairSeatAvailability":1}]}],"filmId":"HO00000801","certificate":{"name":null,"description":null,"src":null},"secondaryCertificates":[],"filmUrl":"https://www.multikino.pl/filmy/fantastyczne-zwierzeta-tajemnice-dumbledore-a","filmAttributes":[],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/multikino_imported/imported_from_external_source/posterimage/pl-fnbst3-plakat-oficjalny-cut_f5cdf984c2.jpg?rev=0a9c0072657b4727ab2bce0e955867d2","cast":"Eddie Redmayne, Jude Law, Mads Mikkelsen, Ezra Miller","releaseDate":"2026-07-17T00:00:00","runningTime":142,"isDurationUnknown":false,"synopsisShort":"Profesor Albus Dumbledore (Jude Law) wie, że potężny i zły czarodziej Gellert Grindelwald (Mads Mikkelsen) zamierza zawładnąć światem czarodziejów. Nie mogąc powstrzymać go w pojedynkę, powierza to zadanie magizoologowi Newtowi Skamanderowi (Eddie Redmayne). Staje on na czele nieustraszonej drużyny, złożonej z czarodziejów, czarodziejek i jednego dzielnego mugolskiego piekarza. W niebezpiecznej misji natkną się oni na znane już i nowe zwierzęta oraz staną do walki z coraz liczniejszymi zastępami zwolenników Grindelwalda. Ale jak długo Dumbledore będzie trzymał się z boku, skoro stawka jest tak wielka?","filmTitle":"Fantastyczne zwierzęta: Tajemnice Dumbledorea","hasSessions":true,"hasTrailer":false,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/multikino_imported/imported_from_external_source/panelimage/fantastyczne-tlo_1a37565df3.jpeg?rev=adb62192411f42c29c1badc09f238366","filmStatus":2,"trailers":[],"director":"David Yates","distributor":"Warner","movieXchangeCode":"","crossCountryMovieXchangeId":"","originalTitle":"","showingInCinemas":["0003","0004","0005","0006","0007","0008","0010","0011","0013","0014","0015","0023","0024","0025","0026","0028","00