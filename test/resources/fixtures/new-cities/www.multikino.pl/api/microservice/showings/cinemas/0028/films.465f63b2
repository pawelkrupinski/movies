[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 3","sessionPricingDisplayStatus":0,"wheelchairSeatAvailability":1}]}],"filmId":"HO00002723","certificate":{"name":null,"description":null,"src":null},"secondaryCertificates":[],"filmUrl":"https://www.multikino.pl/filmy/nt-live-audiencja","filmAttributes":[{"name":"TEATR","shortName":"TEATR - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/images/wydarzenia/teatr/audiencja/audience_plakat.jpg?rev=aff6a9407f624513b3a44c7871e97f7d","cast":"","releaseDate":"2026-08-19T00:00:00","runningTime":180,"isDurationUnknown":false,"synopsisShort":"Retransmisja sztuki wraca do kin po ponad dekadzie. Helen Mirren wciela się w rolę królowej Elżbiety II w uhonorowanej nagrodami Olivier i Tony Award® przebojowej produkcji w reżyserii Stephena Daldry'ego. Przez 60 lat królowa Elżbieta II odbywała cotygodniowe, poufne spotkania z każdym z 12 premierów Wielkiej Brytanii. Takie spotkanie jest znane jako audiencja. Królowa doradzała premierom, począwszy od Winstona Churchilla, przez Margaret Thatcher, po Davida Camerona, w sprawach publicznych i osobistych. Podczas prywatnych audiencji możemy przyjrzeć się bliżej kobiecie kryjącej się za koroną i być świadkami chwil, które ukształtowały monarchinię. Fenomen Netflixa, serial The Crown, za którego sukcesem stoi Peter Morgan, powstał na podstawie tej przebojowej sztuki, którą transmitowano na żywo z londyńskiego West Endu w 2013 roku, a która stała się jedną z najchętniej oglądanych produkcji NT Live.","filmTitle":"NT Live: Audiencja","hasSessions":true,"hasTrailer":true,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/images/wydarzenia/teatr/audiencja/audiencja-kadr.jpg?rev=d9064d15b34743ee9aa40dc60f05efde","filmStatus":2,"trailers":[],"director":"","distributor":"","movieXchangeCode":"ed1b1fa8-ac72-4665-a263-34482c67332e","crossCountryMovieXchangeId":"","originalTitle":"","showingInCinemas":["0003","0004","0005","0006","0007","0010","0011","0013","0023","0028","0029","0034","0035","0036","0040","0053"],"genres":[],"sessionAttributes":[{"name":"TEATR","shortName":"TEATR - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}]},{"showingGroups":[{"date":"2026-07-15T00:00:00","datePrefix":"","pricingTypes":[],"sessions":[{"sessionId":"80251","bookingUrl":"/rezerwacja-biletow/podsumowanie/0028/HO00002722/80251","formattedPrice":null,"isPriceVisible":false,"duration":150,"startTime":"2026-07-15T19:00:00","endTime":"2026-07-15T21:45:00","showTimeWithTimeZone":"2026-07-15T19:00:00+02:00","isSoldOut":false,"color":null,"isMidnightSession":false,"isBookingAvailable":true,"attributes":[{"name":"TEATR","shortName":"TEATR - wydarzenie specjalne","value