alse,"color":null,"isMidnightSession":false,"isBookingAvailable":true,"attributes":[{"name":"KONCERT","shortName":"KONCERT - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"SUPERHIT","shortName":"SUPERHIT","value":"SUPERHIT","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 3","sessionPricingDisplayStatus":0,"wheelchairSeatAvailability":1}]},{"date":"2026-07-12T00:00:00","datePrefix":"","pricingTypes":[],"sessions":[{"sessionId":"83670","bookingUrl":"/rezerwacja-biletow/podsumowanie/0028/HO00002682/83670","formattedPrice":null,"isPriceVisible":false,"duration":95,"startTime":"2026-07-12T15:00:00","endTime":"2026-07-12T16:47:00","showTimeWithTimeZone":"2026-07-12T15:00:00+02:00","isSoldOut":false,"color":null,"isMidnightSession":false,"isBookingAvailable":true,"attributes":[{"name":"KONCERT","shortName":"KONCERT - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"SUPERHIT","shortName":"SUPERHIT","value":"SUPERHIT","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 3","sessionPricingDisplayStatus":0,"wheelchairSeatAvailability":1}]}],"filmId":"HO00002682","certificate":{"name":null,"description":null,"src":null},"secondaryCertificates":[],"filmUrl":"https://www.multikino.pl/filmy/90-urodziny-pavarottiego","filmAttributes":[{"name":"KONCERT","shortName":"KONCERT - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/images/wydarzenia/koncerty/pavarotti/pavarotti90_plakat.jpg?rev=10b0b0776a1740c3bc284f5e077c5434","cast":"Andrea Bocelli, Jonathan Tetelman, Placido Domingo, Jose Carreras, Angela Gheorghiu,  Il Volo, Stjepan Hauser","releaseDate":"2026-05-01T00:00:00","runningTime":95,"isDurationUnknown":false,"synopsisShort":"Jesienią 2025 roku w słynnej Arena di Verona zebrały się największe gwiazdy opery i popu, w tym Andrea Bocelli, Jonathan Tetelman, Angela Gheorghiu i Il Volo, by dać niebywały koncert, który... przywrócił do życia Luciana Pavarottiego, króla tenorów i wielkiego śpiewaka zwykłych ludzi. Jego dwaj żyjący koledzy, Plácido Domingo i José Carreras, zaśpiewali z nim na żywo. Niemożliwe stało się faktem – Trzej Tenorzy powrócili na estradę! Najnowszemu koncertowi ku czci jedzącego za trzech śpiewaka o niebiańskim głosie, który wciąż przywołuje na myśl skąpane w słońcu i spaghetti Włochy, nadano znaczący tytuł: „Luciano Pavarotti. Człowiek, który poruszył świat”. To prawda. Choć święcił nieprawdopodobne tryumfy na najważniejszych scenach, począwszy od mediolańskiej La Scali, a skończywszy na nowojorskiej The Metropolitan Opera, Luciano Pavarotti chciał przybliżyć muzykę klasyczną ludziom na całym świecie. To dzięki swym popularyzatorskim koncertom sprawił, że wielu z nas pokochało operę. Na jego występ w Hyde Parku, mimo ulewy, przyszło ponad 100.000 osób, a jego transmitowane przez telewizję występy z Domingiem i Carrerasem (Trzej Tenorzy) sprawiały, że w miastach i miasteczkach zamierał ruch na ulicach. Koncert z legendarnego werońskiego amfiteatru to wiązanka najsłynniejszych arii operowych i niezaprzeczalnych evergreenów w wykonaniu nie tylko klasycznych śpiewaków, ale też artystów, którzy z powodzeniem łączą muzykę poważną z popową. Oprócz wcześniej wymienionych gwiazd wystąpili również: wiolonczelista Hauser, piosenkarz Umberto Tozzi, a także Vittorio Grigolo, międzynarodowej klasy tenor, który w wieku 13 lat zaśpiewał w Operze Rzymskiej partię Pastuszka w „Tosce” Pucciniego, a rolę Cavaradossiego w tym spektaklu kreował wtedy sam Luciano Pavarotti.","filmTitle":"90. urodziny Pavarottiego","hasSessions":true,"hasTrailer":true,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/images/wydarzenia/koncerty/pavarotti/pavarotti90_tlo.jpg?rev=47abac46f05647138d6cda3ff8a1027e","filmStatus":2,"trailers":[],"director":"Luigi Antonini, Matteo Parmeggiani","distributor":"kinomaestro","movieXchangeCode":"","crossCountryMovieXchangeId":"","originalTitle":"Pavarotti 90 - The Man Who Moved the World","showingInCinemas":["0003","0004","0005","0006","0007","0008","0010","0011","0013","0014","0015","0023","0024","0025","0026","0028","0029","0030","0031","0033","0034","0035","0036","0037","0038","0039","0040","0041","0042","0043","0044","0047","0048","0050","0051","0052","0053"],"genres":[],"sessionAttributes":[{"name":"KONCERT","shortName