 (Derry Girls) w porywającej sztuce pióra Johna Millingtona Synge'a o młodości i odkrywaniu siebie. Życie Pegeen Flaherty wywraca się do góry nogami, gdy do jej pubu wchodzi młody mężczyzna, który twierdzi, że zabił swojego ojca. Zabójca nie spotyka się z potępieniem, lecz staje się lokalnym bohaterem i zaczyna podbijać serca. Wtedy niespodziewanie pojawia się drugi mężczyzna… To filmowana na żywo na scenie National Theatre w reżyserii Caitríony McLaughlin, mroczna, zabawna opowieść naszpikowana sekretami.","filmTitle":"NT Live: Playboy zachodniego świata","hasSessions":true,"hasTrailer":true,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/images/wydarzenia/teatr/playboy-zachodniego-swiata/playboy-kadr.jpg?rev=46a17ad2017540ecbc07d7c08b92b717","filmStatus":2,"trailers":[],"director":"","distributor":"","movieXchangeCode":"38aa215d-0946-4139-82f0-e2b018a7019b","crossCountryMovieXchangeId":"","originalTitle":"","showingInCinemas":["0003","0004","0005","0006","0007","0010","0011","0013","0023","0028","0029","0034","0035","0036","0040","0053"],"genres":[],"sessionAttributes":[{"name":"TEATR","shortName":"TEATR - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}]},{"s