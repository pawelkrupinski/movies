],"sessions":[{"sessionId":"83805","bookingUrl":"/rezerwacja-biletow/podsumowanie/0028/HO00002706/83805","formattedPrice":null,"isPriceVisible":false,"duration":83,"startTime":"2026-06-20T12:50:00","endTime":"2026-06-20T14:39:00","showTimeWithTimeZone":"2026-06-20T12:50:00+02:00","isSoldOut":false,"color":null,"isMidnightSession":false,"isBookingAvailable":true,"attributes":[{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 3","sessionPricingDisplayStatus":0,"wheelchairSeatAvailability":1}]}],"filmId":"HO00002706","certificate":{"name":null,"description":null,"src":null},"secondaryCertificates":[],"filmUrl":"https://www.multikino.pl/filmy/all-you-need-is-kill","filmAttributes":[],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/images/film-and-events/2026/all-you-need-is-kill/allyouneediskill_plakat.jpg?rev=08b1e09f55e449e68afb83c40faed6e7","cast":"","releaseDate":"2026-06-19T00:00:00","runningTime":83,"isDurationUnknown":false,"synopsisShort":"Akcja filmu „ALL YOU NEED IS KILL” rozgrywa się w roku 20XX i opowiada historię Rity, zaradnej, ale samotnej młodej kobiety, która zgłasza się na ochotnika do pomocy przy odbudowie Japonii po tajemniczym pojawieniu się ogromnego obcego kwiatu znanego jako „Darol”. Kiedy Darol niespodziewanie wybucha, wywołując śmiertelne wydarzenie i uwalniając potworne stworzenia, które dziesiątkują populację, Rita zostaje wciągnięta w zniszczenie – i ginie. Ale potem budzi się ponownie. I znowu. Uwięziona w niekończącej się pętli czasowej, Rita musi zmagać się z traumą i powtarzającą się śmiercią, aż w końcu spotyka Keiji, nieśmiałego młodego mężczyznę uwięzionego w tym samym cyklu. Razem walczą, by wyrwać się z pętli i odnaleźć sens w otaczającym ich chaosie.","filmTitle":"All You Need Is Kill","hasSessions":true,"hasTrailer":false,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/images/film-and-events/2026/all-you-need-is-kill/allyouneediskill_tlo.jpg?rev=5da57c78e7c94a5c8c8e182b6ad00885","filmStatus":2,"trailers":[],"director":"","distributor":"Piece Of Magic","movieXchangeCode":"d48c4f1c-363a-4302-9244-cec752b12688","crossCountryMovieXchangeId":"","originalTitle":"","showingInCinemas":["0003","0004","0005","0006","0007","0008","0010","0011","0013","0014","0015","0023","0024","0025","0026","0028","0029","0030","0033","0034","0035","0036","0037","0038","0039","0040","0042","0043","0044","0047","0048","0050","0051","0052","0053"],"genres":[],"sessionAttributes":[{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}]},{"showingGroups":[{"date":"2026-08-21T00:00:00","datePrefix":"","pricingTypes":[],"sessions":[{"sessionId":"84523","bookingUrl":"/rezerwacja-biletow/podsumowanie/0028/HO00002775/84523","formattedPrice":null,"isPriceVisible":false,"duration":170,"startTime":"2026-08-21T17:30:00","endTime":"2026-08-21T20:35:00","showTimeWithTimeZone":"2026