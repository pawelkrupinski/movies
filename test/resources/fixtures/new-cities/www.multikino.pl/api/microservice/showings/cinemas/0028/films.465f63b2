wn":false,"synopsisShort":"A co, gdybyśmy poprzez zaangażowanie naszej wyobraźni i otwarcie naszych umysłów mogli otworzyć drzwi do świata cudów? Gabinety osobliwości są przodkami muzeów, znane również jako gabinet cudów w renesansowej Europie. Arystokraci, członkowie klasy kupieckiej i pierwsi praktycy nauki tworzyli kolekcje zabytkowych relikwii, dzieł sztuki lub tajemniczych pamiątek z podróży lub artefaktów. Wśród nich znajdują się między innymi: chaos synchro 1900, duet kołyskowy, rower powietrzny, kontorsjonizm, świat do góry nogami, rola bola, akrobatyczna siatka, pasy powietrzne, kontynent rąk, jojo i banquine.","filmTitle":"Cirque du Soleil: Kurios - Gabinet osobliwości","hasSessions":true,"hasTrailer":true,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/images/film-and-events/2026/cirque-de-soleil/kurios_tlo.jpg?rev=b0dcea89498442aebaf17d506c4b6aa0","filmStatus":2,"trailers":[],"director":"Michel Laprise","distributor":"Qrios Interactive (Pannonia Entertainment)","movieXchangeCode":"2ac83735-66dd-4499-abe0-9f3f40c36a86","crossCountryMovieXchangeId":"6dff1066-d7ee-47d2-8ee5-d823fbc80c9e","originalTitle":"Cirque du Soleil: KURIOS – Cabinet of Curiosities","showingInCinemas":["0003","0004","0005","0006","0007","0008","0010","0011","0013","0014","0015","0023","0024","0025","0026","0027","0028","0029","0030","0031","0033","0034","0035","0036","0037","0038","0039","0041","0042","0043","0044","0047","0048","0050","0051","0052","0053"],"genres":[],"sessionAttributes":[{"name":"WIDOWISKO","shortName":"WIDOWISKO - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[]