rderGradient":[],"backgroundImageUrl":null,"iconName":null}],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/images/wydarzenia/koncerty/john-williams/jwilliams_plakat.jpg?rev=c7d1daa261e2416da7adc8881c9a2801","cast":"John Williams, Duńska Narodowa Orkiestra Symfoniczna, Anna Agafia Egholm, Christine Nonbo Anderson","releaseDate":"2026-06-05T00:00:00","runningTime":83,"isDurationUnknown":false,"synopsisShort":"Odkryj fascynujący świat muzyki Johna Williamsa podczas koncertu, który ożywia kino. Od epickich fanfar z „Gwiezdnych wojen”, przez magiczne dźwięki „Harry'ego Pottera” i „E.T.”, po wzruszające melodie „Listy Schindlera”, ten program łączy w sobie imponującą dynamikę przygody, fantazji i głębokich emocji. Wieczór pełen gęsiej skórki, wielkich emocji i niezapomnianej muzyki filmowej, która budzi wspomnienia i rozpala nowy entuzjazm.","filmTitle":"John Williams - A Tribute","hasSessions":true,"hasTrailer":false,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/images/wydarzenia/koncerty/john-williams/williams_tlo.jpg?rev=60252b6bedb344acb0822ac5e918273a","filmStatus":2,"trailers":[],"director":"Antony Hermus","distributor":"Pannonia Entertainment","movieXchangeCode":"","crossCountryMovieXchangeId":"","originalTitle":"","showingInCinemas":["0003","0004","0005","0006","0007","0008","0010","0011","0013","0014","0015","0023","0024","0025","0026","0028","0029","0030","0031","0033","0034","0035","0036","0037","0038","0039","0040","0041","0042","0043","0044","0047","0048","0050","0051","0052","0053"],"genres":[],"sessionAttributes":[{"name":"KONCERT","shortName":"KONCERT - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}]},{"showingGroups":[{"date":"2026-07-01T00:00:00","datePrefix":"","pricingTypes":[],"sessions":[{"sessionId":"81276","bookingUrl":"/rezerwacja-biletow/podsumowanie/0028/HO00002741/81276","formattedPrice":null,"isPriceVisible":false,"duration":0,"startTime":"2026-07-01T19:00:00","endTime":"2026-07-01T21:13:00","showTimeWithTimeZone":"2026-07-01T19:00:00+02:00","isSoldOut":false,"color":null,"isMidnightSession":false,"isBookingAvailable":true,"attributes":[{"name":"KNO","shortName":"","value":"KNO","description":"Specjalne pokazy dla kobiet z prezentami od sponsor&oacute;w!","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 7","sessionPricingDisplayStatus":0,"wheelchairSeatAvailability":1}]}],"filmId":"HO00002741","certificate":{"name":null,"description":null,"src":null},"secondaryCertificates":[],"filmUrl":"https://www.multikino.pl/filmy/kino-na-obcasach-zaproszenie","filmAttributes":[{"name":"KNO","shortName":"","value":"KNO","description":"Specjalne pokazy dla kobiet z prezentami od sponsor&oacute;w!","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/images/kno/2026/lipiec/kno_lipiec2026_plakat.jpg?rev=9cf9fc043fec4319b8cdc02e4dbdd3d1","cast":"","releaseDate":"2026-07-01T00:00:00","runningTime":0,"isDurationUnknown":true,"synopsisShort":"Joe i Angela są małżeństwem z kilkunastoletnim stażem. Z pozoru ich związek wydaje się wręcz wzorcowy: zgodne, spokojne życie w porządnej dzielnicy, udane dziecko, niezły status materialny. Jednak pod powierzchnią kryją się wzajemne pretensje, drobne konflikty, a przede wszystkim nuda i rutyna. Gdy pewnego wieczoru Joe i Angela zapraszają na kolację parę tajemniczych sąsiadów, swobodna i przyjacielska rozmowa zaczyna zmieniać się w pełną dwuznaczności grę. To, co dotąd skrywane, wychodzi na jaw, a niewypowiedziane pragnienia ducha i ciała zaczynają nabierać niebezpiecznie realnych kształtów. Czy obie pary pójdą dziś spać we własnych łóżkach?","filmTitle":"Kino na obcasach: Zaproszenie","hasSessions":true,"hasTrailer":false,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/global/img/film-panel-default-image.png?rev=-1","filmStatus":2,"trailers":[],"director":"","distributor":"Monolith","movieXchangeCode":"","crossCountryMovieXchangeId":"","originalTitle":"","showingInCinemas":["0003","0004","0005","0007","0008","0010","0011","0013","0015","0024","0028","0030","0035","0036","0037","0040","0041","0043","0044","0048","0051","0053"],"genres":[],"sessionAttributes":[{"name":"KNO","shortName":"","value":"KNO","description":"Specjalne pokazy dla kobiet z prezentami od sponsor&oacute;w!","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":n