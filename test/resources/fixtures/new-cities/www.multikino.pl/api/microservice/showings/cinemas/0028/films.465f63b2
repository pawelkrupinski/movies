ut":false,"color":null,"isMidnightSession":false,"isBookingAvailable":true,"attributes":[{"name":"WYSTAWY","shortName":"WYSTAWY - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 6","sessionPricingDisplayStatus":0,"wheelchairSeatAvailability":1}]}],"filmId":"HO00002585","certificate":{"name":null,"description":null,"src":null},"secondaryCertificates":[],"filmUrl":"https://www.multikino.pl/filmy/art-beats-rafael-mody-geniusz","filmAttributes":[{"name":"WYSTAWY","shortName":"WYSTAWY - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/images/wydarzenia/wystawy/rafael-plakat.jpg?rev=e127f4cbbb104fde8a20d94cf4ba7dc0","cast":"","releaseDate":"2026-07-13T00:00:00","runningTime":80,"isDurationUnknown":false,"synopsisShort":"Zanurz się w epokę renesansu i odkryj wysublimowaną sztukę Rafaela.     Podziwiaj portrety niezwykłych kobiet: Matki, Przyjaciółki, Sekretnej Kochanki i Klientki, których osobowości rozkwitają na płótnach. Matka, która zmarła, gdy artysta miał zaledwie osiem lat. Wielbicielki, które wspierały go na drodze do sukcesu. Kobieta, która niemal przyczyniła się do jego śmierci. Istniały naprawdę lub były tylko wytworem wyobraźni. Rafael (1483-1520) uwiecznił ideał niebiańskiego piękna. Dzięki pracy światowej sławy ekspertów możemy poznać najważniejsze momenty z życia jednego z największych mistrzów renesansu.","filmTitle":"Art Beats: Rafael. Młody geniusz","hasSessions":true,"hasTrailer":true,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/images/wydarzenia/wystawy/rafael-kadr.jpg?rev=9c0053d94c274a9aab34d304ab3dca05","filmStatus":2,"trailers":[],"director":" Massimo Ferrari","distributor":"nazwywkinach","movieXchangeCode":"","crossCountryMovieXchangeId":"","originalTitle":"","showingInCinemas":["0003","0004","0005","0006","0007","0008","0010","0011","0013","0014","0015","0023","0024","0025","0026","0028","0029","0030","0031","0033","0034","0035","0036","0037","0038","0039","0040","0041","0042","0043","0044","0047","0048","0050","0051","0052","0053"],"genres":[],"sessionAttributes":[{"name":"WYSTAWY","shortName":"WYSTAWY - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}]},{"showingGroups":[{"date":"2026-06-13T00:00:00","datePrefix":"","pricingTypes":[],"sessions":[{"sessionId":"83222","bookingUrl":"/rezerwacja-biletow/podsumowanie/0028/HO00002774/83222","formattedPrice":null,"isPriceVisible":false,"duration":180,"startTime":"2026-06-13T11:45:00","endTime":"2026-06-13T14:45:00","showTimeWithTimeZone":"2026-06-13T11:45:00+02:00","isSoldOut":false,"color":null,"isMidnightSession":false,"isBookingAvailable":true,"attributes":[{"name":"KONCERT","shortName":"KONCERT - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"LIVE","shortName":"LIVE","value":"Live","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 9","sessionPricingDisplayStatus":0,"wheelchairSeatAvailability":1},{"sessionId":"83223","bookingUrl":"/rezerwacja-biletow/podsumowanie/0028/HO00002774/83223","formattedPrice":null,"isPriceVisible":false,"duration":180,"startTime":"2026-06-13T15:30:00","endTime":"2026-06-13T18:30:00","showTimeWithTimeZone":"2026-06-13T15:30:00+02:00","isSoldOut":false,"color":null,"isMidnightSession":false,"isBookingAvailable":true,"attributes":[{"name":"KONCERT","shortName":"KONCERT - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"LIVE","shortName":"LIVE","value":"Live","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 9","sessionPricingDisplayStatus":0,"wheelchairSeatAvailability":1}]}],"filmId":"HO00002774","certificate":{"name":null,"description":null,"src":null},"secondaryCertificates":[],"filmUrl":"https://www.multikino.pl/filmy/bts-world-tour-arirang-in-busan-live-viewing","filmAttributes":[{"name":"KONCERT","shortName":"KONCERT - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/images/wydarzenia/koncerty/kpop/bts_busan_plakat.jpg?rev=3ebe23c67eda474c8d47f23309b69661","cast":"","releaseDate":"2026-06-13T00:00:00","runningTime":180,"isDurationUnknown":false,"synopsisShort":"Historyczna trasa trwa dalej! Po rekordowym otwarciu światowej trasy ARIRANG, BTS powraca do legendarnego Busan Asiad Main Stadium na wyjątkowy koncert transmitowany na żywo do kin na całym świecie — także do Multikina. To niezwykle emocjonalny moment zarówno dla zespołu, jak i fanów. Po raz pierwszy od 3 lat i 8 miesięcy BTS wystąpi ponownie w miejscu, gdzie odbył się ich ostatni koncert w pełnym składzie przed rozpoczęciem służby wojskowej członków grupy. Trasa obejmująca 34 miasta i 85 koncertów już teraz zapisała się w historii jako największe tournée koreańskiego artysty. Występ w Busanie odbędzie się dodatkowo 13 czerwca — w rocznicę debiutu BTS — co nadaje wydarzeniu wyjątkowy i symboliczny charakter. Nazwa trasy ARIRANG nawiązuje do piątego albumu studyjnego BTS i opowiada o tożsamości, tęsknocie, szczerości oraz głębokiej miłości. Widowiskowa scena 360° zapewni w pełni immersyjne doświadczenie, dzięki któremu widzowie poczują się częścią tego niezwykłego wydarzenia. Nie przegap jednego z najważniejszych muzycznych wydarzeń roku i przeżyj energię koncertu BTS na wielkim kinowym ekranie — już 13 czerwca, prosto z Busanu.","filmTitle":"BTS WORLD TOUR 'ARIRANG' IN BUSAN: LIVE VIEWING","hasSessions":true,"hasTrailer":false,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/images/wydarzenia/koncerty/kpop/bts_busan_tlo.jpg?rev=b8bf3fc8c1cf4bea8105ed40c440d8ab","filmStatus":1,"trailers":[],"director":"","distributor":"","movieXchangeCode":"","crossCountryMovieXchangeId":"","originalTitle":"","showingInCinemas":["0003","0004","0005","0006","0007","0010","0011","0013","0014","0015","0023","0024","0026","0028","0029","0030","0034","0035","0036","0037","0040","0053"],"genres":[],"sessionAttributes":[{"name":"KONCERT","shortName":"KONCERT - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"LIVE","shortName":"LIVE","value":"Live","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}]},{"showingGroups":[{"date":"2026-06-22T00:00:00","datePrefix":"","pricingTypes":[],"sessions":[{"sessionId":"72606","bookingUrl":"/rezerwacja-biletow/podsumowanie/0028/HO00002588/72606","formattedPrice":null,"isPriceVisible":false,"duration":100,"startTime":"2026-06-22T17:50:00","endTime":"2026-06-22T19:45:00","showTimeWithTimeZone":"2026-06-22T17:50:00+02:00","isSoldOut":false,"color":null,"isMidnightSession":false,"isBookingAvailable":true,"attributes":[{"name":"WYSTAWY","shortName":"WYSTAWY - wydarzenie specjalne","value":"","description":"","attributeType":"Movie"