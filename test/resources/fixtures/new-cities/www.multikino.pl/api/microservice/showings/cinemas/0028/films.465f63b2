"screenName":"Sala 9","sessionPricingDisplayStatus":0,"wheelchairSeatAvailability":1},{"sessionId":"81270","bookingUrl":"/rezerwacja-biletow/podsumowanie/0028/HO00002732/81270","formattedPrice":null,"isPriceVisible":false,"duration":93,"startTime":"2026-06-07T21:15:00","endTime":"2026-06-07T23:14:00","showTimeWithTimeZone":"2026-06-07T21:15:00+02:00","isSoldOut":false,"color":null,"isMidnightSession":false,"isBookingAvailable":true,"attributes":[{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 9","sessionPricingDisplayStatus":0,"wheelchairSeatAvailability":1}]}],"filmId":"HO00002732","certificate":{"name":null,"description":null,"src":null},"secondaryCertificates":[],"filmUrl":"https://www.multikino.pl/filmy/the-amazing-digital-circus-ostatni-akt","filmAttributes":[],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/images/film-and-events/2026/tadc/tadc_plakat1.jpg?rev=6804403f06ff476592b3fb32300bcdf8","cast":"Lizzie Freeman, Michael Kovach, Marissa Lenti, Ashley Nichols","releaseDate":"2026-06-04T00:00:00","runningTime":93,"isDurationUnknown":false,"synopsisShort":"Internetowy fenomen „The Amazing Digital Circus” doczeka się długo wyczekiwanego  finału w formie pełnometrażowego seansu kinowego! „Ostatni akt” łączy odcinek 8 z  zupełnie nowym, godzinnym odcinkiem 9, który fani zobaczą jako pierwsi.  Gdy Caine znika, a cyrk pogrąża się w mroku, bohaterom pozostają jedynie błędy i traumy z  przeszłości. W obliczu nieuchronnej wieczności odkrywają prawdę o Cyfrowym Cyrku i jego  historii.  Czy zaakceptują to, co odkryją… czy zdecydują się na inne wyjście? Na pewno ktoś  rzuci coś zabawnego… bo to zakończenie nie może być aż tak przygnębiające, prawda?","filmTitle":"The Amazing Digital Circus: Ostatni Akt","hasSessions":true,"hasTrailer":true,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/images/film-and-events/2026/tadc/tadc_kadr.jpg?rev=78361b76808f4e93b4cfdcece889d051","filmStatus":1,"trailers":[],"director":"Gooseworx  ","distributor":"Piece of Magic Entertainment","movieXchangeCode":"3ce9a86f-2ab1-419e-9956-0918027fd8ad","crossCountryMovieXchangeId":"bac34ec3-e47f-4008-ab61-d527eacc5939","originalTitle":"The Amazing Digital Circus: The Last Act","showingInCinemas":["0003","0004","0005","0006","0007","0008","0010","0011","0013","0014","0015","0023","0024","0025","0026","0028","0029","0030","0031","0033","0034","0035","0036","0037","0038","0039","0040","0041","0042","0043","0044","0047","0048","0050","0051","0052","0053"],"genres":[],"sessionAttributes":[{"name":"DUBBING","shortName":"DUBBING","value":"DUBBING","description":"DUBBING","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}]},{"showingGroups":[{"date":"2026-06-26T00:00:00","datePrefix":"","pricingTypes":[],"sessi