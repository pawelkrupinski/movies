.","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"12131c24-a1c8-413d-98ee-d6f860dc905c","name":"akcja","description":""},{"id":"726b5445-9bb2-48ff-8ef1-c4e96bb92399","name":"przygodowy","description":""}],"trailers":[],"posters":["https://movies.helios.pl/images/BTTF235thplakat.jpg"],"pictures":["https://movies.helios.pl/images/PowrotdoprzyszłosciII4.jpg","https://movies.helios.pl/images/PowrotdoprzyszłosciII3.jpg","https://movies.helios.pl/images/PowrotdoprzyszłosciII2.jpg","https://movies.helios.pl/images/PowrotdoprzyszłosciII1.jpg"],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"13","value":"13","description":"od lat 13"}],"brightcoveVideos":[],"release":"2D/NAP","name":"Powrót do przyszłości II w Helios RePlay","link":null,"screeningId":"44edb183-b0e4-4954-a8af-e39d78ca77a5","screenId":"2dcd8d2c-ea54-403b-b0b8-d5707fd7dd49","cinemaId":"880f2a3a-e9e8-447c-95ca-72c49ca38a1e","timeFrom":"2026-06-25T18:00:00+02:00","timeTo":"2026-06-25T19:58:00+02:00","saleTimeTo":"2026-06-25T18:30:00+02:00","reservationTimeTo":"2026-06-25T17:00:00+02:00","availabilityStatus":1,"maxOccupancy":207,"maxOccupancyExcludingWheelchair":207,"audience":0,"audienceExcludingWheelchair":0,"generalAdmission":false,"isScreenSwapping":false,"externalId":845654,"items":[{"movieId":"21ecb32b-76fe-4db8-88c4-14ac1c27a8e6","moviePrintId":"2001d0e8-b8aa-4228-ad90-3218d0b999bf","timeFrom":"2026-06-25T18:00:00+02:00","timeTo":"2026-06-25T19:58:00+02:00","movieName":"Powrót do przyszłości II","speakingType":"Napisy","printType":"2D","screenId":"2dcd8d2c-ea54-403b-b0b8-d5707fd7dd49","movieSubPrintLabel":"PS"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":16,"symbol":"HELIOS REPLAY","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"8548c02a-56bf-4df4-8085-fbb356648e06","duration":110,"description":"Waldek ma dość – w domu chaos, w sieci drama, a jego gamingowy team s