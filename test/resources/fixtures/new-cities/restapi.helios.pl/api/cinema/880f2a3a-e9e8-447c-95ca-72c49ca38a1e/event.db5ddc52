[{"id":"7d61261d-af61-4717-8087-35ea842813ee","duration":152,"description":"Złowieszcze Imperium upadło, a imperialni watażkowie rozpierzchli się po Galaktyce. Kiełkująca Nowa Republika pragnie ochronić wszystko, o co walczyła Rebelia. Werbuje więc legendarnego łowcę nagród, Mandalorianina Din Djarina (Pedro Pascal) i jego młodego podopiecznego Grogu. Film, w którym wystąpi również Sigourney Weaver, wyreżyserował Jon Favreau, a wyprodukowali go Jon Favreau, Kathleen Kennedy, Dave Filoni i Ian Bryce. Muzykę spokmponował Ludwig Göransson.\n\nW filmie Mandalorian i Grogu znajduje się kilka scen z dynamicznymi efektami świetlnymi, które mogą powodować dyskomfort u widzów wrażliwych na światło i wpływać na osoby z epilepsją fotogenną.","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"32d53995-2198-4b43-aa57-235bfeee409e","name":"fantasy","description":""},{"id":"12131c24-a1c8-413d-98ee-d6f860dc905c","name":"akcja","description":""},{"id":"726b5445-9bb2-48ff-8ef1-c4e96bb92399","name":"przygodowy","description":""}],"trailers":[],"posters":["https://movies.helios.pl/images/mandalorianplakat.jpg"],"pictures":[],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"13","value":"13","description":"od lat 13"}],"brightcoveVideos":[],"release":"2D/DUB","name":"Mandalorian & Grogu - DUB - KNT","link":null,"screeningId":"036f26e3-3be2-4e18-8369-d80f9f3b469e","screenId":"2dcd8d2c-ea54-403b-b0b8-d5707fd7dd49","cinemaId":"880f2a3a-e9e8-447c-95ca-72c49ca38a1e","timeFrom":"2026-06-22T09:30:00+02:00","timeTo":"2026-06-22T12:02:28+02:00","saleTimeTo":"2026-06-22T10:00:00+02:00","reservationTimeTo":"2026-06-22T08:30:00+02:00","availabilityStatus":1,"maxOccupancy":207,"maxOccupancyExcludingWheelchair":207,"audience":36,"audienceExcludingWheelchair":36,"generalAdmission":false,"isScreenSwapping":false,"externalId":6892222,"items":[{"movieId":"0ec14de2-9816-42db-8c85-4ef4b964c919","moviePrintId":"d534d41b-7579-4bdb-a59b-