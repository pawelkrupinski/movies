d42-0125bcba84ca","duration":130,"description":"Polly i Tim wraz z trójką dzieci stają przed koniecznością przeprowadzenia się na odludną angielską prowincję. Wkrótce po przyjeździe najmłodsi odkrywają niezwykłe drzewo, zamieszkane przez barwne, ekscentryczne postacie. Jeśli odważą się wspiąć na jego szczyt, czekają na nie fantastyczne krainy, pełne zapierających dech przygód.","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"726b5445-9bb2-48ff-8ef1-c4e96bb92399","name":"przygodowy","description":""},{"id":"6bcd8fba-fbc2-466a-9f37-ce7a42443c2e","name":"familijny","description":""},{"id":"32d53995-2198-4b43-aa57-235bfeee409e","name":"fantasy","description":""}],"trailers":["https://www.youtube.com/embed/T1FJ-tzNDXc"],"posters":["https://movies.helios.pl/images/DRZEWOMAGIITEASERPLAKAT(1).png"],"pictures":["https://movies.helios.pl/images/Drzewomagii7(1).jpg","https://movies.helios.pl/images/Drzewomagii6(1).jpg","https://movies.helios.pl/images/Drzewomagii5(1).jpg","https://movies.helios.pl/images/Drzewomagii4(1).jpg","https://movies.helios.pl/images/Drzewomagii3(1).jpg","https://movies.helios.pl/images/Drzewomagii2(1).jpg","https://movies.helios.pl/images/Drzewomagii1(1).jpg"],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"8","value":"8","description":"od lat 8"}],"brightcoveVideos":[],"release":"2D/DUB","name":"Drzewo Magii - KNT","link":null,"screeningId":"5663dab4-d8ae-412d-9215-cc0d545db843","screenId":"c58da81b-efd4-4d97-aa6e-d48fd55aa489","cinemaId":"880f2a3a-e9e8-447c-95ca-72c49ca38a1e","timeFrom":"2026-06-09T09:00:00+02:00","timeTo":"2026-06-09T11:10:00+02:00","saleTimeTo":"2026-06-09T09:30:00+02:00","reservationTimeTo":"2026-06-09T08:00:00+02:00","availabilityStatus":1,"maxOccupancy":397,"audience":24,"generalAdmission":false,"isScreenSwapping":false,"externalId":74222365,"items":[{"movieId":"f222b6a2-1b42-430c-80f9-f93e67d877b5","moviePrintId":"536eb5ef-6dba-4724-8783-7e90a5b0e9f5"