a","moviePrintId":"bfc41d6c-55db-497f-a97e-6f9c112da03b","timeFrom":"2026-06-07T16:00:00+02:00","timeTo":"2026-06-07T17:38:00+02:00","movieName":"Kosmiczny mecz. 30. Rocznica","speakingType":"DUB","printType":"2D","screenId":"020c0fc5-0148-4f54-82de-7d373fb70ba5","movieSubPrintLabel":"PS"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":16,"symbol":"HELIOS REPLAY","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"f7c02d9a-0c5f-4a06-bfcc-9557c509861b","duration":120,"description":"Willow odziedziczyła nie tylko majątek po swej babci, ale także magiczne moce. Niestety jej ojciec planuje sprzedać las, z którego wywodzi się cała magia. Wraz z trzema innymi czarownicami postanawiają uratować czarodziejską krainę.","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"6bcd8fba-fbc2-466a-9f37-ce7a42443c2e","name":"familijny","description":""}],"trailers":[],"posters":["https://movies.helios.pl/images/plakatwillow.jpg"],"pictures":["https://movies.helios.pl/images/Willowitajemniczylas7.jpg","https://movies.helios.pl/images/Willowitajemniczylas6.jpg","https://movies.helios.pl/images/Willowitajemniczylas5.jpg","https://movies.helios.pl/images/Willowitajemniczylas4.jpg","https://movies.helios.pl/images/Willowitajemniczylas3.jpg","https://movies.helios.pl/images/Willowitajemniczylas2.jpg","https://movies.helios.pl/images/Willowitajemniczylas1.jpg"],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"6","value":"6","description":"od lat 6"}],"brightcoveVideos":[],"release":"2D/DUB","name":"Willow i tajemniczy las - KNTJ","link":null,"screeningId":"0fde927a-7d2f-406d-af2e-beb3248ed007","screenId":"2dcd8d2c-ea54-403b-b0b8-d5707fd7dd49","cinemaId":"880f2a3a-e9e8-447c-95ca-72c49ca38a1e","timeFrom":"2026-06-09T09:00:00+02:00","timeTo":"2026-06-09T11:00:00+02:00","saleTimeTo":"2026-06-09T09:30:00+02:00","reservationTimeTo":"2026-06-09T08:00:00+02:00","availabilityStatus":1,"maxOccupancy":209,"audience":119,"generalAdmission":false,"isScreenSwapping":false,"externalId":744412365,"items":[{"movieId":"040d2e11-ff64-4722-b82a-cc2730855c50","moviePrintId":"12377068-57a9-457b-b557-8b2172014f79","timeFrom":"2026-06-09T09:00:00+02:00","timeTo":"2026-06-09T11:00:00+02:00","movieName":"Willow i tajemniczy las ","speakingType":"DUB","printType":"2D","screenId":"2dcd8d2c-ea54-403b-b0b8-d5707fd7dd49","movieSubPrintLabel":"ps"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":8,"symbol":"KINO NA TEMAT JUNIOR","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"4add03a9-c644-43b3-a734-acef3cfe73e8","duration":139,"description":"George Fahmy (w tej roli Fares Fares) to największa gwiazda egipskiego kina. Zwany jest “faraonem ekranu”. Zwraca na niego uwagę sam prezydent Egiptu Abd al-Fattah as Sisi, który życzy sobie, aby gwiazdor zagrał główną rolę w filmie biograficznym, gloryfikującym prezydenta. Okazuje się, że jest to propozycja nie do odrzucenia – władza szantażem wymusza na aktorze jej przyjęcie.\n\nPoczątkowo, jak przystało na gwiazdę, bohater liczy na to, że będzie miał sporo do powiedzenia, zarówno w sprawie swojej roli, jak i kształtu całego filmu. Szybko jednak zostaje sprowadzony na ziemię. Głównie za sprawą obecnego na planie tajemniczego doktora Manssoura, który sprawuje pieczę nad produkcją i jej odpowiednim, propagandowym tonem. Sytuację dodatkowo komplikuje romans, w jaki Fahmy wdaje się z żoną jednego z wysoko postawionych generałów. To moment, w którym fikcja i rzeczywistość zaczynają się niebezpiecznie przenikać.","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"939b8bbb-4f8f-4fd6-875d-16e483eccdea","name":"thriller","description":""}],"trailers":["https://www.youtube.com/embed/-DWKk_XNt0E"],"posters":["https://movies.helios.pl/images/OrlyRepublikiPlakat.jpg"],"pictures":["https://movies.helios.pl/images/Orłyrepubliki7.jpg","https://movies.helios.pl/images/Orłyrepubliki6.jpg","https://movies.helios.pl/images/Orłyrepubliki5.jpg","https://movies.helios.pl/images/Orłyrepubliki4.jpg","https://movies.helios.pl/images/Orłyrepubliki3.jpg","https://movies.helios.pl/images/Orłyrepubliki2.jpg","https://movies.helios.pl/images/Orłyrepubliki1.jpg"],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"15","value":"15","description":"od lat 15"}],"brightcoveVideos":[],"release":"2D/NAP","name":"Orły republiki - Kino Konesera","link":null,"screeningId":"ded4d105-8e17-49ea-8dee-4bd813143b0f","screenId":"2dcd8d2c-ea54-403b-b0b8-d5707fd7dd49","cinemaId":"880f2a3a-e9e8-447c-95ca-72c49ca38a1e","timeFrom":"2026-06-08T18:00:00+02:00","timeTo":"2026-06-08T20:19:00+02:00","saleTimeTo":"2026-06-08T18:30:00+02:00","reservationTimeTo":"2026-06-08T17:00:00+02:00","availabilityStatus":1,"maxOccupancy":209,"audience":0,"generalAdmission":false,"isScreenSwapping":false,"externalId":54668712,"items":[{"movieId":"9fc5d4d9-9c34-4abf-b663-e2ff769a6f15","moviePrintId":"44473cb6-36f2-41c5-aa94-f46b78efb1fd","timeFrom":"2026-06-08T18:00:00+02:00","timeTo":"2026-06-08T20:19:00+02:00","movieName":"Orły republiki","speakingType":"Napisy","printType":"2D","screenId":"2dcd8d2c-ea54-403b-b0b8-d5707fd7dd49","movieSubPrintLabel":"PS"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":1,"symbol":"KINO KONESERA","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"d7bb09f1-a1ea-4982-915d-db91d91397cc","duration":176,"description":"Nigdy nie jest za późno, by zacząć od nowa. Emanujący optymizmem i pogodą ducha portret dojrzałej kobiety, która robi wszystko, by ocalić swój dom i siebie.\n\n María Ángeles od 40 lat mieszka w słonecznym apartamencie w marokańskim Tangerze. Gdy zostaje zmuszona do jego opuszczenia, nie potrafi się z tym pogodzić. To, co początkowo wydaje się bolesną koniecznością, nieoczekiwanie staje się jednak nowym początkiem. W życiu Marii Ángeles pojawia się miejsce zarówno na nowych przyjaciół, jak i na niespodziewaną miłość. „Drugie życie” to zdobywca nagrody publiczności festiwalu w Wenecji. W roli głównej zachwycająca Carmen Maura, ikona filmów Almodóvara.","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"4a3d74ad-af64-4a6a-a640-e75c762899c8","name":"romans","description":""},{"id":"14c7bb44-6562-4ad9-8d7a-ab747fa73829","name":"dramat","description":""}],"trailers":["https://www.youtube.com/embed/8xyTxjwUwfQ"],"posters":["https://movies.helios.pl/images/drugiezycieplakat.jpg"],"pictures":["https://movies.helios.pl/images/Drugiezycie7.jpg","https://movies.helios.pl/images/Drugiezycie6.jpg","https://movies.helios.pl/images/Drugiezycie5.jpg","https://movies.helios.pl/images/Drugiezycie4.jpg","https://movies.helios.pl/images/Drugiezycie3.jpg","https://movies.helios.pl/images/Drugiezycie2.jpg","https://movies.helios.pl/images/Drugiezycie1.jpg"],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"15","value":"15","description":"od lat 15"}],"brightcoveVideos":[],"release":"2D/NAP","name":"Drugie życie - Kino Kobiet","link":null,"screeningId":"4e92ad72-2fe2-4f73-8444-b02111a63013","screenId":"020c0fc5-0148-4f54-82de-7d373fb70ba5","cinemaId":"880f2a3a-e9e8-447c-95ca-72c49ca38a1e","timeFrom":"2026-06-10T18:00:00+02:00","timeTo":"2026-06-10T20:56:00+02:00","saleTimeTo":"2026-06-10T18:30:00+02:00","reservationTimeTo":"2026-06-10T17:00:00+02:00","availabilityStatus":1,"maxOccupancy":395,"audience":24,"generalAdmission":false,"isScreenSwapping":false,"externalId":835356,"items":[{"movieId":"efba3b90-d2db-4d41-b474-60d596a59302","moviePrintId":"4a18ef08-42c9-481a-b3ba-e757ea39fec5","timeFrom":"2026-06-10T18:00:00+02:00","timeTo":"2026-06-10T20:56:00+02:00","movieName":"Drugie życie","speakingType":"Napisy","printType":"2D","screenId":"020c0fc5-0148-4f54-82de-7d373fb70ba5","movieSubPrintLabel":"PS"}],"tagGroups":[{"symbol":