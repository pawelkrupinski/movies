szym przyjacielem Ake rozpoczyna staż w restauracji. Obaj zakochują się w tej samej stażystce. Jak z tego wybrnąć, żeby zachować dziewczynę i najlepszego przyjaciela? Piętrzą się trudne pytania, sekrety i wielkie dylematy. Jak Bert ma to wszystko ogarnąć, żeby nie wydarzyła się totalna katastrofa?","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"14c7bb44-6562-4ad9-8d7a-ab747fa73829","name":"dramat","description":""},{"id":"33b6d7c4-1777-46f4-9ae2-6d1cbf8d8b40","name":"komedia","description":""}],"trailers":[],"posters":["https://movies.helios.pl/images/plakatjakberttowszystkoogar.jpg"],"pictures":["https://movies.helios.pl/images/JakBerttowszystkoogarnie5.jpg","https://movies.helios.pl/images/JakBerttowszystkoogarnie4.jpg","https://movies.helios.pl/images/JakBerttowszystkoogarnie3.jpg","https://movies.helios.pl/images/JakBerttowszystkoogarnie2.jpg","https://movies.helios.pl/images/JakBerttowszystkoogarnie1.jpg"],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"13","value":"13","description":"od lat 13"}],"brightcoveVideos":[],"release":"2D/DUB","name":"Jak Bert to wszystko ogarnie? - KNT","link":null,"screeningId":"61b26c1e-f4ca-4d4d-88d6-a8c40124d3eb","screenId":"020c0fc5-0148-4f54-82de-7d373fb70ba5","cinemaId":"880f2a3a-e9e8-447c-95ca-72c49ca38a1e","timeFrom":"2026-06-09T10:00:00+02:00","timeTo":"2026-06-09T11:43:00+02:00","saleTimeTo":"2026-06-09T10:30:00+02:00","reservationTimeTo":"2026-06-09T09:00:00+02:00","availabilityStatus":1,"maxOccupancy":395,"audience":20,"generalAdmission":false,"isScreenSwapping":false,"externalId":545466,"items":[{"movieId":"6a5dabbc-00aa-438d-bc11-15e4447e76c1","moviePrintId":"714d2599-192e-450c-98b2-26e8216e6558","timeFrom":"2026-06-09T10:00:00+02:00","timeTo":"2026-06-09T11:43:00+02:00","movieName":"Jak Bert to wszystko ogarnie?","speakingType":"DUB","printType":"2D","screenId":"020c0fc5-0148-4f54-82de-7d373fb70ba5","movieSubPrintLabel":"PS"}],"tagGroups":