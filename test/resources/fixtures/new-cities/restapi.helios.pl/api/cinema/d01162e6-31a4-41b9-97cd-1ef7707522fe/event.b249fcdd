[{"id":"9fa84454-3318-4d8f-bd42-0125bcba84ca","duration":130,"description":"Polly i Tim wraz z trójką dzieci stają przed koniecznością przeprowadzenia się na odludną angielską prowincję. Wkrótce po przyjeździe najmłodsi odkrywają niezwykłe drzewo, zamieszkane przez barwne, ekscentryczne postacie. Jeśli odważą się wspiąć na jego szczyt, czekają na nie fantastyczne krainy, pełne zapierających dech przygód.","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"726b5445-9bb2-48ff-8ef1-c4e96bb92399","name":"przygodowy","description":""},{"id":"6bcd8fba-fbc2-466a-9f37-ce7a42443c2e","name":"familijny","description":""},{"id":"32d53995-2198-4b43-aa57-235bfeee409e","name":"fantasy","description":""}],"trailers":["https://www.youtube.com/embed/T1FJ-tzNDXc"],"posters":["https://movies.helios.pl/images/DRZEWOMAGIITEASERPLAKAT(1).png"],"pictures":["https://movies.helios.pl/images/Drzewomagii7(1).jpg","https://movies.helios.pl/images/Drzewomagii6(1).jpg","https://movies.helios.pl/images/Drzewomagii5(1).jpg","https://movies.helios.pl/images/Drzewomagii4(1).jpg","https://movies.helios.pl/images/Drzewomagii3(1).jpg","https://movies.helios.pl/images/Drzewomagii2(1).jpg","https://movies.helios.pl/images/Drzewomagii1(1).jpg"],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"8","value":"8","description":"od lat 8"}],"brightcoveVideos":[],"release":"2D/DUB","name":"Drzewo Magii - KNT","link":null,"screeningId":"e4ea9bc2-e301-4d98-a78b-a391f8519860","screenId":"60f76479-27a9-4c7f-9351-bb74c8c25aa3","cinemaId":"d01162e6-31a4-41b9-97cd-1ef7707522fe","timeFrom":"2026-06-08T09:30:00+02:00","timeTo":"2026-06-08T11:40:00+02:00","saleTimeTo":"2026-06-08T10:00:00+02:00","reservationTimeTo":"2026-06-08T08:30:00+02:00","availabilityStatus":1,"maxOccupancy":209,"audience":27,"generalAdmission":false,"isScreenSwapping":false,"externalId":74222365,"items":[{"movieId":"f222b6a2-1b42-430c-80f9-f93e67d877b5","moviePrintId":"536eb5ef-