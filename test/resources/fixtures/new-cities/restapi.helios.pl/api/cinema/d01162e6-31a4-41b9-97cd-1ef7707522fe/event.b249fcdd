2-4ad9-8d7a-ab747fa73829","name":"dramat","description":""},{"id":"b36e63dc-85ea-4670-93db-f785f49c720e","name":"biograficzny","description":""}],"trailers":[],"posters":["https://movies.helios.pl/images/Michaelnowyplakat.jpg"],"pictures":[],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"13","value":"13","description":"od lat 13"}],"brightcoveVideos":[],"release":"2D/NAP","name":"Michael - AF","link":null,"screeningId":"dfaefd3f-6017-466e-938e-36fb10fb761d","screenId":"6fc1edf0-e867-4881-898d-9e5cf35a42f1","cinemaId":"d01162e6-31a4-41b9-97cd-1ef7707522fe","timeFrom":"2026-06-08T12:15:00+02:00","timeTo":"2026-06-08T14:53:00+02:00","saleTimeTo":"2026-06-08T12:45:00+02:00","reservationTimeTo":"2026-06-08T11:15:00+02:00","availabilityStatus":1,"maxOccupancy":255,"audience":30,"generalAdmission":false,"isScreenSwapping":false,"externalId":75632589,"items":[{"movieId":"6219f570-ced4-42d3-98b0-0afa8957e4fe","moviePrintId":"0d56cd17-925b-4dfc-80fe-c7f2fa1c8bb9","timeFrom":"2026-06-08T12:15:00+02:00","timeTo":"2026-06-08T14:53:00+02:00","movieName":"Michael","speakingType":"Napisy","printType":"2D","screenId":"6fc1edf0-e867-4881-898d-9e5cf35a42f1","movieSubPrintLabel":"ps"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":9,"symbol":"AKADEMIA FILMOWA","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"4add03a9-c644-43b3-a734-acef3cfe73e8","duration":139,"description":"George Fahmy (w tej roli Fares Fares) to największa gwiazda egipskiego kina. Zwany jest “faraonem ekranu”. Zwraca na niego uwagę sam prezydent Egiptu Abd al-Fattah as Sisi, który życzy sobie, aby gwiazdor zagrał główną rolę w filmie biograficznym, gloryfikującym prezydenta. Okazuje się, że jest to propozycja nie do odrzucenia – władza szantażem wymusza na aktorze jej przyjęcie.\n\nPoczątkowo, jak przystało na gwiazdę, bohater liczy na to, że będzie miał sporo do powiedzenia, zarówno w sprawie swojej roli, jak i kształtu całego filmu. Szybko jednak zostaje sprowadzony na ziemię. Głównie za sprawą obecnego na planie tajemniczego doktora Manssoura, który sprawuje pieczę nad produkcją i jej odpowiednim, propagandowym tonem. Sytuację dodatkowo komplikuje romans, w jaki Fahmy wdaje się z żoną jednego z wysoko postawionych generałów. To moment, w którym fikcja i rzeczywistość zaczynają się niebezpiecznie przenikać.","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"939b8bbb-4f8f-4fd6-875d-16e483eccdea","name":"thriller","description":""}],"trailers":["https://www.youtube.com/embed/-DWKk_XNt0E"],"posters":["https://movies.helios.pl/images/OrlyRepublikiPlakat.jpg"],"pictures":["https://movies.helios.pl/images/Orłyrepubliki7.jpg","https://movies.helios.pl/images/Orłyrepubliki6.jpg","https://movies.helios.pl/images/Orłyrepubliki5.jpg","https://movies.helios.pl/images/Orłyrepubliki4.jpg","https://movies.helios.pl/images/Orłyrepubliki3.jpg","https://movies.helios.pl/images/Orłyrepubliki2.jpg","https://movies.helios.pl/images/Orłyrepubliki1.jpg"],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"15","value":"15","description":"od lat 15"}],"brightcoveVideos":[],"release":"2D/NAP","name":"Orły republiki - Kino Konesera","link":null,"screeningId":"4accfb97-54c6-4f27-9b31-4b44ac029629","screenId":"58b8989d-a885-4279-8d78-90ecc0697586","cinemaId":"d01162e6-31a4-41b9-97cd-1ef7707522fe","timeFrom":"2026-06-08T18:00:00+02:00","timeTo":"2026-06-08T20:19:00+02:00","saleTimeTo":"2026-06-08T18:30:00+02:00","reservationTimeTo":"2026-06-08T17:00:00+02:00","availabilityStatus":1,"maxOccupancy":171,"audience":1,"generalAdmission":false,"isScreenSwapping":false,"externalId":54668712,"items":[{"movieId":"9fc5d4d9-9c34-4abf-b663-e2ff769a6f15","moviePrintId":"44473cb6-36f2-41c5-aa94-f46b78efb1fd","timeFrom":"2026-06-08T18:00:00+02:00","timeTo":"2026-06-08T20:19:00+02:00","movieName":"Orły republiki","speakingType":"Napisy","printType":"2D","screenId":"58b8989d-a885-4279-8d78-90ecc0697586","movieSubPrintLabel":"PS"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":1,"symbol":"KINO KONESERA","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"394c674b-a795-4c2a-9757-b904c4e1f794","duration":105,"description":"Mira to pogodna 12-latka. Uwielbia tworzyć małe dzieła sztuki z plastiku z recyklingu i spędzać czas z dwójką swych przyjaciół. Wszystko się zmienia, gdy w jej klasie pojawia się nowa, popularna dziewczyna. Przed Mirą trudne dylematy - czy powinna porzucić plany własnej wystawy sztuki i tak jak inne dziewczyny rozmawiać tylko o zakochiwaniu się?","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"6bcd8fba-fbc2-466a-9f37-ce7a42443c2e","name":"familijny","description":""}],"trailers":[],"posters":["\\\\172.20.202.64\\movies\\images\\miraplakat.jpg"],"pictures":[],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"9","value":"9","description":"od lat 9"}],"brightcoveVideos":[],"release":"2D/DUB","name":"Mira - KNT","link":null,"screeningId":"cf3f837a-97d3-40ba-9821-b6836348dccc","screenId":"60f76479-27a9-4c7f-9351-bb74c8c25aa3","cinemaId":"d01162e6-31a4-41b9-97cd-1ef7707522fe","timeFrom":"2026-06-10T09:30:00+02:00","timeTo":"2026-06-10T11:15:00+02:00","saleTimeTo":"2026-06-10T10:00:00+02:00","reservationTimeTo":"2026-06-10T08:30:00+02:00","availabilityStatus":1,"maxOccupancy":209,"audience":52,"generalAdmission":false,"isScreenSwapping":false,"externalId":74412356,"items":[{"movieId":"1f919af2-f4f8-423b-a737-7cd0d6f36638","moviePrintId":"c02eb697-afa2-41f6-9110-2a4611726d8c","timeFrom":"2026-06-10T09:30:00+02:00","timeTo":"2026-06-10T11:15:00+02:00","movieName":"Mira","speakingType":"DUB","printType":"2D","screenId":"60f76479-27a9-4c7f-9351-bb74c8c25aa3","movieSubPrintLabel":"ps"}],"tagGroups":[{"symbol":"Projekty Specjalne","description":"","tags":[{"orderNo":7,"symbol":"KINO NA TEMAT","description":""}]}],"restrictedToCardTypeIds":[],"screenFeatures":[]},{"id":"d7bb09f1-a1ea-4982-915d-db91d91397cc","duration":176,"description":"Nigdy nie jest za późno, by zacząć od nowa. Emanujący optymizmem i pogodą ducha portret dojrzałej kobiety, która robi wszystko, by ocalić swój dom i siebie.\n\n María Ángeles od 40 lat mieszka w słonecznym apartamencie w marokańskim Tangerze. Gdy zostaje zmuszona do jego opuszczenia, nie potrafi się z tym pogodzić. To, co początkowo wydaje się bolesną koniecznością, nieoczekiwanie staje się jednak nowym początkiem. W życiu Marii Ángeles pojawia się miejsce zarówno na nowych przyjaciół, jak i na niespodziewaną miłość. „Drugie życie” to zdobywca nagrody publiczności festiwalu w Wenecji. W roli głównej zachwycająca Carmen Maura, ikona filmów Almodóvara.","ageLongDescription":null,"releaseDate":null,"distributor":null,"distributorId":null,"genres":[{"id":"4a3d74ad-af64-4a6a-a640-e75c762899c8","name":"romans","description":""},{"id":"14c7bb44-6562-4ad9-8d7a-ab747fa73829","name":"dramat","description":""}],"trailers":["https://www.youtube.com/embed/8xyTxjwUwfQ"],"posters":["https://movies.helios.pl/images/drugiezycieplakat.jpg"],"pictures":["https://movies.helios.pl/images/Drugiezycie7.jpg","https://movies.helios.pl/images/Drugiezycie6.jpg","https://movies.helios.pl/images/Drugiezycie5.jpg","https://movies.helios.pl/images/Drugiezycie4.jpg","https://movies.helios.pl/images/Drugiezycie3.jpg","https://movies.helios.pl/images/Drugiezycie2.jpg","https://movies.helios.pl/images/Drugiezycie1.jpg"],"posPosters":[],"banners":[],"ratings":[{"cinemaGroupId":null,"symbol":"15","value":"15","description":"od lat 15"}],"brightcoveVideos":[],"release":"2D/NAP","name":"Drugie życie - Kino Kobiet","link":null,"screeningId":"815a0d1c-24d5-4470-b302-75dbfad3ce0d","screenId":"3b622942-505b-4802-a341-d2c2f791b373","cinemaId":"d01162e6-31a4-41b9-97cd-1ef7707522fe","timeFrom":"2026-06-10T18:00:00+02:00","timeTo":"2026-06-10T20:56:00+02:00","sale