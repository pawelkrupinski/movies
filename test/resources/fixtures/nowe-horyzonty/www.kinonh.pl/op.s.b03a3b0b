            <span class='labe angielskienapisy wersja' data-etykieta='angielskie napisy'></span><a id='ev_189215' href='bilet.s?eventId=189215&forwardback=https%3A%2F%2Fwww.kinonh.pl%2Fop.s%3Fid%3D22151'  title='kup / rezerwuj bilet' class='xseans'>19:00</a></div>
            
