<p><span style="font-family: 'comic sans ms', sans-serif; font-size: medium;"><strong><strong><strong><strong><strong><strong><strong><strong><img src="images/czyt%20lol.jpg" border="0" width="500" /></strong></strong></strong></strong></strong></strong></strong></strong></span></p>
