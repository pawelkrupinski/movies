		   var COOKIE_NAME ='baranki_cookie';

	    function setCookie(){
    	    document.cookie=COOKIE_NAME + "=1";
	    }
	    function checkCookie(){
    	    var value = document.cookie;
	        return value.substr(value.indexOf(COOKIE_NAME)+COOKIE_NAME.length+1,1);
	    }
	    function cookieOK(){
	        setCookie();
	        jQuery('#cookieBox').css({
	            'display':'none'
	        });
	    }
    	function showInfo(){
        	jQuery('body').append('<div id="cookieBox">' +
            	                    'Ta strona używa mechanizmu ciasteczek. Kontynuując korzystanie ze strony zgadzasz na jego działanie.' +
                	                ' <button onclick="cookieOK();" tabindex="1" id="cookieOK">OK</button><div>');

	        jQuery('#cookieBox').css({
    	        'position':'absolute','right':'10px','float':'right','border-radius':'5px',
        	    'top':'5px','z-index':'1000','padding':'5px','text-align':'right','font-size':'12px',
            	'font-family':'Arial, serif','background':'#efefef','color':'#333'});
	        jQuery('#cookieOK').css({
    	        'border':'0px','border-radius':'5px',
           	 'background':'#333333','color':'#ffffff','cursor':'pointer',
        	    'font-weight':'bold','margin':'0 20px','padding':'4px 12px'
	        });
    	}
