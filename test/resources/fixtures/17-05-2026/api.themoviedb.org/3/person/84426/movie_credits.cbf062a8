{"cast":[{"adult":false,"backdrop_path":"/rRzGhzcN6Q8iBvmxKo4qfLTgkMH.jpg","genre_ids":[18,35],"id":269148,"title":"Samba","original_language":"fr","original_title":"Samba","overview":"Samba i Alice pochodzą z dwóch różnych światów. On pracuje na zmywaku w paryskim hotelu, ona jest woluntariuszką, która po latach pracy w korporacji postanowiła przewartościować swoje życie i pomagać ludziom. Gdy wskutek biurokratycznej pomyłki Samba trafia do aresztu, jego sen o lepszym życiu pryska, a co więcej grozi mu przymusowa deportacja z Francji. Alice postanawia mu pomóc za wszelką cenę, ale żeby to zrobić będzie musiała nie tylko przekroczyć granice prawa, ale też odpowiedzieć sobie na pytanie, gdzie przebiega granica między zaangażowaniem i poczuciem misji, a głębokim uczuciem…","popularity":1.4722,"poster_path":"/4dufPFWMsnjnV8zDg40w7Z8zz4p.jpg","release_date":"2014-10-15","softcore":false,"video":false,"vote_average":6.351,"vote_count":988,"character":"The Pony Club Host (uncredited)","credit_id":"62914cd8cf62cd009d74d86b","order":40},{"adult":false,"backdrop_path":"/beFtfWWbYy7dxMAaUQMe6TSa8ln.jpg","genre_ids":[99],"id":564055,"title":"Omar Sy, c'est ta chance","original_language":"fr","original_title":"Omar Sy, c'est ta chance","overview":"","popularity":0.1955,"poster_path":"/8FabNqgsVaIVUdCtL9OqNWaBfUO.jpg","release_date":"2018-11-21","softcore":false,"video":false,"vote_average":6.0,"vote_count":5,"character":"Self","credit_id":"62e476031bf266005a5fdcf3","order":30},{"adult":false,"backdrop_path":"/jSDvgaNwJFtdgvy6RKVw0oIwzdG.jpg","genre_ids":[99],"id":1192531,"title":"Nakache & Toledano, le cinéma hors normes","original_language":"fr","original_title":"Nakache & Toledano, le cinéma hors normes","overview":"","popularity":0.0658,"poster_path":"/iAXI4skGKibq0cm75BDp67nyfIl.jpg","release_date":"2023-10-17","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"character":"Self - Director","credit_id":"659df9a87776f0025f08ca27","order":2},{"adult":false,"back