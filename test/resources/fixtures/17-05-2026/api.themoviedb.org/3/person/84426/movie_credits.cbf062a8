_date":"2023-12-28","softcore":false,"video":false,"vote_average":7.0,"vote_count":2,"credit_id":"65914e2c4f9a99738e7784bc","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/zhceTJ7NOzgtTRkvmD5bumw74Lj.jpg","genre_ids":[35,10751],"id":19100,"title":"Nos jours heureux","original_language":"fr","original_title":"Nos jours heureux","overview":"","popularity":1.1067,"poster_path":"/507mUw7mtYpmjwJncOggw9gBZcG.jpg","release_date":"2006-06-28","softcore":false,"video":false,"vote_average":7.35,"vote_count":1108,"credit_id":"5746fe6ec3a3684ffc001178","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":"/cEtdt05J72tt5GgRgFAlpgznFMz.jpg","genre_ids":[18,10751,10749],"id":369925,"title":"ఊపిరి","original_language":"te","original_title":"ఊపిరి","overview":"","popularity":0.8065,"poster_path":"/iXsJEdk1P3V2cm2TSRBuG8ZS1pz.jpg","release_date":"2016-03-25","softcore":false,"video":false,"vote_average":7.1,"vote_count":51,"credit_id":"57c69d9cc3a36832d30009c9","department":"Writing","job":"Original Story"},{"adult":false,"backdrop_path":"/5J6EwgPVQOZy6khKrfuZuThqDG8.jpg","genre_ids":[35],"id":847574,"title":"Il giorno più bello","original_language":"it","original_title":"Il giorno più bello","overview":"","popularity":0.2418,"poster_path":"/zr24BSjneXn49aYNOC6CRs5MpFe.jpg","release_date":"2022-06-01","softcore":false,"video":false,"vote_average":5.2,"vote_count":58,"credit_id":"63d0676eb7a154059369652b","department":"Writing","job":"Original Film Writer"},{"adult":false,"backdrop_path":"/10ECHyeW7vZMjCLSRLak9K5fVdB.jpg","genre_ids":[35],"id":432068,"title":"Nasze najlepsze wesele","original_language":"fr","original_title":"Le Sens de la fête","overview":"Max jest właścicielem uznanej firmy weselnej. Przez 30 lat zaplanował i zorganizował setki imprez, ale po drodze utracił cały zapał do pracy. Na wewnętrzne dylematy nie ma jednak czasu, bo oto nadchodzi wielki dzień Pierre’a i Heleny. Para zakochanych postanawia wziąć ślub w romantycznych wnętrzach XVII-wiecznego zamku. Zatem Max, jak przystało na profesjonalistę, bierze się do działania. Rekrutuje kelnerów, kucharzy i pomywaczki. Poleca fotografa, zatrudnia zespół muzyczny, a nawet osobiście zajmuje się aranżacją kwiatów. Jednym słowem robi wszystko, by wielka impreza odniosła równie wielki sukces. Niestety, seria nieprzewidzianych zdarzeń wywraca misterny plan do góry nogami, a wesele marzeń z godziny na godzinę zamienia się w katastrofę stulecia. Czy Max i jego ludzie zdołają opanować sytuację, zanim będzie za późno?","popularity":2.1078,"poster_path":"/wkRmhK90QQCRG2UqckjGyttf5Pk.jpg","release_date":"2017-10-04","softcore":false,"video":false,"vote_average":7.017,"vote_count":1596,"credit_id":"58641b8cc3a36852ba011609","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/10ECHyeW7vZMjCLSRLak9K5fVdB.jpg","genre_ids":[35],"id":432068,"title":"Nasze najlepsze wesele","original_language":"fr","original_title":"Le Sens de la fête","overview":"Max jest właścicielem uznanej firmy weselnej. Przez 30 lat zaplanował i zorganizował setki imprez, ale po drodze utracił cały zapał do pracy. Na wewnętrzne dylematy nie ma jednak czasu, bo oto nadchodzi wielki dzień Pierre’a i Heleny. Para zakochanych postanawia wziąć ślub w romantycznych wnętrzach XVII-wiecznego zamku. Zatem Max, jak przystało na profesjonalistę, bierze się do działania. Rekrutuje kelnerów, kucharzy i pomywaczki. Poleca fotografa, zatrudnia zespół muzyczny, a nawet osobiście zajmuje się aranżacją kwiatów. Jednym słowem robi wszystko, by wielka impreza odniosła równie wielki sukces. Niestety, seria nieprzewidzianych zdarzeń wywraca misterny plan do góry nogami, a wesele marzeń z godziny na godzinę zamienia się w katastrofę stulecia. Czy Max i jego ludzie zdołają opanować sytuację, zanim będzie za późno?","popularity":2.1078,"poster_path":"/wkRmhK90QQCRG2UqckjGyttf5Pk.jpg","release_date":"2017-10-04","softcore":false,"video":false,"vote_average":7.017,"vote_count":1596,"credit_id":"5a7b7eb1c3a3680f9c002f82","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":null,"genre_ids":[35,18],"id":1308960,"title":"المنبوذين","original_language":"ar","original_title":"المنبوذين","overview":"","popularity":0.1713,"poster_path":null,"release_date":"","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"667b151599f8a823efe45db6","department":"Writing","job":"Original Film Writer"},{"adult":false,"backdrop_path":"/5nm7nqTYl6TvCzBblyiiZrFFUPP.jpg","genre_ids":[18],"id":1156116,"title":"Nasz świat","original_language":"sq","original_title":"Bota jonë","overview":"Kosowo, 2007. Zoé (Elsa Mala) i Volta (Albina Krasniqi) opuszczają swoją wioskę, aby studiować na uniwersytecie w Prisztinie. W środku niepokojów społecznych i politycznych obie kobiety odkrywają kraj pogrążony w zamęcie, szukając swojej tożsamości na krawędzi niepodległości.","popularity":0.3,"poster_path":"/sjpcMhV11Dv3dvj0Cv2LkkFxGGh.jpg","release_date":"2024-04-24","softcore":false,"video":false,"vote_average":7.4,"vote_count":11,"credit_id":"64bf9ea501757f00c5ade465","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/580aO5umsOX5FAFmD6ObYvVuk6p.jpg","genre_ids":[35,18],"id":579245,"title":"Nadzwyczajni","original_language":"fr","original_title":"Hors Normes","overview":"Żyd Bruno od lat prowadzi ośrodek dla ludzi z autyzmem. Pomaga mu muzułmanin Malik. Mężczyźni każdego dnia konfrontują się z przeciwnościami, niosąc pomoc osobom, które funkcjonują na marginesie społeczeństwa. Starają się realizować szlachetną misję wbrew trudnościom.","popularity":1.1362,"poster_path":"/ydrStnS02wRKY689JuKh8PuFrwx.jpg","release_date":"2019-10-23","softcore":false,"video":false,"vote_average":7.78,"vote_count":982,"credit_id":"5c83aa84c3a3684e89da5060","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/ct2I74zKDrK1Ts2jJa9WixJrigg.jpg","genre_ids":[35,18],"id":440472,"title":"Spragnieni życia","original_language":"en","original_title":"The Upside","overview":"Do opieki nad starszym zamożnym mężczyzną, poruszającym się na wózku, zostaje zatrudniony bezrobotny czarnoskóry z kryminalną kartoteką na koncie. Mimo ogromnych różnic między nimi, zaczynają się dobrze dogadywać, a w ich życiu niespodziewanie zaczyna się dziać wiele dobrego.","popularity":2.833,"poster_path":"/pO429TdHfBapAbMEdv7YXRM58vz.jpg","release_date":"2019-01-10","softcore":false,"video":false,"vote_average":7.137,"vote_count":1397,"credit_id":"5ccfb3e09251417cce2af507","department":"Writing","job":"Original Film Writer"},{"adult":false,"backdrop_path":"/580aO5umsOX5FAFmD6ObYvVuk6p.jpg","genre_ids":[35,18],"id":579245,"title":"Nadzwyczajni","original_language":"fr","original_title":"Hors Normes","overview":"Żyd Bruno od lat prowadzi ośrodek dla ludzi z autyzmem. Pomaga mu muzułmanin Malik. Mężczyźni każdego dnia konfrontują się z przeciwnościami, niosąc pomoc osobom, które funkcjonują na marginesie społeczeństwa. Starają się realizować szlachetną misję wbrew trudnościom.","popularity":1.1362,"poster_path":"/ydrStnS02wRKY689JuKh8PuFrwx.jpg","release_date":"2019-10-23","softcore":false,"video":false,"vote_average":7.78,"vote_count":982,"credit_id":"5cd00c7dc3a36836c1e229ef","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":"/scK2UEHgr8m9sy66UJthsJGPzR1.jpg","genre_ids":[35],"id":625652,"title":"Ces jours heureux","original_language":"fr","original_title":"Ces jours heureux","overview":"","popularity":0.2235,"poster_path":"/pmHQno0bPrSkZdoQIm71oaOcmrT.jpg","release_date":"2002-06-01","softcore":false,"video":false,"vote_average":6.5,"vote_count":3,"credit_id":"5d61358b6dea3a001293ef7a","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":null,"genre_ids":[],"id":653079,"title":"Le Bon vivant","original_language":"en","original_title":"Le Bon vivant","overview":"","popularity":0.0412,"poster_path":null,"release_date":"","softcore":false,"video":false,"vote_average":0.0,