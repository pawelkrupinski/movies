rop_path":null,"genre_ids":[],"id":751833,"title":"Seltsame Unruhe","original_language":"de","original_title":"Seltsame Unruhe","overview":"","popularity":0.0,"poster_path":null,"release_date":"1997-01-01","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"5f818303ae6f090036316b60","department":"Camera","job":"Director of Photography"},{"adult":false,"backdrop_path":null,"genre_ids":[],"id":751833,"title":"Seltsame Unruhe","original_language":"de","original_title":"Seltsame Unruhe","overview":"","popularity":0.0,"poster_path":null,"release_date":"1997-01-01","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"5f8183762f3b170036fb1177","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/vvVOYKZsY41hWmRBEhKv3HuMeHG.jpg","genre_ids":[99],"id":769599,"title":"Rettet das Dorf","original_language":"de","original_title":"Rettet das Dorf","overview":"","popularity":0.048,"poster_path":"/hh3ibEi3qEz4JV1kgdooC4IvNRh.jpg","release_date":"2020-02-28","softcore":false,"video":false,"vote_average":6.4,"vote_count":5,"credit_id":"5fc2a1ac894ed60041fd222f","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/6vRV8t5yrfKNSJcmEzrNO1fWEFJ.jpg","genre_ids":[18,53,80],"id":54524,"title":"Biegacz","original_language":"de","original_title":"Der Räuber","overview":"Autentyczna opowieść o Johannie Rettenbergeru, maratończyku, który zawodowo zajmuje się napadami na banki. Razem ze swoją dziewczyną prowadzi zwyczajne życie w Wiedniu, a w międzyczasie rabuje banki na terenie całej Austrii. Do dalszych działań motywuje go to, jak po każdej kradzieży adrenalina wpływa na jego ciało. Gdy władzom udaje się namierzyć rabusia, wykorzystuje on swoje zdolności i rozpoczyna ucieczkę przed największą w powojennej Austrii obławą policji.","popularity":0.2944,"poster_path":"/wxJ579nYUXzy9WeI13hIPld8tDs.jpg","release_date":"2010-02-26","softcore":false,"video":false,"vote_average":6.5,"vote_count":97,"credit_id":"6010ee0046f3540041b6714e","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/lOdsi3Vc2bcHBZSjosVtds49TgS.jpg","genre_ids":[99],"id":331414,"title":"Rok po Dayton","original_language":"de","original_title":"Das Jahr nach Dayton","overview":"","popularity":0.0322,"poster_path":"/6sXbiy3VSEnxLfPRfI4SDFtEPS6.jpg","release_date":"1997-08-30","softcore":false,"video":false,"vote_average":7.4,"vote_count":5,"credit_id":"6010ef02d55c3d003e78cc4c","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":"/bSqoQB0KFH8Jd3GOaIO7EtKf804.jpg","genre_ids":[99],"id":125531,"title":"Prypeć","original_language":"ru","original_title":"Pripyat","overview":"","popularity":0.0322,"poster_path":"/yWUggVeLmMonCXsFZsXMIZ0kKQj.jpg","release_date":"1999-09-11","softcore":false,"video":false,"vote_average":7.1,"vote_count":10,"credit_id":"6010ef23b5bc21003e964ced","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":"/banzsoiVGHIKfTS3WWWvRPF8YOq.jpg","genre_ids":[99,10770],"id":688579,"title":"Senad und Edis - Es war einmal der Krieg","original_language":"de","original_title":"Senad und Edis - Es war einmal der Krieg","overview":"","popularity":0.0143,"poster_path":null,"release_date":"2003-01-19","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"6010ef4a0e597b004135b9ba","department":"Camera","job":"Director of Photography"},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":343815,"title":"Kisangani Diary","original_language":"en","original_title":"Kisangani Diary","overview":"","popularity":0.1363,"poster_path":"/7TqVAOU8vqCtzr6NbiqahtVR9wf.jpg","release_date":"1998-02-20","softcore":false,"video":false,"vote_average":8.333,"vote_count":3,"credit_id":"601916d0976a23003ea736ae","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":null,"genre_ids":[],"id":792813,"title":"Michelle","original_language":"de","original_title":"Michelle","overview":"","popularity":0.0327,"poster_path":null,"release_date":"1994-01-01","softcore":false,"video":false,"vote_average":9.0,"vote_count":1,"credit_id":"601957cab97442003e234c28","department":"Camera","job":"Camera Operator"},{"adult":false,"backdrop_path":"/dORZgctjWqZJJSuaoUgCO2YVmcw.jpg","genre_ids":[99],"id":576094,"title":"Ziemia","original_language":"de","original_title":"Erde","overview":"Ludzie codziennie przemieszczają 156 milionów ton skał i ziemi, co powoduje, że staliśmy się dziś najbardziej znaczącym czynnikiem geologicznym naszych czasów. Wydobywając zawartość Ziemi, wydrążamy całe jej obszary, spłaszczamy i przesuwamy góry, na nowo kształtując otaczającą nas rzeczywistość. Film przedstawia ten proces, obrazując zakres niekontrolowanych zmian, jakich dokonujemy. Film zainspirowany jest koncepcją antropocenu, która zakłada, że ludzie dziś fizycznie wpływają i kształtują naszą planetę bardziej niż sama przyroda. Reżyser bada gigantyczny wpływ człowieka na naszą planetę. \"Ziemia\" to bez wątpienia jeden z najbardziej przejmujących i epickich filmów dokumentalnych ostatnich lat na temat środowiska.","popularity":0.1191,"poster_path":"/q1bhc5QJ5EyQMjBTzg1rNZXGLKl.jpg","release_date":"2019-05-17","softcore":false,"video":false,"vote_average":6.3,"vote_count":3,"credit_id":"673cbff93b480481cdddde77","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":"/8wt2qyeon5kPXZNmKOVV36OOIMe.jpg","genre_ids":[99],"id":382212,"title":"Homo Sapiens","original_language":"de","original_title":"Homo Sapiens","overview":"Co pozostanie z naszej cywilizacji, gdy w końcu wyginiemy? Puste przestrzenie, opuszczone budynki, sklepy, kina, szpitale, biura, szkoły, biblioteki, parki rozrywki i więzienia. Ruiny miast, które coraz bardziej porastać będzie roślinność. Przestrzeń, w której mieszkamy, po naszej zagładzie ponownie przejmie natura, z której kiedyś brutalnie ją wyrwaliśmy. Film, kręcony przez 4 lata w Europie, USA, Japonii i Argentynie, jest krytycznym portretem naszej cywilizacji. Zbudowany wyłącznie z precyzyjnie skomponowanych, statycznych ujęć, pozbawionych jakiegokolwiek komentarza. Przyglądamy się życiu ludzi na Ziemi, ich stosunkowi do zwierząt, drugiego człowieka, wojen. Brak tu obrazów przestrzeni prywatnych. Oglądamy wyłącznie miejsca publiczne. Widzimy miejsca opuszczone, zapomniane, odzyskane przez naturę i zwierzęta. Film jest głębokim spojrzeniem na wpływ, jaki ludzkość wywarła na Ziemię, próbą przewidzenia przyszłości, jaka nas czeka i oceną roli człowieka w dobie kryzysu ekologicznego.","popularity":0.2091,"poster_path":"/9yfmw5rZYPQVU1XJ4YcyFVhjxkB.jpg","release_date":"2016-07-29","softcore":false,"video":false,"vote_average":7.1,"vote_count":33,"credit_id":"673cebb9e772ccc1564545ca","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":"/tJxNTC21ScOLwBO7WcihvVKDzgt.jpg","genre_ids":[99],"id":1559209,"title":"Melt","original_language":"de","original_title":"Melt","overview":"","popularity":0.5823,"poster_path":"/8nlXvk4MI9xs9tXk14jJyUL4vGu.jpg","release_date":"2025-11-21","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"68e6781a8495400980f85216","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/tJxNTC21ScOLwBO7WcihvVKDzgt.jpg","genre_ids":[99],"id":1559209,"title":"Melt","original_language":"de","original_title":"Melt","overview":"","popularity":0.5823,"poster_path":"/8nlXvk4MI9xs9tXk14jJyUL4vGu.jpg","release_date":"2025-11-21","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"68e67831e81e2e33431eb3b1","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/tJxNTC21ScOLwBO7WcihvVKDzgt.jpg","genre_ids":[99],"id":1559209,"title":"Melt","original_language":"de","original_title":"Melt","overview":"","popularity":0.5823,"poster_path":"/8nlXvk4MI9xs9tXk14jJyUL4vGu.jpg","release_date":"2025-11-21","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"68e6783e5b4b257a5fa99686","department":"Crew","job":