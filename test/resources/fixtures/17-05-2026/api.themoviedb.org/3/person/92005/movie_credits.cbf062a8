vote_average":7.1,"vote_count":10,"credit_id":"58e3181bc3a3684a79008aad","department":"Camera","job":"Director of Photography"},{"adult":false,"backdrop_path":"/bSqoQB0KFH8Jd3GOaIO7EtKf804.jpg","genre_ids":[99],"id":125531,"title":"Prypeć","original_language":"ru","original_title":"Pripyat","overview":"","popularity":0.0322,"poster_path":"/yWUggVeLmMonCXsFZsXMIZ0kKQj.jpg","release_date":"1999-09-11","softcore":false,"video":false,"vote_average":7.1,"vote_count":10,"credit_id":"58e31822c3a3684a79008ab2","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":1076964,"title":"Lass mich fliegen","original_language":"de","original_title":"Lass mich fliegen","overview":"","popularity":0.0478,"poster_path":"/5txLCZx4gCBdXTKhdJlrdBun30.jpg","release_date":"2022-08-01","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"640ef18cede1b0007b4e1b79","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/di9M6ncpVNoaYJtPO6VsGNKDn8y.jpg","genre_ids":[35,10749],"id":1240422,"title":"What a Feeling","original_language":"de","original_title":"What a Feeling","overview":"Austria. Lekarka Marie Theres Wallner (Caroline Peters) ma 52 lata i od dwóch dekad jest żoną Alexandra (Heikko Deutschmann), z którym wychowuje nastoletnią Annę (Allegra Tinnefeld). Jej udane dotąd życie rozpada się, gdy mąż nagle ją opuszcza. Zrozpaczona idzie do baru, w którym poznaje pewną siebie, niezależną imigrantkę z Iranu, Fa Safir (Proschat Madani), która wraz z rodzeństwem prowadzi firmę stolarską. Choć kobiety bardzo się od siebie różnią, coś ciągnie je do siebie. Jeśli chcą być szczęśliwe, muszą uwolnić się od wielu ograniczeń.","popularity":0.3971,"poster_path":"/7eCwW8438cBtiPCYoD8ujERa2Mo.jpg","release_date":"2024-04-19","softcore":false,"video":false,"vote_average":6.8,"vote_count":6,"credit_id":"662fcaf9c56d2d0123cd365d","department":"Production","job":"Co-Producer"},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":1109093,"title":"Eines Tages, nachts...","original_language":"de","original_title":"Eines Tages, nachts...","overview":"","popularity":0.083,"poster_path":null,"release_date":"2008-03-14","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"642d207d0d2f5300b6cb8d7d","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":433035,"title":"Die Königin von Wien - Anna Sacher und ihr Hotel","original_language":"de","original_title":"Die Königin von Wien - Anna Sacher und ihr Hotel","overview":"","popularity":0.0538,"poster_path":"/jU4IQAO4dVwr0bIhRnkZrPxaPUF.jpg","release_date":"2016-12-25","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"5a55e15c0e0a2607e0020e54","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/pGzSfjkXK46QAOv9aztADqO0ftW.jpg","genre_ids":[99],"id":512029,"title":"Die bauliche Maßnahme","original_language":"de","original_title":"Die bauliche Maßnahme","overview":"","popularity":0.0071,"poster_path":"/bIMMVHfU4eRiqR2TipxFF7dKORM.jpg","release_date":"2018-09-07","softcore":false,"video":false,"vote_average":6.5,"vote_count":4,"credit_id":"5aab1976c3a3686c110079f3","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/pGzSfjkXK46QAOv9aztADqO0ftW.jpg","genre_ids":[99],"id":512029,"title":"Die bauliche Maßnahme","original_language":"de","original_title":"Die bauliche Maßnahme","overview":"","popularity":0.0071,"poster_path":"/bIMMVHfU4eRiqR2TipxFF7dKORM.jpg","release_date":"2018-09-07","softcore":false,"video":false,"vote_average":6.5,"vote_count":4,"credit_id":"5be120d40e0a263d7100412f","department":"Camera","job":"Director of Photography"},{"adult":false,"backdrop_path":"/dORZgctjWqZJJSuaoUgCO2YVmcw.jpg","genre_ids":[99],"id":576094,"title":"Ziemia","original_language":"de","original_title":"Erde","overview":"Ludzie codziennie przemieszczają 156 milionów ton skał i ziemi, co powoduje, że staliśmy się dziś najbardziej znaczącym czynnikiem geologicznym naszych czasów. Wydobywając zawartość Ziemi, wydrążamy całe jej obszary, spłaszczamy i przesuwamy góry, na nowo kształtując otaczającą nas rzeczywistość. Film przedstawia ten proces, obrazując zakres niekontrolowanych zmian, jakich dokonujemy. Film zainspirowany jest koncepcją antropocenu, która zakłada, że ludzie dziś fizycznie wpływają i kształtują naszą planetę bardziej niż sama przyroda. Reżyser bada gigantyczny wpływ człowieka na naszą planetę. \"Ziemia\" to bez wątpienia jeden z najbardziej przejmujących i epickich filmów dokumentalnych ostatnich lat na temat środowiska.","popularity":0.1191,"poster_path":"/q1bhc5QJ5EyQMjBTzg1rNZXGLKl.jpg","release_date":"2019-05-17","softcore":false,"video":false,"vote_average":6.3,"vote_count":3,"credit_id":"5c41f9ea0e0a2655c4949de9","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/dORZgctjWqZJJSuaoUgCO2YVmcw.jpg","genre_ids":[99],"id":576094,"title":"Ziemia","original_language":"de","original_title":"Erde","overview":"Ludzie codziennie przemieszczają 156 milionów ton skał i ziemi, co powoduje, że staliśmy się dziś najbardziej znaczącym czynnikiem geologicznym naszych czasów. Wydobywając zawartość Ziemi, wydrążamy całe jej obszary, spłaszczamy i przesuwamy góry, na nowo kształtując otaczającą nas rzeczywistość. Film przedstawia ten proces, obrazując zakres niekontrolowanych zmian, jakich dokonujemy. Film zainspirowany jest koncepcją antropocenu, która zakłada, że ludzie dziś fizycznie wpływają i kształtują naszą planetę bardziej niż sama przyroda. Reżyser bada gigantyczny wpływ człowieka na naszą planetę. \"Ziemia\" to bez wątpienia jeden z najbardziej przejmujących i epickich filmów dokumentalnych ostatnich lat na temat środowiska.","popularity":0.1191,"poster_path":"/q1bhc5QJ5EyQMjBTzg1rNZXGLKl.jpg","release_date":"2019-05-17","softcore":false,"video":false,"vote_average":6.3,"vote_count":3,"credit_id":"5c41fae70e0a2646a293bc44","depart