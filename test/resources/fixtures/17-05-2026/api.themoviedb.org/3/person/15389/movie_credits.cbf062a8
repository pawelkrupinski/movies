gatego żydowskiego krawca.","popularity":0.6839,"poster_path":"/6UEsBovuiDfJFloCnk0mmHL9f6c.jpg","release_date":"1974-01-30","softcore":false,"video":false,"vote_average":7.027,"vote_count":164,"credit_id":"52fe48c8c3a36847f8179393","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":"/ikO0koqdi0V7Z9CJXwwKf5tiTrs.jpg","genre_ids":[18,10752],"id":55368,"title":"Lacombe Lucien","original_language":"fr","original_title":"Lacombe Lucien","overview":"Małe miasteczko w południowo - zachodniej Francji, 1944 rok. Ojciec 18 - letniego Luciena Lacombe'a przebywa w niemieckim więzieniu, a jego matka spotyka się ze swoim pracodawcą. On sam, odrzucony przez ruch oporu, pracuje dla niemieckiej policji. Pewnego dnia poznaje France Horn - córkę bogatego żydowskiego krawca.","popularity":0.6839,"poster_path":"/6UEsBovuiDfJFloCnk0mmHL9f6c.jpg","release_date":"1974-01-30","softcore":false,"video":false,"vote_average":7.027,"vote_count":164,"credit_id":"52fe48c8c3a36847f817938d","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/jkOxEQ4iwjuuAoqUZ4F6uyyZuuE.jpg","genre_ids":[35,80,18,36],"id":55370,"title":"Życie Złodzieja","original_language":"fr","original_title":"Le Voleur","overview":"Rok 1890. 25-letni Georges Randal zostaje złodziejem. Wybiera tę drogę, ponieważ chce się zemścić na wuju, który wychowywał go po śmierci rodziców i ograbił z należnego majątku. Ma również żal do Charlotte, którą pragnął poślubić, a która wybrała bogatszego konkurenta. W dniu zaręczyn Georges okrada rodzinę przyszłego męża dziewczyny...\r Z czasem okazuje się, że nie różni się niczym od swych ofiar. Wspaniały obraz Paryża epoki fin de siecle.","popularity":0.4634,"poster_path":"/j9FUFzxYohCvJZkGpVsN2KhSbRy.jpg","release_date":"1967-02-22","softcore":false,"video":false,"vote_average":6.712,"vote_count":85,"credit_id":"52fe48c8c3a36847f81793d9","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/jkOxEQ4iwjuuAoqUZ4F6uyyZuuE.jpg","genre_ids":[35,80,18,36],"id":55370,"title":"Życie Złodzieja","original_language":"fr","original_title":"Le Voleur","overview":"Rok 1890. 25-letni Georges Randal zostaje złodziejem. Wybiera tę drogę, ponieważ chce się zemścić na wuju, który wychowywał go po śmierci rodziców i ograbił z należnego majątku. Ma również żal do Charlotte, którą pragnął poślubić, a która wybrała bogatszego konkurenta. W dniu zaręczyn Georges okrada rodzinę przyszłego męża dziewczyny...\r Z czasem okazuje się, że nie różni się niczym od swych ofiar. Wspaniały obraz Paryża epoki fin de siecle.","popularity":0.4634,"poster_path":"/j9FUFzxYohCvJZkGpVsN2KhSbRy.jpg","release_date":"1967-02-22","softcore":false,"video":false,"vote_average":6.712,"vote_count":85,"credit_id":"52fe48c8c3a36847f81793eb","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":837105,"title":"La Fontaine-de-Vaucluse","original_language":"fr","original_title":"La Fontaine-de-Vaucluse","overview":"","popularity":0.1086,"poster_path":null,"release_date":"1955-01-01","softcore":false,"video":false,"vote_average":0.0,"vote_count":0,"credit_id":"60baf11c8d2f8d00415495bc","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":837113,"title":"Bons baisers de Bangkok","original_language":"fr","original_title":"Bons baisers de Bangkok","overview":"","popularity":0.0357,"poster_path":"/edSEK7di2YpK4K6xuFORqaCyNOT.jpg","release_date":"1964-01-01","softcore":false,"video":false,"vote_average":7.0,"vote_count":1,"credit_id":"60baf883c8f8580058b20429","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/dKA6LX3W1MkXyJBnqq2dMAyIetZ.jpg","genre_ids":[28,35,80],"id":87235,"title":"Świry","original_language":"en","original_title":"Crackers","overview":"Weslake i jego koledzy to grupa życiowych wykolejeńców i nieudaczników. Ponieważ nie chce im się pracować, by zdobyć środki do życia Weslake postanawia okraść sklep Garveya, gdy ten będzie odwiedzać rodzinę. Weslake układa, jak mu się wydaje, absolutnie niezawodny plan “akcji”. Gdy jednak wraz z kumplami wciela go w życie, okazuje się, że plan był, delikatnie mówiąc, cokolwiek niedopracowany.","popularity":0.7672,"poster_path":"/AkfLpER2b9gAtOH49z6KnvbxzuI.jpg","release_date":"1984-02-17","softcore":false,"video":false,"vote_average":4.676,"vote_count":34,"credit_id":"52fe49ba9251416c910b6dc7","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/50ysROkN7Eu5e1yhxhwyztokkjx.jpg","genre_ids":[99,10770],"id":79179,"title":"God's Country","original_language":"en","original_title":"God's Country","overview":"","popularity":0.4423,"poster_path":"/lsJLMACGOqFnE1TVZ2ilYLrmXMz.jpg","release_date":"1985-11-27","softcore":false,"video":false,"vote_average":7.395,"vote_count":19,"credit_id":"52fe49c4c3a368484e13ec4b","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":112451,"title":"Humain, trop humain","original_language":"fr","original_title":"Humain, trop humain","overview":"","popularity":0.0739,"poster_path":"/hWYx3qttsgj70siRQ3eSnhPE8qB.jpg","release_date":"1974-04-03","softcore":false,"video":false,"vote_average":5.833,"vote_count":12,"credit_id":"52fe4b19c3a36847f81f2357","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":112630,"title":"Calcutta","original_language":"fr","original_title":"Calcutta","overview":"","popularity":0.2305,"poster_path":"/zt4W4TpyvorqtaTtgWHtpALoMP9.jpg","release_date":"1969-04-16","softcore":false,"video":false,"vote_average":6.714,"vote_count":14,"credit_id":"52fe4b1cc3a36847f81f2fc3","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":112630,"title":"Calcutta","original_language":"fr","original_title":"Calcutta","overview":"","popularity":0.2305,"poster_path":"/zt4W4TpyvorqtaTtgWHtpALoMP9.jpg","release_date":"1969-04-16","softcore":false,"video":false,"vot