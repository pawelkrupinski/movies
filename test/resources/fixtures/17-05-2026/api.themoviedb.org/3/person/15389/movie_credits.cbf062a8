original_language":"fr","original_title":"Crazeologie","overview":"","popularity":0.0168,"poster_path":"/h2L6hvYmWDLZ7RHs5iZu2zZJjaC.jpg","release_date":"1954-04-18","softcore":false,"video":false,"vote_average":5.1,"vote_count":10,"credit_id":"52fe4db1c3a368484e1f75c9","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/4ikyxnlMzsQpVXbMO9Fn3OuPK41.jpg","genre_ids":[53,9648],"id":226261,"title":"死刑台のエレベーター","original_language":"ja","original_title":"死刑台のエレベーター","overview":"","popularity":0.9567,"poster_path":"/wgEQtQPBjBWv4GUGzp1mod8uaja.jpg","release_date":"2010-10-09","softcore":false,"video":false,"vote_average":6.6,"vote_count":13,"credit_id":"52fe4e789251416c75157933","department":"Writing","job":"Original Story"},{"adult":false,"backdrop_path":"/dN2KJv7pNW4wS7vNh4f9WoI7Ijz.jpg","genre_ids":[99],"id":63893,"title":"Vive Le Tour","original_language":"fr","original_title":"Vive Le Tour","overview":"","popularity":0.1638,"poster_path":"/9A4gdpHBARq49QqyOXaZRncQ4Xs.jpg","release_date":"1962-10-01","softcore":false,"video":false,"vote_average":6.88,"vote_count":25,"credit_id":"5538b0339251413f5a00137d","department":"Camera","job":"Director of Photography"},{"adult":false,"backdrop_path":"/7CZRjhX7LIqljczO2GiX1R5a39m.jpg","genre_ids":[99,12],"id":60234,"title":"Le Monde du silence","original_language":"fr","original_title":"Le Monde du silence","overview":"","popularity":0.6317,"poster_path":"/x1V5crwN7uqhApqwTcyoTYwHq10.jpg","release_date":"1956-02-15","softcore":false,"video":false,"vote_average":6.511,"vote_count":47,"credit_id":"655d4e35629b2c013bb0849b","department":"Crew","job":"Cinematography"},{"adult":false,"backdrop_path":"/s8h41U0rqM0PP6qCas8qzBtxeen.jpg","genre_ids":[27,9648,18],"id":41225,"title":"Historie niesamowite","original_language":"fr","original_title":"Histoires extraordinaires","overview":"Film składa się z trzech części, z których każda jest ekranizacją jednego z opowiadań Edgara Allana Poe. W pierwszej nowelce hrabianka Fryderyka  stara się uwieść swego kuzyna Wilhelma . Ten jednak pozostaje obojętny na jej zaloty i każdą wolną chwilę poświęca swym koniom. Odrzucona kobieta z zemsty podpala jego stajnie. Niestety, mężczyzna ginie w pożarze podczas próby ratowania swego ukochanego zwierzęcia. Bohater drugiej opowieści, William Wilson , zawsze, gdy popełni niegodziwy czyn, spotyka swego sobowtóra. Wreszcie wyzywa go na pojedynek i zabija. W trzeciej historii angielski aktor Toby, alkoholik i narkoman, przyjeżdża do Rzymu, by wziąć udział w filmie. Nawiedzają go sny, w których dostrzega tajemniczą dziewczynkę z piłką. Niespodziewanie mężczyzna ginie w wypadku samochodowym. Świadkiem tragedii jest dziecko z jego wizji.","popularity":1.1078,"poster_path":"/9ZWK6zANBNGN643bOmcXYUb4dwX.jpg","release_date":"1968-05-16","softcore":false,"video":false,"vote_average":6.3,"vote_count":184,"credit_id":"61c0ada4699fb70060cc5e73","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":"/s8h41U0rqM0PP6qCas8qzBtxeen.jpg","genre_ids":[27,9648,18],"id":41225,"title":"Historie niesamowite","original_language":"fr","original_title":"Histoires extraordinaires","overview":"Film składa się z trzech części, z których każda jest ekranizacją jednego z opowiadań Edgara Allana Poe. W pierwszej nowelce hrabianka Fryderyka  stara się uwieść swego kuzyna Wilhelma . Ten jednak pozostaje obojętny na jej zaloty i każdą wolną chwilę poświęca swym koniom. Odrzucona kobieta z zemsty podpala jego stajnie. Niestety, mężczyzna ginie w pożarze podczas próby ratowania swego ukochanego zwierzęcia. Bohater drugiej opowieści, William Wilson , zawsze, gdy popełni niegodziwy czyn, spotyka swego sobowtóra. Wreszcie wyzywa go na pojedynek i zabija. W trzeciej historii angielski aktor Toby, alkoholik i narkoman, przyjeżdża do Rzymu, by wziąć udział w filmie. Nawiedzają go sny, w których dostrzega tajemniczą dziewczynkę z piłką. Niespodziewanie mężczyzna ginie w wypadku samochodowym. Świadkiem tragedii jest dziecko z jego wizji.","popularity":1.1078,"poster_path":"/9ZWK6zANBNGN643bOmcXYUb4dwX.jpg","release_date":"1968-05-16","softcore":false,"video":false,"vote_average":6.3,"vote_count":184,"credit_id":"61c0ad9dc4ad590068562149","department":"Writing","job":"Adaptation"},{"adult":false,"backdrop_path":"/d3u97tjDhvPJjeyYMTIEfodtk9j.jpg","genre_ids":[18,35],"id":42501,"title":"Szmery w sercu","original_language":"fr","original_title":"Le Souffle au cœur","overview":"\"Szmery w sercu\" to historia piętnastoletniego chłopca o imieniu Laurent Chevalier, który dorasta w burżuazyjnym otoczeniu w Dijon (Francja). Wszystko dzieje się w środkowych latach pięćdziesiątych. Laurent jest sprowadzony na złą drogę przez nowoczesnego młodzieńca z Ameryki: upija się, pali, uprawia sex (pierwszy raz przeżywa z prostytutką - za sprawą starszych braci). Jest pupilem mamy, ojciec go ignoruje, w końcu dostaje reumatoidalnej gorączki i wyjeżdża do sanatorium, tam dochodzi do pewnego zbliżenia...","popularity":2.3261,"poster_path":"/7JosnBDCu9fnJZlQ5Bw9u8cwQcE.jpg","release_date":"1971-04-27","softcore":false,"video":false,"vote_average":7.007,"vote_count":213,"credit_id":"570812d89251415bc50000fb","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":"/7CZRjhX7LIqljczO2GiX1R5a39m.jpg","genre_ids":[99,12],"id":60234,"title":"Le Monde du silence","original_language":"fr","original_title":"Le Monde du silence","overview":"","popularity":0.6317,"poster_path":"/x1V5crwN7uqhApqwTcyoTYwHq10.jpg","release_date":"1956-02-15","softcore":false,"video":false,"vote_average":6.511,"vote_count":47,"credit_id":"5823e77f9251411a3b002ae1","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/ikO0koqdi0V7Z9CJXwwKf5tiTrs.jpg","genre_ids":[18,10752],"id":55368,"title":"Lacombe Lucien","original_language":"fr","original_title":"Lacombe Lucien","overview":"Małe miasteczko w południowo - zachodniej Francji, 1944 rok. Ojciec 18 - letniego Luciena Lacombe'a przebywa w niemieckim więzieniu, a jego matka spotyka się ze swoim pracodawcą. On sam, odrzucony przez ruch oporu, pracuje dla niemieckiej policji. Pewnego dnia poznaje France Horn - córkę bogatego żydowskiego krawca.","popularity":0.6839,"poster_path":"/6UEsBovuiDfJFloCnk0mmHL9f6c.jpg","release_date":"1974-01-30","softcore":false,"video":false,"vote_average":7.027,"vote_count":164,"credit_id":"59672709c3a3680dec11858d","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/nVaaYlGszQafKEkhzY1UvhPKCdL.jpg","genre_ids":[18],"id":45694,"title":"Der junge Törless","original_language":"de","original_title":"Der junge Törless","overview":"","popularity":0.6075,"poster_path":"/vtWS4k7LzzTmNVnEq72DIt0tow3.jpg","release_date":"1966-05-20","softcore":false,"video":false,"vote_average":6.608,"vote_count":60,"credit_id":"597b04edc3a368375a00cfba","department":"Production","job":"Producer"},{"adult":false,"backdrop_path":"/7CZRjhX7LIqljczO2GiX1R5a39m.jpg","genre_ids":[99,12],"id":60234,"title":"Le Monde du silence","original_language":"fr","original_title":"Le Monde du silence","overview":"","popularity":0.6317,"poster_path":"/x1V5crwN7uqhApqwTcyoTYwHq10.jpg","release_date":"1956-02-15","softcore":false,"video":false,"vote_average":6.511,"vote_count":47,"credit_id":"59e640a3c3a36863d8001e58","department":"Camera","job":"Director of Photography"},{"adult":false,"backdrop_path":"/2CEVxNixZEVzJukMoeQ0fiL4vHm.jpg","genre_ids":[99],"id":1157240,"title":"Français, si vous saviez","original_language":"fr","original_title":"Français, si vous saviez","overview":"","popularity":0.0785,"poster_path":"/rGF4xWUGUlenxFe7KdgBt8RKCdp.jpg","release_date":"1973-02-22","softcore":false,"video":false,"vote_average":9.5,"vote_count":2,"credit_id":"666b762e20019131655ab763","department":"Production","job":"Delegated Producer"},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":585548,"title":"Station 307","original_language":"fr","original_title":"Station 307","overview":"","popularity":0.051,"post