{"page":1,"results":[{"adult":false,"backdrop_path":"/wbykOr1LrP463tXqIMH0wZPvMpz.jpg","genre_ids":[18],"id":1182861,"title":"Romería","original_language":"es","original_title":"Romería","overview":"Marina jedzie do Vigo, aby spotkać się z rodziną swojego biologicznego ojca, który, podobnie jak jej matka, zmarł na AIDS, gdy ona była bardzo młoda. Marina, poprzez spotkania z wujkami, ciotkami i dziadkami, próbuje złożyć w spójną opowieść o swoim ojcu i historii miłosnej, którą dzielił z jej matką, ale nie potrafi: wszyscy wstydzą się problemów narkotykowych pary, o czym Marina przypomina im swoją obecnością.","popularity":2.0745,"poster_path":"/svscmm7MZml1JqBMl62REnbxhjP.jpg","release_date":"2025-09-05","softcore":false,"video":false,"vote_average":6.542,"vote_count":60},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":347991,"title":"Romería asturiana","original_language":"es","original_title":"Romería asturiana","overview":"","popularity":0.0143,"poster_path":null,"release_date":"1942-07-07","softcore":false,"video":false,"vote_average":7.0,"vote_count":2},{"adult":false,"backdrop_path":null,"genre_ids":[],"id":1558647,"title":"A Romería da Morte","original_language":"gl","original_title":"A Romería da Morte","overview":"","popularity":0.0261,"poster_path":null,"release_date":"1974-07-30","softcore":false,"video":false,"vote_average":0.0,"vote_count":0},{"adult":false,"backdrop_path":null,"genre_ids":[35],"id":771480,"title":"Martinchu Perrugorria en día de romería","original_language":"es","original_title":"Martinchu Perrugorria en día de romería","overview":"","popularity":0.0338,"poster_path":null,"release_date":"1925-01-01","softcore":false,"video":false,"vote_average":0.0,"vote_count":0},{"adult":false,"backdrop_path":null,"genre_ids":[99],"id":404016,"title":"Bal espagnol dans la rue (Mexique)","original_language":"fr","original_title":"Bal espagnol dans la rue (Mexique)","overview":"","popularity":0.059,"poster_path":"/vV20U3NviL1meSKC33mOrGwtQjK.j