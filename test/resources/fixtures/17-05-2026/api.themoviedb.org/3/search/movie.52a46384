{"page":1,"results":[{"adult":false,"backdrop_path":"/563sRDK3rZS31TXCdTY4lfcwrNK.jpg","genre_ids":[18],"id":581734,"title":"Nomadland","original_language":"en","original_title":"Nomadland","overview":"Fern pakuje swojego vana i wyrusza w drogę jako współczesna nomadka, po tym jak w wyniku recesji straciła właściwie cały swój dotychczasowy dobytek. \"Nomadland\", trzeci film fabularny reżyserki Chloé Zhao, przedstawia historię Lindy May, Swankie i Boba Wellsa, prawdziwych nomadów, którzy stają się mentorami i towarzyszami Fern podczas jej podróży po rozległym amerykańskim Zachodzie.","popularity":2.87,"poster_path":"/q3b8RNOw8blBajvtZX2I7ybDq2x.jpg","release_date":"2021-01-29","softcore":false,"video":false,"vote_average":7.174,"vote_count":3348},{"adult":false,"backdrop_path":null,"genre_ids":[],"id":1141511,"title":"Nomadland","original_language":"en","original_title":"Nomadland","overview":"","popularity":0.0261,"poster_path":"/2S8rC5EuVMqZ3peNTyYKF0bEPbw.jpg","release_date":"","softcore":false,"video":false,"vote_average":0.0,"vote_count":0}],"total_pages":1,"total_results":2}