e. Diane za wszelką cenę próbuje otrzymać zatrudnienie w teatrze, gdyż ma nadzieję, że dowie się czegoś na temat siostry. Gdy udaje jej się zdobyć pracę garderobianej, szybko przekonuje się, że świat paryskiej elity, w który nieoczekiwanie wkracza jest pełen tajemnic, intryg i nieczystych rozgrywek.","popularity":0.2735,"poster_path":"/ojPrrKGu3jb7tasqI8E0G5qw29k.jpg","release_date":"2011-06-10","softcore":false,"video":false,"vote_average":5.3,"vote_count":11},{"adult":false,"backdrop_path":"/u9NkHe8YI6Xe5orGlMDwl4QHwya.jpg","genre_ids":[35],"id":121316,"title":"2 mattacchioni al Moulin Rouge","original_language":"it","original_title":"2 mattacchioni al Moulin Rouge","overview":"","popularity":0.1656,"poster_path":"/aGDMRqsDMgTet3MtldKLSCpOm5e.jpg","release_date":"1964-01-17","softcore":false,"video":false,"vote_average":5.056,"vote_count":9},{"adult":false,"backdrop_path":null,"genre_ids":[18],"id":825525,"title":"Queen of the Moulin Rouge","original_language":"en","original_title":"Queen of the Moulin Rouge","overview":"","popularity":0.0466,"poster_path":"/gn7nzwv2g7pzNU6YgjclzFamRMi.jpg","release_date":"1922-09-10","softcore":false,"video":false,"vote_average":0.0,"vote_count":0},{"adult":false,"backdrop_path":null,"genre_ids":[10402],"id":1202317,"title":"Mata Hari at the Moulin Rouge","original_language":"ko","original_title":"Mata Hari at the Moulin Rouge","overview":"","popularity":0.1079,"poster_path":"/nX0XgVStHAZqJu3mKhSs9Z52fg1.jpg","release_date":"","softcore":false,"video":true,"vote_average":0.0,"vote_count":0},{"adult":false,"backdrop_path":null,"genre_ids":[18],"id":1370002,"title":"Shadows of the Moulin Rouge","original_language":"en","original_title":"Shadows of the Moulin Rouge","overview":"","popularity":0.0555,"poster_path":null,"release_date":"","softcore":false,"video":false,"vote_average":0.0,"vote_count":0},{"adult":false,"backdrop_path":null,"genre_ids":[],"id":526589,"title":"Vue de Moulin-Rouge","original_language":"en","original_title"