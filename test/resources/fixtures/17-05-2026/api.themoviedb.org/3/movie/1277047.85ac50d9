{"adult":false,"backdrop_path":"/pJlPRzus9xdajjVAWdydiY7sbR2.jpg","belongs_to_collection":null,"budget":0,"genres":[{"id":16,"name":"Animation"},{"id":10751,"name":"Family"},{"id":14,"name":"Fantasy"},{"id":12,"name":"Adventure"}],"homepage":"https://chlopiecfilm.pl/main-page/","id":1277047,"imdb_id":null,"origin_country":["PL"],"original_language":"pl","original_title":"Chłopiec na krańcach świata","overview":"Omul lives with his family on a remote island in the Fire Archipelago. During a beach trip, a storm sweeps Omul and his younger sister Kimi into the sea, where Omul witnesses a mysterious creature threatening Kimi’s soul.  Rescued by a whale, the siblings survive, but Kimi is left in a coma. Omul’s ability to talk to animals becomes crucial as he and his brother – who blames him for the accident – set out to find Sadumea, the mythical figure behind Kimi’s torment.  With their dog Tela, they embark on a dangerous expedition deep into the island to save Kimi…","popularity":0.8892,"poster_path":"/1FMsjKzudN0lVQKW7vzv6bEDW8C.jpg","production_companies":[{"id":88672,"logo_path":"/meFXC1APvM2kb6nxpOhHF1I9w9G.png","name":"Animoon","origin_country":"PL"},{"id":114433,"logo_path":null,"name":"Letko","origin_country":"PL"},{"id":82294,"logo_path":"/z2WExPhsX9E8NGruZrEWosQoC86.png","name":"FIXAFILM","origin_country":"PL"},{"id":6480,"logo_path":"/qJUUNzFYXNUDaisssBTV3Zdki9R.png","name":"Telewizja Polska","origin_country":"PL"},{"id":243999,"logo_path":null,"name":"WKND","origin_country":"ES"},{"id":191259,"logo_path":null,"name":"Mystic House","origin_country":"CA"},{"id":205689,"logo_path":"/3AlqSHKDWnD03SwW3sGhvFdqj2Z.png","name":"7Sky Animation","origin_country":"TR"}],"production_countries":[{"iso_3166_1":"PL","name":"Poland"},{"iso_3166_1":"ES","name":"Spain"},{"iso_3166_1":"CA","name":"Canada"},{"iso_3166_1":"TR","name":"Turkey"}],"release_date":"2026-06-26","revenue":0,"runtime":93,"softcore":false,"spoken_languages":[{"english_name":"Polish","iso_639_1":"pl","na