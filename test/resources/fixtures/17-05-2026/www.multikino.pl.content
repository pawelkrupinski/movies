Multikino"},"addToSitemap":{"value":true},"sitemapPriority":{"value":0.5}}},{"id":"e44ae695-73e8-4e45-b8bb-605a321f130e","url":"/filmy/takie-jest-zycie","name":"Takie jest zycie","displayName":"Takie jest zycie","fields":{"embargoEndDate":{"value":"0001-01-01T00:00:00Z"},"embargoLevel":null,"embargoTextMessage":{"value":"Nie możesz się doczekać? Ustaw przypomnienie, a my damy Ci znać, gdy tylko bilety trafią do sprzedaży."},"filmName":{"value":"Takie jest życie"},"ticketImageDesktop":{"value":{"src":"/-/media/multikino/images/film-and-events/2026/takie-jest-zycie/takie-jest-zycie-kadr.jpg?h=667\u0026iar=0\u0026w=1000\u0026rev=0748da983a3d4b288356a7561160060e","alt":"","width":"1000","height":"667"}},"ticketImageMobile":{"value":{"src":"/-/media/multikino/images/film-and-events/2026/takie-jest-zycie/takie-jest-zycie-kadr.jpg?h=667\u0026iar=0\u0026w=1000\u0026rev=0748da983a3d4b288356a7561160060e","alt":"","width":"1000","height":"667"}},"movieXchangeId":{"value":""},"filmId":{"value":"HO00002745"},"childFilmIds":{"value":""},"crossCountryMovieXchangeId":{"value":""},"originalTitle":{"value":""},"consumerAdvice":{"value":""},"certificate":null,"distributor":{"value":"Best Film"},"genres":[],"longSynopsis":{"value":""},"secondaryCertificates":[],"shortSynopsis":{"value":"TAKIE JEST ŻYCIE to inspirowana prawdziwymi wydarzeniami poruszająca historia, która rozgrywa się na słonecznym wybrzeżu południowej Sardynii. Efisio Mulas, żyjący po swojemu pasterz, musi nagle stanąć do nierównej walki z bezkompromisowym deweloperem. Niespodziewany najeźdźca chce zamienić jego dom i ziemię w luksusowy kurort. Gdy w grę wchodzą milionowe oferty oraz nowe miejsca pracy dla lokalnej społeczności, drobny konflikt przeradza się w pełną emocji, ale i komediowego absurdu batalię. Stawką są dom, ziemia i przyszłość kolejnych pokoleń, a także prawo do życia w zgodzie ze swoimi wartościami. W centrum tej historii znajduje się Francesca, córka pasterza – rozdarta między obietnicą zmian a rodzinnymi relacjami. To pokrzepiająca i wzruszająca opowieść o korzeniach, odwadze i sile, by bronić tego, co najważniejsze."},"cast":{"value":""},"director":{"value":""},"duration":{"value":null},"isDurationUnknown":{"value":true},"releaseDate":{"value":"2026-06-26T00:00:00Z"},"alternativeCertificate":null,"attributes":[],"backgroundImage":{"value":{}},"panelImage":{"value":{"src":"/-/media/multikino/images/film-and-events/2026/takie-jest-zycie/takie-jest-zycie-kadr.jpg?h=667\u0026iar=0\u0026w=1000\u0026rev=0748da983a3d4b288356a7561160060e","alt":"","width":"1000","height":"667"}},"wideScreenImage":{"value":{"src":"/-/media/multikino/images/film-and-events/2026/takie-jest-zycie/takie-jest-zycie-kadr.jpg?h=667\u0026iar=0\u0026w=1000\u0026rev=0748da983a3d4b288356a7561160060e","alt":"","width":"1000","height":"667"}},"associatedTrailers":[],"featuredTrailer":null,"posterImage":{"value":{"src":"/-/media/multikino/images/film-and-events/2026/takie-jest-zycie/takie-jest-zycie_plakat_cut.jpg?h=1024\u0026iar=0\u0026w=696\u0026rev=e82839aaf1ab465eae23753b5e0aecab","alt":"","width":"696","height":"1024"}},"isPremiumPlayTrailerButton":{"value":false},"popularity":{"value":null},"filmPriority":{"value":null},"hidePriceMessage":{"value":false},"searchEntryKeyWords":{"value":""},"searchEntryType":{"value":"film"},"searchEntryTypePriority":{"value":null},"metaKeywords":{"value":"Takie jest zycie"},"metaImage":{"value":{}},"metaDescription":{"value":"Kup bilety na Takie jest zycie w Multikinie. Obejrzyj zwiastun."},"metaRobots":{"value":""},"browserTitle":{"value":"Takie jest zycie | Multikino"},"addToSitemap":{"value":true},"sitemapPriority":{"value":0.5}}}],"setReminderButtonLabel":{"value":"USTAW PRZYPOMNIENIE"},"notSetReminderIcon":{"id":"fe3b8893-819a-4d4b-8fb7-6eea06c78119","url":"/sitecore/content/global/content/icons/notification-bell-white-icon","name":"notification-bell-white-icon","displayName":"notification-bell-white-icon","fields":{"iconName":{"value":"notification_bell_wh