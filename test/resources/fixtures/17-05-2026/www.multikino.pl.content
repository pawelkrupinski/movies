1000","height":"522"}},"ticketImageMobile":{"value":{"src":"/-/media/multikino/images/film-and-events/2026/supergirl/supergirl-kadr1.jpg?h=522\u0026iar=0\u0026w=1000\u0026rev=3ef14912a2aa4c1aa06edac139e69764","alt":"","width":"1000","height":"522"}},"movieXchangeId":{"value":""},"filmId":{"value":"HO00002548"},"childFilmIds":{"value":""},"crossCountryMovieXchangeId":{"value":""},"originalTitle":{"value":""},"consumerAdvice":{"value":""},"certificate":null,"distributor":{"value":"Warner"},"genres":[{"id":"a367b758-0b1c-443f-be9f-ba523801883b","url":"/content/films/genres/ekranizacja-komiksu","name":"Ekranizacja komiksu","displayName":"ekranizacja komiksu","fields":{"genreName":{"value":"ekranizacja komiksu"},"genreId":{"value":7},"seatsToAllocate":{"value":null}}}],"longSynopsis":{"value":""},"secondaryCertificates":[],"shortSynopsis":{"value":"Kiedy nieoczekiwany i bezwzględny przeciwnik atakuje niebezpiecznie blisko domu, Kara Zor-El, znana też jako Supergirl, niechętnie łączy siły z zaskakującym towarzyszem w pełnej przygód, międzygalaktycznej podróży w poszukiwaniu zemsty i sprawiedliwości."},"cast":{"value":"Milly Alcock, Jason Momoa, Matthias Schoenaerts, Eve Ridley"},"director":{"value":"Craig Gillespie"},"duration":{"value":99},"isDurationUnknown":{"value":false},"releaseDate":{"value":"2026-06-26T00:00:00Z"},"alternativeCertificate":null,"attributes":[],"backgroundImage":{"value":{}},"panelImage":{"value":{"src":"/-/media/multikino/images/film-and-events/2026/supergirl/supergirl-kadr1.jpg?h=522\u0026iar=0\u0026w=1000\u0026rev=3ef14912a2aa4c1aa06edac139e69764","alt":"","width":"1000","height":"522"}},"wideScreenImage":{"value":{"src":"/-/media/multikino/images/film-and-events/2026/supergirl/supergirl-kadr1.jpg?h=522\u0026iar=0\u0026w=1000\u0026rev=3ef14912a2aa4c1aa06edac139e69764","alt":"","width":"1000","height":"522"}},"associatedTrailers":[],"featuredTrailer":{"id":"ed936660-a473-47da-b7a3-0cd6d4a52494","url":"/content/films/films/2025/08/04/10/57/supergir