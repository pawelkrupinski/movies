"name":"Ojczyzna","displayName":"Ojczyzna","fields":{"embargoEndDate":{"value":"0001-01-01T00:00:00Z"},"embargoLevel":null,"embargoTextMessage":{"value":"Nie możesz się doczekać? Ustaw przypomnienie, a my damy Ci znać, gdy tylko bilety trafią do sprzedaży."},"filmName":{"value":"Ojczyzna"},"ticketImageDesktop":{"value":{"src":"/-/media/multikino/images/film-and-events/2026/ojczyzna/ojczyzna-kadr-1.jpg?h=746\u0026iar=0\u0026w=1000\u0026rev=f6aa7609c63a4a5db56acee06979a33a","alt":"","width":"1000","height":"746"}},"ticketImageMobile":{"value":{"src":"/-/media/multikino/images/film-and-events/2026/ojczyzna/ojczyzna-kadr-1.jpg?h=746\u0026iar=0\u0026w=1000\u0026rev=f6aa7609c63a4a5db56acee06979a33a","alt":"","width":"1000","height":"746"}},"movieXchangeId":{"value":""},"filmId":{"value":"HO00002771"},"childFilmIds":{"value":""},"crossCountryMovieXchangeId":{"value":""},"originalTitle":{"value":""},"consumerAdvice":{"value":""},"certificate":null,"distributor":{"value":"Kino Świat"},"genres":[{"id":"eaccd62b-4019-479e-902e-e4c198c0166d","url":"/content/films/genres/dramat","name":"Dramat","displayName":"Dramat","fields":{"genreName":{"value":"dramat"},"genreId":{"value":5},"seatsToAllocate":{"value":null}}}],"longSynopsis":{"value":""},"secondaryCertificates":[],"shortSynopsis":{"value":"„Ojczyzna\" opowiada o relacji między Thomasem Mannem (Hanns Zischler), laureatem Nagrody Nobla w dziedzinie literatury, a jego córką Eriką (Sandra Hüller) – aktorką i pisarką. Akcja rozgrywa się w szczytowym okresie zimnej wojny. Ojciec i córka wyruszają w trudną, pełną emocji podróż czarnym Buickiem przez zrujnowane Niemcy – z Frankfurtu pod kontrolą amerykańską do Weimaru pod wpływem sowieckim. Po raz pierwszy od wojny Mann wraca do swojej ojczyzny, po tym jak podjął wcześniej trudną decyzję o emigracji do Stanów Zjednoczonych."},"cast":{"value":"Hanns Zischler, Sandra Hüller"},"director":{"value":"Paweł Pawlikowski"},"duration":{"value":82},"isDurationUnknown":{"value":false},"releaseDate":{"value":"2026-06-19T00:00:00Z"},"alternativeCertificate":null,"attributes":[],"backgroundImage":{"value":{}},"panelImage":{"value":{"src":"/-/media/multikino/images/film-and-events/2026/ojczyzna/ojczyzna-kadr-1.jpg?h=746\u0026iar=0\u0026w=1000\u0026rev=f6aa7609c63a4a5db56acee06979a33a","alt":"","width":"1000","height":"746"}},"wideScreenImage":{"value":{"src":"/-/media/multikino/images/film-and-events/2026/ojczyzna/ojczyzna-kadr-1.jpg?h=746\u0026iar=0\u0026w=1000\u0026rev=f6aa7609c63a4a5db56acee06979a33a","alt":"","width":"1000","height":"746"}},"associatedTrailers":[],"featuredTrailer":{"id":"761c8db0-9bd6-4e91-b927-c4156f679e10","url":"/content/films/films/2026/05/13/06/51/ojczyzna/trailers-folder/zwiastun","name":"Film Trailer","displayName":"Zwiastun","fields":{"sendPushNotificationToAll":{"value":false},"streamVideo":{"id":"114506ed-88fa-4bcb-be87-dbc686645ff6","url":"/-/media/multikino/video/uploads/2026/ojczyzna_zwiastun1.ashx?rev=4b3d2f06dd674e23978346d5741a1042","name":"Ojczyzna_zwiastun1","displayName":"Ojczyzna_zwiastun1","fields":{"hls":{"value":{"href":"https://customer-s5ao6f6rq71kswao.cloudflarestream.com/644d53a9b0780ac5b0e6902b02c61fdc/manifest/video.m3u8","linktype":"external","url":"https://customer-s5ao6f6rq71kswao.cloudflarestream.com/644d53a9b0780ac5b0e6902b02c61fdc/manifest/video.m3u8"}},"dash":{"value":{"href":"https://customer-s5ao6f6rq71kswao.cloudflarestream.com/644d53a9b0780ac5b0e6902b02c61fdc/manifest/video.mpd","linktype":"external","url":"https://customer-s5ao6f6rq71kswao.cloudflarestream.com/644d53a9b0780ac5b0e6902b02c61fdc/manifest/video.mpd"}},"preview":{"value":{"href":"https://customer-s5ao6f6rq71kswao.cloudflarestream.com/644d53a9b0780ac5b0e6902b02c61fdc/watch","linktype":"external","url":"https://customer-s5ao6f6rq71kswao.cloudflarestream.com/644d53a9b0780ac5b0e6902b02c61fdc/watch"}},"uid":{"value":"644d53a9b0780ac5b0e6902b02c61fdc"},"thumbnail":{"value":"https://customer-s5ao6f6rq71kswao.cloudflarestream.com/644d53a9b0780