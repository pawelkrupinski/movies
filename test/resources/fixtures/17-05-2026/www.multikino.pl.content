,"name":"Cirque du Soleil Kooza","displayName":"Cirque du Soleil Kooza","fields":{"embargoEndDate":{"value":"0001-01-01T00:00:00Z"},"embargoLevel":null,"embargoTextMessage":{"value":"Nie możesz się doczekać? Ustaw przypomnienie, a my damy Ci znać, gdy tylko bilety trafią do sprzedaży."},"filmName":{"value":"Cirque du Soleil: Kooza"},"ticketImageDesktop":{"value":{"src":"/-/media/multikino/images/film-and-events/2026/cirque-de-soleil/kooza_tlo.jpg?h=563\u0026iar=0\u0026w=1000\u0026rev=7843f98f5a1b417e89a23a1574cf7539","alt":"","width":"1000","height":"563"}},"ticketImageMobile":{"value":{"src":"/-/media/multikino/images/film-and-events/2026/cirque-de-soleil/kooza_tlo.jpg?h=563\u0026iar=0\u0026w=1000\u0026rev=7843f98f5a1b417e89a23a1574cf7539","alt":"","width":"1000","height":"563"}},"movieXchangeId":{"value":"d74aae68-943c-4fff-8e76-dc0a66155639"},"filmId":{"value":"HO00002648"},"childFilmIds":{"value":""},"crossCountryMovieXchangeId":{"value":"63836845-9240-4061-86b7-30047219dc29"},"originalTitle":{"value":"Cirque du Soleil: Kooza"},"consumerAdvice":{"value":""},"certificate":null,"distributor":{"value":"Qrios Interactive (Pannonia Entertainment)"},"genres":[],"longSynopsis":{"value":""},"secondaryCertificates":[],"shortSynopsis":{"value":"Pomiędzy siłą a kruchością, śmiechem a uśmiechem, zamętem a harmonią, KOOZA zgłębia tematy tożsamości, uznania i władzy. Spektakl rozgrywa się w elektryzującym i egzotycznym świecie pełnym niespodzianek, emocji, dreszczyku emocji, śmiałości i całkowitego zaangażowania. Składa się z dziesięciu aktów: balansowanie na krzesłach, charivari, kontorsjonizm, chodzenie po linie, obręcze, obręcz powietrzna, huśtawka, duet na monocyklu, koło śmierci i diabolo: akt w rotacji."},"cast":{"value":"Cirque du Soleil"},"director":{"value":"Mario Janelle, David Shiner"},"duration":{"value":90},"isDurationUnknown":{"value":false},"releaseDate":{"value":"2026-07-16T00:00:00Z"},"alternativeCertificate":null,"attributes":[],"backgroundImage":{"value":{}},"panelImage":{"value":{"src":"/-/media/multikino/images/film-and-events/2026/cirque-de-soleil/kooza_tlo.jpg?h=563\u0026iar=0\u0026w=1000\u0026rev=7843f98f5a1b417e89a23a1574cf7539","alt":"","width":"1000","height":"563"}},"wideScreenImage":{"value":{"src":"/-/media/multikino/images/film-and-events/2026/cirque-de-soleil/kooza_tlo.jpg?h=563\u0026iar=0\u0026w=1000\u0026rev=7843f98f5a1b417e89a23a1574cf7539","alt":"","width":"1000","height":"563"}},"associatedTrailers":[],"featuredTrailer":{"id":"4570a5d6-8f65-49a9-b468-c8a153bcebc1","url":"/content/films/films/2026/02/26/11/37/cirque-du-soleil-kooza/trailers/zwiastun","name":"Film Trailer","displayName":"Zwiastun","fields":{"sendPushNotificationToAll":{"value":false},"streamVideo":{"id":"6f119a83-6272-4c86-b247-d9634d038aaa","url":"/-/media/multikino/video/uploads/2026/kooza.ashx?rev=f4b0c367b4074c2abc6e29b1256d3bce","name":"KOOZA","displayName":"KOOZA","fields":{"hls":{"value":{"href":"https://customer-s5ao6f6rq71kswao.cloudflarestream.com/fe31243394ce1e5ef9fbf7a7514cf061/manifest/video.m3u8","linktype":"external","url":"https://customer-s5ao6f6rq71kswao.cloudflarestream.com/fe31243394ce1e5ef9fbf7a7514cf061/manifest/video.m3u8"}},"dash":{"value":{"href":"https://customer-s5ao6f6rq71kswao.cloudflarestream.com/fe31243394ce1e5ef9fbf7a7514cf061/manifest/video.mpd","linktype":"external","url":"https://customer-s5ao6f6rq71kswao.cloudflarestream.com/fe31243394ce1e5ef9fbf7a7514cf061/manifest/video.mpd"}},"preview":{"value":{"href":"https://customer-s5ao6f6rq71kswao.cloudflarestream.com/fe31243394ce1e5ef9fbf7a7514cf061/watch","linktype":"external","url":"https://customer-s5ao6f6rq71kswao.cloudflarestream.com/fe31243394ce1e5ef9fbf7a7514cf061/watch"}},"uid":{"value":"fe31243394ce1e5ef9fbf7a7514cf061"},"thumbnail":{"value":"https://customer-s5ao6f6rq71kswao.cloudflarestream.com/fe31243394ce1e5ef9fbf7a7514cf061/thumbnails/thumbnail.jpg"}}},"videoLink":{"value":{"href":""}},"mediaId":{"value":""},"image":{"value":{"src":"/-/media/m