a niespodziewaną miłość. „Drugie życie” to zdobywca nagrody publiczności festiwalu w Wenecji. W roli głównej zachwycająca Carmen Maura, ikona filmów Almodóvara."},"cast":{"value":""},"director":{"value":""},"duration":{"value":null},"isDurationUnknown":{"value":true},"releaseDate":{"value":"2026-06-12T00:00:00Z"},"alternativeCertificate":null,"attributes":[],"backgroundImage":{"value":{}},"panelImage":{"value":{"src":"/-/media/multikino/images/offowe-czwartki/drugie-zycie_kadr.jpg?h=562\u0026iar=0\u0026w=1000\u0026rev=7870cedfb52a4bd3ab84e2928e2600c5","alt":"","width":"1000","height":"562"}},"wideScreenImage":{"value":{"src":"/-/media/multikino/images/offowe-czwartki/drugie-zycie_kadr.jpg?h=562\u0026iar=0\u0026w=1000\u0026rev=7870cedfb52a4bd3ab84e2928e2600c5","alt":"","width":"1000","height":"562"}},"associatedTrailers":[],"featuredTrailer":null,"posterImage":{"value":{"src":"/-/media/multikino/images/offowe-czwartki/drugiezycie_plakat.jpg?h=1024\u0026iar=0\u0026w=711\u0026rev=b3e62875d7b248b78e1a7d07fdf010d2","alt":"","width":"711","height":"1024"}},"isPremiumPlayTrailerButton":{"value":false},"popularity":{"value":null},"filmPriority":{"value":null},"hidePriceMessage":{"value":false},"searchEntryKeyWords":{"value":""},"searchEntryType":{"value":"film"},"searchEntryTypePriority":{"value":null},"metaKeywords":{"value":"Drugie zycie"},"metaImage":{"value":{"src":"/-/media/multikino/images/offowe-czwartki/drugie-zycie_kadr.jpg?h=562\u0026iar=0\u0026w=1000\u0026rev=7870cedfb52a4bd3ab84e2928e2600c5","alt":"","width":"1000","height":"562"}},"metaDescription":{"value":"Kup bilety na Drugie zycie w Multikinie. Obejrzyj zwiastun."},"metaRobots":{"value":""},"browserTitle":{"value":"Drugie zycie | Multikino"},"addToSitemap":{"value":true},"sitemapPriority":{"value":0.5}}},{"id":"01597593-2354-4402-a5f2-a37369326661","url":"/filmy/toy-story-5","name":"Toy Story 5","displayName":"Toy Story 5","fields":{"embargoEndDate":{"value":"0001-01-01T00:00:00Z"},"embargoLevel":null,"emba