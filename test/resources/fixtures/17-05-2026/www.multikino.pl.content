ckground_wydarzenia/kno_tlo_ds10final.jpg?h=540\u0026iar=0\u0026w=1600\u0026rev=959c0e2bab684723bd567d6f8aec240b","alt":"","width":"1600","height":"540"}},"titleImage":{"value":{}},"backgroundImageMobile":{"value":{"src":"/-/media/multikino/multikino_imported/images/events/background_wydarzenia/kno_tlo_ms10final.jpg?h=432\u0026iar=0\u0026w=768\u0026rev=7fa90570087940ce93e33733a4e51e48","alt":"","width":"768","height":"432"}},"title":{"value":""},"detailsPage":{"value":{"href":"/wydarzenia/kino-na-obcasach","text":"SPRAWDŹ","anchor":"","linktype":"internal","class":"","title":"","target":"","querystring":"","id":"{D47C83BB-CEA6-458F-80D6-78E067CD7B6E}"}},"contentOrientation":{"value":"left"},"applyShadowEffect":{"value":false},"description":{"value":"„Kino na Obcasach” - propozycja dla kobiet na spędzenie wolnego wieczoru w kinie z przyjaciółkami, koleżankami z pracy lub członkiniami rodziny. Raz w miesiącu panie podczas seansu filmowego będą miały okazję do relaksu, poznania nowych ludzi, czerpania radości z oglądania wybranych produkcji na wielkim ekranie oraz refleksji na temat ważnych dla kobiet kwestii."}}},{"uid":"9589c003-703e-46fa-902f-bcc35e105a02","componentName":"SuggestionWrapper","dataSource":"{CEA9EFC7-8F45-4594-A499-AA44015E744D}","fields":{"suggestionActionLink":{"value":{"href":"/newsy","class":"","id":"{BEA99F3D-6D0D-493A-B351-5CD2881F39B9}","querystring":"","anchor":"","target":"","title":"","linktype":"internal","text":"Zobacz więcej","url":"/Multikino/home/newsy"}},"suggestionTitle":{"value":"Newsy"}},"placeholders":{"suggestion-element-wrapper":[{"uid":"0fa88c1f-e8e5-4768-8cf3-c72adb76b515","componentName":"InsideVue","dataSource":"{A7CE3175-6153-4562-B941-44A6A7F60AD3}","fields":{"readMoreLabel":{"value":"Więcej"},"articlesCount":{"value":"3"},"newsTitle":{"value":"NEWSY"},"filterAttributes":[],"newsArticles":[{"title":{"value":"Multi Bubble: Nowe smaki, znana wolność wyboru"},"date":{"value":"2026-06-05T00:00:00Z"},"previewImage":{"alt":"","he