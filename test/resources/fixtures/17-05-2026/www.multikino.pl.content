"notSetReminderButtonLabel":{"value":"PRZYPOMNIJ MI"},"aspectRatio":{"id":"a715f7b0-21db-49ba-816a-71893137a0d1","url":"/sitecore/content/global/content/aspect-ratios/16x9","name":"16x9","displayName":"16x9","fields":{"width":{"value":16},"height":{"value":9}}},"anchorLinkText":{"value":""}}},{"uid":"60b4d39f-93ab-41f2-8357-bf1db8d59a48","componentName":"Advert","dataSource":"{7D668D1B-E4DF-4B33-A016-320DA22F5466}","fields":{"variant":{"value":"general"},"slotId":{"value":"/22807192926/multikino_pl_2024/homepage_ad_position_2"},"appSlotId":{"value":""}}},{"uid":"abd67ed8-fca2-453a-ad5a-1556a12d6556","componentName":"SuggestionWrapper","dataSource":"{07E022DA-0BBB-4C51-8BC7-30D84A97AD97}","fields":{"suggestionActionLink":{"value":{"href":"/wydarzenia","text":"Zobacz więcej","anchor":"","linktype":"internal","class":"","title":"","target":"","querystring":"","id":"{7C4B3A8A-5242-4033-A24F-91B959F28C51}"}},"suggestionTitle":{"value":"WYDARZENIA NA WIELKIM EKRANIE"}},"placeholders":{"suggestion-element-wrapper":[]}},{"uid":"74f5d2a7-f609-4676-8a43-cf49e387373c","componentName":"CuratedPremium","dataSource":"{07D49F1A-87E9-4F29-96D6-E4CD1FE5B5FA}","fields":{"bookNowButtonIcon":{"id":"c2d9bfe7-50b9-48b5-b03c-6abab08dcc24","url":"/sitecore/content/global/content/icons/booking/tickets-white-icon","name":"tickets-white-icon","displayName":"tickets-white-icon","fields":{"iconName":{"value":"tickets_white_icon"}}},"bookNowButtonLabel":{"value":"KUP ONLINE"},"castLabel":{"value":"Obsada"},"autoplay":{"value":false},"directorLabel":{"value":"Reżyseria"},"films":[{"id":"0ed4aae1-7178-4a29-bab8-909144887ec5","url":"/filmy/nt-live-audiencja","name":"NT Live Audiencja","displayName":"NT Live Audiencja","fields":{"embargoEndDate":{"value":"0001-01-01T00:00:00Z"},"embargoLevel":null,"embargoTextMessage":{"value":"Nie możesz się doczekać? Ustaw przypomnienie, a my damy Ci znać, gdy tylko bilety trafią do sprzedaży."},"filmName":{"value":"NT Live: Audiencja"},"ticketImageDesktop":{"value":{"src":"/-/media/multikino/images/wydarzenia/teatr/audiencja/audiencja-kadr.jpg?h=679\u0026iar=0\u0026w=1000\u0026rev=d9064d15b34743ee9aa40dc60f05efde","alt":"","width":"1000","height":"679"}},"ticketImageMobile":{"value":{"src":"/-/media/multikino/images/wydarzenia/teatr/audiencja/audiencja-kadr.jpg?h=679\u0026iar=0\u0026w=1000\u0026rev=d9064d15b34743ee9aa40dc60f05efde","alt":"","width":"1000","height":"679"}},"movieXchangeId":{"value":""},"filmId":{"value":"HO00002723"},"childFilmIds":{"value":""},"crossCountryMovieXchangeId":{"value":""},"originalTitle":{"value":""},"consumerAdvice":{"value":""},"certificate":null,"distributor":{"value":""},"genres":[{"id":"21c57e7b-fb0e-4535-8215-90c8ec0330db","url":"/content/films/genres/teatr","name":"Teatr","displayName":"Teatr","fields":{"genreName":{"value":"teatr"},"genreId":{"value":28},"seatsToAllocate":{"value":null}}}],"longSynopsis":{"value":""},"secondaryCertificates":[],"shortSynopsis":{"value":"Retransmisja sztuki wraca do kin po ponad dekadzie. Helen Mirren wciela się w rolę królowej Elżbiety II w uhonorowanej nagrodami Olivier i Tony Award® przebojowej produkcji w reżyserii Stephena Daldry'ego. Przez 60 lat królowa Elżbieta II odbywała cotygodniowe, poufne spotkania z każdym z 12 premierów Wielkiej Brytanii. Takie spotkanie jest znane jako audiencja. Królowa doradzała premierom, począwszy od Winstona Churchilla, przez Margaret Thatcher, po Davida Camerona, w sprawach publicznych i osobistych. Podczas prywatnych audiencji możemy przyjrzeć się bliżej kobiecie kryjącej się za koroną i być świadkami chwil, które ukształtowały monarchinię. Fenomen Netflixa, serial The Crown, za którego sukcesem stoi Peter Morgan, powstał na podstawie tej przebojowej sztuki, którą transmitowano na żywo z londyńskiego West Endu w 2013 roku, a która stała się jedną z najchętniej oglądanych produkcji NT Live."},"cast":{"value":""},"director":{"value":""},"duration":{"value":180},"isDurationUnknown":{"value":false},"releaseDate":{"value":"2026-08-19T00:00:00Z"},"alternativeCertificate":null,"attributes":[],"backgroundImage":{"value":{}},"panelImage":{"value":{"src":"/-/media/multikino/images/wydarzenia/teatr/audiencja/audiencja-kadr.jpg?h=679\u0026iar=0\u0026w=1000\u0026rev=d9064d15b34743ee9aa40dc60f05efde","alt":"","width":"1000","height":"679"}},"wideScreenImage":{"value":{"src":"/-/media/multikino/images/wydarzenia/teatr/audiencja/audiencja-kadr.jpg?h=679\u0026iar=0\u0026w=1000\u0026rev=d9064d15b34743ee9aa40dc60f05efde","alt":"","width":"1000","height":"679"}},"associatedTrailers":[],"featuredTrailer":{"id":"7116a29b-58ac-469e-87c8-7629fda483ff","url":"/content/films/films/2026/04/17/07/24/nt-live-audiencja/trailers-folder/zwiastun","name":"Film Trailer","displayName":"Zwiastun","fields":{"sendPushNotificationToAll":{"value":false},"streamVideo":{"id":"8837eb32-48ea-46f3-80d5-828bcfa5ee65","url":"/-/media/multikino/video/uploads/2026/teatr26.ashx?rev=feace79e93c542de9213a9e884027113","name":"Teatr26","displayName":"Teatr26","fields":{"hls":{"value":{"href":"https://customer-s5ao6f6rq71kswao.cloudflarestream.com/e334f40ee150966c3d4a7de58350d59f/manifest/video.m3u8","linktype":"external","url":"https://customer-s5ao6f6rq71kswao.cloudflarestream.com/e334f40ee150966c3d4a7de58350d59f/manifest/video.m3u8"}},"dash":{"value":{"href":"https://customer-s5ao6f6rq71kswao.cloudflarestream.com/e334f40ee150966c3d4a7de58350d59f/manifest/video.mpd","linktype":"external","url":"https://customer-s5ao6f6rq71kswao.cloudflarestream.com/e334f40ee150966c3d4a7de58350d59f/manifest/video.mpd"}},"preview":{"value":{"href":"https://customer-s5ao6f6rq71kswao.cloudflarestream.com/e334f40ee150966c3d4a7de58350d59f/watch","linktype":"external","url":"https://customer-s5ao6f6rq71kswao.cloudflarestream.com/e334f40ee150966c3d4a7de58350d59f/watch"}},"uid":{"value":"e334f40ee150966c3d4a7de58350d59f"},"thumbnail":{"value":"https://customer-s5ao6f6rq71kswao.cloudflarestream.com/e334f40ee150966c3d4a7de58350d59f/thumbnails/thumbnail.jpg"}}},"videoLink":{"value":{"href":""}},"mediaId":{"value":""},"image":{"value":{"src":"/-/media/multikino/images/wydarzenia/teatr/audiencja/audiencja-kadr.jpg?h=679\u0026iar=0\u0026w=1000\u0026rev=d9064d15b34743ee9aa40dc60f05efde","alt":"","width":"1000","height":"679"}},"sendPushNotificationToSubscribers":{"value":false},"imageLink":{"value":{"href":""}},"isFeature":{"value":true},"certificate":null,"captions":{"value":""}}},"posterImage":{"value":{"src":"/-/media/multikino/images/wydarzenia/teatr/audiencja/audience_plakat.jpg?h=1024\u0026iar=0\u0026w=691\u0026rev=aff6a9407f624513b3a44c7871e97f7d","alt":"","width":"691","height":"1024"}},"isPremiumPlayTrailerButton":{"value":false},"popularity":{"value":null},"filmPriority":{"value":null},"hidePriceMessage":{"value":false},"searchEntryKeyWords":{"value":""},"searchEntryType":{"value":"film"},"searchEntryTypePriority":{"value":null},"metaKeywords":{"value":"NT Live: Audiencja"},"metaImage":{"value":{"src":"/-/media/multikino/images/wydarzenia/teatr/audiencja/audiencja-kadr.jpg?h=679\u0026iar=0\u0026w=1000\u0026rev=d9064d15b34743ee9aa40dc60f05efde","alt":"","width":"1000","height":"679"}},"metaDescription":{"value":"Kup bilety na NT Live: Audiencja w Multikinie. Obejrzyj zwiastun."},"metaRobots":{"value":""},"browserTitle":{"value":"NT Live: Audiencja | Multikino"},"addToSitemap":{"value":true},"sitemapPriority":{"value":0.5}}},{"id":"519f4c03-77ef-4c55-a5b8-3f150a3b99f1","url":"/filmy/90-urodziny-pavarottiego","name":"90 urodziny Pavarottiego","displayName":"90 urodziny Pavarottiego","fields":{"embargoEndDate":{"value":"0001-01-01T00:00:00Z"},"embargoLevel":null,"embargoTextMessage":{"value":"Nie możesz się doczekać? Ustaw przypomnienie, a my damy Ci znać, gdy tylko bilety trafią do sprzedaży."},"filmName":{"value":"90. urodziny Pavarottiego"},"ticketImageDesktop":{"value":{"src":"/-/media/multikino/images/wydarzenia/koncerty/pavarotti/pavarotti90_tlo.jpg?h=1181\u0026iar=0\u0026w=1600\u0026rev=47abac46f05647138d6cda3ff8a1027e","alt":"","width":"1600","height":"1181"}},"ticketImageMobile":{"value":{"src":"/-/media/multikino/images/wydarzenia/koncerty/pavarotti/pavarotti90_tlo.jpg?h=1181\u0026iar=0\u0026w=1600\u0026rev=47abac46f05647138d6cda3ff8a1027e","alt":"","width":"1600","height":"1181"}},"movieXchangeId":{"value":""},"filmId":{"value":"HO00002682"},"childFilmIds":{"value":""},"crossCountryMovieXchangeId":{"value":""},"originalTitle":{"value":"Pavarotti 90 - The Man Who Moved the World"},"consumerAdvice":{"value":""},"certificate":null,"distributor":{"value":"kinomaestro"},"genres":[{"id":"46b313d0-fd71-4b12-bf68-0254e8b5741e","url":"/content/films/genres/koncert","name":"Koncert","displayName":"Koncert","fields":{"genreName":{"value":"koncert"},"genreId":{"value":29},"seatsToAllocate":{"value":null}}}],"longSynopsis":{"value":""},"secondaryCertificates":[],"shortSynopsis":{"value":"Jesienią 2025 roku w słynnej Arena di Verona zebrały się największe gwiazdy opery i popu, w tym Andrea Bocelli, Jonathan Tetelman, Angela Gheorghiu i Il Volo, by dać niebywały koncert, który... przywrócił do życia Luciana Pavarottiego, króla tenorów i wielkiego śpiewaka zwykłych ludzi. Jego dwaj żyjący koledzy, Plácido Domingo i José Carreras, zaśpiewali z nim na żywo. Niemożliwe stało się faktem – Trzej Tenorzy powrócili na estradę! Najnowszemu koncertowi ku czci jedzącego za trzech śpiewaka o niebiańskim głosie, który wciąż przywołuje na myśl skąpane w słońcu i spaghetti Włochy, nadano znaczący tytuł: „Luciano Pavarotti. Człowiek, który poruszył świat”. To prawda. Choć święcił nieprawdopodobne tryumfy na najważniejszych scenach, począwszy od mediolańskiej La Scali, a skończywszy na nowojorskiej The Metropolitan Opera, Luciano Pavarotti chciał przybliżyć muzykę klasyczną ludziom na całym świecie. To dzięki swym popularyzatorskim koncertom sprawił, że wielu z nas pokochało operę. Na jego występ w Hyde Parku, mimo ulewy, przyszło ponad 100.000 osób, a jego transmitowane przez telewizję występy z Domingiem i Carrerasem (Trzej Tenorzy) sprawiały, że w miastach i miasteczkach zamierał ruch na ulicach. Koncert z legendarnego werońskiego amfiteatru to wiązanka najsłynniejszych arii operowych i niezaprzeczalnych evergreenów w wykonaniu nie tylko klasycznych śpiewaków, ale też artystów, którzy z powodzeniem łączą muzykę poważną z popową. Oprócz wcześniej wymienionych gwiazd wystąpili również: wiolonczelista Hauser, piosenkarz Umberto Tozzi, a także Vittorio Grigolo, międzynarodowej klasy tenor, który w wieku 13 lat zaśpiewał w Operze Rzymskiej partię Pastuszka w „Tosce” Pucciniego, a rolę Cavaradossiego w tym spektaklu kreował wtedy sam Luciano Pavarotti."},"cast":{"value":"Andrea Bocelli, Jonathan Tetelman, Placido Domingo, Jose Carreras, Angela Gheorghiu,  Il Volo, Stjepan Hauser"},"director":{"value":"Luigi Antonini, Matteo Parmeggiani"},"duration":{"value":95},"isDurationUnknown":{"value":false},"releaseDate":{"value":"2026-05-01T00:00:00Z"},"alternativeCertificate":null,"attributes":[],"backgroundImage":{"value":{}},"panelImage":{"value":{"src":"/-/media/multikino/images/wydarzenia/koncerty/pavarotti/pavarotti90_tlo.jpg?h=1181\u0026iar=0\u0026w=1600\u0026rev=47abac46f05647138d6cda3ff8a1027e","alt":"","width":"1600","height":"1181"}},"wideScreenImage":{"value":{"src":"/-/media/multikino/images/wydarzenia/koncerty/pavarotti/pavarotti90_tlo.jpg?h=1181\u0026iar=0\u0026w=1600\u0026rev=47abac46f05647138d6cda3ff8a1027e","alt":"","width":"1600","height":"1181"}},"associatedTrailers":[],"featuredTrailer":{"id":"b69e8da9-93d7-404e-bdb9-aa06618b1a99","url":"/content/films/films/2026/03/20/06/28/90-urodziny-pavarottiego/trailers-folder/zwiastun","name":"Film Trailer","displayName":"Zwiastun","fields":{"sendPushNotificationToAll":{"value":false},"streamVideo":{"id":"142ad2a9-1a94-4fc9-aff8-9f4e7a9c9307","url":"/-/media/multikino/video/uploads/2026/pavarotti90_zwiastun.ashx?rev=7b9a4bea4fb342a3947fca6d2aa1f9aa","name":"Pavarotti90_zwiastun","displayName":"Pavarotti90_zwiastun","fields":{"hls":{"value":{"href":"https://customer-s5ao6f6rq71kswao.cloudflarestream.com/5e83e2bdce1b04dc6762d9ffc501a27c/manifest/video.m3u8","linktype":"external","url":"https://customer-s5ao6f6rq71kswao.cloudflarestream.com/5e83e2bdce1b04dc6762d9ffc501a27c/manifest/video.m3u8"}},"dash":{"value":{"href":"https://customer-s5ao6f6rq71kswao.cloudflarestream.com/5e83e2bdce1b04dc6762d9ffc501a27c/manifest/video.mpd","linktype":"external","url":"https://customer-s5ao6f6rq71kswao.cloudflarestream.com/5e83e2bdce1b04dc6762d9ffc501a27c/manifest/video.mpd"}},"preview":{"value":{"href":"https://customer-s5ao6f6rq71kswao.cloudflarestream.com/5e83e2bdce1b04dc6762d9ffc501a27c/watch","linktype":"external","url":"https://customer-s5ao6f6rq71kswao.cloudflarestream.com/5e83e2bdce1b04dc6762d9ffc501a27c/watch"}},"uid":{"value":"5e83e2bdce1b04dc6762d9ffc501a27c"},"thumbnail":{"value":"https://customer-s5ao6f6rq71kswao.cloudflarestream.com/5e83e2bdce1b04dc6762d9ffc501a27c/thumbnails/thumbnail.jpg"}}},"videoLink":{"value":{"href":""}},"mediaId":{"value":""},"image":{"value":{"src":"/-/media/multikino/images/wydarzenia/koncerty/pavarotti/pavarotti90_tlo.jpg?h=1181\u0026iar=0\u0026w=1600\u0026rev=47abac46f05647138d6cda3ff8a1027e","alt":"","width":"1600","height":"1181"}},"sendPushNotificationToSubscribers":{"value":false},"imageLink":{"value":{"href":""}},"isFeature":{"value":true},"certificate":null,"captions":{"value":""}}},"posterImage":{"value":{"src":"/-/media/multikino/images/wydarzenia/koncerty/pavarotti/pavarotti90_plakat.jpg?h=1024\u0026iar=0\u0026w=690\u0026rev=10b0b0776a1740c3bc284f5e077c5434","alt":"","width":"690","height":"1024"}},"isPremiumPlayTrailerButton":{"value":false},"popularity":{"value":null},"filmPriority":{"value":null},"hidePriceMessage":{"value":false},"searchEntryKeyWords":{"value":""},"searchEntryType":{"value":"film"},"searchEntryTypePriority":{"value":null},"metaKeywords":{"value":"90 urodziny Pavarottiego"},"metaImage":{"value":{}},"metaDescription":{"value":"Kup bilety na 90. urodziny Pavarottiego w Multikinie. Obejrzyj zwiastun."},"metaRobots":{"value":""},"browserTitle":{"value":"90. urodziny Pavarottiego | Multikino"},"addToSitemap":{"value":true},"sitemapPriority":{"value":0.5}}},{"id":"1ded90ce-cbb4-4694-9d0f-9f1e7ff95293","url":"/filmy/la-traviata-verdiego-z-arena-di-verona","name":"La Traviata Verdiego z Arena di Verona","displayName":"La Traviata Verdiego z Arena di Verona","fields":{"embargoEndDate":{"value":"0001-01-01T00:00:00Z"},"embargoLevel":null,"embargoTextMessage":{"value":"Nie możesz się doczekać? Ustaw przypomnienie, a my damy Ci znać, gdy tylko bilety trafią do sprzedaży."},"filmName":{"value":"La Traviata Verdiego z Arena di Verona"},"ticketImageDesktop":{"value":{"src":"/-/media/multikino/images/wydarzenia/opera/latraviata2026_tlo.png?h=1181\u0026iar=0\u0026w=1600\u0026rev=533a682c72464492aaefba9320a4e984","alt":"","width":"1600","height":"1181"}},"ticketImageMobile":{"value":{"src":"/-/media/multikino/images/wydarzenia/opera/latraviata2026_tlo.png?h=1181\u0026iar=0\u0026w=1600\u0026rev=533a682c72464492aaefba9320a4e984","alt":"","width":"1600","height":"1181"}},"movieXchangeId":{"value":""},"filmId":{"value":"HO00002591"},"childFilmIds":{"value":""},"crossCountryMovieXchangeId":{"value":""},"originalTitle":{"value":""},"consumerAdvice":{"value":""},"certificate":null,"distributor":{"value":"Ferment"},"genres":[{"id":"bd68e130-2001-49fe-8815-eec93ac24e62","url":"/content/films/genres/opera","name":"Opera","displayName":"Opera","fields":{"genreName":{"value":"opera"},"genreId":{"value":25},"seatsToAllocate":{"value":null}}}],"longSynopsis":{"value":"La Traviata Verdiego z Arena di Verona"},"secondaryCertificates":[],"shortSynopsis":{"value":"„La traviata” to jedna z najpopularniejszych oper świata, a toast „Libiamo” („Więc pijmy”) z jej pierwszego aktu potrafi zanucić każdy. Ten bezsprzeczny wyciskacz łez widzowie polskich kin zobaczą wprost ze słynnej Arena di Verona. W nowej inscenizacji „Zbłąkanej” – bo tak należy tłumaczyć ten tytuł – przygotowanej w 2021 roku, wystąpiły międzynarodowe gwiazdy opery: wspaniała bułgarska sopranistka Sonya Yoncheva oraz przebojowy włoski tenor Vittorio Grigolo, który w wieku 13 lat debiutował u boku Luciana Pavarottiego. Fabuła dzieła Verdiego oparta jest na słynnym romansie „Dama kameliowa” Alexandre’a Dumas syna. To poruszająca historia umierającej Violetty, francuskiej kurtyzany, która z miłości do ukochanego Alfreda, młodzieńca z wyższych sfer, gotowa jest poświęcić ostatnie chwile swojego szczęścia. Dziś trudno w to uwierzyć, ale prapremiera tej opery w 1853 roku zakończyła się totalną klapą. Publiczności nie spodobało się, że główną bohaterką kompozytor uczynił współczesną im postać, w dodatku kobietę upadłą, która w świecie mieszczańskiej obłudy okazała się jedyną uczciwą i szlachetną osobą. Akcję werońskiego przedstawienia przeniesiono 30 lat do przodu, do Belle Époque, a dokładnie w okres paryskiej Wystawy Światowej z 1889 roku. Tradycyjne dekoracje i kostiumy połączono z nowoczesną technologią. Na gigantycznych ekranach o powierzchni ponad 400 metrów kwadratowych wyświetlono malarskie arcydzieła ze słynnej Galerii Uffizi we Florencji."},"cast":{"value":"Sonya Yoncheva, Vittorio Grigolo, George Petean"},"director":{"value":"Michele Olcese, Francesco Ivan Ciampa"},"duration":{"value":160},"isDurationUnknown":{"value":false},"releaseDate":{"value":"2026-05-10T00:00:00Z"},"alternativeCertificate":null,"attributes":[],"backgroundImage":{"value":{}},"panelImage":{"value":{"src":"/-/media/multikino/images/wydarzenia/opera/latraviata2026_tlo.png?h=1181\u0026iar=0\u0026w=1600\u0026rev=533a682c72464492aaefba9320a4e984","alt":"","width":"1600","height":"1181"}},"wideScreenImage":{"value":{"src":"/-/media/multikino/images/wydarzenia/opera/latraviata2026_tlo.png?h=1181\u0026iar=0\u0026w=1600\u0026rev=533a682c72464492aaefba9320a4e984","alt":"","width":"1600","height":"1181"}},"associatedTrailers":[],"featuredTrailer":{"id"