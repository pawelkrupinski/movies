:"711","height":"1024"}},"isPremiumPlayTrailerButton":{"value":false},"popularity":{"value":null},"filmPriority":{"value":180800},"hidePriceMessage":{"value":false},"searchEntryKeyWords":{"value":""},"searchEntryType":{"value":"film"},"searchEntryTypePriority":{"value":null},"metaKeywords":{"value":"Supergirl"},"metaImage":{"value":{"src":"/-/media/multikino/images/film-and-events/2026/supergirl/supergirl-kadr1.jpg?h=522\u0026iar=0\u0026w=1000\u0026rev=3ef14912a2aa4c1aa06edac139e69764","alt":"","width":"1000","height":"522"}},"metaDescription":{"value":"Kup bilety na Supergirl w Multikinie. Obejrzyj zwiastun."},"metaRobots":{"value":""},"browserTitle":{"value":"Supergirl | Multikino"},"addToSitemap":{"value":true},"sitemapPriority":{"value":0.5}}},{"id":"806afa47-39cc-4203-a39c-4825b0c1b5bf","url":"/filmy/chlopiec-na-krancach-swiata","name":"Chlopiec na krancach swiata","displayName":"Chlopiec na krancach swiata","fields":{"embargoEndDate":{"value":"0001-01-01T00:00:00Z"},"embargoLevel":null,"embargoTextMessage":{"value":"Nie możesz się doczekać? Ustaw przypomnienie, a my damy Ci znać, gdy tylko bilety trafią do sprzedaży."},"filmName":{"value":"Chłopiec na krańcach świata "},"ticketImageDesktop":{"value":{"src":"/-/media/multikino/images/film-and-events/2026/chlopiec-na-krancach-swiata/chlopiec-na-krancach-swiata-kadr.png?h=539\u0026iar=0\u0026w=1000\u0026rev=2f47411a545f4c36931ac41dcc7698d5","alt":"","width":"1000","height":"539"}},"ticketImageMobile":{"value":{"src":"/-/media/multikino/images/film-and-events/2026/chlopiec-na-krancach-swiata/chlopiec-na-krancach-swiata-kadr.png?h=539\u0026iar=0\u0026w=1000\u0026rev=2f47411a545f4c36931ac41dcc7698d5","alt":"","width":"1000","height":"539"}},"movieXchangeId":{"value":""},"filmId":{"value":"HO00002740"},"childFilmIds":{"value":""},"crossCountryMovieXchangeId":{"value":""},"originalTitle":{"value":""},"consumerAdvice":{"value":""},"certificate":null,"distributor":{"value":"NH"},"genres":[{"id":"a8b85942-127c-4de1-b419-328aab8b0ee4","url":"/content/films/genres/animowany","name":"Animowany","displayName":"Animowany","fields":{"genreName":{"value":"animowany"},"genreId":{"value":3},"seatsToAllocate":{"value":null}}},{"id":"6e5aab54-8a5f-475e-ba2f-efb49ad773c8","url":"/content/films/genres/familijny","name":"Familijny","displayName":"Familijny","fields":{"genreName":{"value":"familijny"},"genreId":{"value":1},"seatsToAllocate":{"value":null}}},{"id":"9ea3385e-ee02-47be-9b62-2e6380613466","url":"/content/films/genres/przygodowy","name":"Przygodowy","displayName":"Przygodowy","fields":{"genreName":{"value":"przygodowy"},"genreId":{"value":14},"seatsToAllocate":{"value":null}}}],"longSynopsis":{"value":""},"secondaryCertificates":[],"shortSynopsis":{"value":"Czy odważyłbyś się wyruszyć tam, gdzie kończy się świat, by uratować kogoś bliskiego? Omul rozumie mowę zwierząt, ale nie potrafi dogadać się z własnym bratem. Los zmusi ich jednak do współpracy, gdy mityczna istota odbierze duszę ich siostrze. Omul jest jedenastoletnim chłopcem, żyjącym z rodzicami, bratem Mikro i siostrą Kimi w wiosce nad morzem. Nie jest jednak zwyczajnym jedenastolatkiem. Gdy morska bestia, mityczna Sadumea, wykrada duszę jego młodszej siostry, Omul wie, że jedynym ratunkiem jest wyprawa na mroźny koniec świata. Dzięki niezwykłemu amuletowi zdobędzie dar rozmawiania ze zwierzętami. Razem z psem Telą i starszym bratem Omul przemierzy Archipelag Ognia, pokona zdradliwe bagna i zmierzy się z zaklętymi potworami.To nie będzie jednak tylko walka z czasem i magią, ale przede wszystkim próba braterskiej więzi. Czy bracia zdołają wybaczyć sobie błędy z przeszłości i odzyskać siostrę, zanim będzie za późno?"},"cast":{"value":""},"director":{"value":"Grzegorz Wacławek, Marta Szymańska"},"duration":{"value":88},"isDurationUnknown":{"value":false},"releaseDate":{"value":"2026-06-26T00:00:00Z"},"alternativeCertificate":null,"attributes":[{"id":"b19c2960-939e-4f89-9d1f-5d8d1838cda4","url":"/content/films/attributes/movie-attributes/familijny","name":"FAMILIJNY","displayName":"FAMILIJNY","fields":{"name":{"value":"FAMILIJNY"},"attributeType":{"id":"893b9186-5bd2-4d22-9abe-c501f891c93d","url":"/sitecore/content/global/content/attributetypes/movie","name":"movie","displayName":"movie","fields":{"type":{"value":"movie"}}},"description":{"value":"Film idealny do wsp\u0026oacute;lnego oglądania \u0026mdash; dla dzieci, rodzic\u0026oacute;w i całych rodzin."},"shortName":{"value":"FAMILIJNY"},"value":{"value":"familijny"},"color":{"value":""},"icon":null,"borderGradient":{"value":""},"backgroundImage":{"value":{}},"relatedAttributes":[],"vistaAttributeId":{"value":""},"priority":{"value":null}}}],"backgroundImage":{"value":{}},"panelImage":{"value":{"src":"/-/media/multikino/images/film-and-events/2026/chlopiec-na-krancach-swiata/chlopiec-na-krancach-swiata-kadr.png?h=539\u0026iar=0\u0026w=1000\u0026rev=2f47411a545f4c36931ac41dcc7698d5","alt":"","width":"1000","height":"539"}},"wideScreenImage":{"value":{"src":"/-/media/multikino/images/film-and-events/2026/chlopiec-na-krancach-swiata/chlopiec-na-krancach-swiata-kadr.png?h=539\u0026iar=0\u0026w=1000\u0026rev=2f47411a545f4c36931ac41dcc7698d5","alt":"","width":"1000","height":"539"}},"associatedTrailers":[],"featuredTrailer":{"id":"015911b4-716a-4496-b7be-fc5e354a076a","url":"/content/films/films/2026/03/16/10/06/chlopiec-na-krancach-swiata/trailers-folder/zwiastun","name":"Film Trailer","displayName":"Zwiastun","fields":{"sendPushNotificationToAll":{"value":false},"streamVideo":{"id":"6058fcc7-9af8-4102-837c-b2a46eeafc57","url":"/-/media/multikino/video/uploads/2026/chlopiec-na-krancach-swiata.ashx?rev=20bbd9c0a60e48eba14ed996a41b2bb3","name":"Chlopiec na krancach swiata","displayName":"Chlopiec na krancach swiata","fields":{"hls":{"value":{"href":"https://customer-s5ao6f6rq71kswao.cloudflarestream.com/928db8f26d7614f1680660017f151a86/manifest/video.m3u8","linktype":"external","url":"https://customer-s5ao6f6rq71kswao.cloudflarestream.com/928db