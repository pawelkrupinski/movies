aRobots":{"value":""},"browserTitle":{"value":"NT Live: Wszyscy moi synowie| Multikino"},"addToSitemap":{"value":true},"sitemapPriority":{"value":0.5}}},{"id":"d556f385-bf31-4a0a-bbee-4213aff9f609","url":"/filmy/nt-live-playboy-zachodniego-swiata","name":"NT Live Playboy zachodniego swiata","displayName":"NT Live Playboy zachodniego swiata","fields":{"embargoEndDate":{"value":"0001-01-01T00:00:00Z"},"embargoLevel":null,"embargoTextMessage":{"value":"Nie możesz się doczekać? Ustaw przypomnienie, a my damy Ci znać, gdy tylko bilety trafią do sprzedaży."},"filmName":{"value":"NT Live: Playboy zachodniego świata"},"ticketImageDesktop":{"value":{"src":"/-/media/multikino/images/wydarzenia/teatr/playboy-zachodniego-swiata/playboy-kadr.jpg?h=667\u0026iar=0\u0026w=1000\u0026rev=46a17ad2017540ecbc07d7c08b92b717","alt":"","width":"1000","height":"667"}},"ticketImageMobile":{"value":{"src":"/-/media/multikino/images/wydarzenia/teatr/playboy-zachodniego-swiata/playboy-kadr.jpg?h=667\u0026iar=0\u0026w=1000\u0026rev=46a17ad2017540ecbc07d7c08b92b717","alt":"","width":"1000","height":"667"}},"movieXchangeId":{"value":""},"filmId":{"value":"HO00002721"},"childFilmIds":{"value":""},"crossCountryMovieXchangeId":{"value":""},"originalTitle":{"value":""},"consumerAdvice":{"value":""},"certificate":null,"distributor":{"value":""},"genres":[{"id":"21c57e7b-fb0e-4535-8215-90c8ec0330db","url":"/content/films/genres/teatr","name":"Teatr","displayName":"Teatr","fields":{"genreName":{"value":"teatr"},"genreId":{"value":28},"seatsToAllocate":{"value":null}}}],"longSynopsis":{"value":""},"secondaryCertificates":[],"shortSynopsis":{"value":"Nicola Coughlan (Bridgertonowie) u boku Éanny Hardwicke (Szóste przykazanie) i Siobhán McSweeney (Derry Girls) w porywającej sztuce pióra Johna Millingtona Synge'a o młodości i odkrywaniu siebie. Życie Pegeen Flaherty wywraca się do góry nogami, gdy do jej pubu wchodzi młody mężczyzna, który twierdzi, że zabił swojego ojca. Zabójca nie spotyka się z potępieniem, lecz staje się lokalnym bohaterem i zaczyna podbijać serca. Wtedy niespodziewanie pojawia się drugi mężczyzna… To filmowana na żywo na scenie National Theatre w reżyserii Caitríony McLaughlin, mroczna, zabawna opowieść naszpikowana sekretami."},"cast":{"value":""},"director":{"value":""},"duration":{"value":150},"isDurationUnknown":{"value":false},"releaseDate":{"value":"2026-06-24T00:00:00Z"},"alternativeCertificate":null,"attributes":[],"backgroundImage":{"value":{}},"panelImage":{"value":{"src":"/-/media/multikino/images/wydarzenia/teatr/playboy-zachodniego-swiata/playboy-kadr.jpg?h=667\u0026iar=0\u0026w=1000\u0026rev=46a17ad2017540ecbc07d7c08b92b717","alt":"","width":"1000","height":"667"}},"wideScreenImage":{"value":{"src":"/-/media/multikino/images/wydarzenia/teatr/playboy-zachodniego-swiata/playboy-kadr.jpg?h=667\u0026iar=0\u0026w=1000\u0026rev=46a17ad2017540ecbc07d7c08b92b717","alt":"","width":"1000","height":"667"}},"associatedTrailers":[],"featuredTrailer":{"id":"7665f01e-196c-4371-b13b-f19f3b473d52","url":"/content/films/films/2026/04/17/07/23/nt-live-playboy-zachodniego-swiata/trailers-folder/zwiastun","name":"Film Trailer","displayName":"Zwiastun","fields":{"sendPushNotificationToAll":{"value":false},"streamVideo":{"id":"8837eb32-48ea-46f3-80d5-828bcfa5ee65","url":"/-/media/multikino/video/uploads/2026/teatr26.ashx?rev=feace79e93c542de9213a9e884027113","name":"Teatr26","displayName":"Teatr26","fields":{"hls":{"value":{"href":"https://customer-s5ao6f6rq71kswao.cloudflarestream.com/e334f40ee150966c3d4a7de58350d59f/manifest/video.m3u8","linktype":"external","url":"https://customer-s5ao6f6rq71kswao.cloudflarestream.com/e334f40ee150966c3d4a7de58350d59f/manifest/video.m3u8"}},"dash":{"value":{"href":"https://customer-s5ao6f6rq71kswao.cloudflarestream.com/e334f40ee150966c3d4a7de58350d59f/manifest/video.mpd","linktype":"external","url":"https://customer-s5ao6f6rq71kswao.cloudflarestream.com/e334f40ee150966c3d4a7de58350d59f/manifest/video.mpd"}},"preview":{"v