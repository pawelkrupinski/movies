4-126d-4f06-972c-15e6804286c6","url":"/content/films/genres/fantasy","name":"Fantasy","displayName":"Fantasy","fields":{"genreName":{"value":"fantastyczny"},"genreId":{"value":22},"seatsToAllocate":{"value":null}}},{"id":"9ea3385e-ee02-47be-9b62-2e6380613466","url":"/content/films/genres/przygodowy","name":"Przygodowy","displayName":"Przygodowy","fields":{"genreName":{"value":"przygodowy"},"genreId":{"value":14},"seatsToAllocate":{"value":null}}}],"longSynopsis":{"value":""},"secondaryCertificates":[],"shortSynopsis":{"value":"Film \"Władcy Wszechświata\" jest oparty na kultowym serialu z lat 80-tych.  Reżyserem jest Travis Knight (Bumblebee), na podstawie scenariusza autorstwa Chrisa Butlera. Producentami filmu „Masters of the Universe” są Todd Black, Jason Blumenthal i Steve Tisch z Escape Artists oraz Robbie Brenner z Mattel Films.  Seria Masters of the Universe, skupiająca się na walce między bohaterskim He-Manem (znanym również jako książę Adam z Eternii) — najpotężniejszym człowiekiem we wszechświecie — a złowrogim Szkieletorem, została wprowadzona na rynek w 1982 roku poprzez serię popularnych figurek. Rok później miała miejsce premiera serialu animowanego „He-Man i Masters of the Universe”,"},"cast":{"value":"Nicholas Galitzine, Camila Mendes, Alison Brie"},"director":{"value":"Travis Knight"},"duration":{"value":null},"isDurationUnknown":{"value":true},"releaseDate":{"value":"2026-06-05T00:00:00Z"},"alternativeCertificate":null,"attributes":[],"backgroundImage":{"value":{}},"panelImage":{"value":{"src":"/-/media/multikino/images/film-and-events/2026/wladcy-wszechswiata/wladcywszechswiata-kadr1.jpg?h=512\u0026iar=0\u0026w=1000\u0026rev=4c1acce3ec0a467f94678bfa0d32a985","alt":"","width":"1000","height":"512"}},"wideScreenImage":{"value":{"src":"/-/media/multikino/images/film-and-events/2026/wladcy-wszechswiata/wladcywszechswiata-kadr1.jpg?h=512\u0026iar=0\u0026w=1000\u0026rev=4c1acce3ec0a467f94678bfa0d32a985","alt":"","width":"1000","height":"512"}},"associat