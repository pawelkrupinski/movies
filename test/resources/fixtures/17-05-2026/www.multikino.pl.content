:""},"secondaryCertificates":[],"shortSynopsis":{"value":"To zuchwała, absurdalna historia o tym, jak Minionki podbiły Hollywood, zostały gwiazdami filmowymi, następnie straciły wszystko, uwolniły straszydła, aby ostatecznie zjednoczyć siły i spróbować ocalić planetę przed chaosem, który same wywołały."},"cast":{"value":""},"director":{"value":"Pierre Coffin"},"duration":{"value":90},"isDurationUnknown":{"value":false},"releaseDate":{"value":"2026-07-01T00:00:00Z"},"alternativeCertificate":null,"attributes":[{"id":"b19c2960-939e-4f89-9d1f-5d8d1838cda4","url":"/content/films/attributes/movie-attributes/familijny","name":"FAMILIJNY","displayName":"FAMILIJNY","fields":{"name":{"value":"FAMILIJNY"},"attributeType":{"id":"893b9186-5bd2-4d22-9abe-c501f891c93d","url":"/sitecore/content/global/content/attributetypes/movie","name":"movie","displayName":"movie","fields":{"type":{"value":"movie"}}},"description":{"value":"Film idealny do wsp\u0026oacute;lnego oglądania \u0026mdash; dla dzieci, rodzic\u0026oacute;w i całych rodzin."},"shortName":{"value":"FAMILIJNY"},"value":{"value":"familijny"},"color":{"value":""},"icon":null,"borderGradient":{"value":""},"backgroundImage":{"value":{}},"relatedAttributes":[],"vistaAttributeId":{"value":""},"priority":{"value":null}}}],"backgroundImage":{"value":{}},"panelImage":{"value":{"src":"/-/media/multikino/images/film-and-events/2026/minionki-i-straszydla/minionki-kadr.jpg?h=458\u0026iar=0\u0026w=1000\u0026rev=4fe16abbf0214cf58c7fc6b8a7d14f9a","alt":"","width":"1000","height":"458"}},"wideScreenImage":{"value":{"src":"/-/media/multikino/images/film-and-events/2026/minionki-i-straszydla/minionki-kadr.jpg?h=458\u0026iar=0\u0026w=1000\u0026rev=4fe16abbf0214cf58c7fc6b8a7d14f9a","alt":"","width":"1000","height":"458"}},"associatedTrailers":[],"featuredTrailer":{"id":"3580a369-e788-4816-a854-5e94b4ecd165","url":"/content/films/films/2026/02/09/12/55/minionki-i-straszydla/trailers-folder/zwiastun","name":"Film Trailer","displayName":"Zwiastu