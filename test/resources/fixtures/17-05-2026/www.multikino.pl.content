wystawy/caravaggio_tlo.jpg?h=659\u0026iar=0\u0026w=1067\u0026rev=ae2988d5ba094c0790489a046b9d7a44","alt":"","width":"1067","height":"659"}},"metaDescription":{"value":"Kup bilety na Caravaggio. Arcydzieła niepokornego geniusza w Multikinie. Obejrzyj zwiastun."},"metaRobots":{"value":""},"browserTitle":{"value":"Caravaggio. Arcydzieła niepokornego geniusza | Multikino"},"addToSitemap":{"value":true},"sitemapPriority":{"value":0.5}}},{"id":"04e6cfe1-b5c7-4e63-82a2-c83b8cbf1b64","url":"/filmy/art-beats-rafael-mody-geniusz","name":"Art Beats Rafael Mody geniusz","displayName":"Art Beats Rafael Mody geniusz","fields":{"embargoEndDate":{"value":"0001-01-01T00:00:00Z"},"embargoLevel":null,"embargoTextMessage":{"value":"Nie możesz się doczekać? Ustaw przypomnienie, a my damy Ci znać, gdy tylko bilety trafią do sprzedaży."},"filmName":{"value":"Art Beats: Rafael. Młody geniusz"},"ticketImageDesktop":{"value":{"src":"/-/media/multikino/images/wydarzenia/wystawy/rafael-kadr.jpg?h=804\u0026iar=0\u0026w=1920\u0026rev=9c0053d94c274a9aab34d304ab3dca05","alt":"","width":"1920","height":"804"}},"ticketImageMobile":{"value":{"src":"/-/media/multikino/images/wydarzenia/wystawy/rafael-kadr.jpg?h=804\u0026iar=0\u0026w=1920\u0026rev=9c0053d94c274a9aab34d304ab3dca05","alt":"","width":"1920","height":"804"}},"movieXchangeId":{"value":""},"filmId":{"value":"HO00002585"},"childFilmIds":{"value":""},"crossCountryMovieXchangeId":{"value":""},"originalTitle":{"value":""},"consumerAdvice":{"value":""},"certificate":null,"distributor":{"value":"nazwywkinach"},"genres":[{"id":"ddef3f90-d82f-4789-b113-bd6d099ea7e1","url":"/content/films/genres/dokumentalny","name":"Dokumentalny","displayName":"Dokumentalny","fields":{"genreName":{"value":"dokument"},"genreId":{"value":4},"seatsToAllocate":{"value":null}}},{"id":"93052461-bad3-48db-a7db-d1ef6c228a38","url":"/content/films/genres/wystawa","name":"Wystawa","displayName":"Wystawa","fields":{"genreName":{"value":"wystawa"},"genreId":{"value":27},"seatsToAllocate":{"value":null}}}],"longSynopsis":{"value":""},"secondaryCertificates":[],"shortSynopsis":{"value":"Zanurz się w epokę renesansu i odkryj wysublimowaną sztukę Rafaela.     Podziwiaj portrety niezwykłych kobiet: Matki, Przyjaciółki, Sekretnej Kochanki i Klientki, których osobowości rozkwitają na płótnach. Matka, która zmarła, gdy artysta miał zaledwie osiem lat. Wielbicielki, które wspierały go na drodze do sukcesu. Kobieta, która niemal przyczyniła się do jego śmierci. Istniały naprawdę lub były tylko wytworem wyobraźni. Rafael (1483-1520) uwiecznił ideał niebiańskiego piękna. Dzięki pracy światowej sławy ekspertów możemy poznać najważniejsze momenty z życia jednego z największych mistrzów renesansu."},"cast":{"value":""},"director":{"value":" Massimo Ferrari"},"duration":{"value":80},"isDurationUnknown":{"value":false},"releaseDate":{"value":"2026-07-13T00:00:00Z"},"alternativeCertificate":null,"attributes":[],"backgroundImage":{"value":{}},"panelImage":{"value":{"src":"/-/media/multikino/images/wydarzenia/wystawy/rafael-kadr.jpg?h=804\u0026iar=0\u0026w=1920\u0026rev=9c0053d94c274a9aab34d304ab3dca05","alt":"","width":"1920","height":"804"}},"wideScreenImage":{"value":{"src":"/-/media/multikino/images/wydarzenia/wystawy/rafael-kadr.jpg?h=804\u0026iar=0\u0026w=1920\u0026rev=9c0053d94c274a9aab34d304ab3dca05","alt":"","width":"1920","height":"804"}},"associatedTrailers":[],"featuredTrailer":{"id":"8ac0338d-1fc0-42c2-9544-032f0c5a8bc2","url":"/content/films/films/2026/01/21/09/37/art-beats-rafael-mody-geniusz/trailers-folder/zwiastun","name":"Film Trailer","displayName":"Zwiastun","fields":{"sendPushNotificationToAll":{"value":false},"streamVideo":{"id":"ff70c043-efec-497c-aa5a-12022a3cddb8","url":"/-/media/multikino/video/uploads/2026/rafael.ashx?rev=a3fce177fc984fef8d6bdfab7d62723c","name":"Rafael","displayName":"Rafael","fields":{"hls":{"value":{"href":"https://customer-s5ao6f6rq71kswao.cloudflarestream.com/2fe2b2b4b911758a69eb49ccf1c73763/manifest/video.m3u8","linktype":"external","url":"https://customer-s5ao6f6rq71kswao.cloudflarestream.com/2fe2b2b4b911758a69eb49ccf1c73763/manifest/video.m3u8"}},"dash":{"value":{"href":"https://customer-s5ao6f6rq71kswao.cloudflarestream.com/2fe2b2b4b911758a69eb49ccf1c73763/manifest/video.mpd","linktype":"external","url":"https://customer-s5ao6f6rq71kswao.cloudflarestream.com/2fe2b2b4b911758a69eb49ccf1c73763/manifest/video.mpd"}},"preview":{"value":{"href":"https://customer-s5ao6f6rq71kswao.cloudflarestream.com/2fe2b2b4b911758a69eb49ccf1c73763/watch","linktype":"external","url":"https://customer-s5ao6f6rq71kswao.cloudflarestream.com/2fe2b2b4b911758a69eb49ccf1c73763/watch"}},"uid":{"value":"2fe2b2b4b911758a69eb49ccf1c73763"},"thumbnail":{"value":"https://customer-s5ao6f6rq71kswao.cloudflarestream.com/2fe2b2b4b911758a69eb49ccf1c73763/thumbnails/thumbnail.jpg"}}},"videoLink":{"value":{"href":""}},"mediaId":{"value":""},"image":{"value":{"src":"/-/media/multikino/images/wydarzenia/wystawy/rafael-kadr.jpg?h=804\u0026iar=0\u0026w=1920\u0026rev=9c0053d94c274a9aab34d304ab3dca05","alt":"","width":"1920","height":"804"}},"sendPushNotificationToSubscribers":{"value":false},"imageLink":{"value":{"href":""}},"isFeature":{"value":true},"certificate":null,"captions":{"value":""}}},"posterImage":{"value":{"src":"/-/media/multikino/images/wydarzenia/wystawy/rafael-plakat.jpg?h=1024\u0026iar=0\u0026w=691\u0026rev=e127f4cbbb104fde8a20d94cf4ba7dc0","alt":"","width":"691","height":"1024"}},"isPremiumPlayTrailerButton":{"value":false},"popularity":{"value":null},"filmPriority":{"value":null},"hidePriceMessage":{"value":false},"searchEntryKeyWords":{"value":""},"searchEntryType":{"value":"film"},"searchEntryTypePriority":{"value":null},"metaKeywords":{"value":"Art Beats: Rafael. Młody geniusz"},"metaImage":{"value":{}},"metaDescription":{"value":"Kup bilety na Art Beats: Rafael. Młody geniusz w Multikinie. Obejrzyj zwiastun."},"metaRobots":{"value":""},"browserTitle":{"value":"Art Beats: Rafael. Młody geniusz | Multikino"},"addToSitemap":{"value":true},"sitemapPriority":{"value":0.5}}},{"id":"997770ff-ec4f-4e9b-90bb-8f12b1b3de72","url":"/filmy/art-beats-lotto-i-berenson---splecione-losy","name":"Art Beats Lotto i Berenson - splecione losy","displayName":"Art Beats Lotto i Berenson - splecione losy","fields":{"embargoEndDate":{"value":"0001-01-01T00:00:00Z"},"embargoLevel":null,"embargoTextMessage":{"value":"Nie możesz się doczekać? Ustaw przypomnienie, a my damy Ci znać, gdy tylko bilety trafią do sprzedaży."},"filmName":{"value":"Art Beats: Lotto i Berenson - splecione losy. Śladami renesansowego mistrza"},"ticketImageDesktop":{"value":{"src":"/-/media/multikino/images/wydarzenia/wystawy/lotto-kadr.jpg?h=563\u0026iar=0\u0026w=1000\u0026rev=c2e3fc695756485dad1e26afde490e5f","alt":"","width":"1000","height":"563"}},"ticketImageMobile":{"value":{"src":"/-/media/multikino/images/wydarzenia/wystawy/lotto-kadr.jpg?h=563\u0026iar=0\u0026w=1000\u0026rev=c2e3fc695756485dad1e26afde490e5f","alt":"","width":"1000","height":"563"}},"movieXchangeId":{"value":""},"filmId":{"value":"HO00002586"},"childFilmIds":{"value":""},"crossCountryMovieXchangeId":{"value":""},"originalTitle":{"value":""},"consumerAdvice":{"value":""},"certificate":null,"distributor":{"value":"nazywowkinach"},"genres":[],"longSynopsis":{"value":""},"secondaryCertificates":[],"shortSynopsis":{"value":"Lotto i Berenson – splecione losy. Śladami renesansowego mistrza to opowieść  o przenikających się losach Lorenza Lotta, zapomnianego szesnastowiecznego malarza, i Bernarda Berensona, krytyka sztuki, któremu zawdzięczamy odkrycie artysty na nowo.      Wyprodukowany przez 3D Produzioni i wyreżyserowany przez Simonę Risi, dokument podąża za aktorem Alessandrem Sperdutim podczas jego podróży śladami Lotta. Dzieła malarza poszukującego sławy i bogactwa, rywalizującego z innymi twórcami, rozproszone są po północnych i centralnych Włoszech; dotrzemy do regionu Marche, do Bergamo, Wenecji. Dzięki zachowanym listom i dokumentom poznajemy nie tylko twórczość malarza, ale i jego osobiste zmagania: ambicję, silną potrzebę uznania, strach przed porażką.  Równolegle śledzimy losy Berensona, młodego litewskiego Żyda, który wychował się w Bostonie i, urzeczony renesansem, wyruszył do Włoch w wieku dwudziestu czterech lat. Zachwycił go talent, z jakim Lotto potrafił uchwycić świat wewnętrzny portretowanych, ich psychologię. Przekonujemy się, że niepokoje i obawy, jakie w odległych epokach żywili Lotto i Berenson, i dziś są nam bliskie. Lotto i Berenson... jest zatem nie tylko refleksją nad sztuką, ale i ludzką naturą."},"cast":{"value":"Alessandro Sperduti"},"director":{"value":"Simona Risi"},"duration":{"value":80},"isDurationUnknown":{"value":false},"releaseDate":{"value":"2026-08-17T00:00:00Z"},"alternativeCertificate":null,"attributes":[],"backgroundImage":{"value":{}},"panelImage":{"value":{"src":"/-/media/multikino/images/wydarzenia/wystawy/lotto-kadr.jpg?h=563\u0026iar=0\u0026w=1000\u0026rev=c2e3fc695756485dad1e26afde490e5f","alt":"","width":"1000","height":"563"}},"wideScreenImage":{"value":{"src":"/-/media/multikino/images/wydarzenia/wystawy/lotto-kadr.jpg?h=563\u0026iar=0\u0026w=1000\u0026rev=c2e3fc695756485dad1e26afde490e5f","alt":"","width":"1000","height":"563"}},"associatedTrailers":[],"featuredTrailer":null,"posterImage":{"value":{"src":"/-/media/multikino/images/wydarzenia/wystawy/lotto-plakat.jpg?h=1024\u0026iar=0\u0026w=717\u0026rev=38a9f6140a1a4ffcab6674adfc953e0e","alt":"","width":"717","height":"1024"}},"isPremiumPlayTrailerButton":{"value":false},"popularity":{"value":null},"filmPriority":{"value":null},"hidePriceMessage":{"value":false},"searchEntryKeyWords":{"value":""},"searchEntryType":{"value":"film"},"searchEntryTypePriority":{"value":null},"metaKeywords":{"value":"Art Beats: Lotto i Berenson - splecione losy. Śladami renesansowego mistrza"},"metaImage":{"value":{}},"metaDescription":{"value":"Kup bilety na Art Beats: Lotto i Berenson - splecione losy. Śladami ren