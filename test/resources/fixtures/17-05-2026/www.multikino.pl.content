1024\u0026iar=0\u0026w=690\u0026rev=d55bc88afb2b4c949d93ba3113f446ce","alt":"","width":"690","height":"1024"}},"isPremiumPlayTrailerButton":{"value":false},"popularity":{"value":null},"filmPriority":{"value":null},"hidePriceMessage":{"value":false},"searchEntryKeyWords":{"value":""},"searchEntryType":{"value":"film"},"searchEntryTypePriority":{"value":null},"metaKeywords":{"value":"La Traviata Verdiego z Arena di Verona"},"metaImage":{"value":{}},"metaDescription":{"value":"Kup bilety na La Traviata Verdiego z Arena di Verona w Multikinie. Obejrzyj zwiastun."},"metaRobots":{"value":""},"browserTitle":{"value":"La Traviata Verdiego z Arena di Verona | Multikino"},"addToSitemap":{"value":true},"sitemapPriority":{"value":0.5}}},{"id":"724ac83d-f587-434e-9316-3d478b375941","url":"/filmy/nt-live-wszyscy-moi-synowie","name":"NT Live Wszyscy moi synowie","displayName":"NT Live Wszyscy moi synowie","fields":{"embargoEndDate":{"value":"0001-01-01T00:00:00Z"},"embargoLevel":null,"embargoTextMessage":{"value":"Nie możesz się doczekać? Ustaw przypomnienie, a my damy Ci znać, gdy tylko bilety trafią do sprzedaży."},"filmName":{"value":"NT Live: Wszyscy moi synowie"},"ticketImageDesktop":{"value":{"src":"/-/media/global/img/film-panel-default-image.png?h=720\u0026iar=0\u0026w=1440\u0026rev=-1","alt":"","width":"1440","height":"720"}},"ticketImageMobile":{"value":{"src":"/-/media/global/img/film-panel-default-image.png?h=720\u0026iar=0\u0026w=1440\u0026rev=-1","alt":"","width":"1440","height":"720"}},"movieXchangeId":{"value":""},"filmId":{"value":"HO00002720"},"childFilmIds":{"value":""},"crossCountryMovieXchangeId":{"value":""},"originalTitle":{"value":""},"consumerAdvice":{"value":""},"certificate":null,"distributor":{"value":""},"genres":[{"id":"21c57e7b-fb0e-4535-8215-90c8ec0330db","url":"/content/films/genres/teatr","name":"Teatr","displayName":"Teatr","fields":{"genreName":{"value":"teatr"},"genreId":{"value":28},"seatsToAllocate":{"value":null}}}],"longSynopsis":{"value":""},"secondaryCertificates":[],"shortSynopsis":{"value":"Bryan Cranston (Breaking Bad) i Marianne Jean-Baptiste (Niewygodna prawda) w pięciogwiazdkowej, entuzjastycznie przyjętej przez krytyków i widownię nowej inscenizacji klasycznej sztuki Arthura Millera, w reżyserii wizjonera Ivo Van Hove’a (Widok z mostu). Dzieje rodziny w złotej erze amerykańskiego snu. Wojna przynosi Joemu spore zyski, ale przychodzi mu zapłacić wysoką cenę, gdy wspólnik zostaje oskarżony o zaniedbania produkcyjne, a najstarszy syn zostaje uznany za zaginionego na froncie. Czy czas pokoju przyniesie mu spokój ducha, czy też będzie musiał zmierzyć się z konsekwencjami swoich czynów? W tej niepokojąco proroczej sztuce, nagranej na żywo na West Endzie, występują również Paapa Essiedu (Mogę cię zniszczyć), Tom Glynn-Carney (Ród smoka) i Hayley Squires (Ja, Daniel Blake)."},"cast":{"value":""},"director":{"value":""},"duration":{"value":130},"isDurationUnknown":{"value":false},"releaseDate":{"value":"2026-05-27T00:00:00Z"},"alternativeCertificate":null,"attributes":[],"backgroundImage":{"value":{}},"panelImage":{"value":{"src":"/-/media/global/img/film-panel-default-image.png?h=720\u0026iar=0\u0026w=1440\u0026rev=-1","alt":"","width":"1440","height":"720"}},"wideScreenImage":{"value":{"src":"/-/media/global/img/film-panel-default-image.png?h=720\u0026iar=0\u0026w=1440\u0026rev=-1","alt":"","width":"1440","height":"720"}},"associatedTrailers":[],"featuredTrailer":{"id":"fc5496a7-8234-4a66-8fe8-76b275d51e2a","url":"/content/films/films/2026/04/17/07/22/nt-live-wszyscy-moi-synowie/trailers-folder/zwiastun","name":"Film Trailer","displayName":"Zwiastun","fields":{"sendPushNotificationToAll":{"value":false},"streamVideo":{"id":"8837eb32-48ea-46f3-80d5-828bcfa5ee65","url":"/-/media/multikino/video/uploads/2026/teatr26.ashx?rev=feace79e93c542de9213a9e884027113","name":"Teatr26","displayName":"Teatr26","fields":{"hls":{"value":{"href":"https://customer-s5ao6f6rq71kswao.cloudflarestream.com/e334f40ee150966c