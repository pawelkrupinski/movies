                            <li class="js-search-filter searchNav__filter" data-filter="movie" tabindex="0"><span data-qa="search-filter-text">Movies (1927)</span></li>
                        
                        
                            <li class="js-search-filter searchNav__filter" data-filter="tvSeries" tabindex="0"><span data-qa="search-filter-text">TV Shows (390)</span></li>
                        
                        
                    </ul>
                </nav>

                
                    <search-page-result skeleton="panel" type="movie" data-qa="search-result">
                        <h2 class="unset" slot="title" data-qa="search-result-title">
                            <rt-text context="heading" size="1.25"> Movies </rt-text>
                        </h2>
                        <button slot="prev-btn" data-qa="paging-btn-prev">Prev</button>
