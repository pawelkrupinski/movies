<script>
(function () {
    var SEAT_PRICE = 25;
    var ROWS = ['A','B','C','D','E','F','G','H'];
    var SEATS_PER_ROW = 10;

    // Seeded pseudo-random occupied seats (stable per session)
    var occupiedSeeds = [2,5,7,12,15,23,31,42,47,55,61,68,73];
    function isOccupied(idx) {
        return occupiedSeeds.indexOf(idx) !== -1;
    }

    var selectedSeats = [];

    // ---- DATE STRIP ----
    var activeDate = '20260605';  // domyślnie dzisiaj

    var dateBtns = document.querySelectorAll('.cks-date-btn');
    dateBtns.forEach(function (btn) {
        btn.addEventListener('click', function () {
            var clickedDate = btn.getAttribute('data-date');
            // Kliknięcie aktywnej daty → odznacz (pokaż wszystkie)
            if (activeDate === clickedDate) {
                activeDate = '';
                dateBtns.forEach(function (b) {
                    b.classList.remove('bg-swit-gold', 'text-white', 'shadow-md');
                    b.classList.add('bg-gray-100', 'text-gray-700', 'hover:bg-gray-200');
                });
            } else {
                activeDate = clickedDate;
                dateBtns.forEach(function (b) {
                    b.classList.remove('bg-swit-gold', 'text-white', 'shadow-md');
                    b.classList.add('bg-gray-100', 'text-gray-700', 'hover:bg-gray-200');
                });
                btn.classList.remove('bg-gray-100', 'text-gray-700', 'hover:bg-gray-200');
                btn.classList.add('bg-swit-gold', 'text-white', 'shadow-md');
            }
            applyFilters();
        });
    });

    // ---- FILTERS ----
    var activeRating = 'Wszystkie';
    var activeAudio = false;

    function applyFilters() {
        var cards = document.querySelectorAll('.cks-movie-card');
        var visible = 0;
        cards.forEach(function (card) {
            var r     = card.getAttribute('data-rating');
            var a     = card.getAttribute('data-audio') === '1';
            var dates = JSON.parse(card.getAttribute('data-event-dates') || '[]');
            var show  = true;
            if (activeRating !== 'Wszystkie' && r !== activeRating) show = false;
            if (activeAudio && !a) show = false;
            if (activeDate && dates.length > 0 && dates.indexOf(activeDate) === -1) show = false;
            card.classList.toggle('hidden', !show);
            if (show) visible++;

            // Filtruj godziny seansów wewnątrz karty
            card.querySelectorAll('.cks-showtime-item').forEach(function (item) {
                var itemDate = item.getAttribute('data-showtime-date') || '';
                var showItem = !activeDate || itemDate === activeDate;
                item.classList.toggle('hidden', !showItem);
                // Ukryj prefix daty gdy filtr daty aktywny (pokazuj tylko godzinę)
                var dateSpan = item.querySelector('.cks-st-date');
                if (dateSpan) dateSpan.style.display = activeDate ? 'none' : '';
            });
        });
        document.getElementById('cks-no-movies').classList.toggle('hidden', visible > 0);

        var hasFilters = activeRating !== 'Wszystkie' || activeAudio || activeDate !== '';
        document.getElementById('cks-clear-btn').classList.toggle('hidden', !hasFilters);

        // Rating button style
        var rBtn = document.getElementById('cks-rating-btn');
        if (activeRating !== 'Wszystkie') {
            rBtn.classList.add('bg-swit-gold', 'text-white');
            rBtn.classList.remove('bg-white', 'text-swit-gold', 'hover:bg-swit-gold', 'hover:text-white');
        } else {
            rBtn.classList.remove('bg-swit-gold', 'text-white');
            rBtn.classList.add('bg-white', 'text-swit-gold', 'hover:bg-swit-gold', 'hover:text-white');
        }

        // Audio button style
        var aBtn = document.getElementById('cks-audio-btn');
        if (activeAudio) {
            aBtn.classList.add('bg-swit-gold', 'text-white');
            aBtn.classList.remove('bg-white', 'text-swit-gold', 'hover:bg-swit-gold', 'hover:text-white');
        } else {
            aBtn.classList.remove('bg-swit-gold', 'text-white');
            aBtn.classList.add('bg-white', 'text-swit-gold', 'hover:bg-swit-gold', 'hover:text-white');
        }
    }

    // Rating dropdown
    var ratingDropdown = document.querySelector('.cks-cinema-dropdown');
    var ratingMenu     = ratingDropdown ? ratingDropdown.querySelector('.cks-cinema-dd-menu') : null;
    var ratingChevron  = ratingDropdown ? ratingDropdown.querySelector('.cks-cinema-chevron') : null;

    if (ratingDropdown) {
        document.getElementById('cks-rating-btn').addEventListener('click', function (e) {
            e.stopPropagation();
            ratingMenu.classList.toggle('hidden');
            if (ratingChevron) ratingChevron.classList.toggle('rotate-180');
        });
        document.addEventListener('click', function () {
            ratingMenu.classList.add('hidden');
            if (ratingChevron) ratingChevron.classList.remove('rotate-180');
        });

        document.querySelectorAll('.cks-rating-option').forEach(function (opt) {
            opt.addEventListener('click', function () {
                activeRating = opt.getAttribute('data-rating');
                ratingMenu.classList.add('hidden');
                if (ratingChevron) ratingChevron.classList.remove('rotate-180');
                // Update active option highlight
                document.querySelectorAll('.cks-rating-option').forEach(function (o) {
                    o.classList.remove('font-semibold', 'text-swit-gold', 'bg-amber-50');
                    o.classList.add('text-gray-700');
                });
                opt.classList.add('font-semibold', 'text-swit-gold', 'bg-amber-50');
                opt.classList.remove('text-gray-700');
                applyFilters();
            });
        });
    }

    // Audio toggle
    document.getElementById('cks-audio-btn').addEventListener('click', function () {
        activeAudio = !activeAudio;
        applyFilters();
    });

    // Pokaż cały repertuar — czyści tylko filtr daty
    document.getElementById('cks-all-repertuar-btn').addEventListener('click', function () {
        activeDate = '';
        dateBtns.forEach(function (b) {
            b.classList.remove('bg-swit-gold', 'text-white', 'shadow-md');
            b.classList.add('bg-gray-100', 'text-gray-700', 'hover:bg-gray-200');
        });
        applyFilters();
    });

    // Clear filters
    document.getElementById('cks-clear-btn').addEventListener('click', function () {
        activeRating = 'Wszystkie';
        activeAudio = false;
        activeDate = '';
        dateBtns.forEach(function (b) {
            b.classList.remove('bg-swit-gold', 'text-white', 'shadow-md');
            b.classList.add('bg-gray-100', 'text-gray-700', 'hover:bg-gray-200');
        });
        document.querySelectorAll('.cks-rating-option').forEach(function (o) {
            o.classList.remove('font-semibold', 'text-swit-gold', 'bg-amber-50');
            o.classList.add('text-gray-700');
            if (o.getAttribute('data-rating') === 'Wszystkie') {
                o.classList.add('font-semibold', 'text-swit-gold', 'bg-amber-50');
                o.classList.remove('text-gray-700');
            }
        });
        applyFilters();
    });

    // Zastosuj filtr daty przy załadowaniu strony
    applyFilters();

    // ---- BOOKING MODAL ----
    var modal     = document.getElementById('cks-booking-modal');
    var modalTitle = document.getElementById('cks-modal-title');
    var modalTime  = document.getElementById('cks-modal-time');
    var seatMap    = document.getElementById('cks-seat-map');
    var seatsLabel = document.getElementById('cks-selected-seats-label');
    var totalPrice = document.getElementById('cks-total-price');
    var confirmBtn = document.getElementById('cks-confirm-btn');

    function buildSeatMap() {
        seatMap.innerHTML = '';
        selectedSeats = [];
        updateSummary();

        ROWS.forEach(function (row) {
            var rowDiv = document.createElement('div');
            rowDiv.className = 'flex items-center justify-center gap-2';

            var label = document.createElement('span');
            label.className = 'w-6 text-sm font-medium text-gray-600';
            label.textContent = row;
            rowDiv.appendChild(label);

            for (var i = 1; i <= SEATS_PER_ROW; i++) {
                var seatId  = row + i;
                var idx     = ROWS.indexOf(row) * SEATS_PER_ROW + (i - 1);
                var occupied = isOccupied(idx);

                var btn = document.createElement('button');
                btn.className = 'w-8 h-8 rounded-t-lg transition-all text-xs ';
                if (occupied) {
                    btn.className += 'bg-gray-300 cursor-not-allowed text-gray-500';
                    btn.disabled = true;
                    btn.textContent = '✕';
                } else {
                    btn.className += 'bg-gray-100 hover:bg-amber-50 text-gray-700';
                    btn.textContent = i;
                    btn.setAttribute('data-seat', seatId);
                    btn.addEventListener('click', function () {
                        toggleSeat(this);
                    });
                }
                rowDiv.appendChild(btn);
            }
            seatMap.appendChild(rowDiv);
        });
    }

    function toggleSeat(btn) {
        var seat = btn.getAttribute('data-seat');
        var idx = selectedSeats.indexOf(seat);
        if (idx === -1) {
            selectedSeats.push(seat);
            btn.classList.remove('bg-gray-100', 'hover:bg-amber-50', 'text-gray-700');
            btn.classList.add('bg-swit-gold', 'text-white', 'shadow-md');
        } else {
            selectedSeats.splice(idx, 1);
            btn.classList.remove('bg-swit-gold', 'text-white', 'shadow-md');
            btn.classList.add('bg-gray-100', 'hover:bg-amber-50', 'text-gray-700');
        }
        updateSummary();
    }

    function updateSummary() {
        if (selectedSeats.length === 0) {
            seatsLabel.textContent = 'Brak';
            totalPrice.textContent = '0 PLN';
            confirmBtn.className = 'w-full py-3 rounded-lg font-semibold bg-gray-200 text-gray-400 cursor-not-allowed transition-all';
        } else {
            seatsLabel.textContent = selectedSeats.join(', ');
            totalPrice.textContent = (selectedSeats.length * SEAT_PRICE) + ' PLN';
            confirmBtn.className = 'w-full py-3 rounded-lg font-semibold bg-swit-gold text-white hover:bg-amber-800 shadow-md transition-all cursor-pointer';
            var n = selectedSeats.length;
            var bilety = n === 1 ? 'bilet' : (n < 5 ? 'bilety' : 'biletów');
            confirmBtn.textContent = 'Potwierdź rezerwację (' + n + ' ' + bilety + ')';
        }
    }

    function openModal(movieTitle, time) {
        modalTitle.textContent = movieTitle;
        modalTime.textContent  = time;
        buildSeatMap();
        modal.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
    }

    function closeModal() {
        modal.classList.add('hidden');
        document.body.style.overflow = '';
    }

    document.getElementById('cks-modal-close').addEventListener('click', closeModal);
    modal.addEventListener('click', function (e) {
        if (e.target === modal) closeModal();
    });

    document.querySelectorAll('.cks-showtime-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
            openModal(
                btn.getAttribute('data-movie-title'),
                btn.getAttribute('data-time')
            );
        });
    });

    confirmBtn.addEventListener('click', function () {
        if (selectedSeats.length === 0) return;
        alert('Rezerwacja złożona! Skontaktujemy się z Tobą wkrótce.');
        closeModal();
    });

})();
</script>


