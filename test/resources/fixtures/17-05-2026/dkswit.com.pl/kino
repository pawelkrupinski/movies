        },
        post: {
            label: 'Artykuł',
            color: 'bg-gray-100 text-gray-700',
            icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9.5a2 2 0 00-.586-1.414l-4.5-4.5A2 2 0 0013.5 3H5z"/></svg>'
        },
        page: {
            label: 'Strona',
            color: 'bg-gray-100 text-gray-700',
            icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>'
        }
    };

    function getType(t) {
        return typeConfig[t] || typeConfig['page'];
    }

    function pluralCount(n) {
        if (n === 1) return '1 wynik';
        if (n >= 2 && n <= 4) return n + ' wyniki';
        return n + ' wyników';
    }

    function showLoading() {
        loader.style.display = 'flex';
        list.innerHTML = '';
        count.textContent = '';
        footer.style.display = 'none';
        modal.style.display = 'flex';
    }

    function renderResults(data) {
        loader.style.display = 'none';

        if (!data.results.length) {
            list.innerHTML = '<div class="px-6 py-10 text-center text-gray-500">' +
                '<svg class="w-10 h-10 mx-auto mb-3 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>' +
                '<p class="font-medium">Brak wyników</p>' +
                '<p class="text-sm mt-1">Spróbuj innych słów kluczowych</p>' +
                '</div>';
            count.textContent = 'Brak wyników dla: "' + escHtml(data.query) + '"';
            footer.style.display = 'none';
            return;
        }

        count.textContent = pluralCount(data.results.length) + ' dla: "' + escHtml(data.query) + '"';

        allLink.href = 'https://dkswit.com.pl/?s=' + encodeURIComponent(data.query);
        footer.style.display = 'block';

        var html = '';
        data.results.forEach(function (r) {
            var cfg = getType(r.type);
            html += '<a href="' + escHtml(r.url) + '" class="flex items-start gap-4 px-6 py-4 hover:bg-gray-50 transition-colors border-b border-gray-100 last:border-0 group" onclick="cksSearchClose()">';
            html += '<div class="flex-shrink-0 w-10 h-10 bg-[#996515]/10 rounded-lg flex items-center justify-center text-[#996515] group-hover:bg-[#996515] group-hover:text-white transition-colors">' + cfg.icon + '</div>';
            html += '<div class="flex-1 min-w-0">';
            html += '<div class="flex items-center gap-2 mb-0.5">';
            html += '<span class="font-semibold text-gray-900 group-hover:text-[#996515] transition-colors truncate">' + escHtml(r.title) + '</span>';
            if (r.category) {
                html += '<span class="flex-shrink-0 text-xs px-2 py-0.5 rounded-full ' + cfg.color + '">' + escHtml(r.category) + '</span>';
            } else {
                html += '<span class="flex-shrink-0 text-xs px-2 py-0.5 rounded-full ' + cfg.color + '">' + cfg.label + '</span>';
            }
            html += '</div>';
            if (r.description) {
                html += '<p class="text-sm text-gray-500 line-clamp-2">' + escHtml(r.description) + '</p>';
            }
            if (r.date) {
                html += '<div class="flex items-center gap-1 mt-1 text-xs text-gray-400">';
                html += '<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>';
                html += escHtml(r.date);
                html += '</div>';
            }
            html += '</div>';
            html += '</a>';
        });
        list.innerHTML = html;
    }

    function escHtml(str) {
        return String(str)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;');
    }

    function doSearch(q) {
        if (!window.cksAjax) return;
        showLoading();
        fetch(cksAjax.ajaxurl + '?action=cks_search&nonce=' + encodeURIComponent(cksAjax.nonce) + '&q=' + encodeURIComponent(q))
            .then(function (r) { return r.json(); })
            .then(function (resp) {
                if (resp.success) renderResults(resp.data);
                else loader.style.display = 'none';
            })
            .catch(function () { loader.style.display = 'none'; });
    }

    // Debounced input handler
    input.addEventListener('input', function () {
        clearTimeout(timer);
        var q = this.value.trim();
        if (q.length < 2) { cksSearchClose(); return; }
        timer = setTimeout(function () { doSearch(q); }, 350);
    });

    // Prevent native form submit
    form.addEventListener('submit', function (e) {
        e.preventDefault();
        var q = input.value.trim();
        if (q.length >= 2) doSearch(q);
    });

    // Close modal
    window.cksSearchClose = function (e) {
        if (e && e.target !== modal) return;
        modal.style.display = 'none';
        loader.style.display = 'none';
        footer.style.display = 'none';
    };

    // Escape key
    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') cksSearchClose();
    });

    // Mobile sidebar search input (shares the same modal)
    var sidebarInput = document.getElementById('sidebar-search-input');
    if (sidebarInput) {
        sidebarInput.addEventListener('input', function () {
            clearTimeout(timer);
            var q = this.value.trim();
            if (q.length < 2) { cksSearchClose(); return; }
            timer = setTimeout(function () { doSearch(q); }, 350);
        });
    }
})();
</script>

