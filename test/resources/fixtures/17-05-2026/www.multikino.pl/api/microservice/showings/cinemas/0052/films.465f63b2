nguage","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 3","sessionPricingDisplayStatus":1,"wheelchairSeatAvailability":1}]}],"filmId":"HO00002706","certificate":{"name":null,"description":null,"src":null},"secondaryCertificates":[],"filmUrl":"https://www.multikino.pl/filmy/all-you-need-is-kill","filmAttributes":[],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/images/film-and-events/2026/all-you-need-is-kill/allyouneediskill_plakat.jpg?rev=08b1e09f55e449e68afb83c40faed6e7","cast":"","releaseDate":"2026-06-19T00:00:00","runningTime":83,"isDurationUnknown":false,"synopsisShort":"Akcja filmu „ALL YOU NEED IS KILL” rozgrywa się w roku 20XX i opowiada historię Rity, zaradnej, ale samotnej młodej kobiety, która zgłasza się na ochotnika do pomocy przy odbudowie Japonii po tajemniczym pojawieniu się ogromnego obcego kwiatu znanego jako „Darol”. Kiedy Darol niespodziewanie wybucha, wywołując śmiertelne wydarzenie i uwalniając potworne stworzenia, które dziesiątkują populację, Rita zostaje wciągnięta w zniszczenie – i ginie. Ale potem budzi się ponownie. I znowu. Uwięziona w niekończącej się pętli czasowej, Rita musi zmagać się z traumą i powtarzającą się śmiercią, aż w końcu spotyka Keiji, nieśmiałego młodego mężczyznę uwięzionego w tym samym cyklu. Razem walczą, by wyrwać się z pętli i odnaleźć sens w otaczającym ich chaosie.","filmTitle":"All You Need Is Kill","hasSessions":true,"hasTrailer":false,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":n