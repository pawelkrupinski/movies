mageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 6","sessionPricingDisplayStatus":1,"wheelchairSeatAvailability":1}]}],"filmId":"HO00002773","certificate":{"name":null,"description":null,"src":null},"secondaryCertificates":[],"filmUrl":"https://www.multikino.pl/filmy/minimaraton-superman-i-supergirl","filmAttributes":[],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/images/maraton/superduo/maratonsuperduo_plakat.jpg?rev=ec5a2979870645fead22bab34742a2c8","cast":"","releaseDate":"2026-06-26T00:00:00","runningTime":248,"isDurationUnknown":false,"synopsisShort":"Zapraszamy fanów losów superbohaterów na wyjątkowy Minimaraton „Superman i Supergirl”, który odbędzie się 26 czerwca 2026 roku w wybranych kinach sieci Multikino w całej Polsce. Tego wieczoru widzowie zobaczą dwa widowiskowe filmy z uniwersum DC, pełne spektakularnej akcji, emocji i międzygalaktycznych przygód. W ramach Minimaratonu premierowo na wielkim ekranie zostanie zaprezentowana „Supergirl”, której premiera przypada właśnie na 26 czerwca. Kara Zor-El, znana jako Supergirl, wyruszy w pełną niebezpieczeństw podróż w poszukiwaniu zemsty i sprawiedliwości. W roli głównej zobaczymy Milly Alcock, a na ekranie pojawią się także Jason Momoa oraz Matthias Schoenaerts. Pokaz premierowy poprzedzi „Superman” w reżyserii Jamesa Gunna, ostatnia odsłona historii jednego z najbardziej ikonicznych superbohaterów wszech czasów. Film przedstawia Supermana jako bohatera kierującego się współczuciem oraz głęboko zakorzenioną wiarą w dobro ludzkości. Produkcja łączy widowiskową akcję, humor i emocje, otwierając nowy rozdział filmowego uniwersum DC Studios.","filmTitle":"M