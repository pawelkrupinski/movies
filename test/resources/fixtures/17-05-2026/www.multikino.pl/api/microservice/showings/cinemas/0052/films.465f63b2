l":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"KULTOWE KINO","shortName":"KULTOWE KINO","value":"","description":"<span style=\"color: #474747; background-color: #ffffff;\">Największe polskie i światowe hity ponownie na wielkim ekranie!</span>","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 3","sessionPricingDisplayStatus":1,"wheelchairSeatAvailability":1}]}],"filmId":"HO00001674","certificate":{"name":null,"description":null,"src":null},"secondaryCertificates":[],"filmUrl":"https://www.multikino.pl/filmy/spirited-away-w-krainie-bogow","filmAttributes":[],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/multikino_imported/images/films-and-events/2024/ghibli/spirited_away_plakatpl_hq-cut.jpg?rev=863d8e00f1794bb3bd69d2bbb12a2a4a","cast":"","releaseDate":"2024-05-10T00:00:00","runningTime":0,"isDurationUnknown":false,"synopsisShort":"Nagrodzony Oscarem dla Najlepszego Filmu Animowanego, „Spirited Away: W krainie bogów” to arcydzieło światowego kina stworzone przez jednego z najbardziej cenionych twórców animacji, Hayao Miyazakiego. Dziesięcioletnia Chihiro wraz z rodzicami trafia do tajemniczego, opuszczonego miasteczka. Ku swojemu przerażeniu, dziewczynka odkrywa, że to kraina zamieszkana przez bóstwa i duchy, a jej rodzicie zostali przemienieni... w świnie! Aby ich ocalić, Chihiro będzie musiała rozpocząć pracę u potężnej wiedźmy Jubaby. Czy dziewczynce uda się zdjąć z rodziców klątwę? Film z polskim napisami lub polskim dubbingiem, dla widzów od 10. roku życia.","filmTitle":"Spirited Away: W krainie bogów","hasSessions":true,"hasTrailer":false,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,