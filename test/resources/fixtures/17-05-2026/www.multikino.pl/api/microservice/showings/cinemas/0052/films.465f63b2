}]},{"date":"2026-07-15T00:00:00","datePrefix":"","pricingTypes":[],"sessions":[{"sessionId":"65831","bookingUrl":"/rezerwacja-biletow/podsumowanie/0052/HO00002585/65831","formattedPrice":"27,90 zł","isPriceVisible":true,"duration":80,"startTime":"2026-07-15T12:30:00","endTime":"2026-07-15T14:05:00","showTimeWithTimeZone":"2026-07-15T12:30:00+02:00","isSoldOut":false,"color":null,"isMidnightSession":false,"isBookingAvailable":true,"attributes":[{"name":"Projektor laserowy","shortName":"Projektor laserowy","value":"Projektor laserowy","description":"Projektor laserowy","attributeType":"Session_Special","color":"#FFA500","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"WYSTAWY","shortName":"WYSTAWY - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 3","sessionPricingDisplayStatus":1,"wheelchairSeatAvailability":1}]}],"filmId":"HO00002585","certificate":{"name":null,"description":null,"src":null},"secondaryCertificates":[],"filmUrl":"https://www.multikino.pl/filmy/art-beats-rafael-mody-geniusz","filmAttributes":[{"name":"WYSTAWY","shortName":"WYSTAWY - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/images/wydarzenia/wystawy/rafael-plakat.jpg?rev=e127f4cbbb104fde8a20d94cf4ba7dc0","cast":"","releaseDate":"2026-07-13T00:00:00","runningTime":80,"isDurationUnknown":false,"synopsisShort":"Zanurz się w epokę renesansu i odkryj wysublimowaną sztukę Rafaela.     Podziwiaj portrety niezwykłych kobiet: Matki, Przyjaciółki, Sekretnej Kochanki i Klientki, których osobowości rozkwitają na płótnach. Matka, która zmarła, gdy artysta miał zaledwie osiem lat. Wielbicielki, które wspierały go na drodze do sukcesu. Kobieta, która niemal przyczyniła się do jego śmierci. Istniały naprawdę lub były tylko wytworem wyobraźni. Rafael (1483-1520) uwiecznił ideał niebiańskiego piękna. Dzięki pracy światowej sławy ekspertów możemy poznać najważniejsze momenty z życia jednego z największych mistrzów renesansu.","filmTitle":"Art Beats: Rafael. Młody geniusz","hasSessions":true,"hasTrailer":true,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/images/wydarzenia/wystawy/rafael-kadr.jpg?rev=9c0053d94c274a9aab34d304ab3dca05","filmStatus":2,"trailers":[],"director":" Massimo Ferrari","distributor":"nazwywkinach","movieXchangeCode":"","crossCountryMovieXchangeId":"","originalTitle":"","showingInCinemas":["0003","0004","0005","0006","0007","0008","0010","0011","0013","0014","0015","0023","0024","0025","0026","0028","0029","0030","0031","0033","0034","0035","0036","0037","0038","0039","0040","0041","0042","0043","0044","0047","0048","0050","0051","0052","0053"],"genres":[],"sessionAttributes":[{"name":"Projektor laserowy","shortName":"Projektor laserowy","value":"Projektor laserowy","description":"Projektor laserowy","attributeType":"Session_Special","color":"#FFA500","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"WYSTAWY","shortName":"WYSTAWY - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGr