ions":[{"sessionId":"72939","bookingUrl":"/rezerwacja-biletow/podsumowanie/0052/HO00002488/72939","formattedPrice":"14,90 zł","isPriceVisible":true,"duration":0,"startTime":"2026-06-08T10:00:00","endTime":"2026-06-08T11:56:00","showTimeWithTimeZone":"2026-06-08T10:00:00+02:00","isSoldOut":false,"color":null,"isMidnightSession":false,"isBookingAvailable":true,"attributes":[{"name":"Projektor laserowy","shortName":"Projektor laserowy","value":"Projektor laserowy","description":"Projektor laserowy","attributeType":"Session_Special","color":"#FFA500","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"POLSKI","shortName":"POLSKI","value":"POLSKI","description":"","attributeType":"Language","color":"#FFFFFF","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"SZKOŁY","shortName":"SZKOŁY","value":"SZKOŁY","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 6","sessionPricingDisplayStatus":1,"wheelchairSeatAvailability":1}]}],"filmId":"HO00002488","certificate":{"name":null,"description":null,"src":null},"secondaryCertificates":[],"filmUrl":"https://www.multikino.pl/filmy/za-duzy-na-bajki-3","filmAttributes":[],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/images/film-and-events/2026/za-duzy-na-bajki-3/zaduzynabajki3_plakat.jpg?rev=9b8f08e7580848568d5657d0881b4a65","cast":"Maciej Karaś, Amelia Fijałkowska, Patryka Siemek, Karolina Gruszka","releaseDate":"2026-03-06T00:00:00","runningTime":0,"isDurationUnknown":true,"synopsisShort":"Waldek ma dość – w domu chaos, w sieci drama, a jego gamingowy team się sypie. W emocjach robi coś głupiego – pisze złośliwy komentarz… i nieświadomie uruchamia lawinę hejtu, która uderza w jedną z najbliższych mu osób – Delfinę. Przygnieciony ciężarem własnego błędu, Waldi nie potrafi przyznać się ani Staszkowi, ani rodzinie, że to on zapoczątkował łańcuch nienawiści. Ale kiedy sytuacja zaczyna zagrażać bezpieczeństwu Delfiny, chłopak wie, że musi działać i staje do walki – nie tylko z hejterami, ale i własnym strachem. Czy Waldek znajdzie odwagę, by przyznać się do winy? Czy uda mu się uratować przyjaźń? I czy naprawdę jeden komentarz w sieci może zniszczyć komuś życie?","filmTitle":"Za duży na bajki 3","hasSessions":true,"hasTrailer":true,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/images/film-and-events/2026/za-duzy-na-bajki-3/za-duzy-na-bajki-3-kadr.jpg?rev=c3a3986dba6b4269b9f40b505cc2f16d","filmStatus":1,"trailers":[],"director":"Kristoffer Rus","distributor":"Next Film","movieXchangeCode":"8d82a23a-265a-4e35-9320-dff467b850fe","crossCountryMovieXchangeId":"","originalTitle":"","showingInCinemas":["0011","0024","0044","0052"],"genres":[],"sessionAttributes":[{"name":"Projektor laserowy","shortName":"Projektor laserowy","value":"Projektor laserowy","description":"Projektor laserowy","attributeType":"Session_Special","color":"#FFA500","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"POLSKI","shortName":"POLSKI","value":"POLSKI","description":"","attributeType":"Language","color":"#FFFFFF","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType"