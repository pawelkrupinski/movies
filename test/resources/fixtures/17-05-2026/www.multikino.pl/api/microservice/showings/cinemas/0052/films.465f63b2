ion":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 4","sessionPricingDisplayStatus":1,"wheelchairSeatAvailability":1}]}],"filmId":"HO00002591","certificate":{"name":null,"description":null,"src":null},"secondaryCertificates":[],"filmUrl":"https://www.multikino.pl/filmy/la-traviata-verdiego-z-arena-di-verona","filmAttributes":[{"name":"OPERA","shortName":"OPERA - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/images/wydarzenia/opera/latraviata2026_plakat.png?rev=d55bc88afb2b4c949d93ba3113f446ce","cast":"Sonya Yoncheva, Vittorio Grigolo, George Petean","releaseDate":"2026-05-10T00:00:00","runningTime":160,"isDurationUnknown":false,"synopsisShort":"„La traviata” to jedna z najpopularniejszych oper świata, a toast „Libiamo” („Więc pijmy”) z jej pierwszego aktu potrafi zanucić każdy. Ten bezsprzeczny wyciskacz łez widzowie polskich kin zobaczą wprost ze słynnej Arena di Verona. W nowej inscenizacji „Zbłąkanej” – bo tak należy tłumaczyć ten tytuł – przygotowanej w 2021 roku, wystąpiły międzynarodowe gwiazdy opery: wspaniała bułgarska sopranistka Sonya Yoncheva oraz przebojowy włoski tenor Vittorio Grigolo, który w wieku 13 lat debiutował u boku Luciana Pavarottiego. Fabuła dzieła Verdiego oparta jest na słynnym romansie „Dama kameliowa” Alexandre’a Dumas syna. To poruszająca historia umierającej Violetty, francuskiej kurtyzany, która z miłości do ukochanego Alfreda, młodzieńca z wyższych sfer, gotowa jest poświęcić ostatnie chwile swojego szczęścia. Dziś trudno w to uwierzyć, ale prapremiera tej opery w 1853 roku zakończyła się totalną klapą. Publiczności nie spodobało się, że główną bohaterką kompozytor uczynił współczesną im postać, w dodatku kobietę upadłą, która w świecie mieszczańskiej obłudy okazała się jedyną uczciwą i szlachetną osobą. Akcję werońskiego przedstawienia przeniesiono 30 lat do przodu, do Belle Époque, a dokładnie w okres paryskiej Wystawy Światowej z 1889 roku. Tradycyjne dekoracje i kostiumy połączono z nowoczesną technologią. Na gigantycznych ekranach o powierzchni ponad 400 metrów kwadratowych wyświetlono malarskie arcydzieła ze słynnej Galerii Uffizi we Florencji.","filmTitle":"La Traviata Verdiego z Arena di Verona","hasSessions":true,"hasTrailer":true,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/images/wydarzenia/opera/latraviata2026_tlo.png?rev=533a682c72464492aaefba9320a4e984","filmStatus":2,"trailers":[],"director":"Michele Olcese, Francesco Ivan Ciampa","distributor":"Ferment","movieXchangeCode":"6f2d94ca-0e82-4335-849b-27725d40c5fe","crossCountryMovieXchangeId":"","originalTitle":"","showingInCinemas":["0003","0004","0005","0006","0007","0008","0010","0011","0013","0014","0015","0023","0024","0025","0026","0028","0029","0030","0031","0033","0034","0035","0036","0037","0038","0039","0040","0041","0042","0044","0047","0048","0050","0051","0052","0053"],"genres":[],"sessionAttributes":[{"name":"Projektor laserowy","shortName":"Projektor laserowy","value":"Projektor laserowy","description":"Projektor laserowy","attributeType":"Session_Special","color":"#FFA500","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"OPERA","shortName":"OPERA - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session"