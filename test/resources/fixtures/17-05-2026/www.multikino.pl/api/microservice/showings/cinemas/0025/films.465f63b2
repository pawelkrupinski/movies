onName":null}],"screenName":"Sala 6","sessionPricingDisplayStatus":0,"wheelchairSeatAvailability":0}]}],"filmId":"HO00002612","certificate":{"name":null,"description":null,"src":null},"secondaryCertificates":[],"filmUrl":"https://www.multikino.pl/filmy/drzewo-magii","filmAttributes":[],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/images/film-and-events/2026/drzewo-magii/drzewo-magii_plakat-glowny_plakat.jpg?rev=78ae4df57ddb40d98d5535803ff32357","cast":"Andrew Garfield, Claire Foy, Nicola Coughlan, Rebecca Ferguson ","releaseDate":"2026-05-29T00:00:00","runningTime":110,"isDurationUnknown":false,"synopsisShort":"Polly i Tim wraz z trójką dzieci to współczesna rodzina, która staje przed koniecznością przeprowadzenia się na odległą angielską prowincję. Wkrótce po przyjeździe okazuje się, że najmłodsi muszą obejść się bez Wi-Fi i ukochanych elektronicznych gadżetów oraz odkryć uroki świata na świeżym powietrzu. Podczas eksploracji okolicznych lasów trafiają na niezwykłe drzewo, zamieszkane przez barwne, ekscentryczne istoty. Jeśli odważą się wspiąć na jego szczyt, czekają na nie fantastyczne krainy, pełne zapierających dech przygód. Dzięki magicznym doświadczeniom rodzina na nowo uczy się bycia razem i odkrywa, jak ważne jest wzajemne wsparcie i bliskość.","filmTitle":"Drzewo magii","hasSessions":true,"hasTrailer":true,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/images/film-and-events/2026/drzewo-magii/drzewomagii_kadr.jpg?rev=d00b279ff0fe4aad9fcc6625b9f43a9d","filmStatus":1,"trailers":[],"director":"","distributor":"Kino Świat","movieXchangeCode":"64763037-407b-40fb-a672-4cf029d77392","crossCountryMovieXchangeId":"","originalTitle":"","showingInCinemas":["0003","0004","0005","0006","0007","0008","0010","0011","0013","0014","0015","0023","0024","0025","0026"