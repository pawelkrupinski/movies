[],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/images/film-and-events/2026/wladcy-wszechswiata/wladcy-wszechswiata-plakat-final.jpg?rev=26ca550333f54fff9f8122a285f12cc6","cast":"Nicholas Galitzine, Camila Mendes, Alison Brie","releaseDate":"2026-06-05T00:00:00","runningTime":0,"isDurationUnknown":true,"synopsisShort":"Film \"Władcy Wszechświata\" jest oparty na kultowym serialu z lat 80-tych.  Reżyserem jest Travis Knight (Bumblebee), na podstawie scenariusza autorstwa Chrisa Butlera. Producentami filmu „Masters of the Universe” są Todd Black, Jason Blumenthal i Steve Tisch z Escape Artists oraz Robbie Brenner z Mattel Films.  Seria Masters of the Universe, skupiająca się na walce między bohaterskim He-Manem (znanym również jako książę Adam z Eternii) — najpotężniejszym człowiekiem we wszechświecie — a złowrogim Szkieletorem, została wprowadzona na rynek w 1982 roku poprzez serię popularnych figurek. Rok później miała miejsce premiera serialu animowanego „He-Man i Masters of the Universe”,","filmTitle":"Władcy wszechświata","hasSessions":true,"hasTrailer":true,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/images/film-and-events/2026/wladcy-wszechswiata/wladcywszechswiata-kadr1.jpg?rev=4c1acce3ec0a467f94678bfa0d32a985","filmStatus":1,"trailers":[],"director":"Travis Knight","distributor":"UIP","movieXchangeCode":"11115ba2-20fb-48a5-a6d5-4f008d3dc379","crossCountryMovieXchangeId":"","originalTitle":"","showingInCinemas":["0003","0004","0005","0006","0007","0008","0010","0011","0013","0014","0015","0023","0024","0025","0026","0027","0028","0029","0030","0031","0033","0034","0035","0036","0037","0038","0039","0040","0041","0042","0043","0044","0047","0048","0050","0051","0052","0053"],"genres":[],"sessionAttributes":[{"name":"DUBBING","shortName":"DUBBING","v