SY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 3","sessionPricingDisplayStatus":0,"wheelchairSeatAvailability":1}]}],"filmId":"HO00002584","certificate":{"name":null,"description":null,"src":null},"secondaryCertificates":[],"filmUrl":"https://www.multikino.pl/filmy/art-beats-nenufary-moneta---cuda-z-wody-i-swiata","filmAttributes":[{"name":"WYSTAWY","shortName":"WYSTAWY - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/images/wydarzenia/wystawy/monet-nenufary-plakat.jpg?rev=0ec23b8a082f4b7bb70c073696776d8a","cast":"Elisa Lasowski","releaseDate":"2026-06-15T00:00:00","runningTime":95,"isDurationUnknown":false,"synopsisShort":"Dokument opowiada o pochodzeniu i powstaniu ogromnego dzieła sztuki, które zerwało z wszelkimi konwencjami.    Jest to opowieść o obsesji artysty na punkcie światła i wody, z której malarz nie mógł się wyrwać, więc przekształcił ją w swój własny rodzaj magii. To także opowieść o radykalnych ideach, które zrewolucjonizowały sztukę współczesną: wyraźnym zamiarem Moneta było przeniesienie na płótno „pierwszego, czystego wrażenia” form i przedmiotów, jakie pojawiają się w oku, które nigdy wcześniej ich nie widziało. Film jest wyjątkowym, ekskluzywnym spojrzeniem na arcydzieła znajdujące się w Muzeum Orangerie, Muzeum Marmottan, Muzeum Orsay i Giverny, gdzie mieszkał i tworzył Monet, po raz pierwszy ukazane na dużym ekranie, aby zapewnić niepowtarzalne wrażenia widzom obcującym z pięknem jego „Nenufarów”.","filmTitle":"Art Beats: Nenufary Moneta - cuda z wody i światła","hasSessions":true,"hasTrailer":false,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/global/img/film-panel-default-image.png?rev=-1","filmStatus":2,"trailers":[],"director":"Giovanni Troilo","distributor":"nazwywkinach","movieXchangeCode":"","crossCountryMovieXchangeId":"","originalTitle":"","showingInCinemas":["0003","0004","0005","0006","0007","0008","0010","0011","0013","0014","0015","0023","0024","0025","0026","0028","0029","0030","0031","0033","0034","0035","0036","0037","0038","0039","0040","0041","0042","0043","0044","0047","0048","0050","0051","0052","0053"],"genres":[],"sessionAttributes":[{"name":"WYSTAWY","shortName":"WYSTAWY - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}]},{"showingGroups":[{"date":"2026-07-13T00:00:00","datePrefix":"","pricingTypes":[],"sessions":[{"sessionId":"47146","bookingUrl":"/rezerwacja-biletow/podsumowanie/0025/HO00002585/47146","formattedPrice":null,"isPriceVisible":false,"duration":80,"startTime":"2026-07-13T18:00:00","endTime":"2026-07-13T19:35:00","showTimeWithTimeZone":"2026-07-13T18:00:00+02:00","isSoldOut":false,"color":null,"isMidnightSession":false,"isBookingAvailable":true,"attributes":[{"name":"WYSTAWY","shortName":"WYSTAWY - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 3","sessionPricingDisplayStatus":0,"wheelchairSeatAvailability":1}]},{"date":"2026-07-15T00:00:00","datePrefix":"","pricingTypes":[],"sessions":[{"sessionId":"47147","bookingUrl":"/rezerwacja-biletow/podsumowanie/0025/HO00002585/47147","formattedPrice":null,"isPriceVisible":false,"duration":80,"startTime":"2026-07-15T12:30:00","endTime":"2026-07-15T14:05:00","showTimeWithTimeZone":"2026-07-15T12:30:00+02:00","isSoldOut":false,"color":null,"isMidnightSession":false,"isBookingAvailable":true,"attributes":[{"name":"WYSTAWY","shortName":"WYSTAWY - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 3","sessionPricingDisplayStatus":0,"wheelchairSeatAvailability":1}]}],"filmId":"HO00002585","certificate":{"name":null,"description":null,"src":null},"secondaryCertificates":[],"filmUrl":"https://www.multikino.pl/filmy/art-beats-rafael-mody-geniusz","filmAttributes":[{"name":"WYSTAWY","shortName":"WYSTAWY - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/images/wydarzenia/wystawy/rafael-plakat.jpg?rev=e127f4cbbb104fde8a20d94cf4ba7dc0","cast":"","releaseDate":"2026-07-13T00:00:00","runningTime":80,"isDurationUnknown":false,"synopsisShort":"Zanurz się w epokę renesansu i odkryj wysublimowaną sztukę Rafaela.     Podziwiaj portrety niezwykłych kobiet: Matki, Przyjaciółki, Sekretnej Kochanki i Klientki, których osobowości rozkwitają na płótnach. Matka, która zmarła, gdy artysta miał zaledwie osiem lat. Wielbicielki, które wspierały go na drodze do sukcesu. Kobieta, która niemal przyczyniła się do jego śmierci. Istniały naprawdę lub były tylko wytworem wyobraźni. Rafael (1483-1520) uwiecznił ideał niebiańskiego piękna. Dzięki pracy światowej sławy ekspertów możemy poznać najważniejsze momenty z życia jednego z największych mistrzów renesansu.","filmTitle":"Art Beats: Rafael. Młody geniusz","hasSessions":true,"hasTrailer":true,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/images/wydarzenia/wystawy/rafael-kadr.jpg?rev=9c0053d94c274a9aab34d304ab3dca05","filmStatus":2,"trailers":[],"director":" Massimo Ferrari","distributor":"nazwywkinach","movieXchangeCode":"","crossCountryMovieXchangeId":"","originalTitle":"","showingInCinemas":["0003","0004","0005","0006","0007","0008","0010","00