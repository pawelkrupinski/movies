ll},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 1","sessionPricingDisplayStatus":0,"wheelchairSeatAvailability":1}]},{"date":"2026-06-20T00:00:00","datePrefix":"","pricingTypes":[],"sessions":[{"sessionId":"53682","bookingUrl":"/rezerwacja-biletow/podsumowanie/0025/HO00002706/53682","formattedPrice":null,"isPriceVisible":false,"duration":83,"startTime":"2026-06-20T12:50:00","endTime":"2026-06-20T14:39:00","showTimeWithTimeZone":"2026-06-20T12:50:00+02:00","isSoldOut":false,"color":null,"isMidnightSession":false,"isBookingAvailable":true,"attributes":[{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 1","sessionPricingDisplayStatus":0,"wheelchairSeatAvailability":1}]}],"filmId":"HO00002706","certificate":{"name":null,"description":null,"src":null},"secondaryCertificates":[],"filmUrl":"https://www.multikino.pl/filmy/all-you-need-is-kill","filmAttributes":[],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/images/film-and-events/2026/all-you-need-is-kill/allyouneediskill_plakat.jpg?rev=08b1e09f55e449e68afb83c40faed6e7","cast":"","releaseDate":"2026-06-19T00:00:00","runningTime":83,"isDurationUnknown":false,"synopsisShort":"Akcja filmu „ALL YOU NEED IS KILL” rozgrywa się w roku 20XX i opowiada historię Rity, zaradnej, ale samotnej młodej kobiety, która zgłasza się na ochotnika do pomocy przy odbudowie Japonii po tajemniczym pojawieniu się ogromnego obcego kwiatu znanego jako „Darol”. Kiedy Darol niespodziewanie wybucha, wywołując śmiertelne wydarzenie i uwalniając potworne stworzenia, które dziesiątkują populację, Rita zostaje wciągnięta w zniszczenie – i ginie. Ale potem budzi się ponownie. I znowu. Uwięziona w niekończącej się pętli czasowej, Rita musi zmagać się z traumą i powtarzającą się śmiercią, aż w końcu spotyka Keiji, nieśmiałego młodego mężczyznę uwięzionego w tym samym cyklu. Razem walczą, by wyrwać się z pętli i odnaleźć sens w otaczającym ich chaosie.","filmTitle":"All You Need Is Kill","hasSessions":true,"hasTrailer":false,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/images/film-and-events/2026/all-you-need-is-kill/allyouneediskill_tlo.jpg?rev=5da57c78e7c94a5c8c8e182b6ad00885","filmStatus":2,"trailers":[],"director":"","distributor":"Piece Of Magic","movieXchangeCode":"d48c4f1c-363a-4302-9244-cec752b12688","crossCountryMovieXchangeId":"","originalTitle":"","showingInCinemas":["0003","0004","0005","0006","0007","0008","0010","0011","0013","0014","0015","0023","0024","0025","0026","0028","0029","0030","0033","0034","0035","0036","0037","0038","0039","0040","0042","0043","0044","0047","0048","0050","0051","0052","0053"],"genres":[],"sessionAttributes":[{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}]},{"showingGroups":[{"date":"2026-08-17T00:00:00","datePrefix":"","pricingTypes":[],"sessions":[{"sessionId":"47144","bookingUrl":"/rezerwacja-biletow/podsumowanie/0025/HO00002586/47144","formattedPrice":null,"isPriceVisible":false,"duration":80,"startTime":"2026-08-17T18:00:00","endTime":"2026-08-17T19:35:00","showTimeWithTimeZone":"2026-08-17T18:00:00+02:00","isSoldOut":false,"color":null,"isMidnightSession":false,"isBookingAvailable":true,"attributes":[{"name":"WYSTAWY","shortName":"WYSTAWY - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 3","sessionPricingDisplayStatus":0,"wheelchairSeatAvailability":1}]},{"date":"2026-08-19T00:00:00","datePrefix":"","pricingTypes":[],"sessions":[{"sessionId":"47145","bookingUrl":"/rezerwacja-biletow/podsumowanie/0025/HO00002586/47145","formattedPrice":null,"isPriceVisible":false,"duration":80,"startTime":"2026-08-19T12:30:00","endTime":"2026-08-19T14:05:00","showTimeWithTimeZone":"2026-08-19T12:30:00+02:00","isSoldOut":false,"color":null,"isMidnightSession":false,"isBookingAvailable":true,"attributes":[{"name":"WYSTAWY","shortName":"WYSTAWY - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 3","sessionPricingDisplayStatus":0,"wheelchairSeatAvailability":1}]}],"filmId":"HO00002586","certificate":{"name":null,"description":null,"src":null},"secondaryCertificates":[],"filmUrl":"https://www.multikino.pl/filmy/art-beats-lotto-i-berenson---splecione-losy","filmAttributes":[{"name":"WYSTAWY","shortName":"WYSTAWY - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/images/wydarzenia/wystawy/lotto-plakat.jpg?rev=38a9f6140a1a4ffcab6674adfc953e0e","cast":"Alessandro Sperduti","releaseDate":"2026-08-17T00:00:00","runningTime":80,"isDurationUnknown":false,"synopsisShort":"Lotto i Berenson – splecione losy. Śladami renesansowego mistrza to opowieść  o przenikających się losach Lorenza Lotta, zapomnianego szesnastowiecznego malarza, i Bernarda Berensona, krytyka sztuki, któremu zawdzięczamy odkrycie artysty na nowo.      Wyprodukowany przez 3D Produzioni i wyreżyserowany przez Simonę Risi, dokument podąża za aktorem Alessandrem Sperdutim podczas jego podróży śladami Lotta. Dzieła malarza poszukującego sławy i bogactwa, rywalizującego z innymi twórcami, rozproszone są po północnych i centralnych Włoszech; dotrzemy do regionu Marche, do Bergamo, Wenecji. Dzięki zachowanym listom i dokumentom poznajemy nie tylko twórczość malarza, ale i jego osobiste zmagania: ambicję, silną potrzebę uznania, strach przed porażką.  Równolegle śledzimy losy Berensona, młodego litewskiego Żyda, który wychował się w Bostonie i, urzeczony renesansem, wyruszył do Włoch w wieku dwudziestu czterech lat. Zachwycił go talent, z jakim Lotto potrafił uchwycić świat wewnętrzny portretowanych, ich psychologię. Przekonujemy się, że niepokoje i obawy, jakie w odległych epokach żywili Lotto i Berenson, i dziś są nam bliskie. Lotto i Berenson... jest zatem nie tylko refleksją nad sztuką, ale i ludzką naturą.","filmTitle":"Art Beats: Lotto i Berenson - splecione losy. Śladami renesansowego mistrza","hasSessions":true,"hasTrailer":false,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/images/wydarzenia/wystawy/lotto-kadr.jpg?rev=c2e3fc695756485dad1e26afde490e5f","filmStatus":2,"trailers":[],"director":"Simona Risi","distributor":"nazywowkinach","movieXchangeCode":"","crossCountryMovieXchangeId":"","originalTitle":"","showingInCinemas":["0003","0004","0005","0006","0007","0008","0010","0011","0013","0014","0015","0023","0024","0025","0026","0028","0029","0030","0031","0033","0034","0035","0036","0037","0038","0039","0040","0041","0042","0043","0044","0047","0048","0050","0051","0052","0053"],"genres":[],"sessionAttributes":[{"name":"WYSTAWY","shortName":"WYSTAWY - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgrou