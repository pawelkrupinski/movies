rażeniu, dziewczynka odkrywa, że to kraina zamieszkana przez bóstwa i duchy, a jej rodzicie zostali przemienieni... w świnie! Aby ich ocalić, Chihiro będzie musiała rozpocząć pracę u potężnej wiedźmy Jubaby. Czy dziewczynce uda się zdjąć z rodziców klątwę? Film z polskim napisami lub polskim dubbingiem, dla widzów od 10. roku życia.","filmTitle":"Spirited Away: W krainie bogów","hasSessions":true,"hasTrailer":false,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/multikino_imported/images/films-and-events/2024/ghibli/spirited-away_w-krainie-bogow_tlo.jpg?rev=93d613ebe3cc443baf3b2a8f8c5bed7d","filmStatus":2,"trailers":[],"director":"Hayao Miyazaki","distributor":"Gutek","movieXchangeCode":"","crossCountryMovieXchangeId":"","originalTitle":"","showingInCinemas":["0003","0004","0005","0006","0007","0008","0010","0011","0013","0014","0015","0023","0024","0025","0026","0028","0029","0030","0031","0033","0034","0035","0036","0037","0038","0039","0040","0041","0042","0043","0044","0047","0048","0050","0051","0052","0053"],"genres":[],"sessionAttributes":[{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"KULTOWE KINO","shortName":"KULTOWE KINO","value":"","description":"<span style=\"color: #474747; background-color: #ffffff;\">Największe polskie i światowe hity ponownie na wielkim ekranie!</span>","attribut