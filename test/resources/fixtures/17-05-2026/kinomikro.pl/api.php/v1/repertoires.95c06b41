            "street": "ul. Juliusza Lea 5",
            "event_date": "15.06.2026 18:00",
            "event_date_day_name": "poniedzia\u0142ek",
            "event_date_day": "15",
            "event_date_month": "6",
            "event_date_year": "2026",
            "event_date_hour": "18:00",
            "latitude": "50.0695407",
