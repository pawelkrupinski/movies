<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Coarse location places the user into the nearest supported city on
         first launch; denial falls back to an explicit city pick. -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Kinowo"
        android:usesCleartextTraffic="false">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/Theme.Kinowo"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- OAuth callback: the server redirects here after a web sign-in. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="kinowo" android:host="auth-done" />
            </intent-filter>
            <!-- App Links: verified kinowo.fly.dev links (incl. the
                 copy-to-clipboard filter links) open the app directly. Scoped to
                 /<city>/ and /<city>/film so OAuth (/auth/…) and API paths stay
                 in the browser. autoVerify checks /.well-known/assetlinks.json. -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="kinowo.fly.dev" />
                <data android:pathPattern="/..*/" />
                <data android:pathPattern="/..*/film" />
            </intent-filter>
            <!-- kinowo://<city>/… custom-scheme fallback for deep links. The
                 ViewModel rejects the auth-done host, so it doesn't disturb the
                 OAuth filter above. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="kinowo" />
            </intent-filter>
        </activity>
    </application>
</manifest>
