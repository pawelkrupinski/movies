*.iml
.gradle
/local.properties
/.idea
.DS_Store
/build
/app/build
/captures
.externalNativeBuild
.cxx
local.properties
.kotlin

# Release signing — never commit the keystore, its base64, or its passwords.
*.jks
*.keystore
*.jks.base64
keystore.properties

# Google Play service-account key — never commit it (grants release access).
play-credentials.json

# Play store-listing graphics: the icon / feature graphic are large binaries that
# change rarely, so keep those out of git (re-fetch with `bootstrapReleaseListing`
# when you need to touch them). The phone SCREENSHOTS, however, ARE committed —
# they're generated deterministically from the emulator (English UK + Polish) and
# reviewed as diffs, so `publishReleaseListing` pushes them from the repo. The
# listing TEXT (title/short/full descriptions) is committed under app/src/main/play/.
app/src/main/play/listings/*/graphics/*
!app/src/main/play/listings/*/graphics/phoneScreenshots/
