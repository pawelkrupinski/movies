{
  "uid": "fly-overview",
  "title": "kinowo — Fly health",
  "tags": ["fly", "kinowo"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 4,
  "refresh": "1m",
  "time": { "from": "now-6h", "to": "now" },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "name": "Annotations & Alerts",
        "type": "dashboard"
      },
      {
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": false,
        "iconColor": "purple",
        "name": "Deploys",
        "tags": ["deploy"],
        "type": "tags"
      }
    ]
  },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 9,
      "title": "Mongo CPU load — %core (busy = work it does; steal = host throttling). Watch step-ups against Deploys.",
      "description": "kinowo-mongo is shared-cpu-1x, so 100 = one full core. 'busy' is the work Mongo does (user+system+io); 'steal' is CPU the host withheld because demand crossed the shared-CPU credit — near-zero historically, it only appears when busy saturates the core. A step-up that lines up with a purple Deploy marker means that release added Mongo load.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "fly-prometheus" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "percent", "custom": { "drawStyle": "line", "fillOpacity": 15 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "steal" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] }
        ]
      },
      "targets": [
        { "refId": "A", "expr": "sum(rate(fly_instance_cpu{app=\"kinowo-mongo\",mode!~\"idle|steal\"}[5m]))", "legendFormat": "busy (user+system+io)" },
        { "refId": "B", "expr": "sum(rate(fly_instance_cpu{app=\"kinowo-mongo\",mode=\"steal\"}[5m]))", "legendFormat": "steal" }
      ]
    },
    {
      "id": 1,
      "title": "CPU credit balance (serving apps — alarm < 500)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "fly-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "min by (app) (fly_instance_cpu_balance{app!=\"schowek\"})", "legendFormat": "{{app}}" }
      ]
    },
    {
      "id": 2,
      "title": "CPU throttled (rate, fraction of wall-clock)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "fly-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "max by (app) (rate(fly_instance_cpu_throttle{app!=\"schowek\"}[5m]))", "legendFormat": "{{app}}" }
      ]
    },
    {
      "id": 3,
      "title": "CPU steal %",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "fly-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 17 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum by (app) (rate(fly_instance_cpu{mode=\"steal\",app!=\"schowek\"}[5m])) / sum by (app) (rate(fly_instance_cpu{app!=\"schowek\"}[5m]))", "legendFormat": "{{app}}" }
      ]
    },
    {
      "id": 4,
      "title": "Memory available % (alarm < 8%)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "fly-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 17 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "min by (app) (fly_instance_memory_mem_available{app!=\"schowek\"} / fly_instance_memory_mem_total{app!=\"schowek\"})", "legendFormat": "{{app}}" }
      ]
    },
    {
      "id": 5,
      "title": "HTTP latency — web (s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "fly-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 25 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.99, sum by (le) (rate(fly_app_http_response_time_seconds_bucket{app=\"kinowo\"}[5m])))", "legendFormat": "p99" },
        { "refId": "B", "expr": "histogram_quantile(0.95, sum by (le) (rate(fly_app_http_response_time_seconds_bucket{app=\"kinowo\"}[5m])))", "legendFormat": "p95" },
        { "refId": "C", "expr": "histogram_quantile(0.75, sum by (le) (rate(fly_app_http_response_time_seconds_bucket{app=\"kinowo\"}[5m])))", "legendFormat": "p75" },
        { "refId": "D", "expr": "histogram_quantile(0.50, sum by (le) (rate(fly_app_http_response_time_seconds_bucket{app=\"kinowo\"}[5m])))", "legendFormat": "p50" }
      ]
    },
    {
      "id": 8,
      "title": "HTTP latency — grafana (s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "fly-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 25 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.99, sum by (le) (rate(fly_app_http_response_time_seconds_bucket{app=\"kinowo-grafana\"}[5m])))", "legendFormat": "p99" },
        { "refId": "B", "expr": "histogram_quantile(0.95, sum by (le) (rate(fly_app_http_response_time_seconds_bucket{app=\"kinowo-grafana\"}[5m])))", "legendFormat": "p95" },
        { "refId": "C", "expr": "histogram_quantile(0.75, sum by (le) (rate(fly_app_http_response_time_seconds_bucket{app=\"kinowo-grafana\"}[5m])))", "legendFormat": "p75" },
        { "refId": "D", "expr": "histogram_quantile(0.50, sum by (le) (rate(fly_app_http_response_time_seconds_bucket{app=\"kinowo-grafana\"}[5m])))", "legendFormat": "p50" }
      ]
    },
    {
      "id": 7,
      "title": "Instance up",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "fly-prometheus" },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 33 },
      "fieldConfig": { "defaults": { "min": 0, "max": 1, "custom": { "drawStyle": "line", "fillOpacity": 20, "lineInterpolation": "stepAfter" } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "max by (app) (fly_instance_up{app!=\"schowek\"})", "legendFormat": "{{app}}" }
      ]
    },
    {
      "id": 10,
      "title": "Residential proxy — fetches served vs failed (recent 30 min, from web /metrics)",
      "description": "The Decodo residential-proxy leg of the cinema scrape, surfaced from the in-app /uptime health (Mongo) via web's /metrics scrape. A flip from all-green 'served by proxy' to all-red 'failed → Zyte fallback' is a silent cost regression — scraping keeps working via Zyte, so no cinema bar goes red. Drives the 'Residential proxy failing' alert.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "fly-prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 39 },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0, "custom": { "drawStyle": "line", "fillOpacity": 15 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum(kinowo_uptime_recent_successes{service=\"Residential proxy\"})", "legendFormat": "served by proxy" },
        { "refId": "B", "expr": "sum(kinowo_uptime_recent_failures{service=\"Residential proxy\"})", "legendFormat": "failed → Zyte fallback" }
      ]
    },
    {
      "id": 20,
      "title": "Worker — task flow (per min): enqueued → started → fully worked",
      "description": "The deferred-work pipeline on kinowo-worker, from worker /metrics. enqueued = new tasks added to the queue (dedup collapses excluded); started = tasks claimed by a worker; fully worked (done) = handlers that did real work (excludes 'skipped' freshness no-ops). In steady state the three track; started ≫ done means lots of skipped/rescheduled, done ≪ enqueued means a growing backlog.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "fly-prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 47 },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0, "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum(rate(kinowo_worker_tasks_enqueued_total{result=\"added\"}[$__rate_interval])) * 60", "legendFormat": "enqueued" },
        { "refId": "B", "expr": "sum(rate(kinowo_worker_tasks_started_total[$__rate_interval])) * 60", "legendFormat": "started" },
        { "refId": "C", "expr": "sum(rate(kinowo_worker_tasks_finished_total{outcome=\"done\"}[$__rate_interval])) * 60", "legendFormat": "fully worked (done)" }
      ]
    },
    {
      "id": 30,
      "title": "Worker — enqueued (non-duplicate) by type (per min)",
      "description": "Rate of tasks ADDED to the queue per task type (kinowo_worker_tasks_enqueued_total{result=\"added\"} — re-enqueues that the dedupKey collapses are excluded, so this is net new work, not churn). The per-type split of the 'enqueued' line in the overall flow panel above. Read with 'started by type' and 'fully-worked throughput by type' as one type's enqueue → claim → done funnel.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "fly-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 55 },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0, "custom": { "drawStyle": "line", "fillOpacity": 10, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum by (task_type) (rate(kinowo_worker_tasks_enqueued_total{result=\"added\"}[$__rate_interval])) * 60", "legendFormat": "{{task_type}}" }
      ]
    },
    {
      "id": 31,
      "title": "Worker — started (claimed) by type (per min)",
      "description": "Rate of tasks CLAIMED by a worker per task type (kinowo_worker_tasks_started_total). Counts every claim, including ones that then skip (data already fresh) or reschedule, so started ≫ the same type's 'fully-worked throughput' means that type is handing out a lot of no-op work. The per-type split of the 'started' line in the overall flow panel above.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "fly-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 55 },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0, "custom": { "drawStyle": "line", "fillOpacity": 10, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum by (task_type) (rate(kinowo_worker_tasks_started_total[$__rate_interval])) * 60", "legendFormat": "{{task_type}}" }
      ]
    },
    {
      "id": 21,
      "title": "Worker — fully-worked throughput by type (per min)",
      "description": "rate of done (not skipped) tasks per task type — which kinds of work the worker is actually completing: cinema scrapes, detail enrichment, TMDB/IMDb resolution, the four rating sources, and the staging-incubation steps.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "fly-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 63 },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0, "custom": { "drawStyle": "line", "fillOpacity": 10, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum by (task_type) (rate(kinowo_worker_tasks_finished_total{outcome=\"done\"}[$__rate_interval])) * 60", "legendFormat": "{{task_type}}" }
      ]
    },
    {
      "id": 22,
      "title": "Worker — task outcomes (per min)",
      "description": "Every handler return, by outcome: done (real work), skipped (data already fresh — the queue handed out work that was no longer needed), rescheduled (transient retry/backoff), failed (handler threw), no_handler (claimed mid-deploy on a node without the handler). A spike in skipped/rescheduled is wasted churn; failed is the error signal.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "fly-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 63 },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0, "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [
        { "matcher": { "id": "byName", "options": "failed" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] }
      ] },
      "targets": [
        { "refId": "A", "expr": "sum by (outcome) (rate(kinowo_worker_tasks_finished_total[$__rate_interval])) * 60", "legendFormat": "{{outcome}}" }
      ]
    },
    {
      "id": 23,
      "title": "Worker — fully-worked task duration (done, all types)",
      "description": "Handler wall-clock of done tasks, percentiles over the bucketed histogram (kinowo_worker_task_duration_seconds). Skipped/failed runs are excluded. A rising p95/p99 means the upstreams (cinema sites, TMDB/IMDb, Filmweb/RT/Metacritic) or the scrape are getting slower.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "fly-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 71 },
      "fieldConfig": { "defaults": { "unit": "s", "min": 0, "custom": { "drawStyle": "line", "fillOpacity": 0 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.99, sum by (le) (rate(kinowo_worker_task_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "p99" },
        { "refId": "B", "expr": "histogram_quantile(0.95, sum by (le) (rate(kinowo_worker_task_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "p95" },
        { "refId": "C", "expr": "histogram_quantile(0.50, sum by (le) (rate(kinowo_worker_task_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "p50" }
      ]
    },
    {
      "id": 24,
      "title": "Worker — queue depth",
      "description": "Live size of the durable task queue: waiting (claimable) + worked_on (leased by a worker right now), from worker /metrics. worked_on tracks pool utilization against pool size (the worker runs poolSize workers, one task each). A climbing 'waiting' is a backlog the pool isn't draining — the thing to correlate with the worker CPU-credit/steal panels above.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "fly-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 71 },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0, "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [
        { "matcher": { "id": "byName", "options": "pool size" }, "properties": [ { "id": "custom.drawStyle", "value": "line" }, { "id": "custom.lineStyle", "value": { "dash": [ 8, 6 ], "fill": "dash" } }, { "id": "color", "value": { "mode": "fixed", "fixedColor": "gray" } } ] }
      ] },
      "targets": [
        { "refId": "A", "expr": "sum(kinowo_worker_queue_depth{state=\"waiting\"})", "legendFormat": "waiting" },
        { "refId": "B", "expr": "sum(kinowo_worker_queue_depth{state=\"worked_on\"})", "legendFormat": "worked_on" },
        { "refId": "C", "expr": "max(kinowo_worker_pool_size)", "legendFormat": "pool size" }
      ]
    },
    {
      "id": 25,
      "title": "Worker — waiting tasks by type",
      "description": "Current backlog broken down by task type (sampled from the bounded active snapshot). Shows WHICH work is piling up — e.g. a wave of staging-incubation steps, or rating refreshes backing up behind a slow source.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "fly-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 79 },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0, "custom": { "drawStyle": "line", "fillOpacity": 10, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "kinowo_worker_queue_waiting_by_type > 0", "legendFormat": "{{task_type}}" }
      ]
    },
    {
      "id": 26,
      "title": "Worker — oldest waiting task age by type (s)",
      "description": "Head-of-line latency: how long the oldest still-waiting task of each type has sat in the queue. A steadily climbing line is starvation — that type's work isn't being picked up (no handler, perpetual backoff, or the pool saturated by another type).",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "fly-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 79 },
      "fieldConfig": { "defaults": { "unit": "s", "min": 0, "custom": { "drawStyle": "line", "fillOpacity": 0 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "kinowo_worker_queue_oldest_waiting_age_seconds > 0", "legendFormat": "{{task_type}}" }
      ]
    },
    {
      "id": 27,
      "title": "Worker — fully-worked task duration p95 by type (s)",
      "description": "Per-type tail latency of done (not skipped) tasks: the 95th-percentile handler wall-clock for each task type, over the bucketed histogram (kinowo_worker_task_duration_seconds). Splits the overall percentiles panel above by task_type so a slowdown localises to one upstream — e.g. ScrapeCinema (a cinema site), the *Rating types (Filmweb/RT/Metacritic/IMDb), or TMDB/IMDb resolution. Change 0.95 → 0.50 for the median.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "fly-prometheus" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 87 },
      "fieldConfig": { "defaults": { "unit": "s", "min": 0, "custom": { "drawStyle": "line", "fillOpacity": 0 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.95, sum by (le, task_type) (rate(kinowo_worker_task_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "{{task_type}}" }
      ]
    },
    {
      "id": 28,
      "title": "Worker — fully-worked task duration p50 (median) by type (s)",
      "description": "Per-type typical latency of done (not skipped) tasks: the 50th-percentile (median) handler wall-clock for each task type, over the bucketed histogram (kinowo_worker_task_duration_seconds). The median companion to the p95-by-type panel above — p50 reads the everyday cost of each work kind, p95 the tail.",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "fly-prometheus" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 96 },
      "fieldConfig": { "defaults": { "unit": "s", "min": 0, "custom": { "drawStyle": "line", "fillOpacity": 0 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.50, sum by (le, task_type) (rate(kinowo_worker_task_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "{{task_type}}" }
      ]
    },
    {
      "id": 29,
      "title": "Worker — staging incubation: movies by step (total = all in staging)",
      "description": "Films currently incubating in pending_movies, stacked by the step each needs NEXT on its way into the live `movies` collection: detail (a cinema's synopsis/poster still owed) → resolve_tmdb (no TMDB match yet) → resolve_imdb (TMDB hit, IMDb cross-ref pending) → fold (concluded, about to graduate). Distinct films (a film's multiple cinema rows count once). The stacked total is the total movie count in staging; a step that keeps growing is where incubation is stalling (correlate with the staging task queue panels + StagingStuckAlerter).",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "fly-prometheus" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 105 },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0, "custom": { "drawStyle": "line", "fillOpacity": 25, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "kinowo_worker_staging_movies", "legendFormat": "{{step}}" }
      ]
    }
  ]
}
