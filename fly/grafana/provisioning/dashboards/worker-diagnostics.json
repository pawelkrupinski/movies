{
  "uid": "kinowo-worker-diag",
  "title": "Kinowo \u2014 Worker Diagnostics",
  "tags": [
    "worker",
    "diagnostics"
  ],
  "timezone": "",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "name": "Annotations & Alerts",
        "type": "dashboard"
      },
      {
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": false,
        "iconColor": "purple",
        "name": "Deploys",
        "tags": [
          "deploy"
        ],
        "type": "tags"
      }
    ]
  },
  "templating": {
    "list": [
      {
        "name": "country",
        "label": "Country",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "app-metrics-live"
        },
        "definition": "label_values(kinowo_worker_throttled, country)",
        "query": {
          "query": "label_values(kinowo_worker_throttled, country)",
          "refId": "country"
        },
        "current": {
          "text": "pl",
          "value": "pl",
          "selected": true
        },
        "includeAll": false,
        "multi": false,
        "refresh": 2,
        "sort": 1,
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Native memory by NMT category (committed)",
      "description": "kinowo_worker_native_memory_bytes \u2014 the native buckets invisible to jvm_memory_*. The one that climbs toward each ~5-6h non-heap OOM restart is the culprit. Needs -XX:NativeMemoryTracking=summary.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "app-metrics-live"
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 0,
            "spanNulls": 300000
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "kinowo_worker_native_memory_bytes and on(app) kinowo_worker_throttled{country=~\"$country\"}",
          "legendFormat": "{{category}}",
          "datasource": {
            "type": "prometheus",
            "uid": "app-metrics-live"
          }
        }
      ]
    },
    {
      "id": 2,
      "title": "Resident set size (RSS) vs cgroup limit",
      "description": "process_resident_memory_bytes. The dashed line is the ~960MB cgroup ceiling. A slow climb that resets at a restart = the native working set; a spike to the line = a Fly RSS-kill.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "app-metrics-live"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 9
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 12,
            "spanNulls": 300000
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byFrameRefID",
              "options": "B"
            },
            "properties": [
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "dash",
                  "dash": [
                    8,
                    4
                  ]
                }
              },
              {
                "id": "custom.fillOpacity",
                "value": 0
              },
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "expr": "process_resident_memory_bytes and on(app) kinowo_worker_throttled{country=~\"$country\"}",
          "legendFormat": "RSS",
          "datasource": {
            "type": "prometheus",
            "uid": "app-metrics-live"
          }
        },
        {
          "refId": "B",
          "expr": "1006632960",
          "legendFormat": "cgroup limit (960MB)",
          "datasource": {
            "type": "prometheus",
            "uid": "app-metrics-live"
          }
        }
      ]
    },
    {
      "id": 3,
      "title": "CPU breakdown \u2014 centicores (process / JIT / GC)",
      "description": "process CPU vs JIT-compilation vs GC, in centicores (100=1 core). Dashed = the 13cc shared-cpu-2x credit breakeven; sustained above it drains the credit bucket.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "app-metrics-live"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 9
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 12,
            "spanNulls": 300000
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byFrameRefID",
              "options": "D"
            },
            "properties": [
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "dash",
                  "dash": [
                    8,
                    4
                  ]
                }
              },
              {
                "id": "custom.fillOpacity",
                "value": 0
              },
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(process_cpu_seconds_total[5m]) and on(app) kinowo_worker_throttled{country=~\"$country\"})*100",
          "legendFormat": "process cc",
          "datasource": {
            "type": "prometheus",
            "uid": "app-metrics-live"
          }
        },
        {
          "refId": "B",
          "expr": "rate(jvm_compilation_time_seconds_total[5m])*100 and on(app) kinowo_worker_throttled{country=~\"$country\"}",
          "legendFormat": "JIT cc",
          "datasource": {
            "type": "prometheus",
            "uid": "app-metrics-live"
          }
        },
        {
          "refId": "C",
          "expr": "sum(rate(jvm_gc_collection_seconds_sum[5m]) and on(app) kinowo_worker_throttled{country=~\"$country\"})*100",
          "legendFormat": "GC cc",
          "datasource": {
            "type": "prometheus",
            "uid": "app-metrics-live"
          }
        },
        {
          "refId": "D",
          "expr": "13",
          "legendFormat": "breakeven (13cc)",
          "datasource": {
            "type": "prometheus",
            "uid": "app-metrics-live"
          }
        }
      ]
    },
    {
      "id": 4,
      "title": "Fly CPU-credit balance vs throttle floor",
      "description": "fly_instance_cpu_balance. Dashed = the 8000 throttle-enter floor. Draining below it trips the scrape throttle.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "fly-prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 17
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 12,
            "spanNulls": 300000
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byFrameRefID",
              "options": "B"
            },
            "properties": [
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "dash",
                  "dash": [
                    8,
                    4
                  ]
                }
              },
              {
                "id": "custom.fillOpacity",
                "value": 0
              },
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "expr": "fly_instance_cpu_balance{app=~\"kinowo-worker.*\"}",
          "legendFormat": "credit balance \u2014 {{app}}",
          "datasource": {
            "type": "prometheus",
            "uid": "fly-prometheus"
          }
        },
        {
          "refId": "B",
          "expr": "8000",
          "legendFormat": "throttle floor (8000)",
          "datasource": {
            "type": "prometheus",
            "uid": "fly-prometheus"
          }
        }
      ]
    },
    {
      "id": 5,
      "title": "Uptime (hours) \u2014 drops mark restarts",
      "description": "(now - process_start_time)/3600. Each drop to ~0 is a restart; the cadence (~5-6h) is the OOM cycle. Cross-check the reason with `flyctl machine status` (exit_code=3 = ExitOnOutOfMemoryError).",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "app-metrics-live"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 17
      },
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 12,
            "spanNulls": 300000
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "(time()-process_start_time_seconds)/3600 and on(app) kinowo_worker_throttled{country=~\"$country\"}",
          "legendFormat": "uptime h",
          "datasource": {
            "type": "prometheus",
            "uid": "app-metrics-live"
          }
        }
      ]
    },
    {
      "id": 6,
      "title": "JVM threads (current / peak)",
      "description": "jvm_threads_current & _peak. A climbing thread count \u2192 'unable to create native thread' OOM. The 2026-07-09 probe found these STABLE (~86-92), so the OOM is not a thread leak \u2014 watch for drift.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "app-metrics-live"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 25
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 12,
            "spanNulls": 300000
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "jvm_threads_current and on(app) kinowo_worker_throttled{country=~\"$country\"}",
          "legendFormat": "current",
          "datasource": {
            "type": "prometheus",
            "uid": "app-metrics-live"
          }
        },
        {
          "refId": "B",
          "expr": "jvm_threads_peak and on(app) kinowo_worker_throttled{country=~\"$country\"}",
          "legendFormat": "peak",
          "datasource": {
            "type": "prometheus",
            "uid": "app-metrics-live"
          }
        }
      ]
    },
    {
      "id": 7,
      "title": "Heap used",
      "description": "jvm_memory_used_bytes{area=heap}. Healthy = sawtooth well under Xmx=320MB; a rising floor = a heap leak (NOT the current failure mode).",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "app-metrics-live"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 25
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 12,
            "spanNulls": 300000
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "jvm_memory_used_bytes{area=\"heap\"} and on(app) kinowo_worker_throttled{country=~\"$country\"}",
          "legendFormat": "heap used",
          "datasource": {
            "type": "prometheus",
            "uid": "app-metrics-live"
          }
        }
      ]
    },
    {
      "id": 8,
      "title": "Read-model projection \u2014 avg duration (ms)",
      "description": "Per-call cost of the read-model projection. A 3-5x inflation at a FLAT call rate = the daytime GC-thrash flare (projection is a victim of GC pauses, not the cause).",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "app-metrics-live"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 33
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 12,
            "spanNulls": 300000
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "1000*sum(rate(kinowo_worker_readmodel_project_duration_seconds_sum{country=~\"$country\"}[5m]))/sum(rate(kinowo_worker_readmodel_project_duration_seconds_count{country=~\"$country\"}[5m]))",
          "legendFormat": "avg project ms",
          "datasource": {
            "type": "prometheus",
            "uid": "app-metrics-live"
          }
        }
      ]
    },
    {
      "id": 10,
      "title": "Worker HTTP outcomes \u2014 error share, all phases (per country)",
      "description": "Every outbound HTTP attempt incl. retries \u2014 ALL phases (cinema scraping AND third-party enrichment) \u2014 as a share of all attempts. Only the error bands are drawn, stacked at the floor, so the total stack height is exactly the failure budget and each band's thickness is that error's share of all attempts (the ~90-99% clean remainder is the empty space above). The 4xx range is split by code because one bucket hid two opposite meanings: http_404 is mostly the RT/Metacritic resolvers probing up to 4 candidate slugs per title (working as designed \u2014 expect a large steady band), while http_403 is a host REFUSING us (Cloudflare, datacentre-IP ban) and any rise there is an outage forming. Improbable codes (409/422/451/\u2026) fold into the residual http_4xx. Other categories: http_429=rate limited, http_5xx=server, timeout=connect/read, connection_error=refused/DNS/reset/TLS, other=unclassified. For the cinema-scrape side alone (listing + chunk + detail), see the phase=scrape panel below.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "app-metrics-live"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 41
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 25,
            "spanNulls": 300000,
            "stacking": {
              "mode": "normal"
            }
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum by (outcome) (rate(kinowo_worker_http_total{country=~\"$country\",outcome!=\"success\"}[5m])) / sum(rate(kinowo_worker_http_total{country=~\"$country\"}[5m]))",
          "legendFormat": "{{outcome}}",
          "datasource": {
            "type": "prometheus",
            "uid": "app-metrics-live"
          }
        }
      ]
    },
    {
      "id": 11,
      "title": "Resolution cache \u2014 hit rate % by source",
      "description": "Share of identity resolutions (film \u2192 TMDB id / IMDb id / rating-site url) served from cache instead of running a live probe chain. A chain costs up to ~30 upstream GETs for RT/Metacritic and ~36 for Filmweb, so this is the cache's actual saving. Low here means the cache is doing little \u2014 the resolved url is persisted on the film record anyway, which is the competing gate.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "app-metrics-live"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 49
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 12,
            "spanNulls": 300000
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum by (source) (rate(kinowo_worker_resolution_total{country=~\"$country\",outcome=~\"hit_.*\"}[5m])) / sum by (source) (rate(kinowo_worker_resolution_total{country=~\"$country\"}[5m]))",
          "legendFormat": "{{source}}",
          "datasource": {
            "type": "prometheus",
            "uid": "app-metrics-live"
          }
        }
      ]
    },
    {
      "id": 12,
      "title": "Resolution chains RUN \u2014 by source and kind",
      "description": "Probe chains actually executed, per second. `miss_resolved` mints a cached answer and should decay as the corpus resolves; `miss_unresolved` is a chain that found nothing and \u2014 because the cache is hits-only \u2014 was NOT cached, so the same film burns the same chain again next cycle. If miss_unresolved dominates, the fix is caching negative results, not deleting the cache.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "app-metrics-live"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 49
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 12,
            "spanNulls": 300000
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (source, outcome) (rate(kinowo_worker_resolution_total{country=~\"$country\",outcome=~\"miss_.*\"}[5m]))",
          "legendFormat": "{{source}} {{outcome}}",
          "datasource": {
            "type": "prometheus",
            "uid": "app-metrics-live"
          }
        }
      ]
    },
    {
      "id": 13,
      "title": "Durable-store share of cache hits % by source",
      "description": "Of the hits, how many came from the Mongo `resolve_*` collections rather than the in-process Caffeine layer. This is what the durable half buys over a plain in-memory cache \u2014 it is the only part that survives a worker restart. Near 0% across sources means the 5 collections + TTL-index reconciliation are carrying nothing and could be dropped.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "app-metrics-live"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 57
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 12,
            "spanNulls": 300000
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum by (source) (rate(kinowo_worker_resolution_total{country=~\"$country\",outcome=\"hit_store\"}[5m])) / sum by (source) (rate(kinowo_worker_resolution_total{country=~\"$country\",outcome=~\"hit_.*\"}[5m]))",
          "legendFormat": "{{source}}",
          "datasource": {
            "type": "prometheus",
            "uid": "app-metrics-live"
          }
        }
      ]
    },
    {
      "id": 14,
      "title": "Cinema-scrape HTTP outcomes — error share, scrape phase (per country)",
      "description": "The same failure-budget view as the all-phases panel above, but scoped to phase=\"scrape\": ONLY the cinema-site HTTP — every listing scrape, chunk scrape and per-film detail fetch — with the third-party metadata/rating/resolution APIs (TMDB/IMDb/RT/Metacritic/Filmweb/Trakt/Letterboxd/Wikidata/Cinemeta, phase=\"enrich\") excluded. Each error band's thickness is that error's share of scrape attempts, stacked at the floor; the empty space above is the clean remainder. This isolates cinema-scrape health from the enrichment APIs' by-design 404 slug-probing and API 429s: here a rising http_403 (a cinema Cloudflare/datacentre-IP block) or http_5xx/timeout stands out instead of hiding under the enrichment 404 noise floor.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "app-metrics-live"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 65
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 25,
            "spanNulls": 300000,
            "stacking": {
              "mode": "normal"
            }
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum by (outcome) (rate(kinowo_worker_http_total{country=~\"$country\",phase=\"scrape\",outcome!=\"success\"}[5m])) / sum(rate(kinowo_worker_http_total{country=~\"$country\",phase=\"scrape\"}[5m]))",
          "legendFormat": "{{outcome}}",
          "datasource": {
            "type": "prometheus",
            "uid": "app-metrics-live"
          }
        }
      ]
    }
  ]
}
