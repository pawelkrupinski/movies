# ── Landing / city selection ──────────────────────────────────────────────────
# Bare `/` is NOT a repertoire page anymore — every page lives under a city
# slug (`/poznan/…`). The landing bounces a returning visitor (city cookie) to
# their city, else renders the city-selection screen (which also tries browser
# geolocation). Hard cut: the old unprefixed URLs are gone.
GET     /                           controllers.LandingController.index()

# ── Repertoire (city-scoped: /:city/…) ─────────────────────────────────────────
GET     /:city/                     controllers.MovieController.index(city: String)
GET     /:city/film                 controllers.MovieController.film(city: String, title: String)
GET     /:city/film/og-image        controllers.MovieController.ogImage(city: String, title: String)
GET     /:city/filmy                controllers.MovieController.browse(city: String, kraj: Option[String] ?= None, rezyser: Option[String] ?= None, aktor: Option[String] ?= None, gatunek: Option[String] ?= None)
GET     /:city/plan                 controllers.PlanController.plan(city: String)

# ── API (JSON) ────────────────────────────────────────────────────────────────
GET     /:city/api/repertoire       controllers.MovieController.apiRepertoire(city: String)
# Detail-only payload (synopsis + trailers), fetched in parallel with the
# listing and merged client-side by title. Kept off the listing so the latency-
# sensitive /:city/api/repertoire stays lean.
GET     /:city/api/details          controllers.MovieController.apiDetails(city: String)

# ── Debug ─────────────────────────────────────────────────────────────────────
# Top-level, not city-scoped: the debug table is the *global* corpus (every
# enriched row across all cities), so there's nothing per-city about it. Each
# /film deep-link picks a city the film actually plays in.
GET     /debug                      controllers.MovieController.debug()
# Dev-only: the /debug row "re-enrich" button enqueues a per-movie ResolveTmdb
# task (worker re-resolves TMDB, then the event chain re-runs the rest). 404 in
# prod like the rest of /debug; nocsrf, posted by the page's fetch.
+ nocsrf
POST    /debug/reenrich             controllers.MovieController.reenrich(title: String, year: Option[Int])
# Dev-only SSE feed of `movies` change-stream events so the /debug table live-
# updates (merged rows vanish, new films appear). 404 in prod — the stream is
# only ever opened in dev, never watching the worker's collection 24/7.
GET     /debug/stream               controllers.DebugStreamController.stream()
# Dev-only visual-tuning page: live sliders over the real movie card that drive
# the CSS custom properties the production card styles read (vertical gaps,
# showtime-pill + rating-pill font/padding/corner). Lets us eyeball spacing
# without redeploying; never exposed in prod.
GET     /:city/debug/tune           controllers.MovieController.tune(city: String)
# Sibling tuning page for the film-detail view, linked by a sub-nav inside the
# /:city/debug/tune* pages. Same live-CSS-variable approach as
# /:city/debug/tune; dev-only.
GET     /:city/debug/tune/film      controllers.MovieController.tuneFilm(city: String)
# Drop the in-memory positive cache and reload it from Mongo. Not gated by
# devOnly — usable on a deployed instance to reconcile after out-of-band
# Mongo edits.
+ nocsrf
POST    /:city/debug/rehydrate      controllers.MovieController.rehydrate(city: String)

# ── Auth (OAuth2 — Google / Facebook) ────────────────────────────────────────
# `/auth/<provider>/start` issues a CSRF state, stashes it in the signed
# session cookie, redirects to the provider's consent screen. The callback
# verifies the state and exchanges the code for a profile; on success the
# session gets a `userId` and the user lands back on /.
GET     /auth/:provider/start       controllers.AuthController.start(provider: String)
GET     /auth/:provider/callback    controllers.AuthController.callback(provider: String)
+ nocsrf
POST    /auth/logout                controllers.AuthController.logout()

GET     /api/me                     controllers.AuthController.me()
+ nocsrf
POST    /auth/token                 controllers.AuthController.token()
+ nocsrf
POST    /auth/exchange              controllers.AuthController.exchange()

# ── Per-user state (hidden / disabled-cinemas) ──────────────────────────────
# The browser JS (Phase D) calls these when logged in instead of writing to
# localStorage. Anonymous requests get 401 and the JS falls back to
# localStorage on its own.
GET     /api/me/state               controllers.UserStateController.get()
+ nocsrf
PUT     /api/me/state               controllers.UserStateController.put()
+ nocsrf
DELETE  /api/me                     controllers.UserStateController.deleteAccount()

# ── Health / Uptime ───────────────────────────────────────────────────────────
GET     /health                     controllers.HealthController.check
GET     /uptime                     controllers.UptimeController.index()
GET     /uptime/fallback            controllers.UptimeController.fallback()
GET     /uptime/stream              controllers.UptimeController.stream()
+ nocsrf
POST    /uptime/img-event           controllers.UptimeController.imgEvent()

# ── Task queue monitor ──────────────────────────────────────────────────────
# Live operational view of the durable Mongo `tasks` queue. The page polls
# /tasks/data every 5s (bounded, index-backed read) rather than a 24/7 change
# stream — cost scales with viewers-while-open, not queue churn.
GET     /tasks                      controllers.TasksController.index()
GET     /tasks/data                 controllers.TasksController.data()
# Operator-triggered corpus-wide refresh runs (the page's buttons). nocsrf to
# match the other admin POSTs; the AdminAction gate is the auth check. `job` is
# one of tmdb|imdb|filmweb|metacritic|rt.
+ nocsrf
POST    /tasks/run/:job             controllers.TasksController.run(job: String)

# ── Legal ─────────────────────────────────────────────────────────────────────
# Public privacy policy (Polish). Required by Meta/Facebook before the Login
# app can leave Development mode; the URL goes in the dashboard's Privacy
# Policy field.
GET     /polityka-prywatnosci       controllers.LegalController.privacy

# ── Facebook data deletion (Meta callback) ──────────────────────────────────
# Meta POSTs a signed_request here when a user removes the app from their
# Facebook account; we verify it, delete the matching local account, and
# return the required JSON receipt. The status URL in that receipt points at
# the GET page below. `nocsrf` because Facebook posts a form body without our
# CSRF token — the signed_request's HMAC is the authenticity check instead.
+ nocsrf
POST    /facebook/data-deletion          controllers.FacebookDataDeletionController.callback()
GET     /facebook/data-deletion/status   controllers.FacebookDataDeletionController.status(code: String)

# ── Admin: title-stripping rules editor ─────────────────────────────────────
# Gated by the login session + the ADMIN_ALLOWLIST env (comma-separated user
# ids). Edits write straight to Mongo; the change stream propagates them to the
# worker and back, so they take effect on the next scrape and the live display.
GET     /admin/title-rules               controllers.AdminTitleRulesController.index()
+ nocsrf
POST    /admin/title-rules               controllers.AdminTitleRulesController.save()
+ nocsrf
POST    /admin/title-rules/delete        controllers.AdminTitleRulesController.delete()
+ nocsrf
POST    /admin/title-rules/preview       controllers.AdminTitleRulesController.preview()
GET     /admin/title-rules/report        controllers.AdminTitleRulesController.report()

# ── robots.txt ────────────────────────────────────────────────────────────────
# Returning a 404 on /robots.txt confused Facebook's link-preview scraper
# (`facebookexternalhit`) — its debugger reported "403 due to robots.txt
# block" against the film page. Serving a permissive robots.txt explicitly
# allowlists every crawler and matches Facebook's stated requirement.
GET     /robots.txt                 controllers.MovieController.robotsTxt

# ── Static assets ─────────────────────────────────────────────────────────────
GET     /assets/*file               controllers.Assets.versioned(path="/public", file: Asset)
