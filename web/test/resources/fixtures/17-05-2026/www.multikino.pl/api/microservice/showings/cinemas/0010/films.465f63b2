,{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"LIVE","shortName":"LIVE","value":"Live","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 9","sessionPricingDisplayStatus":0,"wheelchairSeatAvailability":1},{"sessionId":"92499","bookingUrl":"/rezerwacja-biletow/podsumowanie/0010/HO00002774/92499","formattedPrice":null,"isPriceVisible":false,"duration":180,"startTime":"2026-06-13T15:30:00","endTime":"2026-06-13T18:30:00","showTimeWithTimeZone":"2026-06-13T15:30:00+02:00","isSoldOut":false,"color":null,"isMidnightSession":false,"isBookingAvailable":true,"attributes":[{"name":"KONCERT","shortName":"KONCERT - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"LIVE","shortName":"LIVE","value":"Live","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 9","sessionPricingDisplayStatus":0,"wheelchairSeatAvailability":1}]}],"filmId":"HO00002774","certificate":{"name":null,"description":null,"src":null},"secondaryCertificates":[],"filmUrl":"https://www.multikino.pl/filmy/bts-world-tour-arirang-in-busan-live-viewing","filmAttributes":[{"name":"KONCERT","shortName":"KONCERT - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/images/wydarzenia/koncerty/kpop/bts_busan_plakat.jpg?rev=3ebe23c67eda474c8d47f23309b69661","cast":"","releaseDate":"2026-06-13T00:00:00","runningTime":180,"isDurationUnknown":false,"synopsisShort":"Historyczna trasa trwa dalej! Po rekordowym otwarciu światowej trasy ARIRANG, BTS powraca do legendarnego Busan Asiad Main Stadium na wyjątkowy koncert transmitowany na żywo do kin na całym świecie — także do Multikina. To niezwykle emocjonalny moment zarówno dla zespołu, jak i fanów. Po raz pierwszy od 3 lat i 8 miesięcy BTS wystąpi ponownie w miejscu, gdzie odbył się ich ostatni koncert w pełnym składzie przed rozpoczęciem służby wojskowej członków grupy. Trasa obejmująca 34 miasta i 85 koncertów już teraz zapisała się w historii jako największe tournée koreańskiego artysty. Występ w Busanie odbędzie się dodatkowo 13 czerwca — w rocznicę debiutu BTS — co nadaje wydarzeniu wyjątkowy i symboliczny charakter. Nazwa trasy ARIRANG nawiązuje do piątego albumu studyjnego BTS i opowiada o tożsamości, tęsknocie, szczerości oraz głębokiej miłości. Widowiskowa scena 360° zapewni w pełni immersyjne doświadczenie, dzięki któremu widzowie poczują się częścią tego niezwykłego wydarzenia. Nie przegap jednego z najważniejszych muzycznych wydarzeń roku i przeżyj energię koncertu BTS na wielkim kinowym ekranie — już 13 czerwca, prosto z Busanu.","filmTitle":"BTS WORLD TOUR 'ARIRANG' IN BUSAN: LIVE VIEWING","hasSessions":true,"hasTrailer":false,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/images/wydarzenia/koncerty/kpop/bts_busan_tlo.jpg?rev=b8bf3fc8c1cf4bea8105ed40c440d8ab","fi