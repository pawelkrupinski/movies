hodniego-swiata","filmAttributes":[{"name":"TEATR","shortName":"TEATR - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/images/wydarzenia/teatr/playboy-zachodniego-swiata/playboy_plakat.jpg?rev=61b7db6ed64243cbb0fbb2d2ea71f81d","cast":"","releaseDate":"2026-06-24T00:00:00","runningTime":150,"isDurationUnknown":false,"synopsisShort":"Nicola Coughlan (Bridgertonowie) u boku Éanny Hardwicke (Szóste przykazanie) i Siobhán McSweeney (Derry Girls) w porywającej sztuce pióra Johna Millingtona Synge'a o młodości i odkrywaniu siebie. Życie Pegeen Flaherty wywraca się do góry nogami, gdy do jej pubu wchodzi młody mężczyzna, który twierdzi, że zabił swojego ojca. Zabójca nie spotyka się z potępieniem, lecz staje się lokalnym bohaterem i zaczyna podbijać serca. Wtedy niespodziewanie pojawia się drugi mężczyzna… To filmowana na żywo na scenie National Theatre w reżyserii Caitríony McLaughlin, mroczna, zabawna opowieść naszpikowana sekretami.","filmTitle":"NT Live: Playboy zachodniego świata","hasSessions":true,"hasTrailer":true,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/images/wydarzenia/teatr/playboy-zachodniego-swiata/playboy-kadr.jpg?rev=46a17ad2017540ecbc07d7c08b92b717","filmStatus":2,"trailers":[],"director":"","distributor":"","movieXchangeCode":"38aa215d-0946-4139-82f0-e2b018a7019b","crossCountryMovieXchangeId":"","originalTitle":"","showingInCinemas":["0003","0004","0005","0006","0007","0010","0011","0013","0023","0028","0029","0034","0035","0036","0040","0053"],"genres":[],"sessionAttributes":[{"name":"TEATR","shortName":"TEATR - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"",