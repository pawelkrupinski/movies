,{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 4","sessionPricingDisplayStatus":0,"wheelchairSeatAvailability":1}]},{"date":"2026-06-11T00:00:00","datePrefix":"","pricingTypes":[],"sessions":[{"sessionId":"93801","bookingUrl":"/rezerwacja-biletow/podsumowanie/0010/HO00002602/93801","formattedPrice":null,"isPriceVisible":false,"duration":109,"startTime":"2026-06-11T10:25:00","endTime":"2026-06-11T12:40:00","showTimeWithTimeZone":"2026-06-11T10:25:00+02:00","isSoldOut":false,"color":null,"isMidnightSession":false,"isBookingAvailable":true,"attributes":[{"name":"DUBBING","shortName":"DUBBING","value":"DUBBING","description":"DUBBING","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 8","sessionPricingDisplayStatus":0,"wheelchairSeatAvailability":1}]}],"filmId":"HO00002602","certificate":{"name":null,"description":null,"src":null},"secondaryCertificates":[],"filmUrl":"https://www.multikino.pl/filmy/sprawiedliwosc-owiec","filmAttributes":[],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/images/film-and-events/2026/sprawiedliwosc-owiec/sprawiedliwoscowiec_plakat.jpg?rev=be0f91ffd2f248caaed986a915b760f8","cast":"Hugh Jackman, Nicholas Galitzine, Molly Gordon, Julia Louis-Dreyfus","releaseDate":"2026-05-08T00:00:00","runningTime":109,"isDurationUnknown":false,"synopsisShort":"George Hardy (Hugh Jackman) to pasterz, który kocha swoje owce i hoduje je wyłącznie dla wełny. Każdej nocy czyta im na głos kryminały, udając, że owce je rozumieją, nie podejrzewając, że nie tylko je rozumieją, ale także godzinami dyskutują o tym, kto jest sprawcą zbrodni.  Kiedy George zostaje znaleziony martwy w tajemniczych okolicznościach, owce od razu zdają sobie sprawę, że było to morderstwo i uważają, że wiedzą wszystko o tym, jak je rozwiązać. Z drugiej strony lokalny policjant Tim Derry (Nicholas Braun) nigdy w życiu nie rozwiązał poważnej zbrodni, więc owce dochodzą do wniosku, że będą musiały rozwiązać ją same – nawet jeśli oznacza to opuszczenie swojej łąki po raz pierwszy i zmierzenie się z faktem, że świat ludzi nie jest tak prosty, jak wydaje się w książkach.","filmTitle":"Sprawiedliwość owiec","hasSessions":true,"hasTrailer":true,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/images/film-and-events/2026/sprawiedliwosc-owiec/sprawiedliwosc-owiec-kadr-1.jpg?rev=7ca18a3f40434870a1972afae25fcaee","filmStatus":1,"trailers":[],"director":"Kyle Balda","distributor":"UIP","movieXchangeCode":"0000add7-4e99-41eb-9cfe-d2f576fd923b","crossCountryMovieXchangeId":"","originalTitle":"","showingInCinemas":["0003","0004","0005","0006","0007","0010","0011","0013","0014","0023","0024","0035","0039","0040","0042","0050","0053"],"genres":[],"sessionAttributes":[{"name":"DUBBING","shortName":"DUBBING","value":"DUBBING","description":"DUBBING","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","va