Jeremy Allen White","releaseDate":"2026-05-22T00:00:00","runningTime":132,"isDurationUnknown":false,"synopsisShort":"Imperium zostało pokonane, jednak jego dawni dowódcy, wciąż stanowiąc zagrożenie, ukrywają się w różnych częściach galaktyki. Rodząca się Nowa Republika, by uchronić przed zniszczeniem to, co wywalczyła Rebelia, zwraca się o pomoc do legendarnego mandaloriańskiego łowcy nagród Din Djarina (Pedro Pascal) oraz z jego młodego ucznia Grogu.","filmTitle":"Mandalorian i Grogu. Ukrainian dubbing ","hasSessions":true,"hasTrailer":false,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/images/film-and-events/2026/mandalorian-grogu/mandaloriangrogu_sliderd.jpg?rev=9155b826d7e641379d3fe4088153c58f","filmStatus":1,"trailers":[],"director":"Jon Favreau","distributor":"Disney","movieXchangeCode":"","crossCountryMovieXchangeId":"","originalTitle":"","showingInCinemas":["0010"],"genres":[],"sessionAttributes":[{"name":"UA","shortName":"UKRAIŃSKI","value":"ua","description":"Filmy z ukraińskim dubbingiem.","attributeType":"Language","color":"#FFFFFF","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"DUBBING","shortName":"DUBBING","value":"DUBBING","description":"DUBBING","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}]},{"showingGroups":[{"date":"2026-09-05T00:00:00","datePrefix":"","pricingTypes":[],"sessions":[{"sessionId":"89690","bookingUrl":"/rezerwacja-bileto