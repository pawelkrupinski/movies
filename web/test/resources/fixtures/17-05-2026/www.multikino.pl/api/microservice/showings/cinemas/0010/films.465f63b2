ocji, śmiałości i całkowitego zaangażowania. Składa się z dziesięciu aktów: balansowanie na krzesłach, charivari, kontorsjonizm, chodzenie po linie, obręcze, obręcz powietrzna, huśtawka, duet na monocyklu, koło śmierci i diabolo: akt w rotacji.","filmTitle":"Cirque du Soleil: Kooza","hasSessions":true,"hasTrailer":true,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/images/film-and-events/2026/cirque-de-soleil/kooza_tlo.jpg?rev=7843f98f5a1b417e89a23a1574cf7539","filmStatus":2,"trailers":[],"director":"Mario Janelle, David Shiner","distributor":"Qrios Interactive (Pannonia Entertainment)","movieXchangeCode":"d74aae68-943c-4fff-8e76-dc0a66155639","crossCountryMovieXchangeId":"63836845-9240-4061-86b7-30047219dc29","originalTitle":"Cirque du Soleil: Kooza","showingInCinemas":["0003","0004","0005","0006","0007","0008","0010","0011","0013","0014","0015","0023","0024","0025","0026","0028","0029","0030","0031","0033","0034","0035","0036","0037","0038","0039","0040","0041","0042","0043","0044","0047","0048","0050","0051","0052","0053"],"genres":[],"sessionAttributes":[{"name":"WIDOWISKO","shortName":"WIDOWISKO - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}]},{"showingGroups":[{"date":"2026-10-15T00:00:00","datePrefix":"","pricingTypes":[],"sessions":[{"sessionId":"85292","bookingUrl":"/rezerwacja-biletow/podsumowanie/0010/HO00002649/85292","f