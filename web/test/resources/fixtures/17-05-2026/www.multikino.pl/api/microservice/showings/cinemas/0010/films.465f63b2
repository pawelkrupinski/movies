"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 3","sessionPricingDisplayStatus":0,"wheelchairSeatAvailability":1},{"sessionId":"93860","bookingUrl":"/rezerwacja-biletow/podsumowanie/0010/HO00002669/93860","formattedPrice":null,"isPriceVisible":false,"duration":98,"startTime":"2026-06-11T20:30:00","endTime":"2026-06-11T22:34:00","showTimeWithTimeZone":"2026-06-11T20:30:00+02:00","isSoldOut":false,"color":null,"isMidnightSession":false,"isBookingAvailable":true,"attributes":[{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 1","sessionPricingDisplayStatus":0,"wheelchairSeatAvailability":1}]}],"filmId":"HO00002669","certificate":{"name":null,"description":null,"src":null},"secondaryCertificates":[],"filmUrl":"https://www.multikino.pl/filmy/zawodowcy","filmAttributes":[],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/images/film-and-events/2026/zawodowcy/zawodowcy_plakat_cut.jpg?rev=307b6e79745349b48c3f2df3088133fb","cast":"Jake Gyllenhaal, Henry Cavill, Eiza Gonzalez, Rosamund Pike","releaseDate":"2026-05-29T00:00:00","runningTime":98,"isDurationUnknown":false,"synopsisShort":"Eve, działająca w szarej strefie specjalistka od załatwiania ekstremalnie trudnych spraw dla wyjątkowo bogatych klientów otrzymuje zlecenie od grupy nowojorskich inwestorów. Ma odzyskać dług od mieszkającego na prywatnej wyspie, dysponującego własną armią miliardera o szemranej reputacji. Gdy zawodzą cywilizowane metody negocjacji i staje się jasne, że dłużnik nie ma najmniejszego zamiaru regulować należności, do gry wchodzi ekipa do zadań specjalnych. To grupa byłych żołnierzy, z którymi Eve pracuje do lat. Wspólnie opracowują i wcielają w życie misterny plan wtargnięcia na wyspę, „załatwienia sprawy” i ucieczki. Brzmi prosto, ale ludzie miliardera są przygotowani na takie ewentualności, a okazywanie litości nie należy do zakresu ich obowiązków.","filmTitle":"Zawodowcy","hasSessions":true,"hasTrailer":true,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/images/film-and-events/2026/zawodowcy/zawodowcy-kadr.jpg?rev=1e497157a33741e590f60daad0eac880","filmStatus":1,"trailers":[],"director":"Guy Ritchie ","distributor":"Monolith","movieXchangeCode":"f76e4693-b7a9-418e-88bc-3e31632b6d0f","crossCountryMovieXchangeId":"","originalTitle":"","showingInCinemas":["0003","0004","0005","0006","0007","0008","0010","0011","0013","0014","0015","0023","0024","0025","0026","0027","0028","0029","0030","0031","0033","0034","0035","0036","0037","0038","0039","0040","0041","0042","0043","0044","0047","0048","0050","0051","0052","0053"],"genres":[],"sessionAttributes":[{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,