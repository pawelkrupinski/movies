alse,"duration":95,"startTime":"2026-07-12T15:00:00","endTime":"2026-07-12T16:47:00","showTimeWithTimeZone":"2026-07-12T15:00:00+02:00","isSoldOut":false,"color":null,"isMidnightSession":false,"isBookingAvailable":true,"attributes":[{"name":"KONCERT","shortName":"KONCERT - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"SUPERHIT","shortName":"SUPERHIT","value":"SUPERHIT","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 10","sessionPricingDisplayStatus":0,"wheelchairSeatAvailability":1}]}],"filmId":"HO00002682","certificate":{"name":null,"description":null,"src":null},"secondaryCertificates":[],"filmUrl":"https://www.multikino.pl/filmy/90-urodziny-pavarottiego","filmAttributes":[{"name":"KONCERT","shortName":"KONCERT - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/images/wydarzenia/koncerty/pavarotti/pavarotti90_plakat.jpg?rev=10b0b0776a1740c3bc284f5e077c5434","cast":"Andrea Bocelli, Jonathan Tetelman, Placido Domingo, Jose Carreras, Angela Gheorghiu,  Il Volo, Stjepan Hauser","releaseDate":"2026-05-01T00:00:00","runningTime":95,"isDurationUnknown":false,"synopsisShort":"Jesienią 2025 roku w słynnej Arena di Verona zebrały się największe gwiazdy opery i popu, w tym Andrea Bocelli, Jonathan Tetelman, Angela Gheorghiu i Il Volo, by dać niebywały koncert, który... przywrócił do życia Luciana Pavarottiego, króla tenorów i wielkiego śpiewaka zwykłych ludzi. Jego dwaj żyjący koledzy, Plácido Domingo i José Carreras, zaśpiewali z nim na żywo. Niemożliwe stało się faktem – Trzej Tenorzy powrócili na estradę! Najnowszemu koncertowi ku czci jedzącego za trzech śpiewaka o niebiańskim głosie, który wciąż przywołuje na myśl skąpane w słońcu i spaghetti Włochy, nadano znaczący tytuł: „Luciano Pavarotti. Człowiek, który poruszył świat”. To prawda. Choć święcił nieprawdopodobne tryumfy na najważniejszych scenach, począwszy od mediolańskiej La Scali, a skończywszy na nowojorskiej The Metropolitan Opera, Luciano Pavarotti chciał przybliżyć muzykę klasyczną ludziom na całym świecie. To dzięki swym popularyzatorskim koncertom sprawił, że wielu z nas pokochało operę. Na jego występ w Hyde Parku, mimo ulewy, przyszło ponad 100.000 osób, a jego transmitowane przez telewizję występy z Domingiem i Carrerasem (Trzej Tenorzy) sprawiały, że w miastach i miasteczkach zamierał ruch na ulicach. Koncert z legendarnego werońskiego amfiteatru to wiązanka najsłynniejszych arii operowych i niezaprzeczalnych evergreenów w wykonaniu nie tylko klasycznych śpiewaków, ale też artystów, którzy z powodzeniem łączą muzykę poważną z popową. Oprócz wcześniej wymienionych gwiazd wystąpili również: wiolonczelista Hauser, piosenkarz Umberto Tozzi, a także Vittorio Grigolo, międzynarodowej klasy tenor, który w wieku 13 lat zaśpiewał w Operze Rzymskiej partię Pastuszka w „Tosce” Pucciniego, a rolę Cavaradossiego w tym spektaklu kreował wtedy sam Luciano Pavarotti.","filmTitle":"90. urodziny Pavarottiego","hasSessions":true,"hasTrailer":true,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/images/wydarzenia/koncerty/pavarotti/pavarotti90_tlo.jpg?rev=47abac46f05647138d6cda3ff8a1027e","filmStatus":2,"trailers":[],"director":"Luigi Antonini, Matteo Parmeggiani","distributor":"kinomaestro","movieXchangeCode":"","crossCountryMovieXchangeId":"","originalTitle":"Pavarotti 90 - The Man Who Moved the World","showingInCinemas":["0003","0004","0005","0006","0007","0008","0010","0011","0013","0014","0015","0023","0024","0025","0026","0028","0029","0030","0031","0033","0034","0035","0036","0037","0038","0039","0040","0041","0042","0043","0044","0047","0048","0050","0051","0052","0053"],"genres":[],"sessionAttributes":[{"name":"KONCERT","shortName":"KONCERT - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"SUPERHIT","shortName":"SUPERHIT","value":"SUPERHIT","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}]},{"showingGroups":[{"date":"2026-06-19T00:00:00","datePrefix":"","pricingTypes":[],"sessions":[{"sessionId":"93035","bookingUrl":"/rezerwacja-biletow/podsumowanie/0010/HO00002706/93035","formattedPrice":null,"isPriceVisible":false,"duration":83,"startTime":"2026-06-19T17:30:00","endTime":"2026-06-19T19:19:00","showTimeWithTimeZone":"2026-06-19T17:30:00+02:00","isSoldOut":false,"color":null,"isMidnightSession":false,"isBookingAvailable":true,"attributes":[{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 11","sessionPricingDisplayStatus":0,"wheelchairSeatAvailability":1}]},{"date":"2026-06-20T00:00:00","datePrefix":"","pricingTypes":[],"sessions":[{"sessionId":"93036","bookingUrl":"/rezerwacja-biletow/podsumowanie/0010/HO00002706/93036","formattedPrice":null,"isPriceVisible":false,"duration":83,"startTime":"2026-06-20T12:50:00","endTime":"2026-06-20T14:39:00","showTimeWithTimeZone":"2026-06-20T12:50:00+02:00","isSoldOut":false,"color":null,"isMidnightSession":false,"isBookingAvailable":true,"attributes":[{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 10","sessionPricingDisplayStatus":0,"wheelchairSeatAvailability":1}]}],"filmId":"HO00002706","certificate":{"name":null,"description":null,"src":null},"secondaryCertificates":[],"filmUrl":"https://www.multikino.pl/filmy/all-you-need-is-kill","filmAttributes":[],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/images/film-and-events/2026/all-you-need-is-kill/allyouneediskill_plakat.jpg?rev=08b1e09f55e449e68afb83c40faed6e7","cast":"","releaseDate":"2026-06-19T00:00:00","runningTime":83,"isDurationUnknown":false,"synopsisShort":"Akcja filmu „ALL YOU NEED IS KILL” rozgrywa się w roku 20XX i opowiada historię Rity, zaradnej, ale samotnej młodej kobiety, która zgłasza się na ochotnika do pomocy przy odbudowie Japonii po tajemniczym pojawieniu się ogromnego obcego kwiatu znanego jako „Darol”. Kiedy Darol niespodziewanie wybucha, wywołując śmiertelne wydarzenie i uwalniając potworne stworzenia, które dziesiątkują populację, Rita zostaje wciągnięta w zniszczenie – i ginie. Ale potem budzi się ponownie. I znowu. Uwięziona w niekończącej się pętli czasowej, Rita musi zmagać się z traumą i powtarzającą się śmiercią, aż w końcu spotyka Keiji, nieśmiałego młodego mężczyznę uwięzionego w tym samym cyklu. Razem walczą, by wyrwać się z pętli i odnaleźć sens w otaczającym ich chaosie.","filmTitle":"All You Need Is Kill","hasSessions":true,"hasTrailer":false,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/images/film-and-events/2026/all-you-need-is-kill/allyouneediskill_tlo.jpg?rev=5da57c78e7c94a5c8c8e182b6ad00885","filmStatus":2,"trailers":[],"director":"","distributor":"Piece Of Magic","movieXchangeCode":"d48c4f1c-363a-4302-9244-cec752b12688","crossCountryMovieXchangeId":"","originalTitle":"","showingInCinemas":["0003","0004","0005","0006","0007","0008","0010","0011","0013","0014","0015","0023","0024","0025","0026","0028","0029","0030","0033","0034","0035","0036","0037","0038","0039","0040","0042","0043","0044","0047","0048","0050","0051","0052","0053"],"genres":[],"sessionAttributes":[{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}]},{"showingGroups":[{"date":"2026-08-17T00:00:00","datePrefix":"","pricingTypes":[],"sessions":[{"sessionId":"82583","bookingUrl":"/rezerwacja-biletow/podsumowanie/0010/HO00002586/82583","formattedPrice":null,"isPriceVisible":false,"duration":80,"startTime":"2026-08-17T18:00:00","endTime":"2026-08-17T19:35:00","showTimeWithTimeZone":"2026-08-17T18:00:00+02:00","isSoldOut":false,"color":null,"isMidnightSession":false,"isBookingAvailable":true,"attributes":[{"name":"WYSTAWY","shortName":"WYSTAWY - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 10","sessionPricingDisplayStatus":0,"wheelchairSeatAvailability":1}]},{"date":"2026-08-19T00:00:00","datePrefix":"","pricingTypes":[],"sessions":[{"sessionId":"82584","bookingUrl":"/rezerwacja-biletow/podsumowanie/0010/HO00002586/82584","formattedPrice":null,"isPriceVisible":false,"duration":80,"startTime":"2026-08-19T12:30:00","endTime":"2026-08-19T14:05:00","showTimeWithTimeZone":"2026-08-19T12:30:00+02:00","isSoldOut":false,"color":null,"isMidnightSession":false,"isBookingAvailable":true,"attributes":[{"name":"WYSTAWY","shortName":"WYSTAWY - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 10","sessionPricingDisplayStatus":0,"wheelchairSeatAvailability":1}]}],"filmId":"HO00002586","certificate":{"name":null,"description":null,"src":null},"secondaryCertificates":[],"filmUrl":"https://www.multikino.pl/filmy/art-beats-lotto-i-berenson---splecione-losy","filmAttributes":[{"name":"WYSTAWY","shortName":"WYSTAWY - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/images/wydarzenia/wystawy/lotto-plakat.jpg?rev=38a9f6140a1a4ffcab6674adfc953e0e","cast":"Alessandro Sperduti","releaseDate":"2026-08-17T00:00:00","runningTime":80,"isDurationUnknown":false,"synopsisShort":"Lotto i Berenson – splecione losy. Śladami renesansowego mistrza to opowieść  o przenikających się losach Lorenza Lotta, zapomnianego szesnastowiecznego malarza, i Bernarda Berensona, krytyka sztuki, któremu zawdzięczamy odkrycie artysty na nowo.      Wyprodukowany przez 3D Produzioni i wyreżyserowany przez Simonę Risi, dokument podąża za aktorem Alessandrem Sperdutim podczas jego podróży śladami Lotta. Dzieła malarza poszukującego sławy i bogactwa, rywalizującego z innymi twórcami, rozproszone są po północnych i centralnych Włoszech; dotrzemy do regionu Marche, do Bergamo, Wenecji. Dzięki zachowanym listom i dokumentom poznajemy nie tylko twórczość malarza, ale i jego osobiste zmagania: ambicję, silną potrzebę uznania, strach przed porażką.  Równolegle śledzimy losy Berensona, młodego litewskiego Żyda, który wychował się w Bostonie i, urzeczony renesansem, wyruszył do Włoch w wieku dwudziestu czterech lat. Zachwycił go talent, z jakim Lotto potrafił uchwycić świat wewnętrzny portretowanych, ich psychologię. Przekonujemy się, że niepokoje i obawy, jakie w odległych epokach żywili Lotto i Berenson, i dziś są nam bliskie. Lotto i Berenson... jest zatem nie tylko refleksją nad sztuką, ale i ludzką naturą.","filmTitle":"Art Beats: Lotto i Berenson - splecione losy. Śladami renesansowego mistrza","hasSessions":true,"hasTrailer":false,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/images/wydarzenia/wystawy/lotto-kadr.jpg?rev=c2e3fc695756485dad1e26afde490e5f","filmStatus":2,"trailers":[],"director":"Simona Risi","distributor":"nazywowkinach","movieXchangeCode":"","crossCountryMovieXchangeId":"","originalTitle":"","showingInCinemas":["0003","0004","0005","0006","0007","0008","0010","0011","0013","0014","0015","0023","0024","0025","0026","0028","0029","0030","0031","0033","0034","0035","0036","0037","0038","0039","0040","0041","0042","0043","0044","0047","0048","0050","0051","0052","0053"],"genres":[],"sessionAttributes":[{"name":"WYSTAWY","shortName":"WYSTAWY - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}]},{"showingGroups":[{"date":"2026-06-15T00:00:00","datePrefix":"","pricingTypes":[],"sessions":[{"sessionId":"82579","bookingUrl":"/rezerwacja-biletow/podsumowanie/0010/HO00002584/82579","formattedPrice":null,"isPriceVisible":false,"duration":95,"startTime":"2026-06-15T17:50:00","endTime":"2026-06-15T19:40:00","showTimeWithTimeZone":"2026-06-15T17:50:00+02:00","isSoldOut":false,"color":null,"isMidnightSession":false,"isBookingAvailable":true,"attributes":[{"name":"WYSTAWY","shortName":"WYSTAWY - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 10","sessionPricingDisplayStatus":0,"wheelchairSeatAvailability":1}]},{"date":"2026-06-17T00:00:00","datePrefix":"","pricingTypes":[],"sessions":[{"sessionId":"92984","bookingUrl":"/rezerwacja-biletow/podsumowanie/0010/HO00002584/92984","formattedPrice":null,"isPriceVisible":false,"duration":95,"startTime":"2026-06-17T12:30:00","endTime":"2026-06-17T14:20:00","showTimeWithTimeZone":"2026-06-17T12:30:00+02:00","isSoldOut":false,"color":null,"isMidnightSession":false,"isBookingAvailable":true,"attributes":[{"name":"WYSTAWY","shortName":"WYSTAWY - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 10","sessionPricingDisplayStatus":0,"wheelchairSeatAvailability":1}]}],"filmId":"HO00002584","certificate":{"name":null,"description":null,"src":null},"secondaryCertificates":[],"filmUrl":"https://www.multikino.pl/filmy/art-beats-nenufary-moneta---cuda-z-wody-i-swiata","filmAttributes":[{"name":"WYSTAWY","shortName":"WYSTAWY - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/images/wydarzenia/wystawy/monet-nenufary-plakat.jpg?rev=0ec23b8a082f4b7bb70c073696776d8a","cast":"Elisa Lasowski","releaseDate":"2026-06-15T00:00:00","runningTime":95,"isDurationUnknown":false,"synopsisShort":"Dokument opowiada o pochodzeniu i powstaniu ogromnego dzieła sztuki, które zerwało z wszelkimi konwencjami.    Jest to opowieść o obsesji artysty na punkcie światła i wody, z której malarz nie mógł się wyrwać, więc przekształcił ją w swój własny rodzaj magii. To także opowieść o radykalnych ideach, które zrewolucjonizowały sztukę współczesną: wyraźnym zamiarem Moneta było przeniesienie na płótno „pierwszego, czystego wrażenia” form i przedmiotów, jakie pojawiają się w oku, które nigdy wcześniej ich nie widziało. Film jest wyjątkowym, ekskluzywnym spojrzeniem na arcydzieła znajdujące się w Muzeum Orangerie, Muzeum Marmottan, Muzeum Orsay i Giverny, gdzie mieszkał i tworzył Monet, po raz pierwszy ukazane na dużym ekranie, aby zapewnić niepowtarzalne wrażenia widzom obcującym z pięknem jego „Nenufarów”.","filmTitle":"Art Beats: Nenufary Moneta - cuda z wody i światła","hasSessions":true,"hasTrailer":false,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/global/img/film-panel-default-image.png?rev=-1","filmStatus":2,"trailers":[],"director":"Giovanni Troilo","distributor":"nazwywkinach","movieXchangeCode":"","crossCountryMovieXchangeId":"","originalTitle":"","showingInCinemas":["0003","0004","0005","0006","0007","0008","0010","0011","0013","0014","0015","0023","0024","0025","0026","0028","0029","0030","0031","0033","0034","0035","0036","0037","0038","0039","0040","0041","0042","0043","0044","0047","0048","0050","0051","0052","0053"],"genres":[],"sessionAttributes":[{"name":"WYSTAWY","shortName":"WYSTAWY - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}]},