iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 4","sessionPricingDisplayStatus":0,"wheelchairSeatAvailability":1}]}],"filmId":"HO00002630","certificate":{"name":null,"description":null,"src":null},"secondaryCertificates":[],"filmUrl":"https://www.multikino.pl/filmy/kolekcja-mamoru-hosody-o-dziewczynie-skaczacej-przez-czas","filmAttributes":[],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/images/wydarzenia/anime/o-dziewczynie-skaczacej-przez-czas-plakat2.jpg?rev=125e66df557f4228bf3605103ca217f9","cast":"Riisa Naka, Mitsutaka Itakura, Takuya Ishida, Ayami Kakiuchi","releaseDate":"2026-06-12T00:00:00","runningTime":98,"isDurationUnknown":false,"synopsisShort":"Makoto jest zwyczajną nastolatką, spędzającą większość czasu z przyjaciółmi. Kiedy pewnego dnia, spiesząc się z wizytą do ciotki, cudem unika potrącenia przez pociąg – przeskakuje w czasie do momentu sprzed wypadku. Korzystając z nowo poznanych zdolności, naprawia swoje codzienne błędy – od słabych ocen na sprawdzianach po nieudane wyznania miłości. Kiedy jednak dosięgają ją konsekwencje manipulowania czasem, Makoto musi zrobić wszystko, żeby uniknąć straszliwej przyszłości, której nie da się cofnąć. ","filmTitle":"Kolekcja Mamoru Hosody: O dziewczynie skaczącej przez czas","hasSessions":true,"hasTrailer":false,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/global/img/film-panel-default-image.png?rev=-1","filmStatus":2,"trailers":[],"director":"Mamoru Hosoda","distributor":"","movieXcha