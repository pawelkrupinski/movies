biwak we własnym salonie! Gdy przychodzi pora kąpieli, Puciowi i Bobo towarzystwa dotrzymuje wesoły zabawkowy krokodyl, który również pilnie potrzebuje się wykąpać! Pucio uczy się dzielić z innymi, nawiązywać nowe przyjaźnie i radzić sobie z nudą w deszczowy dzień. W każdym odcinku Pucio udowadnia, że wyobraźnia i kreatywność potrafią zamienić najzwyklejsze chwile w coś naprawdę wyjątkowego!","filmTitle":"Pucio","hasSessions":true,"hasTrailer":true,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/images/film-and-events/2026/pucio/pucio-kadr.jpg?rev=6887f91632584976a659640efa377246","filmStatus":1,"trailers":[],"director":"Marta Stróżycka","distributor":"Młode Horyzonty","movieXchangeCode":"a62f983e-4b69-42ed-ac37-cc720d64e615","crossCountryMovieXchangeId":"","originalTitle":"","showingInCinemas":["0003","0004","0005","0006","0007","0008","0010","0011","0013","0014","0015","0023","0024","0025","0026","0027","0028","0029","0030","0031","0033","0034","0035","0036","0037","0038","0039","0040","0041","0042","0043","0044","0047","0048","0050","0051","0052","0053"],"genres":[],"sessionAttributes":[{"name":"Projektor laserowy","shortName":"Projektor laserowy","value":"Projektor laserowy","description":"Projektor laserowy","attributeType":"Session_Special","color":"#FFA500","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"DUBBING","shortName":"DUBBING","value":"DUBBING","description":"DUBBING","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","