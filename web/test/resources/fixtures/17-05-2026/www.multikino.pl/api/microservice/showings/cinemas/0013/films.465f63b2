Availability":1}]}],"filmId":"HO00002755","certificate":{"name":null,"description":null,"src":null},"secondaryCertificates":[],"filmUrl":"https://www.multikino.pl/filmy/zawiescie-czerwone-latarnie","filmAttributes":[],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/images/kultowe-kino/zawiecie_czerwone_laternie_plakat.jpg?rev=300dbab82eef4904a6bb9c1888bbea70","cast":"","releaseDate":"2026-06-18T00:00:00","runningTime":0,"isDurationUnknown":true,"synopsisShort":"Akcja rozgrywa się w latach 20. XX wieku. 19-letnia Songlian zostaje czwartą konkubiną zamożnego pana Chena. Trafia do jego imponującej posiadłości, gdzie obowiązują specyficzne zasady, a każdy aspekt codzienności kształtują wielowiekowe tradycje. Główna bohaterka powoli odkrywa, że w kobiecym gronie, do którego dołączyła, trwa rywalizacja o względy pana domu. Do czego mogą jednak doprowadzić ciągłe erupcje zazdrości, atmosfera wzajemnych oskarżeń i niepewność dotycząca własnej pozycji? Czy niedoświadczona Songlian odnajdzie się w skomplikowanym labiryncie dziedzińców i korytarzy?","filmTitle":"Zawieście czerwone latarnie","hasSessions":true,"hasTrailer":false,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/images/kultowe-kino/zawiescieczerwonelatanie-kadr.jpg?rev=d2a79d120e8c49a7bcfa1c4cbe3bfd80","filmStatus":2,"trailers":[],"director":"","distributor":"","movieXchangeCode":"","crossCountryMovieXchangeId":"","originalTitle":"","showingInCinemas":["0003","0004","0005","0006","0007","0008","0010","0013","0014","0015","0023","0024","0025","0026","0028","0029","0030","0031","0033","0034","0035","0036","0037","0038","0039","0040","0041","0042","0043","0044","0047","0048","0050","0051","0052","0053"],"genres":[],"sessionAttributes":[{"name":"Projektor laserowy","shortName":"Projektor laserowy","value":"Projek