wn":false,"synopsisShort":"Dobry maraton to taki, który nie daje poczucia powtarzalności. W Multikinie udowadniamy, że groza to najbardziej elastyczny gatunek na świecie. Przygotowaliśmy selekcję dla koneserów, którzy szukają różnorodności: od internetowych legend w Backrooms. Bez wyjścia, przez religijny thriller z Sydney Sweeney, aż po bezkompromisowe kino klasy B i artystyczny mix w wykonaniu Michaela Shanksa (Together). Każdy z tych filmów gra na innych strunach – od obrzydzenia, przez śmiech, aż po czystą fascynację. Nie szukaj jednego filmu, szukaj pełnego doświadczenia.","filmTitle":"NMF: Maraton Horrorów 19 czerwca 2026","hasSessions":true,"hasTrailer":false,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/images/maraton/horrory/czerwiec-2026/maratonhorrorow_190626_tlo.jpg?rev=f7c97f99550a4913a98ac31b87b8ba10","filmStatus":2,"trailers":[],"director":"","distributor":"","movieXchangeCode":"","crossCountryMovieXchangeId":"","originalTitle":"","showingInCinemas":["0003","0004","0005","0006","0007","0008","0010","0011","0013","0014","0015","0023","0024","0026","0028","0029","0030","0034","0035","0036","0038","0039","0040","0044","0050","0053"],"genres":[],"sessionAttributes":[{"name":"Projektor laserowy","shortName":"Projektor laserowy","value":"Projektor laserowy","description":"Projektor laserowy","attributeType":"Session_Special","color":"#FFA500","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"NAPISY","shortName":"NAPISY","value":"NAPISY","description":"NAPISY","attributeType":"Language","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","sho