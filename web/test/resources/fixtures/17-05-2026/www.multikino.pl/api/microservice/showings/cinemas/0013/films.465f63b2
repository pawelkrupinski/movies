lor":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"screenName":"Sala 6","sessionPricingDisplayStatus":0,"wheelchairSeatAvailability":1}]}],"filmId":"HO00002585","certificate":{"name":null,"description":null,"src":null},"secondaryCertificates":[],"filmUrl":"https://www.multikino.pl/filmy/art-beats-rafael-mody-geniusz","filmAttributes":[{"name":"WYSTAWY","shortName":"WYSTAWY - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/images/wydarzenia/wystawy/rafael-plakat.jpg?rev=e127f4cbbb104fde8a20d94cf4ba7dc0","cast":"","releaseDate":"2026-07-13T00:00:00","runningTime":80,"isDurationUnknown":false,"synopsisShort":"Zanurz się w epokę renesansu i odkryj wysublimowaną sztukę Rafaela.     Podziwiaj portrety niezwykłych kobiet: Matki, Przyjaciółki, Sekretnej Kochanki i Klientki, których osobowości rozkwitają na płótnach. Matka, która zmarła, gdy artysta miał zaledwie osiem lat. Wielbicielki, które wspierały go na drodze do sukcesu. Kobieta, która niemal przyczyniła się do jego śmierci. Istniały naprawdę lub były tylko wytworem wyobraźni. Rafael (1483-1520) uwiecznił ideał niebiańskiego piękna. Dzięki pracy światowej sławy ekspertów możemy poznać najważniejsze momenty z życia jednego z największych mistrzów renesansu.","filmTitle":"Art Beats: Rafael. Młody geniusz","hasSessions":true,"hasTrailer":true,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/images/wydarzenia/wystawy/rafael-kadr.jpg?rev=9c0053d94c274a9aab34d304ab3dca0