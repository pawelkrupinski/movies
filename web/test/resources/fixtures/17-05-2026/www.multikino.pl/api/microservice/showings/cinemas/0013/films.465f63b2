cji i niezapomnianej muzyki filmowej, która budzi wspomnienia i rozpala nowy entuzjazm.","filmTitle":"John Williams - A Tribute","hasSessions":true,"hasTrailer":false,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/images/wydarzenia/koncerty/john-williams/williams_tlo.jpg?rev=60252b6bedb344acb0822ac5e918273a","filmStatus":1,"trailers":[],"director":"Antony Hermus","distributor":"Pannonia Entertainment","movieXchangeCode":"","crossCountryMovieXchangeId":"","originalTitle":"","showingInCinemas":["0003","0004","0005","0006","0007","0008","0010","0011","0013","0014","0015","0023","0024","0025","0026","0027","0028","0029","0030","0031","0033","0034","0035","0036","0037","0038","0039","0040","0041","0042","0043","0044","0047","0048","0050","0051","0052","0053"],"genres":[],"sessionAttributes":[{"name":"Projektor laserowy","shortName":"Projektor laserowy","value":"Projektor laserowy","description":"Projektor laserowy","attributeType":"Session_Special","color":"#FFA500","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"KONCERT","shortName":"KONCERT - wydarzenie specjalne","value":"","description":"","attributeType":"Movie","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"2D","shortName":"2D","value":"2D","description":"","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null},{"name":"Single Seat","shortName":"","value":"Single Seat","description":"SingleSeat","attributeType":"Session","color":"","borderGradient":[],"backgroundImageUrl":null,"iconName":null}]},{"showingGroups":[{"date":"2026-07-01T00:00:00","datePrefix":"","pricingTypes":[],"sessions":[{"sessionId":"75096","bookingUrl":"/rezerwacja-biletow/podsumowanie/0013/HO00002741/75096","formattedPrice":null,"isPriceVisible":fal