tAvailability":1}]}],"filmId":"HO00002669","certificate":{"name":null,"description":null,"src":null},"secondaryCertificates":[],"filmUrl":"https://www.multikino.pl/filmy/zawodowcy","filmAttributes":[],"posterImageSrc":"https://www.multikino.pl/-/media/multikino/images/film-and-events/2026/zawodowcy/zawodowcy_plakat_cut.jpg?rev=307b6e79745349b48c3f2df3088133fb","cast":"Jake Gyllenhaal, Henry Cavill, Eiza Gonzalez, Rosamund Pike","releaseDate":"2026-05-29T00:00:00","runningTime":98,"isDurationUnknown":false,"synopsisShort":"Eve, działająca w szarej strefie specjalistka od załatwiania ekstremalnie trudnych spraw dla wyjątkowo bogatych klientów otrzymuje zlecenie od grupy nowojorskich inwestorów. Ma odzyskać dług od mieszkającego na prywatnej wyspie, dysponującego własną armią miliardera o szemranej reputacji. Gdy zawodzą cywilizowane metody negocjacji i staje się jasne, że dłużnik nie ma najmniejszego zamiaru regulować należności, do gry wchodzi ekipa do zadań specjalnych. To grupa byłych żołnierzy, z którymi Eve pracuje do lat. Wspólnie opracowują i wcielają w życie misterny plan wtargnięcia na wyspę, „załatwienia sprawy” i ucieczki. Brzmi prosto, ale ludzie miliardera są przygotowani na takie ewentualności, a okazywanie litości nie należy do zakresu ich obowiązków.","filmTitle":"Zawodowcy","hasSessions":true,"hasTrailer":true,"embargoMessage":null,"embargoEndDate":null,"embargoLevel":null,"priceMessage":"Kup bilety online i zapłać mniej!","alternativeCertificate":{"name":null,"description":null,"src":null},"panelImageUrl":"https://www.multikino.pl/-/media/multikino/images/film-and-events/2026/zawodowcy/zawodowcy-kadr.jpg?rev=1e497157a33741e590f60daad0eac880","filmStatus":1,"trailers":[],"director":"Guy Ritchie ","distributor":"Monolith","movieXchangeCode":"f76e4693-b7a9-418e-88bc-3e31632b6d0f","crossCountryMovieXchangeId":"","originalTitle":"","showingInCinemas":["0003","0004","0005","0006","0007","0008","0010","0011","0013","0014","0015","0023","0024","0025","0026",