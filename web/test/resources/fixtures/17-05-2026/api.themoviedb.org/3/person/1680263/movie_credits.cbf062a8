ftcore":false,"video":false,"vote_average":6.3,"vote_count":20,"credit_id":"65d0ce27693e2001634f1202","department":"Writing","job":"Writer"},{"adult":false,"backdrop_path":"/xi1Ys1SGeGaxIaGVUKtV0WuIXDC.jpg","genre_ids":[18],"id":595875,"title":"آدم","original_language":"ar","original_title":"آدم","overview":"","popularity":0.5057,"poster_path":"/bQY8ss1kJhtNcXPcLClcqiBt8wG.jpg","release_date":"2019-10-18","softcore":false,"video":false,"vote_average":6.945,"vote_count":82,"credit_id":"5cb863950e0a266b98f12dd3","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":"/xi1Ys1SGeGaxIaGVUKtV0WuIXDC.jpg","genre_ids":[18],"id":595875,"title":"آدم","original_language":"ar","original_title":"آدم","overview":"","popularity":0.5057,"poster_path":"/bQY8ss1kJhtNcXPcLClcqiBt8wG.jpg","release_date":"2019-10-18","softcore":false,"video":false,"vote_average":6.945,"vote_count":82,"credit_id":"5cdc5e430e0a26407dd31192","department":"Writing","job":"Screenplay"},{"adult":false,"backdrop_path":"/81jteI5xIztDCFPhMXBTmT5MdW9.jpg","genre_ids":[18],"id":1399462,"title":"Drugie życie","original_language":"es","original_title":"Calle Málaga","overview":"Maria Angeles, 79-letnia Hiszpanka, mieszka samotnie w Tangerze w Maroku i cieszy się codziennym życiem. Jednak jej życie wywraca się do góry nogami, gdy jej córka przyjeżdża z Madrytu, aby sprzedać mieszkanie, w którym zawsze mieszkała. Zdeterminowana, by zostać, robi wszystko, co w jej mocy, by odzyskać dom i dobytek, i niespodziewanie na nowo odkrywa miłość i zmysłowość.","popularity":4.0538,"poster_path":"/fWagBXNDk44UaupYtwQOAvDwGiT.jpg","release_date":"2025-10-31","softcore":false,"video":false,"vote_average":7.221,"vote_count":43,"credit_id":"675629abcf1801968f02dcd0","department":"Directing","job":"Director"},{"adult":false,"backdrop_path":null,"genre_ids":[18,53],"id":1437968,"title":"Cours, et sans tristesse","original_language":"fr","original_title":"Cours, et sans tristesse","overview":"","popularity":0.0927,"po