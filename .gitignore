### SBT ###
# Simple Build Tool
# http://www.scala-sbt.org/release/docs/Getting-Started/Directories.html#configuring-version-control

dist/*
target/
# Local mirror of CI's `actions/download-artifact@v4 -> stage`. Only
# present when verifying the Docker build off-CI; never committed.
/stage/
lib_managed/
src_managed/
project/boot/
project/plugins/project/
.history
.cache
.lib/

### Scala ###
*.class
*.log
*.metals

# End of https://www.gitignore.io/api/sbt,scala
.idea
**/.DS_Store
.bsp

# Local env vars (e.g. SCRAPINGANT_KEY) loaded by tools.Env
.env.local

# Per-viewport PNG renders produced by `sbt PageTest/runMain
# tools.MobileScreenshots`. Re-runnable diagnostic; the runner
# regenerates them on demand from the same fixture corpus the page
# specs use, so committing them would just churn the diff.
/web/src/page/screenshots/

# Playwright drops a `.last-run.json` and trace zips here when run
# from the project root (which the CI workflow does via the
# `page-tests-playwright/` working directory but local devs may
# accidentally run from root). Never committed either way.
/test-results/

# npm dependencies — the top-level `package.json` exists only to host
# ESLint for `public/js/`; CI installs on demand from the lockfile.
node_modules/

# Local Claude Code state (machine-specific — settings, locks, agent worktrees)
.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/worktrees/
