# Copy to `.env.local` (gitignored) and fill in.
# Format: KEY=value (one per line, # for comments, optional quoting around the value).
# Read by tools.Env at runtime; takes precedence after real env vars and -D system props.

# Required by MultikinoClient.DefaultFetch to route the films API through ScrapingAnt
# (Multikino's API is bot-blocked from datacenter IPs without it).
SCRAPINGANT_KEY=

# Required — EnrichmentService uses TMDB to bridge Polish titles → IMDb ids.
# IMDb ratings come from Cinemeta (no key needed); Filmweb data is fetched
# unauthenticated. Register a (free) TMDB key at:
#   https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Optional — EnrichmentRepo persists enrichments to MongoDB so they survive
# restarts. When unset, the service runs off the in-memory cache only.
# Atlas free-tier connection string format:
#   mongodb+srv://user:password@cluster.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=
# Defaults to "kinowo" when unset.
MONGODB_DB=kinowo
