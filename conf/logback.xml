<configuration>
  <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%date{HH:mm:ss} %-5level %logger{36} - %msg%n</pattern>
    </encoder>
  </appender>

  <logger name="services.ShowtimeCache" level="INFO"/>
  <logger name="clients.MultikinoClient" level="INFO"/>

  <root level="WARN">
    <appender-ref ref="STDOUT"/>
  </root>
</configuration>
