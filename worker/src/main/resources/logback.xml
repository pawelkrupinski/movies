<configuration>
  <include resource="logback-base.xml"/>

  <!-- Persistent log file on the Fly volume mounted at /data (KINOWO_LOG_DIR=
       /data/logs in fly.worker.toml) so the worker's logs SURVIVE a restart —
       `flyctl logs` only retains a short rolling window, which loses exactly the
       pre-restart logs you need to diagnose a crash/throttle spiral (the gap hit
       during the 2026-06-24 throttle incident). Unset (local dev) → ./logs.
       Capped so it can't fill the 1GB volume it shares with /data/heapdumps. -->
  <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>${KINOWO_LOG_DIR:-logs}/worker.log</file>
    <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
      <fileNamePattern>${KINOWO_LOG_DIR:-logs}/worker.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
      <maxFileSize>10MB</maxFileSize>
      <maxHistory>14</maxHistory>
      <totalSizeCap>80MB</totalSizeCap>
    </rollingPolicy>
    <encoder>
      <!-- Full date (unlike the console's HH:mm:ss): a persisted file spans days. -->
      <pattern>%date{yyyy-MM-dd HH:mm:ss} %-5level %logger{36} - %msg%n</pattern>
    </encoder>
  </appender>

  <root level="WARN">
    <appender-ref ref="STDOUT"/>
    <appender-ref ref="SENTRY"/>
    <appender-ref ref="FILE"/>
  </root>
</configuration>
